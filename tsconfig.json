{
  "extends": "astro/tsconfigs/strict",
  "exclude": ["dist", "public"],
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@root/*": ["src/*"],
      "@models/*": ["src/models/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@styles/*": ["src/styles/*"],
      "@data/*": ["src/data/*"],
      "@util/*": ["src/util/*"],
      "@includes/*": ["src/content/_includes/*"]
    }
  }
}
