---
import Header from '@components/Landing/Header.astro';
import Footer from '@components/Landing/Footer.astro';
import CookieBanner from '@components/CookieBanner.astro';
import UtmTracker from '@components/UtmTracker.astro';
import GtmNoscript from '@components/GtmNoscript.astro';
import ThirdPartyScripts from '@components/ThirdPartyScripts.astro';
import SeoMeta from '@components/SeoMeta.astro';
import ThemeProvider from '@astrojs/starlight/components/ThemeProvider.astro';
import { formatMarketingTitle } from '@root/consts.ts';
import { getSectionFromPath } from '@util/path-utils';
import { getOgImageUrl } from '@util/getOgImageUrl';
import '@styles/global.scss';
import 'node_modules/@astrojs/starlight/style/props.css';

interface Props {
	title: string;
	description?: string;
	pageId?: string;
	customTitle?: boolean;
	githubLink?: string;
	githubLabel?: string;
	platformQuery?: string;
	noCanonical?: boolean;
	gitHubPlatform?: import('@models/site.models').Products;
	forceLightTheme?: boolean;
	ogImage?: string;
	ogType?: string;
	ogImageAlt?: string;
	publishedTime?: string;
	modifiedTime?: string;
	noIndex?: boolean;
	jsonLd?: Record<string, unknown>;
	/**
	 * Preload an above-the-fold LCP image with fetchpriority=high. Use ONLY for
	 * the page's LCP candidate (typically a CSS background not visible to the
	 * preload scanner — e.g. the hero on the home page). Misuse on decorative
	 * images will compete with the real LCP target for bandwidth.
	 */
	preloadLcpImage?: string;
}

const {
	title,
	description,
	pageId = 'common',
	customTitle = false,
	githubLink = 'https://github.com/thingsboard/thingsboard',
	githubLabel = 'Star thingsboard/thingsboard on GitHub',
	platformQuery = '',
	noCanonical = false,
	gitHubPlatform,
	forceLightTheme = false,
	ogImage: ogImageProp,
	ogType,
	ogImageAlt,
	publishedTime,
	modifiedTime,
	noIndex = false,
	jsonLd,
	preloadLcpImage,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const section = getSectionFromPath(Astro.url.pathname);
const pageTitle = customTitle ? title : formatMarketingTitle(title, section);
const ogImage = ogImageProp ?? getOgImageUrl(Astro.url.pathname);
---

<!doctype html>
<html id={pageId} lang="en" data-theme="light" data-force-light={forceLightTheme ? 'true' : undefined}>
	<head>
		<meta charset="utf-8" />
		<meta name="cf-2fa-verify" content="a08672380de15e9" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<!-- Establish TLS to GTM origin early; tags loaded via GTM (FB, LinkedIn, etc.) stay lazy by design. -->
		<link rel="preconnect" href="https://www.googletagmanager.com" />

		{preloadLcpImage && <link rel="preload" as="image" href={preloadLcpImage} fetchpriority="high" />}

		<title>{pageTitle}</title>

		<SeoMeta
			title={pageTitle}
			description={description}
			canonicalUrl={canonicalUrl}
			noCanonical={noCanonical}
			ogImage={ogImage}
			ogType={ogType}
			ogImageAlt={ogImageAlt}
			publishedTime={publishedTime}
			modifiedTime={modifiedTime}
			noIndex={noIndex}
			jsonLd={jsonLd}
		/>

		<link rel="shortcut icon" type="image/svg+xml" href="/favicon.svg" />

		<ThemeProvider />
		<script is:inline>
			// Pages with data-force-light stay light regardless of user preference.
			// All other pages respect the theme set by ThemeProvider (from localStorage / OS).
			if (document.documentElement.dataset.forceLight === 'true') {
				document.documentElement.dataset.theme = 'light';
			}
		</script>

		<ThirdPartyScripts />
		<slot name="head" />
	</head>

	<body>
		<GtmNoscript />

		<Header githubLink={githubLink} githubLabel={githubLabel} platformQuery={platformQuery} gitHubPlatform={gitHubPlatform} />
		<CookieBanner />
		<UtmTracker />

		<slot />

		<Footer />

		<!-- flip-nav sentinel: IntersectionObserver toggles `flip-nav` on <html> when user scrolls past 50px,
		     replacing a non-passive scroll listener that triggered ~500ms forced reflow on first paint. -->
		<div id="flip-nav-sentinel" aria-hidden="true"></div>
		<style is:inline>
			#flip-nav-sentinel {
				position: absolute;
				top: 50px;
				left: 0;
				width: 1px;
				height: 1px;
				pointer-events: none;
				visibility: hidden;
			}
		</style>
		<script is:inline>
			(function () {
				const html = document.documentElement;
				const pagesWithTransparentHeader = [
					'home',
					'thingsboard-paas',
					'thingsboard-pe',
					'thingsboard-edge',
					'mqtt-broker',
					'pricing',
					'affiliate',
				];
				if (!pagesWithTransparentHeader.includes(html.id)) return;

				const sentinel = document.getElementById('flip-nav-sentinel');
				if (!sentinel) return;

				new IntersectionObserver(
					function (entries) {
						html.classList.toggle('flip-nav', !entries[0].isIntersecting);
					},
					{ threshold: 0 }
				).observe(sentinel);
			})();
		</script>
	</body>
</html>
