    <Footer />

    <!-- Scroll-based header style change -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        const html = document.documentElement;
        const pageId = html.id;
        const pagesWithTransparentHeader = ['home', 'thingsboard-paas', 'thingsboard-pe', 'thingsboard-edge', 'mqtt-broker', 'pricing'];

        if (pagesWithTransparentHeader.includes(pageId)) {
          // Check initial scroll position
          function updateHeaderState() {
            if (window.scrollY > 50) {
              html.classList.add('flip-nav');
            } else {
              html.classList.remove('flip-nav');
            }
          }

          // Run on load
          updateHeaderState();

          // Run on scroll
          window.addEventListener('scroll', updateHeaderState);
        }
      });
    </script>
