---
import BaseLayout from './BaseLayout.astro';

interface Props {
	title: string;
	description?: string;
	pageSlug: string;
}

const { title, description, pageSlug } = Astro.props;
---

<BaseLayout title={title} description={description} pageId="use-cases">
	<main class="use-case-page" data-slug={pageSlug}>
		<slot />
	</main>
</BaseLayout>

<style lang="scss" is:global>
	@use '../styles/variables' as *;

	// Page container
	.use-case-page {
		@include container;
		padding-top: calc(#{$header-height} + #{$spacing-10});
		padding-bottom: $spacing-20;
		border-left: 1px solid #edeef3;
		border-right: 1px solid #edeef3;
	}

	// Page title
	.usecase-title {
		@include page-title;
		color: $color-text-primary;
		margin: $spacing-10 0 $spacing-10;

		@include media-down(md) {
			margin: $spacing-8 0 $spacing-6;
		}
	}

	// Section padding — reused across multiple section components
	.uc-section-padding {
		padding: 60px 0;

		@include media-down(md) {
			padding: $spacing-8 0;
		}
	}

	// Section header — reused across DashboardStructure, ApplicationsSection, SolutionStructure
	.uc-section-header {
		display: flex;
		flex-direction: column;
		gap: $spacing-8;
		max-width: 928px;

		h2 {
			@include section-title;
			color: $color-text-primary;
			margin: 0;
		}

		p {
			@include text-m;
			margin: 0;
		}
	}

	// About text layout — reused in AboutSection + SolutionStructure
	.uc-about-text {
		display: flex;
		gap: $spacing-12;

		@include media-down(lg) {
			flex-direction: column;
			gap: $spacing-6;
		}

		.uc-about-short {
			flex: 1;
			display: flex;
			flex-direction: column;
			gap: $spacing-6;

			.text {
				@include text-m;
				margin: 0;
			}
		}

		.uc-about-long {
			flex: 2;

			p {
				@include text-s;
				margin: 0 0 $spacing-4;

				&:last-child {
					margin-bottom: 0;
				}

				a {
					color: $color-primary;
					text-decoration: none;

					&:hover {
						text-decoration: underline;
					}
				}
			}
		}
	}

	// SCADA mode content — reused in KeyFunctionsSection + scada.astro page
	.uc-scada-content {
		display: none;

		&.active {
			display: block;
		}
	}

	// Header with mode selector — reused in KeyFunctionsSection + scada.astro page
	.uc-header-selector {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: $spacing-6;
		margin-bottom: $spacing-10;

		@include media-down(md) {
			flex-direction: column;
			align-items: flex-start;
		}

		h2 {
			@include section-title;
			color: $color-text-primary;
			margin: 0;
		}

		.uc-mode-selector {
			margin-bottom: 0;
		}
	}
</style>
