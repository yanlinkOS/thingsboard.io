---
import BaseLayout from './BaseLayout.astro';
import { getOgImageUrl } from '~/util/getOgImageUrl';

interface Props {
	title: string;
	description?: string;
	pageSlug: string;
	breadcrumb: string;
	ogImage?: string;
	ogImageAlt?: string;
	preloadLcpImage?: string;
	jsonLd?: Record<string, unknown>;
}

const {
	title,
	description,
	pageSlug,
	breadcrumb,
	ogImage: ogImageProp,
	ogImageAlt,
	preloadLcpImage,
	jsonLd,
} = Astro.props;

const ogImage = ogImageProp ?? getOgImageUrl(Astro.url.pathname);
---

<BaseLayout
	title={title}
	description={description}
	pageId="case-studies"
	ogImage={ogImage}
	ogImageAlt={ogImageAlt}
	ogType="article"
	preloadLcpImage={preloadLcpImage}
	jsonLd={jsonLd}
>
	<main class="case-study-page" data-slug={pageSlug}>
		<div class="case-study-breadcrumb">
			<a href="/case-studies/" class="cs-breadcrumb-link">Case Studies</a>
			<span class="cs-breadcrumb-separator">&rsaquo;</span>
			<span class="cs-breadcrumb-current">{breadcrumb}</span>
		</div>
		<slot />
	</main>
</BaseLayout>

<script>
	const breadcrumbLink = document.querySelector('.cs-breadcrumb-link') as HTMLAnchorElement;
	if (breadcrumbLink) {
		const stored = sessionStorage.getItem('cs-filter-state');
		if (stored) {
			breadcrumbLink.href = '/case-studies/' + stored;
		}
	}
</script>

<style lang="scss" is:global>
	@use '../styles/variables' as *;

	.case-study-page {
		@include container;
		padding-top: calc(#{$header-height} + #{$spacing-6});
		padding-bottom: $spacing-20;
		border-left: 1px solid var(--color-border);
		border-right: 1px solid var(--color-border);
	}

	.case-study-breadcrumb {
		display: flex;
		align-items: center;
		gap: $spacing-2;
		@include text-s;
		margin-bottom: $spacing-8;

		.cs-breadcrumb-link {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}

		.cs-breadcrumb-separator {
			color: var(--color-text-secondary);
		}

		.cs-breadcrumb-current {
			color: var(--color-text-secondary);
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
			max-width: 400px;
		}
	}

	// Section spacing for case study pages
	.cs-section {
		margin-bottom: $spacing-16;

		@include media-down(md) {
			margin-bottom: $spacing-10;
		}
	}
</style>
