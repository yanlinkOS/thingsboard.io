---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { getOgImageUrl } from '~/util/getOgImageUrl';

interface Props {
	title: string;
	description?: string;
	pageSlug: string;
	breadcrumb: string;
	ogImage?: string;
	ogImageAlt?: string;
	preloadLcpImage?: string;
	jsonLd?: Record<string, unknown>;
}

const {
	title,
	description,
	pageSlug,
	breadcrumb,
	ogImage: ogImageProp,
	ogImageAlt,
	preloadLcpImage,
	jsonLd,
} = Astro.props;

const ogImage = ogImageProp ?? getOgImageUrl(Astro.url.pathname);
---

<BaseLayout
	headerVariant="solid-border"
	title={title}
	description={description}
	ogImage={ogImage}
	ogImageAlt={ogImageAlt}
	ogType="article"
	preloadLcpImage={preloadLcpImage}
	jsonLd={jsonLd}
>
	<main class="case-study-page" data-slug={pageSlug}>
		<div class="case-study-breadcrumb">
			<Breadcrumbs
				items={[{ label: 'Case Studies', href: '/case-studies/' }, { label: breadcrumb }]}
			/>
		</div>
		<slot />
	</main>
</BaseLayout>

<script>
	const breadcrumbLink = document.querySelector(
		'.case-study-breadcrumb .breadcrumbs__link',
	) as HTMLAnchorElement;
	if (breadcrumbLink) {
		const stored = sessionStorage.getItem('cs-filter-state');
		if (stored) {
			breadcrumbLink.href = '/case-studies/' + stored;
		}
	}
</script>

<style lang="scss" is:global>
	@use '../styles/variables' as *;

	.case-study-page {
		@include container;
		padding-top: $spacing-6;
		padding-bottom: $spacing-20;
		border-left: 1px solid var(--color-border);
		border-right: 1px solid var(--color-border);
	}

	.case-study-breadcrumb {
		margin-bottom: $spacing-8;
	}

	// Section spacing for case study pages
	.cs-section {
		margin-bottom: $spacing-16;

		@include media-down(md) {
			margin-bottom: $spacing-10;
		}
	}
</style>
