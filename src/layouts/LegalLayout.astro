---
import CookieBanner from '../components/CookieBanner.astro';
import UtmTracker from '../components/UtmTracker.astro';
import SeoMeta from '../components/SeoMeta.astro';
import { formatMarketingTitle } from '~/consts';
import { getSectionFromPath } from '~/util/path-utils';
import { getOgImageUrl } from '~/util/getOgImageUrl';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	noIndex?: boolean;
}

const { title, description, ogImage: ogImageProp, noIndex = false } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const pageTitle = formatMarketingTitle(title, getSectionFromPath(Astro.url.pathname));
const ogImage = ogImageProp ?? getOgImageUrl(Astro.url.pathname);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{pageTitle}</title>
		<SeoMeta
			title={pageTitle}
			description={description}
			canonicalUrl={canonicalUrl}
			ogImage={ogImage}
			noIndex={noIndex}
		/>
		<link rel="shortcut icon" type="image/svg+xml" href="/favicon.svg" />
	</head>
	<body>
		<div class="legal-page">
			<slot />
		</div>
		<CookieBanner />
		<UtmTracker />
	</body>
</html>

<style lang="scss" is:global>
	@use '../styles/variables' as *;
	:root {
		--sl-main-pad: 0;
		--sl-line-height: 1.5;
		--color-text: #{$color-text-primary};
	}

	.legal-page {
		max-width: 860px;
		margin: 0 auto;
		padding: 60px 24px 80px;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
		color: #212529;
		line-height: 1.7;
		font-size: 16px;
		text-align: justify;

		h1,
		h2 {
			font-weight: 600;
			line-height: 1.3;
			margin: 0 0 16px;
		}

		h1 {
			font-size: 1.5em;
			text-align: center;
		}

		h2 {
			font-size: 1.25em;
			margin-top: 32px;
		}

		p {
			@include body-text;
			margin: 0 0 8px;

			b {
				color: var(--color-text);
			}
		}

		a {
			color: #2a7dec;
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}

		ul {
			margin: 0 0 8px !important;
			padding-left: 24px !important;
			list-style: disc !important;

			li {
				margin-bottom: 4px;
				list-style: disc !important;
				color: #75767c !important;

				&::marker {
					color: #75767c !important;
				}
			}
		}

		.date {
			font-size: 0.8em;
			color: grey;
		}
	}
</style>
