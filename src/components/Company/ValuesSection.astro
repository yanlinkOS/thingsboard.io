---
import { getImage } from 'astro:assets';
import img1 from '~/assets/images/company-images/values-images/values-image1.webp';
import img2 from '~/assets/images/company-images/values-images/values-image2.webp';
import img3 from '~/assets/images/company-images/values-images/values-image3.webp';
import img4 from '~/assets/images/company-images/values-images/values-image4.webp';
import img5 from '~/assets/images/company-images/values-images/values-image5.webp';
import img6 from '~/assets/images/company-images/values-images/values-image6.webp';

const [o1, o2, o3, o4, o5, o6] = await Promise.all([
	getImage({ src: img1 }),
	getImage({ src: img2 }),
	getImage({ src: img3 }),
	getImage({ src: img4 }),
	getImage({ src: img5 }),
	getImage({ src: img6 }),
]);

const values = [
	{ src: o1.src, title: 'Results-driven', description: 'We focus on delivering practical outcomes, ensuring every IoT solution provides measurable value for our clients.' },
	{ src: o2.src, title: 'Customer focus', description: 'Our customers are at the core of our business; we tailor our IoT solutions to meet their unique needs and exceed expectations.' },
	{ src: o3.src, title: 'Growth and Self-improvement', description: 'We embrace continuous learning and innovation to stay at the forefront of IoT technology.' },
	{ src: o4.src, title: 'Expertise', description: 'Our commitment to excellence and integrity ensures that we deliver reliable, high-quality products.' },
	{ src: o5.src, title: 'Team work', description: 'Collaboration drives our success, as we harness the strengths of our team to deliver IoT innovations.' },
	{ src: o6.src, title: 'Volunteering', description: 'We actively support our community through impactful initiatives, demonstrating our dedication to creating positive change.' },
];
---

<section class="values-section">
	<h2 class="values-title">Our values</h2>
	<div class="values-wrapper">
		<div class="values-viewport">
			<div class="values-track">
				{values.map((item, i) => (
					<div class={`values-slide${i === 0 ? ' active' : ''}`} style={`background-image: url(${item.src})`}>
						<div class="values-text">
							<h3 class="values-card-title">{item.title}</h3>
							<p class="values-card-desc">{item.description}</p>
						</div>
					</div>
				))}
			</div>
			<div class="values-dots">
				{values.map((_, i) => (
					<button class={`values-dot${i === 0 ? ' active' : ''}`} aria-label={`Slide ${i + 1}`}></button>
				))}
			</div>
		</div>
	</div>
</section>

<style lang="scss">
	.values-section {
		overflow: hidden;
		background: #ffffff;
		padding-bottom: 80px;
		opacity: 0;
	}

	.values-section.animate {
		animation: reveal-ltr 0.8s ease-in-out forwards, opacity-reveal 1.5s ease-out forwards;
	}

	@keyframes reveal-ltr {
		from { clip-path: inset(0 100% 0 0); }
		to   { clip-path: inset(0 0 0 0); }
	}

	@keyframes opacity-reveal {
		from { opacity: 0; }
		to   { opacity: 1; }
	}

	.values-title {
		font-size: 48px;
		font-weight: 600;
		line-height: 72px;
		color: #212529;
		text-align: center;
		padding: 50px 0;
		margin: 0;
	}

	.values-wrapper {
		max-width: 1920px;
		margin: 0 auto;
		position: relative;
	}

	.values-viewport {
		overflow: visible;
		position: relative;
		cursor: grab;

		&.dragging {
			cursor: grabbing;
		}
	}

	.values-track {
		display: flex;
		transition: transform 0.5s ease;
	}

	.values-slide {
		flex: 0 0 100%;
		height: 756px;
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
		position: relative;
		display: flex;
		align-items: center;
		filter: blur(8px);
		transform: scale(0.9);
		transition: filter 0.5s ease, transform 0.5s ease;

		&.active {
			filter: blur(0);
			transform: scale(1);
		}

		// Dark color overlay + backdrop blur
		&::after {
			content: '';
			position: absolute;
			inset: 0;
			background-color: #3f474f99;
			backdrop-filter: blur(4px);
			z-index: 1;
		}

		// ThingsBoard pattern overlay
		&::before {
			content: '';
			position: absolute;
			inset: 0;
			background-image: url('/tbstyled-bg.svg');
			background-repeat: no-repeat;
			opacity: 0.3;
			z-index: 2;
		}
	}

	.values-text {
		position: relative;
		z-index: 3;
		padding: 30px;
		max-width: 1430px;
		width: 100%;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 15px;
	}

	.values-card-title {
		font-size: 96px;
		font-weight: 500;
		line-height: 125%;
		color: #fff;
		margin: 0;
	}

	.values-card-desc {
		font-size: 36px;
		font-weight: 400;
		line-height: 140%;
		color: #fff;
		max-width: 935px;
		margin: 0;
	}

	.values-dots {
		position: absolute;
		bottom: 5px;
		left: 50%;
		transform: translate(-50%, -50%);
		display: flex;
		align-items: center;
		z-index: 4;
	}

	.values-dot {
		width: 12px;
		height: 12px;
		border-radius: 0;
		border: none;
		background: #ccc;
		cursor: pointer;
		padding: 0;
		margin: 5px 7px;
		transition: background 0.3s ease;

		&.active {
			background: #305680;
		}

		&:hover {
			background: #305680;
		}
	}

	@media (max-width: 1279px) {
		.values-card-title { font-size: 64px; }
	}

	@media (max-width: 959px) {
		.values-card-title { font-size: 56px; }
		.values-card-desc { font-size: 32px; }
	}

	@media (max-width: 599px) {
		.values-card-title { font-size: 40px; }
		.values-title { padding: 60px 0; }
	}
</style>

<script>
	const section = document.querySelector('.values-section') as HTMLElement;
	const track = document.querySelector('.values-track') as HTMLElement;
	const viewport = document.querySelector('.values-viewport') as HTMLElement;
	const slides = document.querySelectorAll('.values-slide');
	const dots = document.querySelectorAll('.values-dot');
	const total = slides.length;
	let current = 0;

	function goTo(index: number): void {
		slides[current].classList.remove('active');
		dots[current].classList.remove('active');
		current = (index + total) % total;
		slides[current].classList.add('active');
		dots[current].classList.add('active');
		track.style.transform = `translateX(-${current * 100}%)`;
	}

	dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); resetAutoplay(); }));

	// Autoplay
	const AUTOPLAY_INTERVAL = 5000;
	let autoplayTimer: ReturnType<typeof setInterval>;

	function startAutoplay(): void {
		autoplayTimer = setInterval(() => goTo(current + 1), AUTOPLAY_INTERVAL);
	}

	function stopAutoplay(): void {
		clearInterval(autoplayTimer);
	}

	function resetAutoplay(): void {
		stopAutoplay();
		startAutoplay();
	}

	startAutoplay();


	// Drag
	let dragging = false;
	let dragStartX = 0;
	let didDrag = false;

	function startDrag(clientX: number): void {
		dragging = true;
		didDrag = false;
		dragStartX = clientX;
		track.style.transition = 'none';
		viewport.classList.add('dragging');
		stopAutoplay();
	}

	function endDrag(clientX: number): void {
		if (!dragging) return;
		dragging = false;
		viewport.classList.remove('dragging');
		track.style.transition = '';
		const diff = dragStartX - clientX;
		if (Math.abs(diff) > 50) {
			didDrag = true;
			goTo(diff > 0 ? current + 1 : current - 1);
		} else {
			track.style.transform = `translateX(-${current * 100}%)`;
		}
		startAutoplay();
	}

	viewport.addEventListener('mousedown', (e) => { startDrag(e.clientX); e.preventDefault(); });
	window.addEventListener('mouseup', (e) => { endDrag(e.clientX); });
	viewport.addEventListener('touchstart', (e) => { startDrag(e.touches[0].clientX); }, { passive: true });
	window.addEventListener('touchend', (e) => { endDrag(e.changedTouches[0].clientX); });

	viewport.addEventListener('click', (e) => {
		if (didDrag) { e.stopPropagation(); didDrag = false; }
	}, true);

	// Scroll reveal
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					section.classList.add('animate');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.3 }
	);
	observer.observe(section);
</script>
