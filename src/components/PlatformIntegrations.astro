---
import fs from 'node:fs';
import { join } from 'node:path';
import { docsLink, type Products } from '~/models/site.models';
import { Icon } from '@astrojs/starlight/components';

export interface Props {
	product: Products;
}

const integrations = [
	{ name: 'HTTP', icon: 'http', path: 'user-guide/integrations/http/' },
	{ name: 'OPC-UA', icon: 'opc-ua', path: 'user-guide/integrations/opc-ua/' },
	{ name: 'MQTT', icon: 'mqtt', path: 'user-guide/integrations/mqtt/' },
	{ name: 'SigFox', icon: 'sigfox', path: 'user-guide/integrations/sigfox/' },
	{ name: 'TCP', icon: 'tcp', path: 'user-guide/integrations/tcp/' },
	{
		name: 'Azure Event Hub',
		icon: 'azure-event-hub',
		path: 'user-guide/integrations/azure-event-hub/',
	},
	{
		name: 'Azure IoT Hub',
		icon: 'azure-iot-hub',
		path: 'user-guide/integrations/azure-iot-hub/',
	},
	{ name: 'Azure Service Bus', icon: 'azure-service-bus', path: 'user-guide/integrations/azure-service-bus/' },
	{ name: 'CoAP', icon: 'coap', path: 'user-guide/integrations/coap/' },
	{
		name: 'ThingPark',
		icon: 'thingpark',
		path: 'user-guide/integrations/thingpark/',
	},
	{
		name: 'TheThingsStack Community',
		icon: 'ttn',
		path: 'user-guide/integrations/ttn/',
	},
	{
		name: 'TheThingsStack Industries',
		icon: 'things-stack-industries',
		path: 'user-guide/integrations/tti/',
	},
	{
		name: 'ChirpStack',
		icon: 'chirpstack',
		path: 'user-guide/integrations/chirpstack/',
	},
	{
		name: 'Apache Pulsar',
		icon: 'apache-pulsar',
		path: 'user-guide/integrations/apache-pulsar/',
	},
	{
		name: 'AWS IoT',
		icon: 'aws-iot',
		path: 'user-guide/integrations/aws-iot/',
	},
	{
		name: 'AWS Kinesis',
		icon: 'aws-kinesis',
		path: 'user-guide/integrations/aws-kinesis/',
	},
	{ name: 'AWS SQS', icon: 'aws-sqs', path: 'user-guide/integrations/aws-sqs/' },
	{ name: 'Custom', icon: 'custom', path: 'user-guide/integrations/custom/' },
	{ name: 'Particle', icon: 'particle', path: 'user-guide/integrations/particle/' },
	{ name: 'Kafka', icon: 'kafka', path: 'user-guide/integrations/kafka/' },
	{ name: 'Loriot', icon: 'loriot', path: 'user-guide/integrations/loriot/' },
{ name: 'Pub/Sub', icon: 'pub-sub', path: 'user-guide/integrations/pub-sub/' },
	{ name: 'RabbitMQ', icon: 'rabbitmq', path: 'user-guide/integrations/rabbitmq/' },
	{
		name: 'ThingPark Enterprise',
		icon: 'thingpark-enterprise',
		path: 'user-guide/integrations/thingparkenterprise/',
	},
	{ name: 'KPN Things', icon: 'kpn-things', path: 'user-guide/integrations/kpn-things/' },
	{ name: 'UDP', icon: 'udp', path: 'user-guide/integrations/udp/' },
	{
		name: 'IoT Creators',
		icon: 'iotcreators',
		path: 'user-guide/integrations/iotcreators/',
	},
	{ name: 'Tuya', icon: 'tuya', path: 'user-guide/integrations/tuya/' },
];

const { product } = Astro.props;

const links = integrations.map((item) => {
	const svgPath = join(process.cwd(), 'public', 'logos', 'integration', `${item.icon}.svg`);
	let svg = '';
	try {
		svg = fs.readFileSync(svgPath, 'utf-8');
	} catch {
		/* file not found — svg stays empty */
	}
	return {
		...item,
		href: docsLink(product, item.path),
		svg,
	};
});
---

<h2 class="integrations-heading">
	<a class="heading-link" href={docsLink(product, 'user-guide/integrations/')}>
		Platform Integrations
		<Icon name="right-arrow" />
	</a>
</h2>
<ul class="integrations-grid not-content">
	{
		links.map(({ name, svg, href }) => (
			<li class="card card--minimal">
				<a href={href}>
					<div class="logo" set:html={svg} />
					<span>{name}</span>
				</a>
			</li>
		))
	}
</ul>

<style>
	.integrations-heading {
		margin-block: 3.25rem 1rem;
	}

	.heading-link {
		display: inline-flex;
		flex-direction: row;
		flex-wrap: nowrap;
		align-items: center;
		gap: 0.5em;
		color: var(--sl-color-white);
		text-decoration: none;
		line-height: 1.1875;
	}

	.heading-link :global(svg) {
		flex-shrink: 0;
	}

	.integrations-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 1.5rem 0.75rem;
		padding: 0;
		margin-block: 0.5rem;
		list-style: none;
	}

	@media (max-width: 72rem) {
		.integrations-grid {
			grid-template-columns: repeat(5, 1fr);
		}
	}

	@media (max-width: 56rem) {
		.integrations-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	@media (max-width: 40rem) {
		.integrations-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 24rem) {
		.integrations-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.card {
		position: relative;
		margin: -0.75rem;
		padding: 0.75rem;
		display: grid;
		grid-template-columns: 1fr;
		justify-items: center;
		text-align: center;
		border-radius: 0.5rem;
	}

	.card:hover,
	.card:focus-within {
		background-color: var(--sl-color-gray-6);
		outline: 1px solid var(--sl-color-text-accent);
	}

	@media (forced-colors: active) {
		.card:hover,
		.card:focus-within {
			outline: 1px solid LinkText;
		}
	}

	a {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: var(--sl-color-white);
	}

	/* Capture clicks on the whole card for this link */
	.card a::before {
		content: '';
		position: absolute;
		inset: 0;
	}

	.card a:focus {
		outline: none;
	}

	.logo {
		display: flex;
		place-content: center;
		align-items: center;
		width: 4rem;
		height: 4rem;
		background-color: var(--sl-color-gray-7, var(--sl-color-gray-6));
		border: 1px solid var(--sl-color-hairline-light);
		outline: 1px solid transparent;
		border-radius: 50%;
		overflow: hidden;
		color: var(--sl-color-white);
	}

	.logo :global(svg) {
		width: 2.25rem;
		height: 2.25rem;
	}

	span {
		font-size: var(--sl-text-body);
		font-weight: 600;
		line-height: var(--sl-line-height-headings);
	}
</style>
