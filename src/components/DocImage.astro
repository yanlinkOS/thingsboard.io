---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	src: string;
	alt: string;
	width?: number | string;
	align?: 'left' | 'center' | 'right';
}

const { src, alt, width, align = 'center' } = Astro.props;

const numericWidth = typeof width === 'number' ? width : undefined;
const styleWidth = typeof width === 'string' ? width : undefined;

const styles: string[] = [];
if (styleWidth) styles.push(`max-width: ${styleWidth}`);
if (align !== 'center') styles.push(`text-align: ${align}`);
if (styleWidth && align === 'right') styles.push('margin-inline: auto 0');
else if (styleWidth && align === 'center') styles.push('margin-inline: auto');
const figureStyle = styles.length ? styles.join('; ') : undefined;

const assetModules = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/**/*.{png,jpg,jpeg,webp,gif}',
	{ eager: true }
);

const mod = assetModules[src];
const optimized = mod
	? await getImage({
			src: mod.default,
			...(numericWidth ? { width: numericWidth } : {}),
			format: 'webp',
			quality: 85,
		})
	: null;
---

<figure class="doc-image" style={figureStyle}>
	{
		optimized ? (
			<img
				src={optimized.src}
				alt={alt}
				width={optimized.attributes.width}
				height={optimized.attributes.height}
				loading="lazy"
				decoding="async"
			/>
		) : (
			<img src={src} alt={alt} width={numericWidth} loading="lazy" decoding="async" />
		)
	}
</figure>

<style>
	.doc-image {
		margin: 1.5rem 0;
		text-align: center;
	}

	.doc-image img {
		max-width: 100%;
		height: auto;
		border-radius: 6px;
	}

	:global(.doc-image-row) {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		margin: 1.5rem 0;
	}

	:global(.doc-image-row) .doc-image {
		flex: 1;
		min-width: 0;
		margin: 0;
	}

	@media (max-width: 640px) {
		:global(.doc-image-row) {
			flex-direction: column;
		}

		:global(.doc-image-row) .doc-image {
			max-width: 100% !important;
		}
	}
</style>
