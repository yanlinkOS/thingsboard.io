---
import fs from 'node:fs';
import { join } from 'node:path';
import { docsLink, type Products } from '~/models/site.models';
import { Icon } from '@astrojs/starlight/components';

export interface Props {
	product: Products;
}

const integrations = [
  { name: 'HTTP', icon: 'http', path: 'integrations/http/' },
  { name: 'MQTT', icon: 'mqtt', path: 'integrations/mqtt/' },
  { name: 'Kafka', icon: 'kafka', path: 'integrations/kafka/' },
];

const { product } = Astro.props;

const links = integrations.map((item) => {
	const svgPath = join(process.cwd(), 'public', 'logos', 'integration', `${item.icon}.svg`);
	let svg = '';
	try {
		svg = fs.readFileSync(svgPath, 'utf-8');
	} catch {
		/* file not found — svg stays empty */
	}
	return {
		...item,
		href: docsLink(product, item.path),
		svg,
	};
});
---

<h2 class="integrations-heading">
	<a class="heading-link" href={docsLink(product, 'integrations/')}>
		Integrations
		<Icon name="right-arrow" />
	</a>
</h2>
<ul class="integrations-grid not-content">
	{
		links.map(({ name, svg, href }) => (
			<li class="card card--minimal">
				<a href={href}>
					<div class="logo" set:html={svg} />
					<span>{name}</span>
				</a>
			</li>
		))
	}
</ul>

<style>
	.integrations-heading {
		margin-block: 3.25rem 1rem;
	}

	.heading-link {
		display: inline-flex;
		flex-direction: row;
		flex-wrap: nowrap;
		align-items: center;
		gap: 0.5em;
		color: var(--sl-color-white);
		text-decoration: none;
		line-height: 1.1875;
	}

	.heading-link :global(svg) {
		flex-shrink: 0;
	}

	.integrations-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 1.5rem 0.75rem;
		padding: 0;
		margin-block: 0.5rem;
		list-style: none;
	}

	@media (max-width: 72rem) {
		.integrations-grid {
			grid-template-columns: repeat(5, 1fr);
		}
	}

	@media (max-width: 56rem) {
		.integrations-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	@media (max-width: 40rem) {
		.integrations-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 24rem) {
		.integrations-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.card {
		position: relative;
		margin: -0.75rem;
		padding: 0.75rem;
		display: grid;
		grid-template-columns: 1fr;
		justify-items: center;
		text-align: center;
		border-radius: 0.5rem;
	}

	.card:hover,
	.card:focus-within {
		background-color: var(--sl-color-gray-6);
		outline: 1px solid var(--sl-color-text-accent);
	}

	@media (forced-colors: active) {
		.card:hover,
		.card:focus-within {
			outline: 1px solid LinkText;
		}
	}

	a {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: var(--sl-color-white);
	}

	/* Capture clicks on the whole card for this link */
	.card a::before {
		content: '';
		position: absolute;
		inset: 0;
	}

	.card a:focus {
		outline: none;
	}

	.logo {
		display: flex;
		place-content: center;
		align-items: center;
		width: 4rem;
		height: 4rem;
		background-color: var(--sl-color-gray-7, var(--sl-color-gray-6));
		border: 1px solid var(--sl-color-hairline-light);
		outline: 1px solid transparent;
		border-radius: 50%;
		overflow: hidden;
		color: var(--sl-color-white);
	}

	.logo :global(svg) {
		width: 2.25rem;
		height: 2.25rem;
	}

	span {
		font-size: var(--sl-text-body);
		font-weight: 600;
		line-height: var(--sl-line-height-headings);
	}
</style>
