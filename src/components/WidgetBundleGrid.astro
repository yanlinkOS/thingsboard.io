---
import { docsLink, Products } from '~/models/site.models';

export interface Props {
	product: Products;
}

const { product } = Astro.props;

interface Bundle {
	name: string;
	image: string;
	description: string;
	path?: string;
	peOnly?: boolean;
}

const bundles: Bundle[] = [
	{
		name: 'Charts',
		image: '/images/widgets-library/bundles/charts.svg',
		description: 'Displays time series data using line and bar charts, use various per chart options for advanced configuration.',
		path: 'reference/widgets/widget-library/charts/',
	},
	{
		name: 'Cards',
		image: '/images/widgets-library/bundles/cards.svg',
		description: 'Includes cards that display data from your entities based on data from one or two latest or time series data, and also HTML cards.',
		path: 'reference/widgets/widget-library/cards/',
	},
	{
		name: 'Alarm widgets',
		image: '/images/widgets-library/bundles/alarm-widgets.svg',
		description: 'Alarms table and notification cards for devices, assets, and other entities.',
		path: 'reference/widgets/widget-library/alarm-widgets/',
		peOnly: true,
	},
	{
		name: 'Tables',
		image: '/images/widgets-library/bundles/tables.svg',
		description: 'Contains tables to display alarms, entities, and their telemetry.',
		path: 'reference/widgets/widget-library/tables/',
	},
	{
		name: 'Count widgets',
		image: '/images/widgets-library/bundles/count-widgets.svg',
		description: 'Displays the count of the number of alarms or entities based on the selected filter.',
		path: 'reference/widgets/widget-library/count-widgets/',
	},
	{
		name: 'Maps',
		image: '/images/widgets-library/bundles/maps.svg',
		description: 'Visualize the latest location or top of devices and entities with map widgets for enhanced spatial representation.',
		path: 'reference/widgets/widget-library/maps/',
	},
	{
		name: 'Analogue gauges',
		image: '/images/widgets-library/bundles/analogue_gauges.png',
		description: 'Display temperature, humidity, speed, pressure, and other values on analogy style gauges.',
		path: 'reference/widgets/widget-library/analogue-gauges/',
	},
	{
		name: 'Buttons',
		image: '/images/widgets-library/bundles/buttons.svg',
		description: 'Facilitates user interaction by enabling navigation between dashboard states, sending RPC commands to devices, and updating device attributes or time series data.',
		path: 'reference/widgets/widget-library/buttons/',
	},
	{
		name: 'Control widgets',
		image: '/images/widgets-library/bundles/control_widgets.png',
		description: 'Various interactive widgets to control the behavior and state of the IoT devices.',
		path: 'reference/widgets/widget-library/control-widgets/',
	},
	{
		name: 'Status indicators',
		image: '/images/widgets-library/bundles/status-indicators.svg',
		description: 'Contains widgets displaying battery level and signal strength.',
		path: 'reference/widgets/widget-library/status-indicators/',
	},
	{
		name: 'SCADA symbols',
		image: '/images/widgets-library/bundles/scada-symbols.svg',
		description: 'Bundle with SCADA symbols.',
	},
	{
		name: 'Traditional SCADA fluid system',
		image: '/images/widgets-library/bundles/scada-fluid-system.svg',
		description: 'Bundle with SCADA symbols for fluid system.',
		path: 'reference/widgets/widget-library/traditional-scada-fluid-system/',
	},
	{
		name: 'General high-performance SCADA symbols',
		image: '/images/widgets-library/bundles/general-high-performance-scada-symbol.svg',
		description: 'Bundle with high-performance SCADA symbols.',
		path: 'reference/widgets/widget-library/general-high-performance-scada-symbols/',
	},
	{
		name: 'High-performance SCADA oil & gas',
		image: '/images/widgets-library/bundles/high-performance-scada-oil-gas.svg',
		description: 'Bundle with high-performance SCADA symbols for oil and gas systems.',
		path: 'reference/widgets/widget-library/high-performance-scada-oil-gas/',
	},
	{
		name: 'High-performance SCADA energy system',
		image: '/images/widgets-library/bundles/high-performance-scada-energy-system.svg',
		description: 'Bundle with high-performance SCADA symbols for energy systems.',
	},
	{
		name: 'High-performance SCADA fluid system',
		image: '/images/widgets-library/bundles/high-performance-scada-fluid-system.svg',
		description: 'Bundle with high-performance SCADA symbols for fluid system.',
		path: 'reference/widgets/widget-library/high-performance-scada-fluid-system/',
	},
	{
		name: 'Industrial widgets',
		image: '/images/widgets-library/bundles/industrial-widgets.svg',
		description: 'Contains widgets displaying industrial telemetry.',
	},
	{
		name: 'Indoor Environment',
		image: '/images/widgets-library/bundles/indoor-environment.svg',
		description: 'Contains widgets displaying indoor environment telemetry.',
	},
	{
		name: 'Outdoor Environment',
		image: '/images/widgets-library/bundles/outdoor-environment.svg',
		description: 'Contains widgets displaying outdoor environment telemetry.',
	},
	{
		name: 'Liquid level',
		image: '/images/widgets-library/bundles/liquid-level.svg',
		description: 'Visualize the level of liquid in various tank shapes with multiple tank shapes.',
	},
	{
		name: 'Digital gauges',
		image: '/images/widgets-library/bundles/digital_gauges.svg',
		description: 'Display temperature, speed, pressure, and other values on digital style gauges.',
	},
	{
		name: 'Air quality',
		image: '/images/widgets-library/bundles/air-quality.svg',
		description: 'Contains widgets displaying air quality telemetry.',
	},
	{
		name: 'Entity admin widgets',
		image: '/images/widgets-library/bundles/entity-admin-widgets.svg',
		description: 'Contains templates of complete tables for administering devices and assets.',
	},
	{
		name: 'Input widgets',
		image: '/images/widgets-library/bundles/inputs.svg',
		description: 'Various input widgets to set the location, time, and configuration parameters of the device, asset, or other entity.',
	},
	{
		name: 'Gateway widgets',
		image: '/images/widgets-library/bundles/gateway-widgets.svg',
		description: 'Widgets to manage ThingsBoard IoT Gateway instances.',
	},
	{
		name: 'Edge widgets',
		image: '/images/widgets-library/bundles/edge-widgets.svg',
		description: 'Widgets to manage ThingsBoard Edge instances and navigate through their entities.',
	},
	{
		name: 'Entity widgets',
		image: '/images/widgets-library/bundles/entity-widgets.svg',
		description: 'Visualize entity properties and hierarchy using table and tree widgets.',
	},
	{
		name: 'Home page widgets',
		image: '/images/widgets-library/bundles/home-widgets.svg',
		description: 'Contains useful widgets to design the user\'s home page.',
	},
	{
		name: 'Navigation widgets',
		image: '/images/widgets-library/bundles/nav-widgets.svg',
		description: 'Contains widgets enabling navigation to other dashboards and menu items. Useful to define the home page or dashboard.',
	},
	{
		name: 'Date',
		image: '/images/widgets-library/bundles/date-widgets.svg',
		description: 'Contains widgets to change the date range for other widgets on the dashboard.',
	},
	{
		name: 'HTML widgets',
		image: '/images/widgets-library/bundles/html-widgets.svg',
		description: 'Various HTML widgets commonly configured template in template or function with applied attributes or time series values.',
		path: 'reference/widgets/widget-library/html-widgets/',
	},
	{
		name: 'GPIO widgets',
		image: '/images/widgets-library/bundles/gpio-widgets.svg',
		description: 'Visualization and control of the states of the GPIO devices.',
	},
	{
		name: 'Advanced analytics bundle',
		image: '/images/widgets-library/bundles/advanced-analytics-bundle.svg',
		description: 'Display views created in Advanced analytics to share analysis results.',
		peOnly: true,
	},
	{
		name: 'Files',
		image: '/images/widgets-library/bundles/files.svg',
		description: 'Display files and report links to manage them.',
		path: 'reference/widgets/widget-library/files/',
		peOnly: true,
	},
	{
		name: 'Scheduling',
		image: '/images/widgets-library/bundles/scheduling.svg',
		description: 'Display scheduled events and reports with the ability to manage them.',
		path: 'reference/widgets/widget-library/scheduling/',
		peOnly: true,
	},
];

const tiles = bundles
	.filter((b) => !b.peOnly || product !== Products.CE)
	.map((b) => ({
		...b,
		href: b.path ? docsLink(product, b.path) : undefined,
	}));
---

<ul class="bundle-grid not-content">
	{
		tiles.map(({ name, image, description, href }) => (
			<li class:list={['bundle-card', { 'bundle-card--linked': !!href }]}>
				{href ? (
					<a href={href} class="bundle-card-inner">
						<div class="bundle-img">
							<img src={image} alt={name} loading="lazy" />
						</div>
						<div class="bundle-info">
							<strong class="bundle-name">{name}</strong>
							<p class="bundle-desc">{description}</p>
						</div>
					</a>
				) : (
					<div class="bundle-card-inner">
						<div class="bundle-img">
							<img src={image} alt={name} loading="lazy" />
						</div>
						<div class="bundle-info">
							<strong class="bundle-name">{name}</strong>
							<p class="bundle-desc">{description}</p>
						</div>
					</div>
				)}
			</li>
		))
	}
</ul>

<style>
	.bundle-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1rem;
		padding: 0;
		margin-block: 1.5rem 0;
		list-style: none;
	}

	@media (max-width: 72rem) {
		.bundle-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 50rem) {
		.bundle-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 30rem) {
		.bundle-grid {
			grid-template-columns: 1fr;
		}
	}

	.bundle-card {
		border: 1px solid var(--sl-color-hairline-light);
		border-radius: 0.5rem;
		overflow: hidden;
		transition: border-color 0.2s;
	}

	.bundle-card--linked:hover,
	.bundle-card--linked:focus-within {
		border-color: var(--sl-color-text-accent);
		background-color: var(--sl-color-gray-6);
	}

	.bundle-card-inner {
		display: flex;
		flex-direction: column;
		height: 100%;
		text-decoration: none;
		color: inherit;
	}

	/* Stretch the clickable area across the full card */
	.bundle-card--linked {
		position: relative;
	}

	.bundle-card--linked a.bundle-card-inner::before {
		content: '';
		position: absolute;
		inset: 0;
	}

	.bundle-card--linked a:focus {
		outline: none;
	}

	.bundle-img {
		background-color: var(--sl-color-bg-nav);
		border-bottom: 1px solid var(--sl-color-hairline-light);
		display: flex;
		align-items: center;
		justify-content: center;
		height: 130px;
		padding: 0.75rem;
		overflow: hidden;
	}

	.bundle-img img {
		max-width: 100%;
		max-height: 100%;
		width: auto;
		height: auto;
		object-fit: contain;
	}

	.bundle-info {
		padding: 0.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		flex: 1;
	}

	.bundle-name {
		font-size: var(--sl-text-sm);
		font-weight: 600;
		line-height: var(--sl-line-height-headings);
		color: var(--sl-color-white);
	}

	.bundle-desc {
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
		line-height: 1.4;
		margin: 0;
	}
</style>
