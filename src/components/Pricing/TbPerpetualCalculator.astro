---
import { Icon } from 'astro-icon/components';
import CalculatorModal from './CalculatorModal.astro';
---

<CalculatorModal id="tb-perp-calc">
	<div slot="header"><div class="calc-title-row"><h2 class="calc-title">Perpetual license calculator</h2></div></div>
	<div slot="inputs">
		<div class="calc-input-group">
			<div class="calc-input-row">
				<label class="calc-label">Number of Devices <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Total number of IoT devices that will connect to your ThingsBoard platform. Your license covers 1000 devices; a one-time fee applies to additional devices</span></span></span></label>
				<input id="perp-devices" type="number" value="1000" min="1000" class="calc-number-input" aria-label="Number of devices" />
			</div>
			<div class="calc-slider-container">
				<input type="range" id="perp-devices-slider" min="1000" max="25000" step="10" value="1000" class="calc-slider" aria-label="Devices slider" />
				<div class="calc-tick-marks"><span class="calc-tick" data-val="1000"><span class="calc-tick-line"></span><span class="calc-tick-label">1K</span></span><span class="calc-tick" data-val="5000"><span class="calc-tick-line"></span><span class="calc-tick-label">5K</span></span><span class="calc-tick" data-val="10000"><span class="calc-tick-line"></span><span class="calc-tick-label">10K</span></span><span class="calc-tick" data-val="20000"><span class="calc-tick-line"></span><span class="calc-tick-label">20K</span></span><span class="calc-tick" data-val="25000"><span class="calc-tick-line"></span><span class="calc-tick-label infinity"><Icon name="tabler:infinity" /></span></span></div>
			</div>
		</div>
		<div style="margin-bottom:24px;">
			<div class="calc-input-row" style="margin-bottom:12px;">
				<div style="flex:1;"><label class="calc-label">Production Instances <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Dedicated compute instances for your production environment. Add instances to enable clustering and High Availability (HA).</span></span></span></label><p class="calc-addon-desc" id="perp-prod-desc">1 included. Add a 2nd for high availability (HA). For every 5,000 extra devices, one production instance is added at no charge.</p></div>
				<div class="calc-stepper" id="perp-prod-stepper"><button type="button" class="calc-stepper-btn" data-action="decrement" disabled aria-label="Decrease production instances">&minus;</button><input type="number" class="calc-stepper-input" value="1" min="1" id="perp-prod" aria-label="Production instances" /><button type="button" class="calc-stepper-btn" data-action="increment" aria-label="Increase production instances">+</button></div>
			</div>
			<div class="calc-input-row">
				<div style="flex:1;"><label class="calc-label">Development Instances <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Compute instances used for development, testing, and CI/CD workflows.</span></span></span></label><p class="calc-addon-desc">Add dedicated instances for your dev, test, and CI/CD workflows. Keep your production data clean.</p></div>
				<div class="calc-stepper" id="perp-dev-stepper"><button type="button" class="calc-stepper-btn" data-action="decrement" disabled aria-label="Decrease development instances">&minus;</button><input type="number" class="calc-stepper-input" value="0" min="0" id="perp-dev" aria-label="Development instances" /><button type="button" class="calc-stepper-btn" data-action="increment" aria-label="Increase development instances">+</button></div>
			</div>
		</div>
		<div class="calc-addons-label">Add-ons <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Optional modules to extend platform functionality.</span></span></span></div>
		<div class="calc-addons-grid">
			<div class="calc-addon-card" id="perp-edge-card"><div class="calc-addon-header"><span class="calc-addon-title">Edge Computing <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Deploy and manage Edge instances at remote locations for offline operation, local processing, and automatic cloud sync.</span></span></span></span><label class="calc-toggle"><input type="checkbox" id="perp-edge-toggle" role="switch" aria-label="Toggle Edge Computing" /><span class="calc-toggle-track"></span></label></div><p class="calc-addon-desc" id="perp-edge-desc">Process data where it is collected.</p>
				<div class="calc-addon-counter hidden" id="perp-edge-counter"><span>Edge Instances</span><div class="calc-stepper" id="perp-edge-stepper"><button type="button" class="calc-stepper-btn" data-action="decrement" disabled aria-label="Decrease edge instances">&minus;</button><input type="number" class="calc-stepper-input" value="2" min="2" id="perp-edge" aria-label="Edge instances" /><button type="button" class="calc-stepper-btn" data-action="increment" aria-label="Increase edge instances">+</button></div></div>
			</div>
			<div class="calc-addon-card" id="perp-trendz-card"><div class="calc-addon-header"><span class="calc-addon-title">Trendz Analytics <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Advanced analytics for data insights, custom dashboards, and trend discovery.</span></span></span></span><label class="calc-toggle"><input type="checkbox" id="perp-trendz-toggle" role="switch" aria-label="Toggle Trendz Analytics" /><span class="calc-toggle-track"></span></label></div><p class="calc-addon-desc">Advanced analytics for your solution.</p></div>
			<div class="calc-addon-card" id="perp-offline-card"><div class="calc-addon-header"><span class="calc-addon-title">Offline Mode <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Enables full platform functionality in environments without internet connection.</span></span></span></span><label class="calc-toggle"><input type="checkbox" id="perp-offline-toggle" role="switch" aria-label="Toggle Offline Mode" /><span class="calc-toggle-track"></span></label></div><p class="calc-addon-desc">Full functionality without internet.</p></div>
		</div>
	</div>
</CalculatorModal>

<script>
	// Lazy-load the calculator's JS only when the user first opens the modal.
	// Full body lives in `src/scripts/pricing/calc-tb-perp.ts`.
	let p: Promise<typeof import('~/scripts/pricing/calc-tb-perp')> | null = null;

	function installOpener() {
		(window as any).openTbPerpCalc = async () => {
			// Reset the memo on failure so a flaky / blocked / stale-hash chunk
			// fetch can be retried on the next click instead of wedging the modal
			// until a page refresh.
			p ??= import('~/scripts/pricing/calc-tb-perp').catch((err) => {
				p = null;
				throw err;
			});
			try {
				(await p).openTbPerpCalc();
			} catch {
				/* chunk failed to load — memo already reset; clicking again retries */
			}
		};
	}
	installOpener();
</script>
