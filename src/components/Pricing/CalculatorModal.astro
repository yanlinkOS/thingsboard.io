	// ═══════════════════════════════════════════
	// WHITE LABELING PROMPT
	// ═══════════════════════════════════════════

	.calc-wl-prompt {
		display: flex;
		align-items: center;
		gap: $spacing-2;
		padding: $spacing-2 $spacing-3;
