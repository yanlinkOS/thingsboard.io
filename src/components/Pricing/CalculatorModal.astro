			height: 1px;
			background: var(--sl-color-gray-5);
		}
	}

	// ─── Add-on result row ───
	.calc-addon-active {
		// No extra margin — consistent with disabled addon rows
	}

	.calc-addon-result {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: $spacing-3;
		min-height: 32px;

		.calc-addon-result-name {
			display: flex;
			align-items: center;
			gap: $spacing-2;
			font-size: $font-size-sm;
			font-weight: $font-weight-medium;
			color: var(--color-text);
		}

		.calc-addon-result-action {
			font-size: $font-size-sm;
			font-weight: $font-weight-medium;
			line-height: 1.4;
			color: var(--color-primary);
			background: none;
			border: none;
			padding: 0;
			cursor: pointer;
			text-align: right;
			white-space: nowrap;

			&:hover { text-decoration: underline; }
		}

		// On narrow viewports the default 14px copy ("Multi-AZ Deployment" +
		// "Add to plan ($400.00)") doesn't fit on a single line at 375px and
		// wraps awkwardly. Shrink both label and action to 12px so each addon
		// stays as one clean row that mirrors the desktop layout.
		@include media-down(sm) {
			gap: $spacing-2;

			.calc-addon-result-name,
			.calc-addon-result-action,
			.calc-section-price {
				font-size: $font-size-xs;
			}
		}
	}

	// ─── Billing toggle (Monthly / Annual) ───
	.calc-billing-row {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: $spacing-3;
		margin-bottom: $spacing-3;

		.calc-billing-label {
			font-size: $font-size-sm;
			color: var(--color-text-secondary);
			cursor: pointer;
			user-select: none;
			transition: color 0.15s ease;

			&.active {
				color: var(--color-text);
				font-weight: $font-weight-medium;
			}

			&:hover:not(.active) {
				color: var(--color-text);
			}
		}

		.calc-billing-save {
			font-size: $font-size-xs;
			color: var(--color-primary);
			font-weight: $font-weight-medium;
		}

