<script is:inline>
	// ─── Modal open/close visuals ───
	// Scroll-lock is owned by the consumer scripts via `@util/scroll-lock`
	// (lockScroll/unlockScroll); here we only toggle the fade-in class.
	window.calcModalOpen = function() {
		const overlay = document.querySelector('.calc-modal-overlay:not([style*="display: none"]):not([style*="display:none"])');
		if (overlay) requestAnimationFrame(function() { overlay.classList.add('calc-modal--open'); });
	};
	window.calcModalClose = function() {
		document.querySelectorAll('.calc-modal-overlay').forEach(function(el) { el.classList.remove('calc-modal--open'); });
	};

	// ─── Shared slider utilities (global) ───

	// Cache the two theme-dependent CSS custom properties on `window` so
	// continuous slider `input` events don't force a fresh style recalc per call.
	// State lives on `window` because this `is:inline` script is inlined once per
	// <CalculatorModal /> instance on the page — a block-scoped `let` would throw
	// "already declared" on the 2nd/3rd inlining. Bust the cache when Starlight
	// flips `data-theme` on <html>.
	function _readSliderColors() {
		const cs = getComputedStyle(document.documentElement);
		window._sliderColors = {
			primary: cs.getPropertyValue('--sl-color-text-accent').trim() || '#3D50F5',
			track: cs.getPropertyValue('--sl-color-gray-5').trim() || '#E0E1E2',
		};
		return window._sliderColors;
	}
	if (!window._sliderColorsObserved) {
		window._sliderColorsObserved = true;
		new MutationObserver(function() { window._sliderColors = null; })
			.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
	}

	/** Update slider track fill via background linear-gradient */
	window.sliderProgress = function(slider) {
		const progress = ((parseFloat(slider.value) - parseFloat(slider.min)) / (parseFloat(slider.max) - parseFloat(slider.min))) * 100;
		const c = window._sliderColors || _readSliderColors();
		slider.style.background = 'linear-gradient(to right, ' + c.primary + ' ' + progress + '%, ' + c.track + ' ' + progress + '%)';
	};

	/** Position tick marks using JS (compensates for thumb width) */
	window.initTickMarks = function(container) {
		const sliderInput = container.querySelector('.calc-slider');
		if (!sliderInput) return;

		const min = parseFloat(sliderInput.min);
		const max = parseFloat(sliderInput.max);
		const range = max - min;
		const sliderWidth = sliderInput.offsetWidth;
		const thumbWidth = 25;
		const trackRatio = sliderWidth > 0 ? thumbWidth / sliderWidth : 0;

		container.querySelectorAll('.calc-tick').forEach(function(tick) {
			const tickVal = parseFloat(tick.dataset.val || '0');
			const relative = (tickVal - min) / range;
			const percent = ((trackRatio / 2) + (relative * (1 - trackRatio))) * 100;
			tick.style.left = percent + '%';
		});
	};

	/** Initialize all sliders and tick marks in a container */
	window.initAllSliders = function(root) {
		root = root || document;
		root.querySelectorAll('.calc-slider-container').forEach(function(c) {
			window.initTickMarks(c);
			const slider = c.querySelector('.calc-slider');
			if (slider) window.sliderProgress(slider);
		});
	};

	// Re-init on resize (tick positions depend on slider width)
	if (!window._calcResizeInit) {
		window._calcResizeInit = true;
		let _resizeTimer = null;
		window.addEventListener('resize', function() {
			if (_resizeTimer) clearTimeout(_resizeTimer);
			_resizeTimer = setTimeout(function() { window.initAllSliders(); }, 150);
		});
	}
</script>

<script>

	// ─── Calculator tooltip: JS-only visibility ───
	let activeCalcTip: { trigger: HTMLElement; tip: HTMLElement } | null = null;
	let calcShowTimer: ReturnType<typeof setTimeout> | null = null;
	let calcHideTimer: ReturnType<typeof setTimeout> | null = null;

	function forceHideCalcTip() {
		if (calcShowTimer) { clearTimeout(calcShowTimer); calcShowTimer = null; }
		if (calcHideTimer) { clearTimeout(calcHideTimer); calcHideTimer = null; }
		if (activeCalcTip) {
			activeCalcTip.tip.classList.remove('calc-tooltip--visible', 'calc-tooltip--interactive');
			activeCalcTip.tip.style.left = '-9999px';
			activeCalcTip = null;
		}
	}

	function getEl(e: Event): HTMLElement | null {
		let t = e.target as Node;
		// SVG elements and text nodes don't have .closest — walk up to nearest Element
		while (t && !(t instanceof HTMLElement)) t = t.parentNode as Node;
		return t as HTMLElement | null;
	}

	function initCalcTooltips() {
		// mouseover/mouseout bubble — works with event delegation on dynamic content
		document.addEventListener('mouseover', (e) => {
			const el = getEl(e);
			if (!el) return;

			const trigger = el.closest('.calc-tooltip') as HTMLElement | null;
			if (trigger) {
				// Already active on this trigger? Skip.
				if (activeCalcTip?.trigger === trigger) return;

				const tip = trigger.querySelector('.calc-tooltip-text') as HTMLElement | null;
				if (!tip) return;

				// Cancel pending hide
				if (calcHideTimer) { clearTimeout(calcHideTimer); calcHideTimer = null; }
				// Hide previous
				if (activeCalcTip && activeCalcTip.tip !== tip) forceHideCalcTip();
				if (calcShowTimer) clearTimeout(calcShowTimer);

				// Position — offset by modal wrapper since transform creates a new containing block
				const modal = trigger.closest('.calc-modal-wrapper') as HTMLElement | null;
				const modalRect = modal?.getBoundingClientRect() ?? { left: 0, top: 0, right: window.innerWidth };
				const rect = trigger.getBoundingClientRect();
				const tipWidth = 262;
				const margin = 8;
				const spaceRight = window.innerWidth - rect.right - margin;
				const spaceLeft = rect.left - margin;
				const arrow = tip.querySelector('.calc-tooltip-arrow') as HTMLElement | null;
				let leftVp: number;
				let flexDir: 'row' | 'row-reverse';
				let clamped = false;
				if (spaceRight >= tipWidth + 4) {
					// Fits on the right
					leftVp = rect.right + 4;
					flexDir = 'row';
				} else if (spaceLeft >= tipWidth + 4) {
					// Fits on the left
					leftVp = rect.left - tipWidth - 4;
					flexDir = 'row-reverse';
				} else {
					// Doesn't fit either side (narrow mobile viewport).
					// Clamp the tooltip body into the viewport and hide the arrow.
					leftVp = Math.max(margin, window.innerWidth - tipWidth - margin);
					flexDir = 'row';
					clamped = true;
				}
				tip.style.left = `${leftVp - modalRect.left}px`;
				tip.style.flexDirection = flexDir;
				if (arrow) arrow.style.display = clamped ? 'none' : '';
				tip.style.top = `${rect.top - modalRect.top + rect.height / 2}px`;
				tip.style.transform = 'translateY(-50%)';
				activeCalcTip = { trigger, tip };

				calcShowTimer = setTimeout(() => {
					tip.classList.add('calc-tooltip--visible');
					if (tip.querySelector('a')) tip.classList.add('calc-tooltip--interactive');
				}, 150);
				return;
			}

			// Entering the tooltip body — cancel hide
			const tipBody = el.closest('.calc-tooltip-text') as HTMLElement | null;
			if (tipBody && activeCalcTip?.tip === tipBody && calcHideTimer) {
				clearTimeout(calcHideTimer);
				calcHideTimer = null;
			}
		});

		document.addEventListener('mouseout', (e) => {
			const el = getEl(e);
			if (!el) return;
			const related = getEl({ target: (e as MouseEvent).relatedTarget } as any);

			const trigger = el.closest('.calc-tooltip') as HTMLElement | null;
			if (trigger) {
				// Still inside the same trigger? (moved between children)
				if (related && trigger.contains(related)) return;
				// Moved to the tooltip body?
				if (related && activeCalcTip?.tip.contains(related)) return;
				// Already on a different trigger? Ignore stale leave.
				if (activeCalcTip && activeCalcTip.trigger !== trigger) return;

				if (activeCalcTip?.trigger === trigger) {
					if (calcShowTimer) { clearTimeout(calcShowTimer); calcShowTimer = null; }
					if (activeCalcTip.tip.classList.contains('calc-tooltip--interactive')) {
						calcHideTimer = setTimeout(() => forceHideCalcTip(), 300);
					} else {
						forceHideCalcTip();
					}
				}
				return;
			}

			// Leaving the tooltip body
			const tipBody = el.closest('.calc-tooltip-text') as HTMLElement | null;
			if (tipBody && activeCalcTip?.tip === tipBody) {
				// Moving back to trigger? Don't hide.
				if (related && activeCalcTip.trigger.contains(related)) return;
				forceHideCalcTip();
			}
		});
	}

	initCalcTooltips();

	// Click a tick label → snap the slider to that tick. The classList check is
	// O(1) so the listener is cheap on unrelated clicks; tree walk only runs
	// when the click actually hits a label.
	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement | null;
		if (!target?.classList.contains('calc-tick-label')) return;
		const tick = target.parentElement as HTMLElement | null;
		const slider = tick?.closest('.calc-slider-container')?.querySelector<HTMLInputElement>('.calc-slider');
		if (!slider || !tick?.dataset.val) return;
		slider.value = tick.dataset.val;
		slider.dispatchEvent(new Event('input', { bubbles: true }));
	});
</script>
