---
import { Icon } from 'astro-icon/components';
import CalculatorInline from './CalculatorInline.astro';
---

<CalculatorInline id="tbmq-perp-calc" title="TBMQ Perpetual calculator">
	<div slot="header"><div class="calc-title-row"><h2 class="calc-title">TBMQ Perpetual license calculator</h2></div></div>
	<div slot="inputs">
		<div class="calc-input-group">
			<div class="calc-input-row">
				<label class="calc-label">Sessions <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Total unique logical states managed by the broker, identified by Client ID. Active connections and disconnected clients with persistent sessions both occupy quota slots.</span></span></span></label>
				<input id="mqp-sessions" type="number" value="10000" min="10000" class="calc-number-input" aria-label="Sessions" />
			</div>
			<div class="calc-slider-container">
				<input type="range" id="mqp-sessions-slider" min="10000" max="550000" step="1000" value="10000" class="calc-slider" aria-label="Sessions slider" />
				<div class="calc-tick-marks"><span class="calc-tick" data-val="10000"><span class="calc-tick-line"></span><span class="calc-tick-label">10K</span></span><span class="calc-tick" data-val="50000"><span class="calc-tick-line"></span><span class="calc-tick-label">50K</span></span><span class="calc-tick" data-val="100000"><span class="calc-tick-line"></span><span class="calc-tick-label">100K</span></span><span class="calc-tick" data-val="250000"><span class="calc-tick-line"></span><span class="calc-tick-label">250K</span></span><span class="calc-tick" data-val="500000"><span class="calc-tick-line"></span><span class="calc-tick-label">500K</span></span><span class="calc-tick" data-val="550000"><span class="calc-tick-line"></span><span class="calc-tick-label infinity"><Icon name="tabler:infinity" /></span></span></div>
			</div>
		</div>
		<div class="calc-input-group">
			<div class="calc-input-row">
				<label class="calc-label">Throughput (msg/sec) <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Combined number of MQTT PUBLISH packets processed per second, including both incoming (publisher) and outgoing (subscriber) messages.</span></span></span></label>
				<input id="mqp-throughput" type="number" value="1000" min="1000" class="calc-number-input" aria-label="Throughput" />
			</div>
			<div class="calc-slider-container">
				<input type="range" id="mqp-throughput-slider" min="1000" max="30000" step="100" value="1000" class="calc-slider" aria-label="Throughput slider" />
				<div class="calc-tick-marks"><span class="calc-tick" data-val="1000"><span class="calc-tick-line"></span><span class="calc-tick-label">1K</span></span><span class="calc-tick" data-val="2000"><span class="calc-tick-line"></span><span class="calc-tick-label">2K</span></span><span class="calc-tick" data-val="5000"><span class="calc-tick-line"></span><span class="calc-tick-label">5K</span></span><span class="calc-tick" data-val="10000"><span class="calc-tick-line"></span><span class="calc-tick-label">10K</span></span><span class="calc-tick" data-val="20000"><span class="calc-tick-line"></span><span class="calc-tick-label">20K</span></span><span class="calc-tick" data-val="30000"><span class="calc-tick-line"></span><span class="calc-tick-label infinity"><Icon name="tabler:infinity" /></span></span></div>
			</div>
		</div>
		<div style="margin-bottom:24px;">
			<div class="calc-input-row" style="margin-bottom:12px;">
				<div style="flex:1;"><label class="calc-label">Production Instances <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Dedicated compute instances for your production environment. Add instances to enable clustering and high availability (HA).</span></span></span></label><p class="calc-addon-desc">1 instance included. Add more for high availability (HA) and reliability.</p></div>
				<div class="calc-stepper" id="mqp-prod-stepper"><button type="button" class="calc-stepper-btn" data-action="decrement" disabled aria-label="Decrease production instances">&minus;</button><input type="number" class="calc-stepper-input" value="1" min="1" id="mqp-prod" aria-label="Production instances" /><button type="button" class="calc-stepper-btn" data-action="increment" aria-label="Increase production instances">+</button></div>
			</div>
			<div class="calc-input-row">
				<div style="flex:1;"><label class="calc-label">Development Instances <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Compute instances used for development, testing, and CI/CD workflows. Not intended for production traffic.</span></span></span></label><p class="calc-addon-desc">Add dedicated instances for your dev, test, and CI/CD workflows. Keep your production data clean.</p></div>
				<div class="calc-stepper" id="mqp-dev-stepper"><button type="button" class="calc-stepper-btn" data-action="decrement" disabled aria-label="Decrease development instances">&minus;</button><input type="number" class="calc-stepper-input" value="0" min="0" id="mqp-dev" aria-label="Development instances" /><button type="button" class="calc-stepper-btn" data-action="increment" aria-label="Increase development instances">+</button></div>
			</div>
		</div>
	</div>
</CalculatorInline>

<script>
	// Lazy-load the TBMQ Perpetual calculator. See `TbmqPaygCalculator.astro`
	// for the full rationale (two init paths: the `pricing:product-activated`
	// event for tab switches, plus an immediate load when TBMQ is already the
	// active product on a deep-link, since hoisted-script order isn't
	// guaranteed). initMqpCalc() is idempotent, so the paths can't double-init.
	// Listener registered once per document lifetime.
	if (!(window as any)._tbmqPerpLoaderInited) {
		(window as any)._tbmqPerpLoaderInited = true;
		const loadCalc = () =>
			import('~/scripts/pricing/calc-tbmq-perp')
				.then((m) => m.initMqpCalc())
				.catch(() => {/* chunk fetch failed — keep the console clean */});
		document.addEventListener('pricing:product-activated', ((e: CustomEvent) => {
			if (e.detail === 'tbmq') loadCalc();
		}) as EventListener);
		const activeTab = document.querySelector('.product-tab.active') as HTMLElement | null;
		if (activeTab?.dataset.product === 'tbmq') loadCalc();
	}
</script>
