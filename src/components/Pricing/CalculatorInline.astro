---
import { Icon } from 'astro-icon/components';

interface Props {
	id: string;
	title: string;
}

const { id } = Astro.props as Props;
---

<div id={id} class="calc-inline">
	<div class="calc-inline-body">
		<div class="calc-panel calc-panel--inputs">
			<div class="calc-panel-scroll">
				<slot name="header" />
				<slot name="inputs" />
			</div>
			<div class="calc-inputs-footer">
				<button type="button" class="calc-reset-btn" data-calc-reset>Reset</button>
			</div>
		</div>
		<div class="calc-panel calc-panel--results">
			<div class="calc-panel-scroll">
				<div class="calc-results-head">
					<h3>Calculation summary</h3>
					<div class="calc-results-actions">
						<button type="button" class="calc-icon-btn" data-calc-copy title="Copy" aria-label="Copy calculation to clipboard">
							<Icon name="tabler:copy" />
						</button>
						<button type="button" class="calc-icon-btn" data-calc-download title="Download" aria-label="Download calculation as text file">
							<Icon name="tabler:download" />
						</button>
					</div>
				</div>
				<div data-calc-results></div>
			</div>
			<div class="calc-results-footer" data-calc-footer></div>
		</div>
	</div>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;
	@use './calc-icon-btn' as *;

	@include calc-icon-btn;

	.calc-inline {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 24px;
		overflow: hidden;
		margin-bottom: $spacing-8;
		background: var(--color-bg-surface);
		padding: $spacing-2;
	}

	.calc-inline .calc-panel-scroll {
		padding-top: $spacing-8;
	}

	.calc-inline-body {
		display: grid;
		// `minmax(0, …)` instead of bare `1fr` / `3fr` etc. — the implicit
		// `minmax(auto, …)` lets the track grow to fit children's min-content,
		// which on mobile pushed the inputs panel (fixed-width number input,
		// non-wrapping button text inside results rows) wider than the
		// viewport. `.calc-inline` then clipped the overflow with
		// `overflow: hidden`, hiding the Reset button + summary values.
		grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
		gap: $spacing-2;
		min-height: 600px;

		@include media-down(lg) {
			grid-template-columns: minmax(0, 1fr);
			min-height: auto;
		}

		// Both panels fill their grid cell completely
		> .calc-panel {
			height: 100%;
			border-radius: 16px;
			min-width: 0; // allow the panel to shrink inside the grid track
		}

		// Titles need bottom spacing in inline (no fixed header)
		.calc-title-row,
		.calc-results-head {
			padding-bottom: $spacing-3;
			margin-bottom: $spacing-4;
		}

		@include media-down(md) {
			.calc-panel-scroll {
				padding: $spacing-4 $spacing-5 $spacing-5;
			}

			.calc-inputs-footer {
				padding: $spacing-3 $spacing-5 $spacing-5;
			}

			.calc-results-footer {
				padding: $spacing-3 $spacing-5 $spacing-5;
			}

			.calc-title-row {
				flex-direction: column;
				gap: $spacing-3;
			}
		}

		@include media-down(sm) {
			.calc-addons-grid {
				grid-template-columns: 1fr;
			}

			.calc-input-row {
				flex-direction: column;
				align-items: stretch;
				gap: $spacing-2;
			}
		}
	}
</style>
