---
import { Icon } from 'astro-icon/components';
import CalculatorModal from './CalculatorModal.astro';
---

<CalculatorModal id="tb-payg-calc">
	<div slot="header">
		<div class="calc-title-row">
			<h2 class="calc-title">Self-managed subscription calculator</h2>
		</div>
	</div>

	<div slot="inputs">
		<!-- Device count -->
		<div class="calc-input-group">
			<div class="calc-input-row">
				<label class="calc-label">Number of Devices <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">The total number of IoT devices that will connect to ThingsBoard</span></span></span></label>
				<input id="sm-devices" type="number" value="10" min="1" max="150000" class="calc-number-input" aria-label="Number of devices" />
			</div>
			<div class="calc-slider-container">
				<input type="range" id="sm-slider" min="0" max="5" step="0.01" value="0" class="calc-slider" aria-label="Devices slider" />
				<div class="calc-tick-marks">
					<span class="calc-tick" data-val="0"><span class="calc-tick-line"></span><span class="calc-tick-label">10</span></span>
					<span class="calc-tick" data-val="1"><span class="calc-tick-line"></span><span class="calc-tick-label">50</span></span>
					<span class="calc-tick" data-val="2"><span class="calc-tick-line"></span><span class="calc-tick-label">100</span></span>
					<span class="calc-tick" data-val="3"><span class="calc-tick-line"></span><span class="calc-tick-label">500</span></span>
					<span class="calc-tick" data-val="4"><span class="calc-tick-line"></span><span class="calc-tick-label">1K</span></span>
					<span class="calc-tick" data-val="5"><span class="calc-tick-line"></span><span class="calc-tick-label infinity"><Icon name="tabler:infinity" /></span></span>
				</div>
			</div>
		</div>

		<!-- Instances -->
		<div style="margin-bottom:24px;">
			<div class="calc-input-row" style="margin-bottom:16px;">
				<div style="flex:1;">
					<label class="calc-label" style="margin-bottom:4px;">Production Instances <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Production instances handle your live data and real-time operations</span></span></span></label>
					<p class="calc-addon-desc" id="sm-prod-desc">Maker includes 1 instance. Choose Prototype plan to add more for HA and reliability.</p>
				</div>
				<div class="calc-stepper" id="sm-prod-stepper">
					<button type="button" class="calc-stepper-btn" data-action="decrement" disabled aria-label="Decrease production instances">&minus;</button>
					<input type="number" class="calc-stepper-input" value="1" min="1" id="sm-prod" disabled aria-label="Production instances" />
					<button type="button" class="calc-stepper-btn" data-action="increment" disabled aria-label="Increase production instances">+</button>
				</div>
			</div>
			<div class="calc-input-row">
				<div style="flex:1;">
					<label class="calc-label" style="margin-bottom:4px;">Development Instances <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Development instances for testing and CI/CD workflows</span></span></span></label>
					<p class="calc-addon-desc" id="sm-dev-desc">Choose Prototype plan to add dev instances. Safely test new features without impacting your live data.</p>
				</div>
				<div class="calc-stepper" id="sm-dev-stepper">
					<button type="button" class="calc-stepper-btn" data-action="decrement" disabled aria-label="Decrease development instances">&minus;</button>
					<input type="number" class="calc-stepper-input" value="0" min="0" id="sm-dev" disabled aria-label="Development instances" />
					<button type="button" class="calc-stepper-btn" data-action="increment" disabled aria-label="Increase development instances">+</button>
				</div>
			</div>
			<div class="calc-wl-prompt" id="sm-wl-prompt">
				<span>Need White Labeling?</span>
				<button type="button" id="sm-choose-pilot">Choose Pilot Plan</button>
			</div>
		</div>

		<!-- Add-ons -->
		<div class="calc-addons-label">Add-ons <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Optional features to enhance your plan</span></span></span></div>
		<div class="calc-addons-grid">
			<div class="calc-addon-card" id="sm-edge-card">
				<div class="calc-addon-badge">100% OFF</div>
				<div class="calc-addon-header">
					<span class="calc-addon-title">Edge Computing <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Deploy edge computing instances for local data processing</span></span></span></span>
					<label class="calc-toggle"><input type="checkbox" id="sm-edge-toggle" role="switch" aria-label="Toggle Edge Computing" /><span class="calc-toggle-track"></span></label>
				</div>
				<p class="calc-addon-desc" id="sm-edge-desc">Process data where it is collected.</p>
				<div class="calc-addon-counter hidden" id="sm-edge-counter">
					<span>Edge Instances</span>
					<div class="calc-stepper" id="sm-edge-stepper">
						<button type="button" class="calc-stepper-btn" data-action="decrement" disabled aria-label="Decrease edge instances">&minus;</button>
						<input type="number" class="calc-stepper-input" value="1" min="1" id="sm-edge-count" aria-label="Edge instances" />
						<button type="button" class="calc-stepper-btn" data-action="increment" aria-label="Increase edge instances">+</button>
					</div>
				</div>
			</div>
			<div class="calc-addon-card" id="sm-trendz-card">
				<div class="calc-addon-badge">100% OFF</div>
				<div class="calc-addon-header">
					<span class="calc-addon-title">Trendz Analytics <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Advanced analytics and visualization for your IoT data</span></span></span></span>
					<label class="calc-toggle"><input type="checkbox" id="sm-trendz-toggle" role="switch" aria-label="Toggle Trendz Analytics" /><span class="calc-toggle-track"></span></label>
				</div>
				<p class="calc-addon-desc">Advanced analytics for your solution.</p>
			</div>
			<div class="calc-addon-card" id="sm-mobile-card">
				<div class="calc-addon-header">
					<span class="calc-addon-title">White-labeled Mobile App <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Customizable mobile app branded for your company</span></span></span></span>
					<label class="calc-toggle"><input type="checkbox" id="sm-mobile-toggle" role="switch" aria-label="Toggle Mobile App" /><span class="calc-toggle-track"></span></label>
				</div>
				<p class="calc-addon-desc">Customizable mobile app for your end-users.</p>
			</div>
		</div>
	</div>
</CalculatorModal>

<script>
	// Lazy-load the calculator's JS only when the user first opens the modal.
	// The full ~20 KiB body lives in `src/scripts/pricing/calc-tb-payg.ts` and
	// is only fetched on demand.
	let p: Promise<typeof import('~/scripts/pricing/calc-tb-payg')> | null = null;

	function installOpener() {
		(window as any).openTbPaygCalc = async () => {
			// Reset the memo on failure so a flaky / blocked / stale-hash chunk
			// fetch can be retried on the next click instead of wedging the modal
			// until a page refresh.
			p ??= import('~/scripts/pricing/calc-tb-payg').catch((err) => {
				p = null;
				throw err;
			});
			try {
				(await p).openTbPaygCalc();
			} catch {
				/* chunk failed to load — memo already reset; clicking again retries */
			}
		};
	}
	installOpener();
</script>

