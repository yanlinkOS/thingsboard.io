---
import { Icon } from 'astro-icon/components';
import type { AddOnItem } from '@data/pricing/types.ts';

interface Props {
	title?: string;
	subtitle?: string;
	addOns: AddOnItem[];
}

const {
	title = 'Add-ons',
	subtitle = 'Customize your deployment with optional features to suit your business needs.',
	addOns,
} = Astro.props;
---

<div class="addons-section">
	<h2 class="addons-title">{title}</h2>
	{subtitle && <p class="addons-subtitle">{subtitle}</p>}
	<div class="addons-grid">
		{
			addOns.map((addon) => (
				<div class="addon-card">
					{addon.icon && <span class="addon-icon" set:html={addon.icon} />}
					<div class="addon-info">
						<h3 class="addon-name">
							{addon.name}
							{(addon.faqTooltip || addon.faqId) && (
								<span class="addon-tooltip-trigger" data-faq-id={addon.faqId}>
									<Icon name="tabler:info-circle" class="addon-tooltip-icon" />
									{addon.faqTooltip && (
										<span class="addon-tooltip">
											<span class="addon-tooltip-arrow" />
											<span class="addon-tooltip-body" set:html={addon.faqTooltip} />
										</span>
									)}
								</span>
							)}
						</h3>
						{addon.description && <span class="addon-description">{addon.description}</span>}
						<span class="addon-price">
							{addon.startingFrom && <span class="addon-price-prefix">Starting from </span>}
							<span class="addon-price-value">
								{typeof addon.priceUsd === 'string' ? addon.priceUsd : `$${addon.priceUsd}`}
								{addon.period}
							</span>
							{addon.setupFee != null && addon.setupFee > 0 && (
								<span class="addon-setup">
									{' '}
									({addon.setupFeeCurrency ?? '$'}
									{addon.setupFee.toLocaleString('en-US').replace(/,/g, ' ')} one time setup fee)
								</span>
							)}
						</span>
					</div>
				</div>
			))
		}
	</div>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.addons-section {
		margin-bottom: $spacing-16;
		// Offset the #add-ons-* deep-link scroll so the title clears the sticky header.
		scroll-margin-top: calc(var(--header-height) + #{$spacing-4});
	}

	.addons-title {
		@include subsection-title;
		color: var(--color-text);
		margin: 0 0 $spacing-2;
	}

	.addons-subtitle {
		@include text-m;
		color: var(--color-text-secondary);
		margin: 0 0 $spacing-6;
	}

	.addons-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: $spacing-4;

		@include media-down(sm) {
			grid-template-columns: 1fr;
		}
	}

	.addon-card {
		display: flex;
		align-items: flex-start;
		gap: $spacing-4;
		padding: $spacing-5;
		background: var(--color-bg-surface);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: $radius-lg;
	}

	.addon-icon {
		flex-shrink: 0;
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-primary);

		svg {
			width: 40px;
			height: 40px;
		}
	}

	.addon-info {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.addon-name {
		// Element is h3 for SEO — reset browser defaults to keep the original card styling.
		font-size: $font-size-base;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
		line-height: 1.3;
		margin: 0;
	}

	.addon-description {
		font-size: $font-size-sm;
		color: var(--color-text-secondary);
		line-height: 1.4;
	}

	.addon-price {
		font-size: $font-size-sm;
		color: var(--color-text-secondary);
		line-height: 1.4;
		margin-top: 2px;
	}

	.addon-price-prefix {
		color: var(--color-text-secondary);
	}

	.addon-price-value {
		font-weight: $font-weight-bold;
		color: var(--color-primary);
	}

	.addon-setup {
		color: var(--color-text-secondary);
		font-weight: $font-weight-normal;
	}

	// ─── Addon tooltip (same pattern as plan feature tooltips) ───
	.addon-tooltip-trigger {
		position: relative;
		display: inline;
		cursor: pointer;
		margin-left: 0;
	}

	.addon-tooltip-icon {
		width: 14px;
		height: 14px;
		color: var(--color-text);
		opacity: 0.8;
		vertical-align: text-top;
		margin-top: -1px;
		margin-left: -2px;
		transition:
			color 0.2s ease,
			opacity 0.2s ease;
	}

	.addon-tooltip-trigger:hover .addon-tooltip-icon {
		color: var(--color-primary);
		opacity: 1;
	}

	.addon-tooltip {
		position: fixed;
		z-index: 99999;
		pointer-events: none;
		left: -9999px;
		top: 0;
		display: flex;
		align-items: center;

		opacity: 0;
		visibility: hidden;
		transition:
			opacity 0.15s ease,
			visibility 0.15s ease;
		transition-delay: 0ms;

		&::before {
			content: '';
			position: absolute;
			top: 0;
			left: -12px;
			width: 16px;
			height: 100%;
		}
	}

	.addon-tooltip.pricing-tooltip--visible {
		opacity: 1;
		visibility: visible;
		pointer-events: none;
		&.pricing-tooltip--interactive {
			pointer-events: auto;
		}
	}

	.addon-tooltip-arrow {
		flex-shrink: 0;
		width: 0;
		height: 0;
		border: 6px solid transparent;
		border-right-color: var(--sl-color-gray-5);
		position: relative;

		&::after {
			content: '';
			position: absolute;
			top: -6px;
			left: -4px;
			width: 0;
			height: 0;
			border: 6px solid transparent;
			border-right-color: var(--color-bg-surface);
		}
	}

	.addon-tooltip-body {
		display: block;
		padding: $spacing-3;
		background: var(--color-bg-surface);
		color: var(--color-text);
		font-size: $font-size-sm;
		font-weight: $font-weight-normal;
		line-height: 1.5;
		text-align: left;
		white-space: normal;
		width: 280px;
		border-radius: $radius-lg;
		border: 1px solid var(--sl-color-gray-5);
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);

		a {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}
</style>
