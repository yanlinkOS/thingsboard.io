---
// Diagonal animated wave background — upper-left to bottom-right, converging at bottom
// Uses SMIL <animateTransform> for correct SVG coordinate-space animation
// Light mode: blue waves on white; Dark mode: lighter waves on dark bg
---

<div class="pricing-bg" aria-hidden="true">
	<svg
		class="pricing-bg-svg"
		xmlns="http://www.w3.org/2000/svg"
		viewBox="0 0 900 900"
		preserveAspectRatio="xMaxYMid slice"
	>
		<defs>
			<!--
				`userSpaceOnUse` so the radii are in absolute viewBox units,
				not relative to the backing rect. That lets us stretch the
				rect vertically (below) to cover the same -900..2700 range
				as the wave paths without dragging the gradient centres along
				with it.
			-->
			<radialGradient id="pbg-glow-1" cx="585" cy="315" r="495" gradientUnits="userSpaceOnUse">
				<stop offset="0%" stop-color="var(--pricing-wave-color)" stop-opacity="0.10" />
				<stop offset="100%" stop-color="var(--pricing-wave-color)" stop-opacity="0" />
			</radialGradient>
			<radialGradient id="pbg-glow-2" cx="405" cy="630" r="360" gradientUnits="userSpaceOnUse">
				<stop offset="0%" stop-color="var(--pricing-wave-color)" stop-opacity="0.06" />
				<stop offset="100%" stop-color="var(--pricing-wave-color)" stop-opacity="0" />
			</radialGradient>
		</defs>

		<!--
			Static glow blobs — extended to the same -900..2700 range as the
			waves below so their top/bottom edges don't show as faint
			opacity steps after the SVG's -28deg rotation. The gradients
			use userSpaceOnUse and stay anchored to their original positions
			in the viewBox; the rect just provides the fill canvas.
		-->
		<rect x="0" y="-900" width="900" height="3600" fill="url(#pbg-glow-1)" />
		<rect x="0" y="-900" width="900" height="3600" fill="url(#pbg-glow-2)" />

		<!--
			Wave A — large, very slow, rightmost
			Vertical sine: baseline x=700, amplitude 100, period 900.
			Path body extends one period above (y=-900) and one below
			(y=2700) the original 0..1800 range so the horizontal top/bottom
			closures stay well outside any visible viewport position even
			after the SVG's -28deg rotation slices into the canvas.
		-->
		<g>
			<animateTransform attributeName="transform" type="translate"
				from="0 0" to="0 -900" dur="40s" repeatCount="indefinite" />
			<path
				d="M700,-900 C800,-736 800,-614 700,-450 C600,-286 600,-164 700,0 C800,164 800,286 700,450 C600,614 600,736 700,900 C800,1064 800,1186 700,1350 C600,1514 600,1636 700,1800 C800,1964 800,2086 700,2250 C600,2414 600,2536 700,2700 L900,2700 L900,-900Z"
				fill="var(--pricing-wave-color)"
				fill-opacity="0.055"
			/>
		</g>

		<!--
			Wave B — slow, mid-right, opposite direction
			Baseline x=550, amplitude 80, period 600. Extended -600..2400.
		-->
		<g>
			<animateTransform attributeName="transform" type="translate"
				from="0 -600" to="0 0" dur="28s" repeatCount="indefinite" />
			<path
				d="M550,-600 C630,-491 630,-409 550,-300 C470,-191 470,-109 550,0 C630,109 630,191 550,300 C470,409 470,491 550,600 C630,709 630,791 550,900 C470,1009 470,1091 550,1200 C630,1309 630,1391 550,1500 C470,1609 470,1691 550,1800 C630,1909 630,1991 550,2100 C470,2209 470,2291 550,2400 L900,2400 L900,-600Z"
				fill="var(--pricing-wave-color)"
				fill-opacity="0.045"
			/>
		</g>

		<!--
			Wave C — medium, left-of-center
			Baseline x=380, amplitude 65, period 450. Extended -450..2250.
		-->
		<g>
			<animateTransform attributeName="transform" type="translate"
				from="0 0" to="0 -450" dur="18s" repeatCount="indefinite" />
			<path
				d="M380,-450 C445,-368 445,-307 380,-225 C315,-143 315,-82 380,0 C445,82 445,143 380,225 C315,307 315,368 380,450 C445,532 445,593 380,675 C315,757 315,818 380,900 C445,982 445,1043 380,1125 C315,1207 315,1268 380,1350 C445,1432 445,1493 380,1575 C315,1657 315,1718 380,1800 C445,1882 445,1943 380,2025 C315,2107 315,2168 380,2250 L900,2250 L900,-450Z"
				fill="var(--pricing-wave-color)"
				fill-opacity="0.035"
			/>
		</g>

		<!--
			Wave D — very slow, largest, leftmost, opposite direction
			Baseline x=220, amplitude 120, period 900. Extended -900..2700.
		-->
		<g>
			<animateTransform attributeName="transform" type="translate"
				from="0 -900" to="0 0" dur="50s" repeatCount="indefinite" />
			<path
				d="M220,-900 C340,-736 340,-614 220,-450 C100,-286 100,-164 220,0 C340,164 340,286 220,450 C100,614 100,736 220,900 C340,1064 340,1186 220,1350 C100,1514 100,1636 220,1800 C340,1964 340,2086 220,2250 C100,2414 100,2536 220,2700 L900,2700 L900,-900Z"
				fill="var(--pricing-wave-color)"
				fill-opacity="0.035"
			/>
		</g>
	</svg>
</div>

<style>
	.pricing-bg {
		--pricing-wave-color: #3369FF;

		position: fixed;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		overflow: hidden;
		perspective: 1400px;
	}

	[data-theme='dark'] .pricing-bg {
		--pricing-wave-color: #6b9aff;
	}

	.pricing-bg-svg {
		position: absolute;
		right: -20%;
		top: -45%;
		width: 110%;
		height: 180%;
		overflow: visible;
		transform: rotate(-28deg) rotateY(-6deg);
		transform-origin: top right;

		/* Mask is in the SVG's local space, so this top→bottom fade rotates
		   with `transform` and tracks the -28deg edge — don't change to a
		   screen-space gradient. */
		--pricing-bg-fade: linear-gradient(
			to bottom,
			transparent 0%,
			#000 12%,
			#000 88%,
			transparent 100%
		);
		-webkit-mask-image: var(--pricing-bg-fade);
		mask-image: var(--pricing-bg-fade);
	}

	@media (prefers-reduced-motion: reduce) {
		.pricing-bg-svg {
			display: none;
		}
	}
</style>
