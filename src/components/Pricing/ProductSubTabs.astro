---
import { Icon } from 'astro-icon/components';

interface SubTab {
	id: string;
	label: string;
	icon?: string;
	faqId?: string;
	faqTooltip?: string;
	/** Set by enrichTabs() when tooltip was auto-generated from FAQ answer */
	autoTooltip?: boolean;
	default?: boolean;
	gtmId?: string;
}

interface Props {
	product: string;
	tabs: SubTab[];
}

const { product, tabs } = Astro.props;
---

<div class="segment-tabs segment-tabs--sub" data-product-subtabs={product}>
	{tabs.map((tab) => (
		<button
			type="button"
			id={tab.gtmId}
			class={`sub-tab segment-tab ${tab.gtmId ? 'gtm_button ' : ''}${tab.default ? 'active' : ''}`}
			data-subtab={tab.id}
			data-faq-id={tab.faqId}
		>
			{tab.icon && <span class="segment-tab-icon segment-tab-icon--sub" set:html={tab.icon} />}
			{tab.label}
			{tab.faqId && (
				<span class="sub-tab-info" data-faq-id={tab.faqId}>
					<Icon name="tabler:info-circle" class="sub-tab-info-icon" />
					{tab.faqTooltip && (
						<span class="sub-tab-tooltip">
							<span class="sub-tab-tooltip-arrow"></span>
							<span class="sub-tab-tooltip-body">
								<span set:html={tab.faqTooltip} />
								{tab.autoTooltip && tab.faqId && <span class="sub-tab-tooltip-readmore"> read more</span>}
							</span>
						</span>
					)}
				</span>
			)}
		</button>
	))}
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	// ─── Sub-tab variant ───
	.segment-tabs--sub {
		margin-bottom: $spacing-8;

		.segment-tab {
			padding: $spacing-2 $spacing-5;
			font-size: $font-size-sm;
			font-weight: $font-weight-medium;
			gap: 0;
			display: inline-flex;
			align-items: center;
		}

		@include media-down(md) {
			display: flex;
			flex-direction: column;
			width: fit-content;
			border-radius: $radius-xl;

			.segment-tab {
				justify-content: flex-start;
				padding: $spacing-3 $spacing-5;
				align-self: stretch;
			}

			// Vertical layout uses a wider corner radius on the active tab.
			// The active background + shadow inherits from `.segment-tab.active`
			// (now applied at all viewports — see ProductTabs.astro).
			.segment-tab.active {
				border-radius: $radius-lg;
			}
		}
	}

	.sub-tab:hover {
		z-index: 10;
	}

	// ─── Info icon ───
	.sub-tab-info {
		position: relative;
		display: inline-flex;
		align-items: center;
		margin-left: 2px;
		cursor: pointer;
	}

	.sub-tab-info-icon {
		width: 14px;
		height: 14px;
		color: var(--color-text-secondary);
		opacity: 0.5;
		position: relative;
		top: -4px;
		flex-shrink: 0;
		transition: color 0.2s ease, opacity 0.2s ease;
	}

	// Active segment → icon more visible
	.sub-tab.active .sub-tab-info-icon {
		color: var(--color-text);
		opacity: 0.8;
	}

	// Hovered icon → primary color (works on both active and inactive tabs)
	.sub-tab-info:hover .sub-tab-info-icon {
		color: var(--color-primary);
		opacity: 1;
	}

	// ─── Tooltip ───
	.sub-tab-tooltip {
		position: fixed;
		z-index: 99999;
		pointer-events: none;
		display: flex;
		align-items: center;

		// Hidden with delay
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.15s ease, visibility 0.15s ease;
		transition-delay: 0ms;

		// Invisible bridge from icon to tooltip body
		&::before {
			content: '';
			position: absolute;
			top: 0;
			left: -12px;
			width: 16px;
			height: 100%;
		}
	}

	.sub-tab-tooltip.pricing-tooltip--visible {
		opacity: 1;
		visibility: visible;
		pointer-events: none;
		&.pricing-tooltip--interactive { pointer-events: auto; }
	}

	.sub-tab-tooltip-arrow {
		flex-shrink: 0;
		width: 0;
		height: 0;
		border: 6px solid transparent;
		border-right-color: var(--sl-color-gray-5);
		position: relative;

		// Inner fill arrow to cover the border color
		&::after {
			content: '';
			position: absolute;
			top: -6px;
			left: -4px;
			width: 0;
			height: 0;
			border: 6px solid transparent;
			border-right-color: var(--color-bg-surface);
		}
	}

	.sub-tab-tooltip-body {
		display: block;
		padding: $spacing-4;
		background: var(--color-bg-surface);
		color: var(--color-text);
		font-size: $font-size-sm;
		font-weight: $font-weight-normal;
		line-height: 1.5;
		text-align: left;
		white-space: normal;
		width: 300px;
		border-radius: $radius-lg;
		border: 1px solid var(--sl-color-gray-5);
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
	}

	.sub-tab-tooltip-readmore {
		color: var(--color-primary);
		cursor: pointer;

		&:hover {
			text-decoration: underline;
		}
	}
</style>
