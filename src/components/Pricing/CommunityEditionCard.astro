---
import { Icon } from 'astro-icon/components';
import NButton from '../Landing/NButton.astro';
import type { CommunityEditionData } from '@data/pricing/types.ts';

interface Props {
	data: CommunityEditionData;
}

const { data } = Astro.props;
---

<div class="ce-card">
	<div class="ce-card-content">
		<h3 class="ce-card-title">{data.title}</h3>
		{data.subtitle && <p class="ce-card-subtitle">{data.subtitle}</p>}
		{data.priceLabel && <p class="ce-card-price">{data.priceLabel}</p>}
		<p class="ce-card-description">{data.description}</p>
		<ul class="ce-card-features">
			{data.features.map((feature) => (
				<li>
					<Icon name="tabler:check" />
					<span>{feature}</span>
				</li>
			))}
		</ul>
		<div class="ce-card-actions">
			<NButton
				href={data.ctaOnclick ? '#' : data.ctaHref}
				variant="filled"
				size="sm"
				class="gtm_button"
				onclick={data.ctaOnclick ? `event.preventDefault();${data.ctaOnclick}` : undefined}
			>
				{data.ctaText}
			</NButton>
			{data.secondaryCtaText && (
				<NButton
					href={data.secondaryCtaHref ?? (data.secondaryCtaOnclick ? '#' : undefined)}
					variant="outlined"
					size="sm"
					class="gtm_button"
					onclick={
						data.secondaryCtaHref
							? undefined
							: data.secondaryCtaOnclick
								? `event.preventDefault();${data.secondaryCtaOnclick}`
								: undefined
					}
					target={data.secondaryCtaHref ? '_blank' : undefined}
					rel={data.secondaryCtaHref ? 'noopener noreferrer' : undefined}
				>
					{data.secondaryCtaText}
				</NButton>
			)}
		</div>
	</div>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.ce-card {
		display: flex;
		position: relative;
		overflow: hidden;
		background: var(--color-bg-surface);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: $radius-xl;
		padding: $spacing-10;
		margin-bottom: $spacing-8;

		&::after {
			content: '';
			position: absolute;
			right: -20px;
			bottom: -40px;
			width: 380px;
			height: 380px;
			background: url('/images/pricing/ce-watermark.svg') no-repeat center / contain;
			pointer-events: none;

			@include media-down(md) {
				display: none;
			}
		}

		@include media-down(md) {
			padding: $spacing-6;
		}
	}

	.ce-card-content {
		position: relative;
		z-index: 1;
		max-width: 700px;
	}

	.ce-card-title {
		@include subsection-title;
		color: var(--color-text);
		margin: 0 0 $spacing-3;
	}

	.ce-card-subtitle {
		font-size: $font-size-base;
		color: var(--color-text-secondary);
		line-height: 1.6;
		margin: 0 0 $spacing-3;
	}

	.ce-card-price {
		font-size: $font-size-2xl;
		font-weight: $font-weight-bold;
		color: var(--color-text);
		margin: 0 0 $spacing-3;
	}

	.ce-card-description {
		font-size: $font-size-sm;
		color: var(--color-text-secondary);
		line-height: 1.6;
		margin: 0 0 $spacing-6;
	}

	.ce-card-actions {
		display: flex;
		gap: $spacing-3;
		flex-wrap: wrap;
	}

	.ce-card .n-button {
		min-width: 200px;
	}

	.ce-card-features {
		list-style: none;
		padding: 0;
		margin: 0 0 $spacing-6;
		display: flex;
		flex-direction: column;
		gap: $spacing-3;

		li {
			display: flex;
			align-items: flex-start;
			gap: $spacing-3;
			font-size: $font-size-sm;
			color: var(--color-text);
			line-height: 1.5;

			[data-icon] {
				width: 16px;
				height: 16px;
				color: var(--color-primary);
				flex-shrink: 0;
				margin-top: 3px;
			}
		}
	}
</style>
