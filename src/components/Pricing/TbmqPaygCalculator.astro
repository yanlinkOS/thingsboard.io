---
import { Icon } from 'astro-icon/components';
import CalculatorInline from './CalculatorInline.astro';
---

<CalculatorInline id="tbmq-payg-calc" title="TBMQ Self-managed calculator">
	<div slot="header">
		<div class="calc-title-row"><h2 class="calc-title">TBMQ Pay-as-you-go calculator</h2></div>
	</div>
	<div slot="inputs">
		<div class="calc-input-group">
			<div class="calc-input-row">
				<label class="calc-label">Sessions <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Total unique logical states managed by the broker, identified by Client ID. Active connections and disconnected clients with persistent sessions both occupy quota slots.</span></span></span></label>
				<input id="mq-sessions" type="number" value="100" min="100" class="calc-number-input" aria-label="Sessions" />
			</div>
			<div class="calc-slider-container">
				<input type="range" id="mq-sessions-slider" min="0" max="6" step="0.001" value="0" class="calc-slider" aria-label="Sessions slider" />
				<div class="calc-tick-marks"><span class="calc-tick" data-val="0"><span class="calc-tick-line"></span><span class="calc-tick-label">100</span></span><span class="calc-tick" data-val="1"><span class="calc-tick-line"></span><span class="calc-tick-label">1K</span></span><span class="calc-tick" data-val="2"><span class="calc-tick-line"></span><span class="calc-tick-label">2K</span></span><span class="calc-tick" data-val="3"><span class="calc-tick-line"></span><span class="calc-tick-label">5K</span></span><span class="calc-tick" data-val="4"><span class="calc-tick-line"></span><span class="calc-tick-label">10K</span></span><span class="calc-tick" data-val="5"><span class="calc-tick-line"></span><span class="calc-tick-label">100K</span></span><span class="calc-tick" data-val="6"><span class="calc-tick-line"></span><span class="calc-tick-label infinity"><Icon name="tabler:infinity" /></span></span></div>
			</div>
		</div>
		<div class="calc-input-group">
			<div class="calc-input-row">
				<label class="calc-label">Throughput (msg/sec) <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Combined number of MQTT PUBLISH packets processed per second, including both incoming (publisher) and outgoing (subscriber) messages.</span></span></span></label>
				<input id="mq-throughput" type="number" value="100" min="100" class="calc-number-input" aria-label="Throughput" />
			</div>
			<div class="calc-slider-container">
				<input type="range" id="mq-throughput-slider" min="0" max="6" step="0.001" value="0" class="calc-slider" aria-label="Throughput slider" />
				<div class="calc-tick-marks"><span class="calc-tick" data-val="0"><span class="calc-tick-line"></span><span class="calc-tick-label">100</span></span><span class="calc-tick" data-val="1"><span class="calc-tick-line"></span><span class="calc-tick-label">1K</span></span><span class="calc-tick" data-val="2"><span class="calc-tick-line"></span><span class="calc-tick-label">2K</span></span><span class="calc-tick" data-val="3"><span class="calc-tick-line"></span><span class="calc-tick-label">5K</span></span><span class="calc-tick" data-val="4"><span class="calc-tick-line"></span><span class="calc-tick-label">10K</span></span><span class="calc-tick" data-val="5"><span class="calc-tick-line"></span><span class="calc-tick-label">20K</span></span><span class="calc-tick" data-val="6"><span class="calc-tick-line"></span><span class="calc-tick-label infinity"><Icon name="tabler:infinity" /></span></span></div>
			</div>
		</div>
		<div style="margin-bottom:24px;">
			<div class="calc-input-row" style="margin-bottom:12px;">
				<div style="flex:1;"><label class="calc-label">Production Instances <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Dedicated compute instances for your production environment. Add instances to enable clustering and high availability (HA).</span></span></span></label><p class="calc-addon-desc">1 instance included. Add more for high availability (HA) and reliability.</p></div>
				<div class="calc-stepper" id="mq-prod-stepper"><button type="button" class="calc-stepper-btn" data-action="decrement" disabled aria-label="Decrease production instances">&minus;</button><input type="number" class="calc-stepper-input" value="1" min="1" id="mq-prod" aria-label="Production instances" /><button type="button" class="calc-stepper-btn" data-action="increment" aria-label="Increase production instances">+</button></div>
			</div>
			<div class="calc-input-row">
				<div style="flex:1;"><label class="calc-label">Development Instances <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Compute instances used for development, testing, and CI/CD workflows. Not intended for production traffic.</span></span></span></label><p class="calc-addon-desc">Add dedicated instances for your dev, test, and CI/CD workflows. Keep your production data clean.</p></div>
				<div class="calc-stepper" id="mq-dev-stepper"><button type="button" class="calc-stepper-btn" data-action="decrement" disabled aria-label="Decrease development instances">&minus;</button><input type="number" class="calc-stepper-input" value="0" min="0" id="mq-dev" aria-label="Development instances" /><button type="button" class="calc-stepper-btn" data-action="increment" aria-label="Increase development instances">+</button></div>
			</div>
		</div>
		<div class="calc-addons-label">Add-ons <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Optional modules to extend platform functionality.</span></span></span></div>
		<div class="calc-addons-grid">
			<div class="calc-addon-card" id="mq-wl-card"><div class="calc-addon-header"><span class="calc-addon-title">White Labeling <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Customization of the platform interface with your corporate branding, colors, and logo.</span></span></span></span><label class="calc-toggle"><input type="checkbox" id="mq-wl-toggle" role="switch" aria-label="Toggle White Labeling" /><span class="calc-toggle-track"></span></label></div><p class="calc-addon-desc">Customize UI to match your branding.</p></div>
			<div class="calc-addon-card" id="mq-hd-card"><div class="calc-addon-header"><span class="calc-addon-title">Priority Help Desk <span class="calc-tooltip"><Icon name="tabler:info-circle" /><span class="calc-tooltip-text"><span class="calc-tooltip-arrow"></span><span class="calc-tooltip-body">Moves your support requests to a high-priority queue managed by senior engineers.</span></span></span></span><label class="calc-toggle"><input type="checkbox" id="mq-hd-toggle" role="switch" aria-label="Toggle Priority Help Desk" /><span class="calc-toggle-track"></span></label></div><p class="calc-addon-desc">Dedicated priority support queue.</p></div>
		</div>
	</div>
</CalculatorInline>

<script>
	// Lazy-load the TBMQ PAYG calculator. Body lives in
	// `src/scripts/pricing/calc-tbmq-payg.ts` and only loads when the user
	// switches to the TBMQ product tab — visitors who stay on ThingsBoard
	// never pay its parse cost.
	//
	// Two init paths, because the calc must load both on a later tab click AND
	// on a deep-link that lands directly on TBMQ:
	//   1. `pricing:product-activated` (detail 'tbmq') — dispatched by
	//      activateProductTab() in pricing/index.astro on every tab switch.
	//   2. On registration, if TBMQ is ALREADY the active product. We can't
	//      rely on (1) for the initial activation: both this loader and the
	//      initPricing() dispatcher are hoisted module scripts with no
	//      guaranteed execution order, so initPricing() can fire the one-shot
	//      event before this listener is attached. The pre-paint inline script
	//      in index.astro sets `.product-tab.active` during HTML parse (before
	//      any module runs), so a deep-link visitor has the correct active tab
	//      by the time this deferred loader executes — we read it directly.
	// initTbmqPaygCalc() is idempotent (container `data-inited` guard), so the
	// two paths can't double-init. Listener registered ONCE per document
	// lifetime — the script re-runs on each `astro:page-load`, but the guard
	// prevents stacking duplicate listeners on the persistent document.
	if (!(window as any)._tbmqPaygLoaderInited) {
		(window as any)._tbmqPaygLoaderInited = true;
		const loadCalc = () =>
			import('~/scripts/pricing/calc-tbmq-payg')
				.then((m) => m.initTbmqPaygCalc())
				.catch(() => {/* chunk fetch failed — keep the console clean */});
		document.addEventListener('pricing:product-activated', ((e: CustomEvent) => {
			if (e.detail === 'tbmq') loadCalc();
		}) as EventListener);
		const activeTab = document.querySelector('.product-tab.active') as HTMLElement | null;
		if (activeTab?.dataset.product === 'tbmq') loadCalc();
	}
</script>

