---
import { Products, productDocsPrefix} from '~/models/site.models';

interface Props {
	product: Products;
	path: string;
	bold?: boolean;
	target?: '_blank' | '_self' | '_parent' | '_top';
}
const { product, path, bold = true, target } = Astro.props;
const href=`/docs/${productDocsPrefix[product]}${path.endsWith('/') ? path : path + '/'}`
---

<a href={href} target={target}>{bold ? (<b><slot /></b>):(<slot />)}</a>
