---
import Chevron from '@components/Chevron.astro';

// Shared breadcrumb row used across the site (IoT Hub, blog, case studies,
// partners, device library, …). The component owns only the inline row
// (links + chevron separators) and, optionally, the matching BreadcrumbList
// JSON-LD. Parents own the surrounding layout (header clearance, gaps to
// sibling sections) so each page keeps its own vertical rhythm.

interface Crumb {
	label: string;
	/** Render as `<a href>` when set; otherwise as the current-page span. */
	href?: string;
}

interface Props {
	items: Crumb[];
	/** Allow the row to wrap on narrow viewports (e.g. three crumbs on a
	 *  small screen). Also disables truncation of the current crumb so long
	 *  titles wrap instead of being clipped. */
	wrap?: boolean;
	/** Emit BreadcrumbList JSON-LD. Prepends a Home crumb (site origin) to
	 *  match the schema pattern used elsewhere on the site. Off by default so
	 *  pages that already emit their own BreadcrumbList don't double up. */
	jsonLd?: boolean;
}

const { items, wrap = false, jsonLd = false } = Astro.props;

const breadcrumbSchema = jsonLd
	? {
			'@context': 'https://schema.org',
			'@type': 'BreadcrumbList',
			itemListElement: [
				{
					'@type': 'ListItem',
					position: 1,
					name: 'Home',
					item: new URL('/', Astro.site).href,
				},
				...items.map((crumb, i) => ({
					'@type': 'ListItem',
					position: i + 2,
					name: crumb.label,
					// The current page (last crumb, no href) omits `item` per schema.
					...(crumb.href ? { item: new URL(crumb.href, Astro.site).href } : {}),
				})),
			],
		}
	: null;
---

<nav class:list={['breadcrumbs', wrap && 'breadcrumbs--wrap']} aria-label="Breadcrumb">
	{items.map((crumb, i) => (
		<Fragment>
			{i > 0 && <Chevron direction="right" class="breadcrumbs__sep" />}
			{crumb.href ? (
				<a class="breadcrumbs__link" href={crumb.href}>{crumb.label}</a>
			) : (
				<span class="breadcrumbs__current" aria-current="page">{crumb.label}</span>
			)}
		</Fragment>
	))}
</nav>

{
	breadcrumbSchema && (
		<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	)
}

<style lang="scss">
	@use '../styles/_variables.scss' as *;

	.breadcrumbs {
		display: flex;
		align-items: center;
		gap: 8px;
		@include text-breadcrumb;
		color: var(--color-text-secondary);
	}

	.breadcrumbs--wrap {
		flex-wrap: wrap;
	}

	.breadcrumbs__link {
		color: var(--color-primary);
		text-decoration: none;
		transition: color $transition-fast;

		&:hover,
		&:focus-visible {
			text-decoration: underline;
		}

		:global([data-theme='dark']) & {
			// Light lavender on dark — matches the brand indigo's dark value.
			color: var(--color-brand);
		}
	}

	.breadcrumbs__sep {
		color: var(--color-text-muted);
		flex-shrink: 0;
	}

	.breadcrumbs__current {
		color: var(--color-text-secondary);
		font-weight: $font-weight-normal;
	}

	// Truncate a long current crumb on single-line rows; wrapping rows keep
	// the full label and let it flow onto the next line instead.
	.breadcrumbs:not(.breadcrumbs--wrap) .breadcrumbs__current {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 500px;
	}
</style>
