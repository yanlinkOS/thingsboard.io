---
interface Props {
	sectionId: string;
	defaultMode?: 'high-performance' | 'traditional';
}

const { sectionId, defaultMode = 'high-performance' } = Astro.props;
---

<div class="uc-mode-selector" data-mode-section={sectionId}>
	<button
		class:list={['uc-mode-tab', { active: defaultMode === 'high-performance' }]}
		data-mode="high-performance"
	>
		High-performance
	</button>
	<button
		class:list={['uc-mode-tab', { active: defaultMode === 'traditional' }]}
		data-mode="traditional"
	>
		Traditional
	</button>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.uc-mode-selector {
		display: flex;
		gap: $spacing-2;
		margin-bottom: $spacing-8;

		.uc-mode-tab {
			padding: $spacing-3 $spacing-6;
			font-size: $font-size-lg;
			font-weight: $font-weight-medium;
			background: transparent;
			border: 1px solid $color-border-light;
			border-radius: $radius-sm;
			cursor: pointer;
			color: $color-text-secondary;
			transition: all $transition-base;

			&:hover {
				border-color: $color-primary;
				color: $color-primary;
			}

			&.active {
				background: $color-primary;
				border-color: $color-primary;
				color: $color-white;
			}
		}
	}
</style>

<script>
	function initModeToggles() {
		const selectors = document.querySelectorAll<HTMLElement>('[data-mode-section]');

		selectors.forEach((selector) => {
			const sectionId = selector.dataset.modeSection;
			const tabs = selector.querySelectorAll<HTMLButtonElement>('.uc-mode-tab');

			tabs.forEach((tab) => {
				tab.addEventListener('click', () => {
					if (tab.classList.contains('active')) return;

					// Update tabs
					tabs.forEach((t) => t.classList.remove('active'));
					tab.classList.add('active');

					// Toggle content sections
					const mode = tab.dataset.mode;
					const contentBlocks = document.querySelectorAll<HTMLElement>(
						`[data-mode-content="${sectionId}"]`
					);
					contentBlocks.forEach((block) => {
						if (block.dataset.mode === mode) {
							block.classList.add('active');
						} else {
							block.classList.remove('active');
						}
					});
				});
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initModeToggles);
	document.addEventListener('astro:page-load', initModeToggles);
</script>
