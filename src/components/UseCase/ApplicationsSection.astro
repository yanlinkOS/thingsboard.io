---
import SmartImage from '../SmartImage.astro';
import type { ApplicationItem } from '@data/use-cases/types.ts';

interface Props {
	title: string;
	subtitle?: string;
	applications: ApplicationItem[];
}

const { title, subtitle, applications } = Astro.props;

// Zigzag: odd-indexed items (0, 2, 4) text on top, even-indexed (1, 3) text on bottom
const topApps = applications.filter((_, i) => i % 2 === 0);
const bottomApps = applications.filter((_, i) => i % 2 !== 0);
---

<section class="uc-applications uc-section-padding">
	<div class="uc-section-header">
		<h2>{title}</h2>
		{subtitle && <p>{subtitle}</p>}
	</div>

	{/* Desktop: zigzag layout */}
	<div class="uc-applications-large">
		<div class="uc-text-row uc-text-row-top">
			{
				topApps.map((app) => (
					<div class="uc-text-block">
						<h3>{app.title}</h3>
						<p>{app.description}</p>
					</div>
				))
			}
		</div>

		<div class="uc-images-row">
			{
				applications.map((app) => (
					<div class="uc-app-image">
						<SmartImage
							src={app.desktopImage}
							alt={app.imageAlt}
							width={180}
							height={180}
						/>
					</div>
				))
			}
		</div>

		<div class="uc-text-row uc-text-row-bottom">
			{
				bottomApps.map((app) => (
					<div class="uc-text-block">
						<h3>{app.title}</h3>
						<p>{app.description}</p>
					</div>
				))
			}
		</div>
	</div>

	{/* Mobile: alternating image-text blocks */}
	<div class="uc-applications-small">
		{
			applications.map((app) => (
				<div class="uc-app-block">
					<div class="uc-app-block-image">
						<SmartImage
							src={app.mobileImage}
							alt={app.imageAlt}
							width={120}
							height={120}
						/>
					</div>
					<div class="uc-app-block-text">
						<h3>{app.title}</h3>
						<p>{app.description}</p>
					</div>
				</div>
			))
		}
	</div>
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.uc-applications {

		.uc-section-header {
			margin-bottom: $spacing-10;

			@include media-down(md) {
				margin-bottom: $spacing-8;
			}
		}

		.uc-applications-large {
			display: flex;
			flex-direction: column;
			gap: 35px;

			@include media-down(xl) {
				display: none;
			}
		}

		.uc-applications-small {
			display: none;

			@include media-down(xl) {
				display: flex;
				flex-direction: column;
				gap: $spacing-8;
			}
		}
	}

	// ── Desktop text rows ──────────────────────────
	.uc-text-row {
		display: flex;
		flex-direction: row;
	}

	.uc-text-row-top {
		justify-content: space-between;
	}

	.uc-text-row-bottom {
		justify-content: space-evenly;
	}

	.uc-text-block {
		display: flex;
		flex-direction: column;
		max-width: 373px;
		text-align: center;
		gap: $spacing-3;

		h3 {
			@include card-title;
			color: $color-text-primary;
			margin: 0;
		}

		p {
			@include text-card;
			margin: 0;
		}
	}

	// ── Desktop images row (zigzag stagger) ────────
	.uc-images-row {
		display: flex;
		flex-direction: row;
		justify-content: space-evenly;
		align-self: center;
		max-height: 420px;

		.uc-app-image {
			align-self: start;
			margin-top: 5%;

			img {
				max-width: 100%;
				height: auto;
			}

			// Even images pushed further down for zigzag stagger
			&:nth-child(even) {
				margin-top: 14%;
			}
		}
	}

	// ── Mobile stacked blocks ──────────────────────
	.uc-app-block {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: $spacing-3;

		.uc-app-block-image {
			img {
				width: 120px;
				height: auto;
			}
		}

		.uc-app-block-text {
			max-width: 500px;

			h3 {
				@include card-title;
				color: $color-text-primary;
				margin: 0 0 $spacing-2;
			}

			p {
				@include text-card;
				margin: 0;
			}
		}
	}
</style>
