---
import NButton from '../Landing/NButton.astro';
import SmartImage from '../SmartImage.astro';

interface Props {
	linkLabel?: string;
	linkHref?: string;
}

const { linkLabel = 'Case studies', linkHref = '/case-studies/' } = Astro.props;
---

<div class="uc-contact-banner">
	<div class="uc-contact-banner-content">
		<h2>Accelerate your IoT roadmap with our team</h2>
		<p>Our team is a trusted partner for scalable solutions delivered fast and on a fixed timeline.</p>
		<div class="uc-contact-banner-buttons">
			<NButton href="/docs/contact-us/" target="_blank">
				Contact Us
			</NButton>
			<NButton variant="outlined" href={linkHref}>
				{linkLabel}
			</NButton>
		</div>
	</div>
	<div class="uc-contact-banner-icon">
		<SmartImage
			src="/src/assets/images/usecases/email-icon.svg"
			alt="Letter icon"
			width={380}
			height={267}
		/>
	</div>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.uc-contact-banner {
		background: $color-white;
		border: 1px solid $color-border;
		border-radius: $radius-xl;
		padding: $spacing-12;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: $spacing-8;
		margin: $spacing-16 0;
		overflow: hidden;
		position: relative;

		@include media-down(lg) {
			flex-direction: column;
			text-align: center;
			padding: $spacing-8;
		}

		.uc-contact-banner-content {
			flex: 1;
			position: relative;
			z-index: 1;

			h2 {
				@include subsection-title;
				color: $color-text-primary;
				margin: 0 0 $spacing-3;
			}

			p {
				@include text-m;
				margin: 0 0 $spacing-6;
			}
		}

		.uc-contact-banner-buttons {
			display: flex;
			gap: $spacing-4;

			@include media-down(md) {
				flex-direction: column;
				width: 100%;
			}
		}

		.uc-contact-banner-icon {
			flex-shrink: 0;

			img {
				width: 280px;
				height: auto;

				@include media-down(lg) {
					display: none;
				}
			}
		}
	}
</style>
