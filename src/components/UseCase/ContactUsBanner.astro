---
import NButton from '../Landing/NButton.astro';

interface BannerButton {
	label: string;
	href: string;
	variant?: 'filled' | 'outlined';
	target?: string;
}

interface Props {
	title?: string;
	subtitle?: string;
	iconSrc?: string;
	iconAlt?: string;
	buttons?: BannerButton[];
	variant?: 'surface' | 'light';
}

const {
	title = 'Accelerate your IoT roadmap with our team',
	subtitle = 'Our team is a trusted partner for scalable solutions delivered fast and on a fixed timeline.',
	iconSrc = 'https://img.thingsboard.io/usecases/email-icon.svg',
	iconAlt = 'Letter icon',
	buttons = [
		{ label: 'Contact Us', href: '/contact-us/' },
		{ label: 'Case studies', href: '/case-studies/', variant: 'outlined' as const },
	],
	variant = 'surface',
} = Astro.props;
---

<div class:list={['uc-contact-banner', { 'uc-contact-banner--light': variant === 'light' }]}>
	<div class="uc-contact-banner-content">
		<h2>{title}</h2>
		<p>{subtitle}</p>
		<div class="uc-contact-banner-buttons">
			{buttons.map((btn) => (
				<NButton
					href={btn.href}
					variant={btn.variant || 'filled'}
					target={btn.target}
				>
					{btn.label}
				</NButton>
			))}
		</div>
	</div>
	<div class="uc-contact-banner-icon">
		<img src={iconSrc} alt={iconAlt} width="280" height="200" loading="lazy" />
	</div>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.uc-contact-banner {
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: $radius-xl;
		padding: $spacing-12;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: $spacing-8;
		margin: $spacing-16 0;
		overflow: hidden;
		position: relative;

		&--light {
			background: transparent;
		}

		@include media-down(lg) {
			flex-direction: column;
			text-align: center;
			padding: $spacing-8;
		}

		.uc-contact-banner-content {
			flex: 1;
			position: relative;
			z-index: 1;

			h2 {
				@include subsection-title;
				color: var(--color-text);
				margin: 0 0 $spacing-3;
			}

			p {
				@include text-m;
				margin: 0 0 $spacing-6;
			}
		}

		.uc-contact-banner-buttons {
			display: flex;
			gap: $spacing-4;

			@include media-down(md) {
				flex-direction: column;
				width: 100%;
			}
		}

		.uc-contact-banner-icon {
			flex-shrink: 0;

			img {
				width: 280px;
				height: auto;

				@include media-down(lg) {
					display: none;
				}
			}
		}
	}
</style>
