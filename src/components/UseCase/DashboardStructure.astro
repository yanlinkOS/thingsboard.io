---
import NButton from '../Landing/NButton.astro';
import ImageGallery from '../ImageGallery.astro';
import SmartImage from '../SmartImage.astro';
import type { DashboardPanel } from '@data/use-cases/types.ts';

interface Props {
	title: string;
	subtitle?: string;
	panels: DashboardPanel[];
	demoUrl: string;
	demoButtonId: string;
	contactUsId: string;
	instanceId?: string;
}

const {
	title,
	subtitle,
	panels,
	demoUrl,
	demoButtonId,
	contactUsId,
	instanceId = 'default',
} = Astro.props;
---

<section
	class="uc-dashboard-structure uc-section-padding"
	data-dashboard-id={instanceId}
>
	{
		title && (
			<div class="uc-section-header">
				<h2>{title}</h2>
				{subtitle && <p>{subtitle}</p>}
			</div>
		)
	}

	<div class="uc-dashboard-block">
		{/* Left: Tab navigation */}
		<div class="uc-tab-menu">
			{
				panels.map((panel, index) => (
					<div
						class:list={['uc-tab-item', { active: index === 0 }]}
						data-panel-index={index}
					>
						<h3>{panel.title}</h3>
					</div>
				))
			}

			<div class="uc-dashboard-buttons">
				<NButton id={demoButtonId} href={demoUrl} target="_blank">
					View live demo
				</NButton>
				<NButton
					id={contactUsId}
					variant="outlined"
					href="/docs/contact-us/?subject=Custom%20Development"
					target="_blank"
				>
					Contact us
				</NButton>
			</div>
		</div>

		{/* Right: Description + ImageGallery per panel — desktop only */}
		<div class="uc-dashboard-main">
			{
				panels.map((panel, index) => (
					<div
						class:list={['uc-dashboard-panel', { active: index === 0 }]}
						data-gallery-index={index}
					>
						<p class="uc-main-description">{panel.description}</p>
						<ImageGallery
							images={[
								{
									src: panel.image,
									alt: panel.imageAlt,
									caption: panel.imageTitle,
								},
							]}
						/>
					</div>
				))
			}
		</div>

		{/* Mobile: stacked panels */}
		<div class="uc-mobile-panels">
			{
				panels.map((panel) => (
					<div class="uc-mobile-panel">
						<h3>{panel.title}</h3>
						<p>{panel.description}</p>
						<SmartImage
							src={panel.image}
							alt={panel.imageAlt}
							width={800}
							height={420}
						/>
					</div>
				))
			}
		</div>
	</div>
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.uc-dashboard-structure {
		.uc-section-header {
			margin-bottom: $spacing-10;

			@include media-down(md) {
				margin-bottom: $spacing-8;
			}
		}

		.uc-dashboard-block {
			display: flex;
			gap: 4%;
			position: relative;

			@include media-down(xl) {
				flex-direction: column;
			}
		}

		.uc-tab-menu {
			width: 30%;
			flex-shrink: 0;

			@include media-down(xl) {
				display: none;
			}
		}
	}

	.uc-tab-item {
		position: relative;
		padding: $spacing-4 $spacing-5;
		cursor: pointer;
		border-left: 3px solid transparent;
		transition: border-color $transition-base, background $transition-base;

		h3 {
			font-size: $font-size-lg;
			font-weight: $font-weight-medium;
			line-height: 1.3;
			color: $color-text-secondary;
			margin: 0;
			transition: color $transition-base;
		}

		&:hover {
			h3 {
				color: $color-text-primary;
			}
		}

		&.active {
			border-left-color: $color-primary;
			background: rgba($color-primary, 0.05);

			h3 {
				color: $color-primary;
			}
		}
	}

	.uc-dashboard-main {
		width: 66%;
		position: sticky;
		top: 100px;
		align-self: flex-start;

		@include media-down(xl) {
			display: none;
		}
	}

	.uc-dashboard-panel {
		display: none;

		&.active {
			display: block;
		}
	}

	.uc-main-description {
		@include text-s;
		margin: 0 0 $spacing-5;
	}

	// Reset ImageGallery margins inside dashboard context
	.uc-dashboard-structure .uc-dashboard-panel .image-gallery,
	.uc-dashboard-structure .uc-dashboard-panel .single-image {
		margin: 0;
	}

	.uc-dashboard-structure .uc-dashboard-panel .single-thumb img {
		border-radius: $radius-md;
	}

	// Mobile: stacked panels (visible only on <=xl)
	.uc-mobile-panels {
		display: none;

		@include media-down(xl) {
			display: flex;
			flex-direction: column;
			gap: $spacing-8;
			width: 100%;
		}
	}

	.uc-mobile-panel {
		h3 {
			font-size: $font-size-lg;
			font-weight: $font-weight-semibold;
			color: $color-primary;
			margin: 0 0 $spacing-3;
		}

		p {
			@include text-s;
			margin: 0 0 $spacing-4;
		}

		img {
			width: 100%;
			height: auto;
			border-radius: $radius-md;
		}
	}

	.uc-dashboard-buttons {
		display: flex;
		gap: $spacing-4;
		margin-top: $spacing-8;

		@include media-down(xl) {
			margin-top: $spacing-6;
		}

		@include media-down(md) {
			flex-direction: column;
		}
	}
</style>

<script>
	function initDashboardStructures() {
		const sections = document.querySelectorAll<HTMLElement>('[data-dashboard-id]');

		sections.forEach((section) => {
			if (section.dataset.initialized) return;
			section.dataset.initialized = 'true';

			const tabItems = section.querySelectorAll<HTMLElement>('.uc-tab-item');
			const panels = section.querySelectorAll<HTMLElement>('.uc-dashboard-panel');
			let currentIndex = 0;

			tabItems.forEach((tab, index) => {
				tab.addEventListener('click', () => {
					if (index === currentIndex) return;

					tabItems.forEach((t) => t.classList.remove('active'));
					tab.classList.add('active');

					panels.forEach((p) => p.classList.remove('active'));
					if (panels[index]) panels[index].classList.add('active');

					currentIndex = index;
				});
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initDashboardStructures);
	document.addEventListener('astro:page-load', initDashboardStructures);
</script>
