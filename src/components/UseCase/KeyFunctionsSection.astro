---
import SmartImage from '../SmartImage.astro';
import ScadaModeToggle from './ScadaModeToggle.astro';
import type { ScadaKeyFunction } from '@data/use-cases/types.ts';

interface Props {
	highPerformance: ScadaKeyFunction[];
	traditional: ScadaKeyFunction[];
}

const { highPerformance, traditional } = Astro.props;
---

<section class="uc-key-functions uc-section-padding">
	<div class="uc-header-selector">
		<h2>Key functions of SCADA systems</h2>
		<ScadaModeToggle sectionId="key-functions" />
	</div>

	<div class="uc-scada-content active" data-mode-content="key-functions" data-mode="high-performance">
		{
			highPerformance.map((fn) => (
				<div class="uc-key-function-block">
					<div class="uc-key-function-desc">
						<h3>{fn.title}</h3>
						<p>{fn.description}</p>
					</div>
					<SmartImage src={fn.image} alt={fn.imageAlt} width={400} height={200} />
				</div>
			))
		}
	</div>

	<div class="uc-scada-content" data-mode-content="key-functions" data-mode="traditional">
		{
			traditional.map((fn) => (
				<div class="uc-key-function-block">
					<div class="uc-key-function-desc">
						<h3>{fn.title}</h3>
						<p>{fn.description}</p>
					</div>
					<SmartImage src={fn.image} alt={fn.imageAlt} width={400} height={200} />
				</div>
			))
		}
	</div>
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.uc-key-function-block {
		display: flex;
		align-items: center;
		gap: $spacing-8;
		padding: $spacing-8 0;
		border-bottom: 1px solid $color-border-light;

		@include media-down(md) {
			flex-direction: column;
			gap: $spacing-4;
		}

		.uc-key-function-desc {
			flex: 1;

			h3 {
				@include card-title-sm;
				color: $color-text-primary;
				margin: 0 0 $spacing-3;
			}

			p {
				@include text-s;
				margin: 0;
			}
		}

		> img {
			max-width: 240px;
			width: 100%;
			height: auto;
			flex-shrink: 0;

			@include media-down(md) {
				max-width: 200px;
			}
		}
	}
</style>
