---
import Carousel from '../Landing/Carousel.astro';
import type { CarouselImage } from '@data/use-cases/types.ts';

interface Props {
	images: CarouselImage[];
}

const { images } = Astro.props;

// Map to Carousel's expected format
const carouselItems = images.map((img) => ({
	src: img.src,
	alt: img.alt,
	title: img.title || img.alt,
	href: '#',
	width: img.width,
	height: img.height,
}));
---

<section class="uc-carousel-section">
	<Carousel items={carouselItems} variant="simple" showArrows={true} showDots={true} loop={true} />
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.uc-carousel-section {
		margin: $spacing-10 0;
	}
</style>
