---
import ScadaModeToggle from './ScadaModeToggle.astro';
import DashboardStructure from './DashboardStructure.astro';
import type { UseCaseDashboardStructure } from '@data/use-cases/types.ts';

interface Props {
	highPerformance: UseCaseDashboardStructure;
	traditional: UseCaseDashboardStructure;
}

const { highPerformance, traditional } = Astro.props;
---

{/* Dashboard structure with high-performance / traditional mode toggle. */}
<section class="uc-section-padding">
	<div class="uc-header-selector">
		<h2>Dashboard structure</h2>
		<ScadaModeToggle sectionId="dashboard" />
	</div>

	<div class="uc-scada-content active" data-mode-content="dashboard" data-mode="high-performance">
		<DashboardStructure
			title=""
			badge={highPerformance.badge}
			panels={highPerformance.panels}
			demoUrl={highPerformance.demoUrl}
			demoButtonId={highPerformance.demoButtonId}
			contactUsId={highPerformance.contactUsId}
			instanceId="scada-hp"
		/>
	</div>

	<div class="uc-scada-content" data-mode-content="dashboard" data-mode="traditional">
		<DashboardStructure
			title=""
			badge={traditional.badge}
			panels={traditional.panels}
			demoUrl={traditional.demoUrl}
			demoButtonId={traditional.demoButtonId}
			contactUsId={traditional.contactUsId}
			instanceId="scada-trad"
		/>
	</div>
</section>
