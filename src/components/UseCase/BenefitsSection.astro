---
import type { Benefit } from '@data/use-cases/types.ts';

interface Props {
	title?: string;
	subtitle?: string;
	benefits: Benefit[];
}

const { title, subtitle, benefits } = Astro.props;
---

{
	benefits.length > 0 && (
		<section class="uc-benefits uc-section-padding">
			{(title || subtitle) && (
				<div class="uc-section-header" style="margin-bottom: 32px;">
					{title && <h2>{title}</h2>}
					{subtitle && <p>{subtitle}</p>}
				</div>
			)}
			<div class="uc-benefit-cards">
				{benefits.map((benefit) => (
					<div class="uc-benefit-card">
						<div class="uc-benefit-card__blob" />
						<h3>{benefit.title}</h3>
						<p>{benefit.description}</p>
					</div>
				))}
			</div>
		</section>
	)
}

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.uc-benefit-cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: $spacing-6;

		@include media-down(lg) {
			grid-template-columns: repeat(2, 1fr);
		}

		@include media-down(md) {
			grid-template-columns: 1fr;
		}
	}

	.uc-benefit-card {
		background: $color-white;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 12px;
		padding: $spacing-10;
		position: relative;
		overflow: clip;

		h3 {
			@include card-title-sm;
			color: $color-text-primary;
			margin: 0 0 $spacing-4;
		}

		p {
			@include text-card;
			margin: 0;
		}
	}

	// Color blob — top-right glow
	.uc-benefit-card__blob {
		position: absolute;
		top: -40px;
		right: -40px;
		width: 180px;
		height: 180px;
		border-radius: 50%;
		filter: blur(60px);
		opacity: 0.3;
		pointer-events: none;
	}

	// Accent colors: purple, blue, orange — offset per row
	.uc-benefit-card:nth-child(6n + 1) .uc-benefit-card__blob,
	.uc-benefit-card:nth-child(6n + 6) .uc-benefit-card__blob {
		background: #bd53ee;
	}

	.uc-benefit-card:nth-child(6n + 2) .uc-benefit-card__blob,
	.uc-benefit-card:nth-child(6n + 4) .uc-benefit-card__blob {
		background: #3369ff;
	}

	.uc-benefit-card:nth-child(6n + 3) .uc-benefit-card__blob,
	.uc-benefit-card:nth-child(6n + 5) .uc-benefit-card__blob {
		background: #eebd53;
	}
</style>
