---
import type { ImageMetadata } from 'astro';
import SectionBadge from '../SectionBadge.astro';

interface Props {
	title: string;
	badge?: string;
	shortText: string;
	longText?: string[];
	schemeSrc: string;
	schemeAlt: string;
	schemeCaption?: string;
}

const { title, badge, shortText, longText, schemeSrc, schemeAlt, schemeCaption } = Astro.props;

const schemaModules = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/schemas/*.svg',
	{ eager: true }
);

const dot = schemeSrc.lastIndexOf('.');
if (dot === -1) {
	throw new Error(`SolutionStructure: schemeSrc has no extension: "${schemeSrc}"`);
}
const schemaBase = schemeSrc.slice(0, dot);
const schemaExt = schemeSrc.slice(dot);
const darkPath = `${schemaBase}-dark${schemaExt}`;

const lightMod = schemaModules[schemeSrc];
if (!lightMod) {
	throw new Error(`SolutionStructure: schema asset not found: "${schemeSrc}"`);
}
const darkMod = schemaModules[darkPath];

const lightImage = lightMod.default;
const darkImage = darkMod?.default;
---

<section class="uc-solution-structure">
	<SectionBadge
		text={badge || 'How it works'}
		color="var(--sl-color-accent)"
		borderColor="var(--sl-color-blue-high)"
	/>
	<h2>{title}</h2>
	{
		(shortText || longText) && (
			<div class="uc-solution-text">
				{shortText && <p set:html={shortText} />}
				{longText?.map((p) => (
					<p set:html={p} />
				))}
			</div>
		)
	}
	<figure class="uc-scheme">
		<img
			class:list={['uc-scheme-img', { 'uc-scheme-img--light': darkImage }]}
			src={lightImage.src}
			alt={schemeAlt}
			width={lightImage.width}
			height={lightImage.height}
			loading="lazy"
			decoding="async"
		/>
		{
			darkImage && (
				<img
					class="uc-scheme-img uc-scheme-img--dark"
					src={darkImage.src}
					alt={schemeAlt}
					width={darkImage.width}
					height={darkImage.height}
					loading="lazy"
					decoding="async"
				/>
			)
		}
		{schemeCaption && <figcaption class="uc-scheme-caption" set:html={schemeCaption} />}
	</figure>
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.uc-solution-structure {
		> .section-badge {
			margin-bottom: $spacing-3;
		}

		> h2 {
			@include section-title;
			color: var(--color-text);
			margin: 0 0 $spacing-8;
		}
	}

	.uc-solution-text {
		display: flex;
		flex-direction: column;
		gap: $spacing-4;
		max-width: 928px;

		p {
			@include text-m;
			margin: 0;

			a {
				color: var(--color-primary);
				text-decoration: none;

				&:hover {
					text-decoration: underline;
				}
			}
		}
	}

	.uc-scheme {
		margin: $spacing-12 0;
		text-align: center;
	}

	.uc-scheme-img {
		max-width: 100%;
		height: auto;
		display: block;
		margin: 0 auto;
	}

	/* Theme-aware swap: light is the default, dark is shown only when
	   the page is in dark mode. When no dark variant exists, the light
	   image stays visible in both themes (no `--light` / `--dark`
	   modifier classes are applied). */
	.uc-scheme-img--dark {
		display: none;
	}

	[data-theme='dark'] .uc-scheme-img--light {
		display: none;
	}

	[data-theme='dark'] .uc-scheme-img--dark {
		display: block;
	}

	.uc-scheme-caption {
		@include text-s;
		color: var(--color-text-secondary);
		margin-top: $spacing-3;
	}
</style>
