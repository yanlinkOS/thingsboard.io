---
import SmartImage from '../SmartImage.astro';

interface Props {
	title: string;
	text: string;
	icon: string;
	iconAlt: string;
}

const { title, text, icon, iconAlt } = Astro.props;
---

<section class="uc-summary">
	<div class="uc-summary-text">
		<h2>{title}</h2>
		<p>{text}</p>
	</div>
	<div class="uc-summary-icon">
		<SmartImage src={icon} alt={iconAlt} width={280} height={200} />
	</div>
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.uc-summary {
		display: flex;
		align-items: center;
		gap: $spacing-10;
		background: $color-white;
		border: 1px solid $color-border;
		border-radius: $radius-xl;
		padding: 46px;
		margin-top: $spacing-16;

		@include media-down(lg) {
			flex-direction: column;
			padding: $spacing-8;
		}

		.uc-summary-text {
			flex: 1;

			h2 {
				@include subsection-title;
				color: $color-text-primary;
				margin: 0 0 $spacing-6;
			}

			p {
				@include text-m;
				margin: 0;
			}
		}

		.uc-summary-icon {
			flex-shrink: 0;

			img {
				width: 280px;
				height: auto;
			}

			@include media-down(lg) {
				display: none;
			}
		}
	}
</style>
