---
export type Variant = 'default' | 'hero' | 'compact';

export interface Props {
	/** Image source URL. Not needed when using the default slot. */
	src?: string;
	alt?: string;
	width?: number;
	height?: number;
	id?: string;
	/** Loading strategy for the default image. Default `lazy`. */
	loading?: 'lazy' | 'eager';
	/** Visual geometry + color preset. Default `default`. */
	variant?: Variant;
	class?: string;
}

type Tokens = {
	radius: string;
	frontInset: string;
	middleInset: string;
	backInset: string;
	frontInsetSm: string;
	middleInsetSm: string;
	backInsetSm: string;
	fill?: string;
};

const base: Tokens = {
	radius: '5px',
	frontInset: '8% -8% -8% 8%',
	middleInset: '-6% 6% 6% -6%',
	backInset: '-12% -5% 12% 5%',
	frontInsetSm: '2% -1.5% -2% 1.5%',
	middleInsetSm: '-3% 2% 3% -2%',
	backInsetSm: '-3.5% -1.5% 3.5% 1.5%',
};

const VARIANTS: Record<Variant, Tokens> = {
	default: base,
	// Larger radius — used in hero video/image frames
	hero: { ...base, radius: '8px' },
	// Tighter insets — used in constrained panel contexts
	compact: {
		...base,
		frontInset: '2% -2% -2% 2%',
		middleInset: '-2% 2% 2% -2%',
		backInset: '-4% -2% 4% 2%',
		frontInsetSm: '1% -1% -1% 1%',
		middleInsetSm: '-1% 1% 1% -1%',
		backInsetSm: '-2% -1% 2% 1%',
	},
};

const {
	src,
	alt,
	width,
	height,
	id,
	loading = 'lazy',
	variant = 'default',
	class: className,
} = Astro.props;

const t = VARIANTS[variant];
const style = [
	t.fill ? `--psf-fill:${t.fill}` : '',
	`--psf-img-radius:${t.radius}`,
	`--psf-front-inset:${t.frontInset}`,
	`--psf-middle-inset:${t.middleInset}`,
	`--psf-back-inset:${t.backInset}`,
	`--psf-front-inset-sm:${t.frontInsetSm}`,
	`--psf-middle-inset-sm:${t.middleInsetSm}`,
	`--psf-back-inset-sm:${t.backInsetSm}`,
].filter(Boolean).join(';');

const hasSlot = Astro.slots.has('default');
---

<div class:list={['project-screen-frame', className]} style={style}>
	<div class="psf-inner">
		{
			hasSlot ? (
				<slot />
			) : (
				<img {...(id ? { id } : {})} src={src} alt={alt!} width={width!} height={height!} loading={loading} />
			)
		}
	</div>
</div>

<style lang="scss">
	.project-screen-frame {
		position: relative;
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.psf-inner {
		position: relative;
		width: 100%;
		isolation: isolate;

		img,
		:global(video) {
			display: block;
			width: 100%;
			height: auto;
			border-radius: var(--psf-img-radius);
			transition: opacity 0.3s ease;
		}

		// Layer 1 (front): accent border, offset down-right
		&::before {
			content: '';
			position: absolute;
			inset: var(--psf-front-inset);
			z-index: -1;
			border-radius: 24px;
			border: 1.5px solid var(--psf-accent, #3e9af8);
		}

		// Layer 2 (middle): muted border, offset up-left
		&::after {
			content: '';
			position: absolute;
			inset: var(--psf-middle-inset);
			z-index: -2;
			border-radius: 24px;
			border: 1.5px solid var(--psf-muted, #d1e9ff);
		}
	}

	// Layer 3 (back): filled bg
	.project-screen-frame::before {
		content: '';
		position: absolute;
		inset: var(--psf-back-inset);
		z-index: 0;
		border-radius: 24px;
		background: var(--psf-fill, #f4f8fe);
	}

	@media (max-width: 959px) {
		.psf-inner {
			&::before {
				inset: var(--psf-front-inset-sm);
			}

			&::after {
				inset: var(--psf-middle-inset-sm);
			}
		}

		.project-screen-frame::before {
			inset: var(--psf-back-inset-sm);
		}
	}
</style>
