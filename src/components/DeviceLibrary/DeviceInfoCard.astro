---
import type { CollectionEntry } from 'astro:content';
import NButton from '../Landing/NButton.astro';
import { resolveDeviceImage } from '~/util/device-images';

interface Props {
	device: CollectionEntry<'devices'>;
}

const { device } = Astro.props;
const d = device.data;
const resolved = await resolveDeviceImage(d.deviceImageFileName, 400);
const imageSrc = resolved?.src ?? '';
const imageWidth = resolved?.width;
const imageHeight = resolved?.height;
---

<section class="dl-info-card not-content">
	<img class="dl-info-card__image" src={imageSrc} alt={d.title} loading="eager" width={imageWidth} height={imageHeight} />
	<div class="dl-info-card__body">
		<p class="dl-info-card__title">{d.title}</p>
		{d.vendor && <p class="dl-info-card__vendor">{d.vendor}</p>}
		<dl class="dl-info-card__specs">
			<dt>Platform</dt>
			<dd>{d.platforms.join(', ')}</dd>

			<dt>Hardware Type</dt>
			<dd>{d.hardwareType}</dd>

			<dt>Connectivity</dt>
			<dd>{d.connectivity.join(', ')}</dd>

			{d.chip && (
				<>
					<dt>Chip</dt>
					<dd>{d.chip}</dd>
				</>
			)}

			{d.industry.length > 0 && (
				<>
					<dt>Industry</dt>
					<dd>{d.industry.join(', ')}</dd>
				</>
			)}

			{d.useCase.length > 0 && (
				<>
					<dt>Use Case</dt>
					<dd>{d.useCase.join(', ')}</dd>
				</>
			)}
		</dl>
		<div class="dl-info-card__actions">
			<NButton href="https://thingsboard.cloud/signup" target="_blank" variant="filled" size="sm">
				Try this device in ThingsBoard
			</NButton>
		</div>
	</div>
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.dl-info-card {
		display: grid;
		grid-template-columns: minmax(160px, 200px) 1fr;
		gap: $spacing-6;
		padding: $spacing-6;
		margin-bottom: $spacing-8;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: $radius-lg;
		background: var(--color-bg-surface);
		align-items: start;

		@include media-down(md) {
			grid-template-columns: 1fr;
			gap: $spacing-4;
			padding: $spacing-4;
		}
	}

	.dl-info-card__image {
		width: 100%;
		height: auto;
		max-width: 200px;
		aspect-ratio: 1;
		object-fit: contain;
		border-radius: $radius-md;

		@include media-down(md) {
			margin-inline: auto;
		}
	}

	.dl-info-card__body {
		min-width: 0;
	}

	.dl-info-card__title {
		margin: 0 0 $spacing-1;
		font-size: $font-size-xl;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
		line-height: 1.25;
	}

	.dl-info-card__vendor {
		margin: 0 0 $spacing-4;
		color: var(--color-text-secondary);
		font-size: $font-size-sm;
	}

	.dl-info-card__specs {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: $spacing-2 $spacing-4;
		margin: 0 0 $spacing-5;
		font-size: $font-size-sm;

		dt {
			font-weight: $font-weight-semibold;
			color: var(--color-text);
		}

		dd {
			margin: 0;
			color: var(--color-text-secondary);
		}
	}

	.dl-info-card__actions {
		.n-button {
			min-width: 220px;
		}
	}
</style>
