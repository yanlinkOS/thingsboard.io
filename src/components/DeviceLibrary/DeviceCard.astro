---
import FilterChip from './FilterChip.astro';

interface Props {
	id: string;
	title: string;
	vendor?: string;
	imageSrc: string;
	imageWidth?: number;
	imageHeight?: number;
	hardwareType: string;
	connectivity: string[];
	industry: string[];
	useCase: string[];
	platforms: string[];
	href: string;
}

const { id, title, vendor, imageSrc, imageWidth, imageHeight, hardwareType, connectivity, industry, useCase, platforms, href } =
	Astro.props;
---

<a
	href={href}
	class="device-card"
	data-device-id={id}
	data-hardware-type={hardwareType}
	data-connectivity={JSON.stringify(connectivity)}
	data-industry={JSON.stringify(industry)}
	data-use-case={JSON.stringify(useCase)}
	data-platforms={JSON.stringify(platforms)}
>
	<div class="device-image">
		<img src={imageSrc} alt={title} loading="lazy" width={imageWidth} height={imageHeight} />
	</div>
	<h3 class="device-title">{title}</h3>
	<p class="device-vendor">{vendor ?? ''}</p>
	<div class="device-chips">
		{industry.slice(0, 3).map((ind) => <FilterChip label={ind} />)}
		{industry.length > 3 && <FilterChip label={`+${industry.length - 3}`} />}
	</div>
</a>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	// Card spans 4 row tracks of the parent (.device-grid). Cards in the same
	// visual row share those row heights via subgrid → image / title / vendor /
	// chips align horizontally, but different visual rows are sized independently.
	.device-card {
		display: grid;
		grid-template-rows: subgrid;
		grid-row: span 4;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		transition:
			transform 0.2s,
			box-shadow 0.2s;
		text-decoration: none;
		color: inherit;
	}

	.device-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-card-hover, 0 4px 12px rgba(0, 0, 0, 0.15));
	}

	.device-card[hidden] {
		display: none;
	}

	.device-image {
		width: 100%;
		aspect-ratio: 4 / 3;
		background: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		padding: 1.5rem;
		border-bottom: 1px solid var(--color-border);
	}

	:global([data-theme='dark']) .device-image {
		background: #d5d7db;
	}

	.device-image img {
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
	}

	.device-title {
		@include text-m;
		font-weight: $font-weight-semibold;
		margin: 0;
		padding: 1rem 1rem 0;
		color: var(--color-text);
	}

	.device-vendor {
		@include text-s;
		color: var(--color-text-secondary);
		margin: 0;
		padding: 0.5rem 1rem 0;
		// Empty vendor still occupies the row so subgrid alignment is consistent.
		min-height: 1.4em;
	}

	.device-chips {
		display: flex;
		flex-wrap: wrap;
		align-content: flex-start;
		align-items: flex-start;
		gap: 0.375rem;
		padding: 0.5rem 1rem 1rem;
	}
</style>
