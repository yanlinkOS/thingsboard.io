---
import { Icon } from 'astro-icon/components';
import DeviceCard from './DeviceCard.astro';
import FilterSidebar from './FilterSidebar.astro';
import SearchBar from './SearchBar.astro';
import Pagination from './Pagination.astro';
import { PLATFORM_VALUES } from '~/util/device-platform';

interface Device {
	id: string;
	title: string;
	vendor?: string;
	imageSrc: string;
	imageWidth?: number;
	imageHeight?: number;
	hardwareType: string;
	connectivity: string[];
	industry: string[];
	useCase: string[];
	platforms: string[];
}

interface Props {
	devices: Device[];
}

const { devices } = Astro.props;

const PAGE_SIZE = 12;

const t = {
	filters: 'Filters',
	clearAll: 'Clear all',
	platform: 'Platform',
	hardwareType: 'Hardware Type',
	connectivity: 'Connectivity',
	industry: 'Industry',
	useCase: 'Use Case',
	noResults: 'No devices match your filters.',
	devicesFound: 'devices found',
	searchPlaceholder: 'Search devices...',
	previous: 'Previous',
	next: 'Next',
	page: 'Page',
	of: 'of',
};

// Extract unique filter values with counts
function getFilterValues(key: keyof Device): { value: string; count: number }[] {
	const counts = new Map<string, number>();
	devices.forEach((device) => {
		const values = device[key];
		if (Array.isArray(values)) {
			values.forEach((v) => counts.set(v, (counts.get(v) || 0) + 1));
		} else if (typeof values === 'string') {
			counts.set(values, (counts.get(values) || 0) + 1);
		}
	});
	return Array.from(counts.entries())
		.map(([value, count]) => ({ value, count }))
		.sort((a, b) => a.value.localeCompare(b.value));
}

// Platforms sort in product-progression order (CE → PE → Cloud → Cloud EU →
// Edge → Edge PE), matching the canonical `PLATFORM_VALUES` list rather than
// alphabetical. Unknown platforms (shouldn't happen) fall back to alphabetical
// at the end.
function getPlatformFilterValues(): { value: string; count: number }[] {
	const raw = new Map<string, number>();
	devices.forEach((device) => {
		device.platforms.forEach((v) => raw.set(v, (raw.get(v) || 0) + 1));
	});
	const ordered: { value: string; count: number }[] = [];
	for (const p of PLATFORM_VALUES) {
		if (raw.has(p)) {
			ordered.push({ value: p, count: raw.get(p)! });
			raw.delete(p);
		}
	}
	// Append any stragglers alphabetically.
	const leftover = Array.from(raw.entries())
		.map(([value, count]) => ({ value, count }))
		.sort((a, b) => a.value.localeCompare(b.value));
	return [...ordered, ...leftover];
}

const filterGroups = [
	{ name: t.platform, key: 'platforms', values: getPlatformFilterValues(), single: true },
	{ name: t.hardwareType, key: 'hardwareType', values: getFilterValues('hardwareType') },
	{ name: t.connectivity, key: 'connectivity', values: getFilterValues('connectivity') },
	{ name: t.industry, key: 'industry', values: getFilterValues('industry') },
	{ name: t.useCase, key: 'useCase', values: getFilterValues('useCase') },
];

// Generate href for each device
function getDeviceHref(deviceId: string): string {
	const [, ...slugParts] = deviceId.split('/');
	const slug = slugParts.join('/');
	return `/device-library/${slug}/`;
}

// Prepare device data with href for client-side rendering
const devicesWithHref = devices.map((device) => ({
	...device,
	href: getDeviceHref(device.id),
}));

const initialDevices = devicesWithHref.slice(0, PAGE_SIZE);
---

<div
	class="device-library"
	data-no-results={t.noResults}
	data-devices-found={t.devicesFound}
	data-page-size={PAGE_SIZE}
>
	<FilterSidebar
		filters={filterGroups}
		translations={{ filters: t.filters, clearAll: t.clearAll }}
	/>

	<div class="device-library-main">
		<div class="device-library-header">
			<button type="button" class="mobile-filter-toggle" id="mobile-filter-toggle" aria-expanded="false" aria-controls="filter-sidebar" aria-haspopup="dialog">
				<Icon name="tabler:filter" />
				<span>{t.filters}</span>
				<span class="filter-badge" id="filter-badge" hidden></span>
			</button>
			<SearchBar placeholder={t.searchPlaceholder} />
			<div class="device-count">
				<span id="device-count">{devices.length}</span>
				{t.devicesFound}
			</div>
		</div>

		<div class="device-grid" id="device-grid">
			{
				initialDevices.map((device) => (
					<DeviceCard
						id={device.id}
						title={device.title}
						vendor={device.vendor}
						imageSrc={device.imageSrc}
						imageWidth={device.imageWidth}
						imageHeight={device.imageHeight}
						hardwareType={device.hardwareType}
						connectivity={device.connectivity}
						industry={device.industry}
						useCase={device.useCase}
						platforms={device.platforms}
						href={device.href}
					/>
				))
			}
		</div>

		<div class="no-results" id="no-results" hidden>
			{t.noResults}
		</div>

		<Pagination translations={{ previous: t.previous, next: t.next, page: t.page, of: t.of }} />
	</div>
</div>

<!--
	Store all devices data for client-side filter/search/pagination.
	Inlined rather than fetched so filters are interactive immediately on page
	load. Measured payload at ~123 devices: 66 KB raw / 7.7 KB gzipped — fine.
	If the catalog crosses ~300 devices or ~25 KB gzipped, revisit: move to a
	build-time emitted `/api/devices.json` and fetch on `astro:page-load`.
-->
<script is:inline define:vars={{ devicesWithHref }}>
	window.__DEVICE_LIBRARY_DATA__ = devicesWithHref;
</script>

<script>
	import {
		platformToQueryParam,
		queryParamToPlatform,
		type DevicePlatform,
	} from '~/util/device-platform';

	interface Device {
		id: string;
		title: string;
		vendor?: string;
		imageSrc: string;
		imageWidth?: number;
		imageHeight?: number;
		hardwareType: string;
		connectivity: string[];
		industry: string[];
		useCase: string[];
		platforms: string[];
		href: string;
	}

	declare global {
		interface Window {
			__DEVICE_LIBRARY_DATA__?: Device[];
		}
	}

	interface SearchParams {
		search: string;
		filters: Record<string, string[]>;
		page: number;
		pageSize: number;
	}

	interface SearchResult {
		devices: Device[];
		total: number;
		totalPages: number;
		currentPage: number;
	}

	// Emulated API service
	function createDeviceAPI(allDevices: Device[]) {
		function matchesSearch(device: Device, query: string): boolean {
			if (!query) return true;
			const searchLower = query.toLowerCase();

			const searchableFields = [
				device.title,
				device.vendor || '',
				device.hardwareType,
				...device.connectivity,
				...device.industry,
				...device.useCase,
			];

			return searchableFields.some((field) => field.toLowerCase().includes(searchLower));
		}

		function matchesFilters(device: Device, filters: Record<string, string[]>): boolean {
			for (const [key, values] of Object.entries(filters)) {
				if (values.length === 0) continue;

				let deviceValues: string[];
				if (key === 'hardwareType') {
					deviceValues = [device.hardwareType];
				} else {
					deviceValues =
						device[key as 'connectivity' | 'industry' | 'useCase' | 'platforms'] || [];
				}

				const hasMatch = values.some((v) => deviceValues.includes(v));
				if (!hasMatch) return false;
			}
			return true;
		}

		return {
			search(params: SearchParams): SearchResult {
				// Filter by search query and checkbox filters
				const filtered = allDevices.filter(
					(device) => matchesSearch(device, params.search) && matchesFilters(device, params.filters)
				);

				// Calculate pagination
				const total = filtered.length;
				const totalPages = Math.ceil(total / params.pageSize) || 1;
				const currentPage = Math.min(Math.max(1, params.page), totalPages);
				const startIndex = (currentPage - 1) * params.pageSize;
				const devices = filtered.slice(startIndex, startIndex + params.pageSize);

				return { devices, total, totalPages, currentPage };
			},
		};
	}

	function initDeviceLibrary() {
		const container = document.querySelector<HTMLElement>('.device-library');
		if (!container) return;
		// DOM-level idempotency marker — `astro:page-load` fires on both the
		// initial page load and on every view-transition navigation, so this
		// handler can run multiple times against the same DOM. Without the
		// marker every filter checkbox / pagination button / search input
		// would accumulate listeners (pagination Prev/Next would skip two
		// pages per click, search debounce would leak timers, etc.).
		if (container.dataset.inited === 'true') return;
		container.dataset.inited = 'true';

		const allDevices = window.__DEVICE_LIBRARY_DATA__;
		if (!allDevices) return;

		const api = createDeviceAPI(allDevices);

		// Elements
		const deviceGrid = container.querySelector('#device-grid') as HTMLElement;
		const deviceCountEl = container.querySelector('#device-count') as HTMLElement;
		const noResultsEl = container.querySelector('#no-results') as HTMLElement;
		const clearFiltersBtn = container.querySelector('#clear-filters');
		const filterCheckboxes = container.querySelectorAll<HTMLInputElement>(
			'.filter-sidebar input[type="checkbox"]'
		);
		const searchInput = container.querySelector('#device-search') as HTMLInputElement;
		const searchClearBtn = container.querySelector('#search-clear') as HTMLButtonElement;
		const pagination = container.querySelector('#pagination') as HTMLElement;
		const paginationPages = container.querySelector('#pagination-pages') as HTMLElement;
		const paginationPrev = container.querySelector('#pagination-prev') as HTMLButtonElement;
		const paginationNext = container.querySelector('#pagination-next') as HTMLButtonElement;
		const paginationInfo = container.querySelector('#pagination-info') as HTMLElement;
		const paginationCurrent = container.querySelector('#pagination-current') as HTMLElement;
		const paginationTotal = container.querySelector('#pagination-total') as HTMLElement;

		if (!deviceGrid || !deviceCountEl || !searchInput) return;

		const pageSize = parseInt(container.getAttribute('data-page-size') || '12', 10);
		let currentPage = 1;
		let debounceTimer: ReturnType<typeof setTimeout>;

		// Platform filter checkbox values are the DevicePlatform names themselves
		// ('ThingsBoard', 'Edge'), so we can round-trip through the shared
		// queryParamToPlatform / platformToQueryParam helpers and avoid keeping
		// a second copy of the URL-query ↔ platform-label map in this file.

		function syncFiltersFromUrl(): void {
			const params = new URLSearchParams(window.location.search);
			const platform = queryParamToPlatform(params.get('platform'));
			if (!platform) return;
			filterCheckboxes.forEach((cb) => {
				if (cb.name === 'platforms' && cb.value === platform) cb.checked = true;
			});
		}

		function syncUrlFromFilters(): void {
			const params = new URLSearchParams(window.location.search);
			const checkedPlatforms = Array.from(filterCheckboxes)
				.filter((cb) => cb.checked && cb.name === 'platforms')
				.map((cb) => cb.value);
			if (checkedPlatforms.length === 1) {
				const q = platformToQueryParam(checkedPlatforms[0] as DevicePlatform);
				if (q) params.set('platform', q);
				else params.delete('platform');
			} else {
				params.delete('platform');
			}
			const search = params.toString();
			const url = window.location.pathname + (search ? '?' + search : '');
			window.history.replaceState(null, '', url);
		}

		function getActiveFilters(): Record<string, string[]> {
			const filters: Record<string, string[]> = {};
			filterCheckboxes.forEach((checkbox) => {
				if (checkbox.checked) {
					const key = checkbox.name;
					if (!filters[key]) filters[key] = [];
					filters[key].push(checkbox.value);
				}
			});
			return filters;
		}

		function hrefWithActivePlatform(base: string): string {
			// Carry the catalog's current ?platform= filter onto each card link so
			// a user who filtered to Cloud EU and clicks a device lands on the
			// guide with ?platform=paas-eu — the detail page then substitutes the
			// right hostnames (eu.thingsboard.cloud etc.) in code snippets.
			// Build via URLSearchParams.set so a pre-existing `platform` in `base`
			// is replaced (not duplicated), and encoding stays consistent.
			const platform = new URLSearchParams(window.location.search).get('platform');
			if (!platform) return base;
			const [path, existingQuery = ''] = base.split('?');
			const params = new URLSearchParams(existingQuery);
			params.set('platform', platform);
			return `${path}?${params.toString()}`;
		}

		// HTML entity escape — safe for text content AND attribute values
		// (escapes both `"` and `'`, so either quote style is safe). Used on
		// every frontmatter-sourced string interpolated into the template
		// literal below. Catalog content is authored, not user-submitted, but
		// values like `16A Switch & Power Meter` and future titles with
		// apostrophes ("O'Brien Sensor") would otherwise produce invalid HTML
		// or break single-quoted attributes.
		function esc(s: string): string {
			return s
				.replace(/&/g, '&amp;')
				.replace(/</g, '&lt;')
				.replace(/>/g, '&gt;')
				.replace(/"/g, '&quot;')
				.replace(/'/g, '&#39;');
		}

		function renderDeviceCard(device: Device): string {
			const connectivityJson = esc(JSON.stringify(device.connectivity));
			const industryJson = esc(JSON.stringify(device.industry));
			const useCaseJson = esc(JSON.stringify(device.useCase));
			const platformsJson = esc(JSON.stringify(device.platforms));

			const industryChips = device.industry
				.slice(0, 3)
				.map((ind) => `<span class="filter-chip">${esc(ind)}</span>`)
				.join('');
			const moreChip =
				device.industry.length > 3
					? `<span class="filter-chip">+${device.industry.length - 3}</span>`
					: '';

			const title = esc(device.title);
			return `
				<a href="${esc(hrefWithActivePlatform(device.href))}" class="device-card"
					data-device-id="${esc(device.id)}"
					data-hardware-type="${esc(device.hardwareType)}"
					data-connectivity="${connectivityJson}"
					data-industry="${industryJson}"
					data-use-case="${useCaseJson}"
					data-platforms="${platformsJson}">
					<div class="device-image">
						<img src="${esc(device.imageSrc)}" alt="${title}" loading="lazy"${device.imageWidth ? ` width="${device.imageWidth}"` : ''}${device.imageHeight ? ` height="${device.imageHeight}"` : ''} />
					</div>
					<h3 class="device-title">${title}</h3>
					<p class="device-vendor">${device.vendor ? esc(device.vendor) : ''}</p>
					<div class="device-chips">
						${industryChips}${moreChip}
					</div>
				</a>
			`;
		}

		function renderPagination(currentPage: number, totalPages: number) {
			if (totalPages <= 1) {
				pagination.hidden = true;
				paginationInfo.hidden = true;
				return;
			}

			pagination.hidden = false;
			paginationInfo.hidden = false;

			paginationPrev.disabled = currentPage <= 1;
			paginationNext.disabled = currentPage >= totalPages;

			paginationCurrent.textContent = String(currentPage);
			paginationTotal.textContent = String(totalPages);

			// Generate page buttons
			const pages: (number | string)[] = [];
			const maxVisible = 5;

			if (totalPages <= maxVisible) {
				for (let i = 1; i <= totalPages; i++) pages.push(i);
			} else {
				pages.push(1);

				if (currentPage > 3) {
					pages.push('...');
				}

				const start = Math.max(2, currentPage - 1);
				const end = Math.min(totalPages - 1, currentPage + 1);

				for (let i = start; i <= end; i++) {
					if (!pages.includes(i)) pages.push(i);
				}

				if (currentPage < totalPages - 2) {
					pages.push('...');
				}

				if (!pages.includes(totalPages)) pages.push(totalPages);
			}

			paginationPages.innerHTML = pages
				.map((p) =>
					typeof p === 'number'
						? `<button type="button" class="page-btn${p === currentPage ? ' active' : ''}" data-page="${p}">${p}</button>`
						: `<span class="page-ellipsis">${p}</span>`
				)
				.join('');
		}

		function updateDisplay() {
			const result = api.search({
				search: searchInput.value.trim(),
				filters: getActiveFilters(),
				page: currentPage,
				pageSize,
			});

			// Update device count
			deviceCountEl.textContent = String(result.total);

			// Render devices
			if (result.devices.length > 0) {
				deviceGrid.innerHTML = result.devices.map(renderDeviceCard).join('');
				noResultsEl.hidden = true;
			} else {
				deviceGrid.innerHTML = '';
				noResultsEl.hidden = false;
			}

			// Update pagination
			currentPage = result.currentPage;
			renderPagination(result.currentPage, result.totalPages);

			// Update search clear button
			searchClearBtn.hidden = !searchInput.value;
		}

		function resetAndUpdate() {
			currentPage = 1;
			syncUrlFromFilters();
			updateDisplay();
		}

		// Pre-check filter chips from ?platform=X URL state, then re-render if any synced.
		const hadUrlPlatform = new URLSearchParams(window.location.search).has('platform');
		syncFiltersFromUrl();
		if (hadUrlPlatform) updateDisplay();

		// Event listeners
		filterCheckboxes.forEach((checkbox) => {
			checkbox.addEventListener('change', () => {
				// Single-select groups (e.g. Platform) — uncheck other options
				// in the same group so only one stays active at a time.
				const group = checkbox.closest<HTMLElement>('.filter-group');
				if (group?.dataset.single === 'true' && checkbox.checked) {
					group.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((other) => {
						if (other !== checkbox) other.checked = false;
					});
				}
				resetAndUpdate();
			});
		});

		clearFiltersBtn?.addEventListener('click', () => {
			filterCheckboxes.forEach((checkbox) => {
				checkbox.checked = false;
			});
			resetAndUpdate();
		});

		searchInput.addEventListener('input', () => {
			clearTimeout(debounceTimer);
			debounceTimer = setTimeout(resetAndUpdate, 300);
		});

		searchClearBtn?.addEventListener('click', () => {
			searchInput.value = '';
			resetAndUpdate();
			searchInput.focus();
		});

		paginationPrev?.addEventListener('click', () => {
			if (currentPage > 1) {
				currentPage--;
				updateDisplay();
				deviceGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		});

		paginationNext?.addEventListener('click', () => {
			currentPage++;
			updateDisplay();
			deviceGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
		});

		paginationPages?.addEventListener('click', (e) => {
			const target = e.target as HTMLElement;
			if (target.classList.contains('page-btn')) {
				const page = parseInt(target.dataset.page || '1', 10);
				if (page !== currentPage) {
					currentPage = page;
					updateDisplay();
					deviceGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
				}
			}
		});

		// Initial render is already done by Astro, just set up pagination.
		// Skip when ?platform= was present — updateDisplay() above already rendered
		// pagination for the filtered set; rendering for the unfiltered total
		// would re-add phantom pages with empty grids.
		if (!hadUrlPlatform) {
			const initialTotal = allDevices.length;
			const initialTotalPages = Math.ceil(initialTotal / pageSize);
			renderPagination(1, initialTotalPages);
		}
	}

	// Run on cold load AND on every view-transition navigation. The direct
	// call covers the case where `astro:page-load` already fired before this
	// module finished loading (Astro client scripts are async, so the event
	// can race the listener registration). Running twice is harmless — the
	// `data-inited` marker inside `initDeviceLibrary` makes the second call
	// a no-op.
	initDeviceLibrary();
	document.addEventListener('astro:page-load', initDeviceLibrary);
</script>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.device-library {
		display: flex;
		gap: 2rem;
		align-items: flex-start;
	}

	.device-library-main {
		flex: 1;
		min-width: 0;
	}

	.device-library-header {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.mobile-filter-toggle {
		display: none;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		background: var(--color-primary);
		border: none;
		border-radius: var(--radius-md);
		@include text-s;
		font-weight: $font-weight-semibold;
		color: #fff;
		cursor: pointer;
		white-space: nowrap;

		:global(svg) {
			width: 16px;
			height: 16px;
		}

		:global([data-theme='dark']) & {
			color: #1a1a2e;
		}
	}

	.filter-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.25rem;
		height: 1.25rem;
		padding: 0 0.25rem;
		background: #fff;
		color: var(--color-primary);
		border-radius: 1rem;
		@include text-xs;
		font-weight: $font-weight-bold;
	}

	.filter-badge[hidden] {
		display: none;
	}

	.device-count {
		@include text-s;
		color: var(--color-text-secondary);
	}

	.device-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
		grid-auto-rows: auto;
		// row-gap is 0 so subgrid cards don't inherit inter-element gap; visible
		// inter-row spacing comes from the cards' margin-block-end below.
		column-gap: 1.5rem;
		row-gap: 0;
	}

	.no-results {
		@include text-m;
		text-align: center;
		padding: 3rem 1rem;
		color: var(--color-text-secondary);
	}

	.no-results[hidden] {
		display: none;
	}

	@media (max-width: 768px) {
		.device-library {
			flex-direction: column;
		}

		.mobile-filter-toggle {
			display: inline-flex;
		}

		.device-library-header {
			flex-direction: row;
			align-items: center;
			flex-wrap: wrap;
		}

		.device-grid {
			grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		}
	}
</style>

<style lang="scss" is:global>
	@use '../../styles/_variables.scss' as *;

	/* Card layout for both SSR-rendered DeviceCard.astro and the JS-template
	   cards rendered on filter/pagination. Subgrid spans 4 parent row tracks
	   (image / title / vendor / chips) so cards in the same visual row align
	   horizontally on each track without forcing all rows to the same size.
	   Typography uses the same mixins as DeviceCard.astro so the two render
	   paths stay visually identical even if the design system tunes them. */
	.device-grid .device-card {
		display: grid;
		grid-template-rows: subgrid;
		grid-row: span 4;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		transition:
			transform 0.2s,
			box-shadow 0.2s;
		text-decoration: none;
		color: inherit;
		margin-block-end: 1.5rem;
	}

	.device-grid .device-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-card-hover, 0 4px 12px rgba(0, 0, 0, 0.15));
	}

	.device-grid .device-image {
		width: 100%;
		aspect-ratio: 4 / 3;
		background: #fff;
		display: flex;
		align-items: center;
