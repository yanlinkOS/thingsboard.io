---
import ReadMoreLink from './ReadMoreLink.astro';

interface Props {
	heading: string;
	/** Text content, may contain HTML (e.g. inline links) */
	description: string;
	readMoreHref: string;
	readMoreText?: string;
	/** Dots/points background SVG src */
	phoneBgSrc: string;
	/** Side decorative SVG src */
	phoneSideSrc: string;
	/**
	 * CSS position modifier class for the side SVG.
	 * One of: flexible | alarms-m | devices-nav | mobile-act | w-label | self-reg
	 */
	phoneSideClass: string;
	/** Static frame PNG src */
	frameImageSrc: string;
	/** Video URL (.mp4) */
	videoMp4: string;
	/** Video URL (.webm) */
	videoWebm: string;
	/** Place phone frame on the left, text on the right (default: false) */
	imageFirst?: boolean;
	/** Mirror shadow direction to the right side (used when imageFirst + side SVG is to the right of the phone) */
	shadowRight?: boolean;
	/** Move the dots/points background SVG to the right side */
	pointsRight?: boolean;
	/** Dark background block */
	dark?: boolean;
	/**
	 * Extra block modifier class.
	 * 'vis'   — adds vertical spacing (used for image-first alternating block)
	 * 'micro' — smaller block with max-width image cap
	 */
	blockClass?: 'vis' | 'micro' | '';
	/** Color accent: 'ce' = blue, 'pe' = green */
	variant?: 'ce' | 'pe';
}

const {
	heading,
	description,
	readMoreHref,
	readMoreText = 'Read more',
	phoneBgSrc,
	phoneSideSrc,
	phoneSideClass,
	frameImageSrc,
	videoMp4,
	videoWebm,
	imageFirst = false,
	shadowRight = false,
	pointsRight = false,
	dark = false,
	blockClass = '',
	variant = 'ce',
} = Astro.props;

const linkVariant = dark ? 'light' : variant === 'pe' ? 'pe' : 'default';
---

<div class:list={['block', { dark, 'image-first': imageFirst }, blockClass]}>
	{imageFirst && (
		<div class:list={['preview', { act: phoneSideClass === 'mobile-act' }]}>
			<div class="mobile-frame ios">
				<img class:list={['phone-bg', 'points', { right: pointsRight }]} src={phoneBgSrc} alt="" />
				<img class:list={['phone-bg', 'web', { right: shadowRight }, phoneSideClass]} src={phoneSideSrc} alt="" />
				<div class:list={['phone-shadow', { right: shadowRight }]}></div>
				<div class="frame-image">
					<img src={frameImageSrc} alt={heading} />
				</div>
				<div class="frame-video">
					<video autoplay loop preload="auto" muted playsinline>
						<source src={videoMp4} type="video/mp4" />
						<source src={videoWebm} type="video/webm" />
					</video>
				</div>
			</div>
		</div>
	)}

	<div class="feature-des">
		<h2>{heading}</h2>
		<p set:html={description} />
		<ReadMoreLink href={readMoreHref} text={readMoreText} variant={linkVariant} />
	</div>

	{!imageFirst && (
		<div class:list={['preview', { act: phoneSideClass === 'mobile-act' }]}>
			<div class="mobile-frame ios">
				<img class="phone-bg points" src={phoneBgSrc} alt="" />
				<img class:list={['phone-bg', 'web', phoneSideClass]} src={phoneSideSrc} alt="" />
				<div class="phone-shadow"></div>
				<div class="frame-image">
					<img src={frameImageSrc} alt={heading} />
				</div>
				<div class="frame-video">
					<video autoplay loop preload="auto" muted playsinline>
						<source src={videoMp4} type="video/mp4" />
						<source src={videoWebm} type="video/webm" />
					</video>
				</div>
			</div>
		</div>
	)}
</div>

<style lang="scss">
	@use '../../styles/variables' as *;

	// ── Mobile phone frame ────────────────────────────────────────
	.mobile-frame {
		position: relative;
		width: 320px;

		&::before {
			content: '';
			display: block;
		}

		&::after {
			content: '';
			display: block;
			z-index: 1;
			background-repeat: no-repeat;
			background-size: contain;
			position: absolute;
			inset: 0;
		}

		.phone-bg {
			position: absolute;
			z-index: 0;
			left: -10%;
			top: 11%;
			max-width: none;
			width: unset;

			&.points {
				left: -90%;
				top: 11%;

				&.right {
					left: 53%;
				}
			}

			&.web {
				border-radius: 6px;
				box-shadow: -20px 20px 40px -20px rgba(0, 0, 0, 0.15), -30px 30px 60px rgba(0, 0, 0, 0.15) !important;

				&.right {
					box-shadow: 20px 20px 40px -20px rgba(0, 0, 0, 0.15),
						30px 30px 60px rgba(0, 0, 0, 0.15) !important;
				}
			}

			&.flexible {
				top: 15%;
				left: -70%;
				width: 140%;
			}

			&.alarms-m {
				top: 25%;
				left: 25%;
				width: 140%;
			}

			&.devices-nav {
				top: 15%;
				left: -60%;
				width: 140%;
			}

			&.mobile-act {
				top: 20%;
				left: -70%;
				width: 140%;
			}

			&.w-label {
				top: 11%;
				left: 25%;
				width: 140%;
			}

			&.self-reg {
				top: 13%;
				left: -60%;
				width: 140%;
			}
		}

		.phone-shadow {
			position: absolute;
			z-index: -1;
			right: 1.9%;
			left: 1.9%;
			top: 0.3%;
			bottom: 0.9%;
			border-radius: 50px;
			box-shadow: -20px 20px 20px rgba(0, 0, 0, 0.15), -30px 30px 40px rgba(0, 0, 0, 0.15);

			&.right {
				box-shadow: 20px 20px 20px rgba(0, 0, 0, 0.15), 30px 30px 40px rgba(0, 0, 0, 0.15);
			}
		}

		.frame-video,
		.frame-image {
			position: absolute;

			img,
			video {
				width: 100%;
				position: absolute;
				inset: 0;
			}
		}

		.frame-image {
			z-index: -1;
		}

		&.ios {
			&::before {
				padding-top: 202%;
			}

			&::after {
				background-image: url(/images/mobile/iphone12promax-frame.png);
			}

			.frame-image,
			.frame-video {
				top: 2.15%;
				left: 5.25%;
				right: 5.15%;
				bottom: 2.15%;

				img,
				video {
					border-radius: 4%;
				}
			}
		}
	}

	// ── Block layout ──────────────────────────────────────────────
	.block {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-direction: column;

		.feature-des {
			order: 1;

			h2 {
				margin-top: 100px;
				font-weight: 500;
				line-height: 54px;
				font-size: 36px;
				color: #212529;
			}

			p {
				color: #75767c;
				font-size: 18px;
				font-weight: normal;
				line-height: 27px;
				margin: 4px 0 18px;

				:global(a) {
					color: inherit;
					text-decoration: underline;
				}
			}
		}

		.preview {
			display: flex;
			justify-content: center;
			position: relative;
			margin-top: 32px;
			order: 2;
		}

		.feature-des,
		.preview {
			width: 100%;
		}

		&.vis {
			margin: 70px 0 80px;
		}

		&.micro {
			margin: 80px 0;

			img {
				max-width: 569px;
			}

			.feature-des {
				margin-bottom: 12px;
			}
		}

		&.dark {
			.feature-des {
				h2 {
					color: $color-white;
				}

				p {
					color: #a6a8b2;
				}
			}
		}

		// ── Responsive: tablet ────────────────────────────────
		@media screen and (min-width: 750px) {
			.feature-des,
			.preview {
				width: 80%;
			}

			.preview.act {
				margin-left: 100px;
			}
		}

		// ── Responsive: desktop ───────────────────────────────
		@media screen and (min-width: 1025px) {
			flex-direction: row;

			.feature-des,
			.preview {
				width: calc(50% - 80px);
				order: unset;

				h2 {
					margin-top: unset;
				}
			}

			.preview {
				margin-top: unset;
			}
		}
	}
</style>