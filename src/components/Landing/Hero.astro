---
import { Products } from '@models/site.models';
import { Icon } from 'astro-icon/components';
import SmartImage from '@components/SmartImage.astro';

interface HeroButton {
	text: string;
	href: string;
	variant?: 'primary' | 'outline' | 'white';
	ariaLabel?: string;
	srOnlySuffix?: string;
	target?: string;
}

interface Achievement {
	href: string;
	src: string;
	alt: string;
	width?: number;
	height?: number;
}

interface Props {
	/**
	 * Product type for styling and features
	 */
	product?: Products;
	/**
	 * Main title(s) - can be string or array of strings
	 */
	title: string | string[];
	/**
	 * Subtitle text
	 */
	subtitle: string;
	/**
	 * Hero buttons
	 */
	buttons?: HeroButton[];
	/**
	 * Show down arrow for scrolling
	 */
	showArrow?: boolean;
	/**
	 * Anchor link for arrow/button
	 */
	anchorLink?: string;
	/**
	 * Custom background image URL
	 */
	backgroundImage?: string;
	/**
	 * Video background config (for desktop)
	 */
	videoBackground?: {
		mp4?: string;
		webm?: string;
		poster?: string;
	};
	/**
	 * Custom achievement override (if not using default)
	 */
	achievement?: Achievement | null;
	/**
	 * Additional CSS class for hero section
	 */
	className?: string;
}

const {
	product,
	title,
	subtitle,
	buttons = [],
	showArrow = true,
	anchorLink = '#intro',
	backgroundImage = 'https://img.thingsboard.io/tb-cover.webp',
	achievement,
	className = '',
} = Astro.props;

// Products that show achievement badge
const productsWithAchievement = [Products.CE, Products.PE, Products.PAAS, Products.PAAS_EU];
const showAchievement =
	achievement !== null && (achievement || (product && productsWithAchievement.includes(product)));

// Default achievement for CE/PE/PAAS
const defaultAchievement: Achievement = {
	href: '/blog/top-supplier-retail-2024-2/',
	src: '/src/assets/images/landings/ce/feature-logo/top-supplier-retail-2024.webp',
	alt: 'Top supplier retail 2024',
	width: 110,
	height: 160,
};

const achievementData = achievement || defaultAchievement;
const titles = Array.isArray(title) ? title : [title];
---

<section id="hero" class:list={['light-text', className]}>
	<div class="video-cover" style={`background-image: url(${backgroundImage})`}></div>

	{
		showAchievement && (
			<div class="achievement">
				<a href={achievementData.href}>
					<SmartImage
						class="achieve"
						src={achievementData.src}
						alt={achievementData.alt}
						width={achievementData.width || 110}
						height={achievementData.height || 160}
					/>
				</a>
			</div>
		)
	}

	<div id="hero-content">
		<h1 class="header-animation">
			{titles.map((t) => <span class="tb-title">{t}</span>)}
		</h1>
		<h2 class="header-animation tb-sub-title">{subtitle}</h2>

		{
			buttons.length > 0 && (
				<div class="header-animation hero-buttons">
					{buttons.map((button) => (
						<a
							href={button.href}
							class:list={[
								button.variant === 'outline' ? 'learn-tb' : 'button',
								button.variant === 'primary' && 'accent',
								button.variant === 'white' && 'white',
							]}
							aria-label={button.ariaLabel}
							target={button.target}
							rel={button.target === '_blank' ? 'noopener noreferrer' : undefined}
						>
							{button.text}
							{button.srOnlySuffix && <span class="sr-only">{button.srOnlySuffix}</span>}
						</a>
					))}
				</div>
			)
		}

		{
			showArrow && (
				<div class="tb-arrow">
					<a href={anchorLink} aria-label="Scroll to content">
						<Icon name="tabler:chevron-down" size="32" />
					</a>
				</div>
			)
		}

		<slot />
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	#hero {
		height: 100vh;
		padding-top: 0;
		position: relative;
		overflow: hidden;
		background: none;

		.video-cover {
			position: absolute;
			z-index: -2;
			top: 0;
			left: 0;
			bottom: 0;
			right: 0;
			overflow: hidden;
			background-size: cover;
			background-color: #000;
			background-repeat: no-repeat;
			background-position: 50% 50%;
		}

		.achievement {
			position: absolute;
			top: 90px;
			right: 20px;
			z-index: 100;

			.achieve {
				width: 100%;
				height: auto;

				@media (max-width: 768px) {
					width: 60px;
				}
			}
		}

		#hero-content {
			height: 100%;
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-content: center;
			align-items: center;
			background-color: rgba(0, 0, 0, 0.72);
			text-align: center;
			padding: 0 20px;

			.tb-title {
				margin-bottom: 20px;
				font-size: 22px;
				font-weight: 400;
				text-shadow: 0 0 18px rgba(0, 0, 0, 0.66);
				color: white;
				display: block;

				@media screen and (min-width: 750px) {
					font-size: 36px;
				}

				@media screen and (min-width: 1250px) {
					margin-bottom: 40px;
					font-size: 64px;
				}
			}

			.tb-sub-title {
				margin-bottom: 40px;
				font-size: 14px;
				line-height: 1.5;
				text-shadow: 0 0 18px rgba(0, 0, 0, 0.66);
				color: white;
				font-weight: 300;
				max-width: 800px;

				@media screen and (min-width: 750px) {
					font-size: 20px;
					margin-bottom: 60px;
				}

				@media screen and (min-width: 1250px) {
					font-size: 28px;
					margin-bottom: 80px;
				}
			}

			.hero-buttons {
				display: flex;
				gap: 20px;
				flex-wrap: wrap;
				justify-content: center;
			}

			.learn-tb {
				cursor: pointer;
				line-height: 40px;
				font-size: 16px;
				font-weight: 500;
				padding: 0 15px;
				border: 1px solid white;
				background-color: transparent;
				transition: 0.6s;
				text-shadow: 0 0 18px rgba(0, 0, 0, 0.66);
				color: white;
				text-decoration: none;
				display: inline-block;
				border-radius: 4px;

				&:hover {
					background-color: white;
					color: var(--tb-main-color);
					text-shadow: none;
				}

				@media screen and (min-width: 1250px) {
					line-height: 60px;
					font-size: 28px;
					padding: 0 40px;
					border-width: 3px;
				}
			}

			.button {
				display: inline-block;
				border-radius: 4px;
				padding: 0 15px;
				line-height: 40px;
				color: white;
				background-color: var(--tb-main-color);
				text-decoration: none;
				font-size: 16px;
				font-weight: 500;
				transition: 0.6s;

				&:hover {
					filter: brightness(1.2);
				}

				&.accent {
					background-color: #ff3d00;

					&:hover {
						filter: brightness(1.1);
					}
				}

				&.white {
					background-color: white;
					border: 1px solid white;
					color: var(--tb-main-color);
					text-shadow: none;

					&:hover {
						filter: none;
						background-color: transparent;
						color: white;
						text-shadow: 0 0 18px rgba(0, 0, 0, 0.66);
					}

					@media screen and (min-width: 1250px) {
						border-width: 3px;
					}
				}

				@media screen and (min-width: 1250px) {
					padding: 0 40px;
					line-height: 60px;
					font-size: 28px;
				}
			}

			.tb-arrow {
				position: fixed;
				bottom: 40px;
				left: 0;
				right: 0;
				margin: auto;
				width: 40px;
				height: 40px;
				opacity: 1;
				z-index: 24;
				color: #fff;
				text-align: center;

				a {
					color: #fff;
				}
			}

			&.arrow-hidden .tb-arrow {
				display: none;
			}
		}
	}

	// Animation
	.header-animation {
		max-width: 100%;
		opacity: 0;
		transform: translate3d(0, 45px, 0);
		animation-name: slideup-in;
		animation-duration: 600ms;
		animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
		animation-fill-mode: forwards;
	}

	.header-animation:nth-child(1) {
		animation-delay: 0ms;
	}

	.header-animation:nth-child(2) {
		animation-delay: 300ms;
	}

	.header-animation:nth-child(3) {
		animation-delay: 600ms;
	}

	.header-animation:nth-child(4) {
		animation-delay: 900ms;
	}

	.header-animation:nth-child(5) {
		animation-delay: 1200ms;
	}

	@keyframes slideup-in {
		from {
			opacity: 0;
			transform: translate3d(0, 45px, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}
</style>

<script>
	// Smooth scroll for anchor links
	document.addEventListener('DOMContentLoaded', () => {
		const heroLinks = document.querySelectorAll('#hero-content a[href^="#"], #hero .tb-arrow a');
		heroLinks.forEach((link) => {
			link.addEventListener('click', (e) => {
				e.preventDefault();
				const href = link.getAttribute('href');
				if (!href) return;

				const target = document.querySelector(href);
				if (target) {
					const headerHeight = 60;
					const targetPosition = target.getBoundingClientRect().top + window.scrollY - headerHeight;
					window.scrollTo({
						top: targetPosition,
						behavior: 'smooth',
					});
				}
			});
		});

		// Arrow visibility on scroll
		const heroContent = document.getElementById('hero-content');
		const handleScroll = () => {
			if (heroContent) {
				const rect = heroContent.getBoundingClientRect();
				if (-rect.top >= 60) {
					heroContent.classList.add('arrow-hidden');
				} else {
					heroContent.classList.remove('arrow-hidden');
				}
			}
		};

		window.addEventListener('scroll', handleScroll);
		handleScroll();
	});
</script>
