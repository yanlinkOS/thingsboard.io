---
import SmartImage from '@components/SmartImage.astro';
import ReadMoreLink from './ReadMoreLink.astro';
---

<section id="rbac-section">
	<div class="main-div">
		<div class="block">
			<div class="diagram-panel" id="rbac-diagram">
				<ul class="diagram-tabs">
					<li id="tab-roles" class="tab active">
						<button onclick="activateRbacTab('roles')">Roles</button>
					</li>
					<li id="tab-hierarchy" class="tab">
						<button onclick="activateRbacTab('hierarchy')">Customer hierarchy</button>
					</li>
				</ul>
				<div class="diagram-wrap">
					<div id="rbac-roles" class="diagram-content">
						<SmartImage
							src="/src/assets/images/landings/pe/roles.svg"
							alt="Roles diagram"
							width="500"
							height="238"
							loading="lazy"
						/>
					</div>
					<div id="rbac-hierarchy" class="diagram-content" style="display:none;">
						<SmartImage
							src="/src/assets/images/landings/pe/hierarchy.svg"
							alt="Customer hierarchy diagram"
							width="500"
							height="238"
							loading="lazy"
						/>
					</div>
					<SmartImage
						src="/src/assets/images/landings/pe/diagram-border.svg"
						alt=""
						width="626"
						height="372"
						loading="lazy"
					/>
				</div>
			</div>
			<div class="feature-des">
				<h3 class="phrase-heading">Advanced RBAC for IoT</h3>
				<p>
					Advanced management of user roles and permissions. Manage hierarchy of customers with
					multiple levels of sub-customers, independent users and devices.
				</p>
				<ReadMoreLink href="/docs/user-guide/roles/" text="Read more about advanced RBAC for IoT" variant="pe" />
			</div>
		</div>
	</div>
</section>

<script>
	function activateRbacTab(id: string) {
		document.querySelectorAll('#rbac-section .tab').forEach((li) => li.classList.remove('active'));
		document.getElementById('tab-' + id)?.classList.add('active');
		document.querySelectorAll('#rbac-section .diagram-content').forEach((el) => {
			(el as HTMLElement).style.display = 'none';
		});
		const target = document.getElementById('rbac-' + id);
		if (target) target.style.display = 'flex';
	}

	(window as any).activateRbacTab = activateRbacTab;
</script>

<style lang="scss">
	@use '../../styles/variables' as *;

	#rbac-section {
		width: 100%;

		.main-div {
			max-width: 1200px;
			margin: 0 auto;
			padding: 5rem 1.875rem 0;

			@media screen and (min-width: 1500px) {
				max-width: 1400px;
			}

			@media screen and (max-width: 768px) {
				padding: 3rem 1.25rem 0;
			}
		}

		.block {
			display: flex;
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			gap: 60px;

			@media screen and (max-width: 768px) {
				flex-direction: column;
				gap: 32px;
			}
		}

		.diagram-panel {
			flex: 1;
			min-width: 0;

			@media screen and (max-width: 768px) {
				width: 100%;
				order: 2;
			}
		}

		.diagram-tabs {
			list-style: none;
			margin: 0;
			padding: 0 0 0.75rem 0;
			display: flex;
			gap: 0;

			.tab {
				margin-right: 1.375rem;
				padding: 0.375rem 0;

				button {
					background: none;
					border: none;
					padding: 0;
					font-size: $font-size-base;
					font-weight: $font-weight-normal;
					color: $color-text-secondary;
					cursor: pointer;
				}

				&.active {
					background-color: $color-pe-link;
					border-radius: 6px;
					padding: 0.375rem 0.875rem;

					button {
						color: $color-white;
					}
				}
			}
		}

		.diagram-wrap {
			position: relative;

			:global(img:last-child) {
				display: block;
				width: 100%;
				height: auto;
			}
		}

		.diagram-content {
			position: absolute;
			inset: 0;
			padding: 6% 8%;
			display: flex;
			align-items: center;
			justify-content: center;

			:global(img) {
				width: auto;
				max-width: 100%;
				max-height: 100%;
			}
		}

		.feature-des {
			flex: 0 0 40%;

			@media screen and (max-width: 768px) {
				flex: none;
				width: 100%;
			}

			.phrase-heading {
				font-size: $font-size-3xl;
				font-weight: $font-weight-bold;
				color: $color-text-primary;
				margin: 0 0 1.25rem;
				line-height: 1.3;

				@media screen and (max-width: 768px) {
					font-size: $font-size-2xl;
				}
			}

			p {
				font-size: $font-size-lg;
				line-height: 1.7;
				color: $color-text-secondary;
				margin: 0 0 1.75rem;
			}
		}
	}
</style>
