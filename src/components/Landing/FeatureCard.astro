---
import SmartImage from '@components/SmartImage.astro';
interface Props {
	icon: string;
	title: string;
	description: string;
	href: string;
	class?: string;
	variant?: 'default' | 'pe' | 'tbmq';
}

const { icon, title, description, href, class: className = '', variant = 'default' } = Astro.props;
---

{variant === 'tbmq' ? (
	<div class:list={['tbmq-card', className]}>
		<div class="tbmq-card__inner">
			<SmartImage src={icon} alt={title} loading="lazy" class="tbmq-card__icon" />
			<div class="tbmq-card__body">
				<h3 class="tbmq-card__title">
					<a href={href} target="_blank">{title}</a>
				</h3>
				<p class="tbmq-card__description">{description}</p>
			</div>
		</div>
	</div>
) : variant === 'pe' ? (
	<div class:list={['feature-item', className]}>
		<SmartImage src={icon} alt="" loading="lazy" width="284" height="151" />
		<h3 class="item-heading">
			<a href={href}>{title}</a>
		</h3>
		<p>{description}</p>
	</div>
) : (
	<div class:list={['feature-card', className]}>
		<div class="feature-card__inner">
			<SmartImage src={icon} alt="" class="feature-card__icon" loading="lazy" width="" height="" />
			<div class="feature-card__content">
				<h3 class="feature-card__title">
					<a href={href}>{title}</a>
				</h3>
				<p class="feature-card__description">{description}</p>
			</div>
		</div>
	</div>
)}

<style lang="scss">
	@use '../../styles/variables' as *;

	// TBMQ variant
	.tbmq-card {
		padding: 0 $spacing-4;
		margin-bottom: $spacing-8;
		width: 100%;

		@include media-up(lg) {
			width: 50%;
		}

		&__inner {
			display: flex;
			flex-direction: column;
			align-items: flex-start;
			padding: $spacing-12;
			width: 100%;
			height: 100%;
			background: var(--color-bg-surface);
			border-radius: 24px;
			box-shadow: 0 4px 16px 0 rgba(0, 0, 0, 0.12);

			@include media-up(md) {
				flex-direction: row;
			}

			@include media-down(md) {
				text-align: center;
				align-items: center;
				padding: $spacing-8;
			}
		}

		&__body {
			display: flex;
			flex-direction: column;
		}

		&__title {
			@include card-title;
			margin-bottom: $spacing-2;

			a {
				color: #1f8b4d;
				text-decoration: none;

				&:hover {
					text-decoration: underline;
				}
			}
		}

		&__description {
			@include text-m;
			color: #757c76;
			line-height: 32px;
			margin: $spacing-2 0 0;
		}
	}

	:global(.tbmq-card__icon) {
		height: fit-content;
		width: auto;
		flex-shrink: 0;
		margin: 0 0 18px;

		@include media-up(md) {
			margin: 0 30px 0 0;
		}
	}

	// PE variant
	.feature-item {

		:global(img) {
			display: block;
			max-width: 284px;
			height: auto;
			margin-bottom: 40px;
		}

		.item-heading {
			font-size: $font-size-3xl;
			font-weight: $font-weight-semibold;
			line-height: 1.3;
			color: var(--color-text);
			margin: 0 0 0.5rem;
			text-align: left;

			a {
				color: var(--color-text);
				text-decoration: none;

				&:hover {
					text-decoration: underline;
				}
			}

			@media screen and (max-width: 768px) {
				font-size: $font-size-2xl;
			}
		}

		p {
			color: #757c76;
			font-size: $font-size-lg;
			font-weight: $font-weight-normal;
			line-height: 27px;
			margin: 4px 0 0;
		}
	}

	// Default variant
	.feature-card {
		padding: 0 $spacing-4;
		margin-bottom: $spacing-8;
		width: 100%;

		@include media-up(lg) {
			width: 50%;
		}

		&__inner {
			padding: $spacing-12;
			width: 100%;
			height: 100%;
			background: var(--color-bg-surface);
			border-radius: $radius-md;
			box-shadow: var(--shadow-lg);
			display: flex;
			text-align: left;

			@include media-down(md) {
				display: block;
				text-align: center;
				padding: $spacing-8;
			}
		}

		&__icon {
			height: fit-content;
			margin: 0 30px 0 0;
			width: 92px;
			flex-shrink: 0;

			@include media-down(md) {
				margin: 0 0 $spacing-4;
			}
		}

		&__content {
			width: calc(100% - 122px);

			@include media-down(md) {
				width: 100%;
			}
		}

		&__title {
			@include card-title;
			margin-bottom: $spacing-2;

			a {
				color: $color-primary;
				text-decoration: none;

				&:hover {
					text-decoration: underline;
				}
			}
		}

		&__description {
			@include text-m;
			margin: $spacing-2 0 0;
		}
	}
</style>
