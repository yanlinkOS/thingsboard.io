---
import SmartImage from '@components/SmartImage.astro';
interface Props {
	icon: string;
	title: string;
	description: string;
	href: string;
	class?: string;
}

const { icon, title, description, href, class: className = '' } = Astro.props;
---

<div class:list={['feature-card', className]}>
	<div class="feature-card__inner">
		<SmartImage src={icon} alt="" class="feature-card__icon" loading="lazy" width="" height="" />
		<div class="feature-card__content">
			<h3 class="feature-card__title">
				<a href={href}>{title}</a>
			</h3>
			<p class="feature-card__description">{description}</p>
		</div>
	</div>
</div>

<style lang="scss">
	@use '../../styles/variables' as *;

	.feature-card {
		padding: 0 $spacing-4;
		margin-bottom: $spacing-8;
		width: 100%;

		@include media-up(lg) {
			width: 50%;
		}

		&__inner {
			padding: $spacing-12;
			width: 100%;
			height: 100%;
			background: $color-white;
			border-radius: $radius-md;
			box-shadow: var(--shadow-lg);
			display: flex;
			text-align: left;

			@include media-down(md) {
				display: block;
				text-align: center;
				padding: $spacing-8;
			}
		}

		&__icon {
			height: fit-content;
			margin: 0 30px 0 0;
			width: 62px;
			flex-shrink: 0;

			@include media-down(md) {
				margin: 0 0 $spacing-4;
			}
		}

		&__content {
			width: calc(100% - 92px);

			@include media-down(md) {
				width: 100%;
			}
		}

		&__title {
			@include card-title;
			margin-bottom: $spacing-2;

			a {
				color: $color-primary;
				text-decoration: none;

				&:hover {
					text-decoration: underline;
				}
			}
		}

		&__description {
			@include text-m;
			margin: $spacing-2 0 0;
		}
	}
</style>
