---
import SmartImage from '@components/SmartImage.astro';
interface Props {
  /**
   * Product name (e.g., "Community Edition", "Cloud")
   */
  name: string;
  /**
   * Short description
   */
  description: string;
  /**
   * Product image/icon URL
   */
  image: string;
  /**
   * Link URL
   */
  href: string;
  /**
   * Link text
   */
  linkText: string;
  /**
   * Whether this is the main/featured product
   */
  featured?: boolean;
  /**
   * Product label (e.g., "ThingsBoard")
   */
  productLabel?: string;
  class?: string;
}

const {
  name,
  description,
  image,
  href,
  linkText,
  featured = false,
  productLabel,
  class: className = ''
} = Astro.props;
---

<div class:list={['product-card', { 'product-card--featured': featured }, className]}>
  {productLabel && (
    <div class="product-card__header">
      <span class="product-card__label">{productLabel}</span>
      <h3 class="product-card__name">{name}</h3>
    </div>
  )}
  {!productLabel && <h3 class="product-card__title">{name}</h3>}
  <p class="product-card__description">{description}</p>
  <SmartImage src={image} alt={name} class="product-card__image" loading="lazy" width="" height="" />
  <a href={href} class="product-card__link">{linkText}</a>
</div>

<style lang="scss">
  @use '../../styles/variables' as *;

  .product-card {
    color: $color-text-primary;
    background-color: $color-white;
    box-shadow: var(--shadow-lg);
    border-radius: $radius-md;
    padding: $spacing-10;
    text-align: center;
    flex: 1 1 0%;
    margin-bottom: $spacing-10;

    @include media-down(lg) {
      margin-bottom: $spacing-10;
    }

    &__header {
      display: flex;
      flex-direction: column;
      text-align: center;
      margin-bottom: $spacing-4;
    }

    &__label {
      color: $color-text-secondary;
      font-size: $font-size-lg;
      font-weight: $font-weight-normal;
      line-height: 27px;
    }

    &__name {
      font-size: $font-size-3xl;
      font-weight: $font-weight-semibold;
      line-height: 1.5;
      margin: 0;
    }

    &__title {
      font-size: $font-size-3xl;
      font-weight: $font-weight-semibold;
      line-height: 1.5;
      margin-bottom: $spacing-4;
    }

    &__description {
      font-size: $font-size-base;
      color: $color-text-primary;
      margin: 0;
    }

    &__image {
      display: block;
      margin: 50px auto;
      width: 80%;
      max-width: 280px;
      height: auto;
    }

    &__link {
      color: $color-primary;
      font-weight: $font-weight-medium;
      font-size: $font-size-lg;
      text-decoration: none;

      &:hover {
        text-decoration: underline;
      }
    }

    // Featured/main variant
    &--featured {
      box-shadow: inset 0 -6px 0 $color-primary-dark, var(--shadow-lg);
      margin: 0 30px;

      @include media-down(lg) {
        margin: 0 0 $spacing-10;
      }

      .product-card__name {
        font-size: $font-size-6xl;
      }

      .product-card__image {
        margin: 60px auto;
      }
    }
  }
</style>
