---
import SmartImage from '@components/SmartImage.astro';
import ReadMoreLink from './ReadMoreLink.astro';
---

<section id="scada">
	<div class="main-div">
		<div id="features-top-1">
			<div class="background">
				<div class="main2"></div>
			</div>
			<div class="block scada">
				<div class="feature-des">
					<div class="scada-mode-selector">
						<div class="mode active gtm_button" data-mode="performance">
							<span>High-performance</span>
						</div>
						<div class="mode gtm_button" data-mode="traditional">
							<span>Traditional</span>
						</div>
					</div>
					<h3 class="phrase-heading scada-title">SCADA High-performance</h3>
					<p>
						Monitor and control your industrial processes in real time with SCADA. Use SCADA symbols
						on dashboards to create and manage any workflow, offering full flexibility to design and
						oversee operations according to your requirements.
					</p>
					<ReadMoreLink href="/use-cases/scada/" text="Read more about SCADA" />
				</div>
				<div class="scada-svg">
					<div class="scada-scheme-wrapper">
						<SmartImage
							class="scada-scheme high-perf"
							src="/src/assets/images/landings/ce/high-perf-scada-background.svg"
							alt="SCADA background block schema"
							width="1144"
							height="655"
							loading="lazy"
						/>
						<SmartImage
							class="scada-scheme trad scada-inactive"
							src="/src/assets/images/landings/ce/scada-background.svg"
							alt="SCADA background block schema"
							width="1144"
							height="655"
							loading="lazy"
						/>
					</div>
					<div class="scada-fade"></div>
					<div class="scada-background"></div>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const scadaModes = document.querySelectorAll('.scada-mode-selector .mode');
		scadaModes.forEach((mode) => {
			mode.addEventListener('click', () => {
				if (mode.classList.contains('active')) return;

				scadaModes.forEach((m) => m.classList.remove('active'));
				mode.classList.add('active');

				const isPerformance = mode.getAttribute('data-mode') === 'performance';
				const schemes = document.querySelectorAll('.scada-scheme');
				schemes[0].classList.toggle('scada-inactive', !isPerformance);
				schemes[1].classList.toggle('scada-inactive', isPerformance);

				const title = document.querySelector('.scada-title');
				if (title) {
					title.textContent = isPerformance ? 'SCADA High-performance' : 'SCADA Traditional';
				}
			});
		});
	});
</script>