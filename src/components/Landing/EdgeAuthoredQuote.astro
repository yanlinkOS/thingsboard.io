---
import SmartImage from '@components/SmartImage.astro';
---

<section id="authored-quote">
	<div class="main-div">
		<div class="background">
			<div class="main1"></div>
			<div class="small3"></div>
			<div class="small4"></div>
		</div>
		<div class="main-content">
		<SmartImage
			src="/src/assets/images/landings/edge/Dominic_Winkler.webp"
			alt="Dominic Winkler — ÖBB-Infrastruktur AG IT Enterprise Architect"
			width={400}
			height={258}
		/>
		<div class="text">
			<h2>ÖBB-Infrastruktur AG</h2>
			<p class="quote">
				"Thingsboard Edge gives us the invaluable ability to allow data to flow within our IT
				network without the need to bridge Firewalls and Public Internet."
			</p>
			<p class="author">Dominic Winkler</p>
			<p class="title">IT Enterprise Architect</p>
		</div>
		</div>
	</div>
</section>

<style lang="scss">
	#authored-quote {
		margin-top: 150px;
		padding: 20px;
	}

	.main-div {
		position: relative;
		z-index: 1;
	}

	.background {
		z-index: -1;
		position: absolute;
		top: 0;
		left: 50%;

		div {
			position: absolute;
			transform: skewY(-6deg);
			width: 436px;
			height: 90px;
		}

		.main1 {
			top: -150px;
			width: 2560px;
			height: 627px;
			left: -1280px;
			background-color: #effaf9;
		}

		.small3 {
			top: -300px;
			left: 789px;
			background-color: #185b55;
			border: none;
		}

		.small4 {
			top: -90px;
			right: 814px;
			border: 2px solid #185b55;
		}
	}

	.main-content {
		max-width: 1400px;
		margin: 0 auto;
		background: white;
		border: 2px solid #e8ebf0;
		border-radius: 24px;
		padding: 24px;
		display: grid;
		grid-template-columns: 185px 1fr;
		gap: 40px;
		position: relative;

		:global(img) {
			grid-column: 1;
			grid-row: 1;
			width: 200px;
			height: 200px;
			border-radius: 12px;
			object-fit: cover;
			object-position: 15% center;
		}
	}

	.text {
		grid-column: 2;
		grid-row: 1;
		padding-left: 32px;
		border-left: 4px solid #009688;

		h2 {
			font-size: 24px;
			font-weight: 600;
			color: #212529;
			margin-bottom: 20px;
		}

		.quote {
			font-size: 16px;
			line-height: 1.6;
			color: #3d3d3d;
			margin-bottom: 24px;
		}

		.author {
			font-size: 18px;
			font-weight: 600;
			color: #212529;
			margin-bottom: 4px;
		}

		.title {
			font-size: 14px;
			color: #5e6560;
			margin: 0;
		}
	}

	@media screen and (max-width: 750px) {
		#authored-quote {
			margin-top: 80px;
			padding: 20px 16px;
		}

		.background .main1 {
			top: -80px;
		}

		.main-content {
			display: flex;
			flex-direction: column;
			gap: 16px;
			padding: 20px;

			:global(img) {
				width: 140px;
				height: 140px;
				margin: 0 auto;
				order: 1;
			}
		}

		.text {
			order: 2;
			border-left: none;
			padding-left: 0;
			padding-top: 16px;
			border-top: 4px solid #009688;
			text-align: center;

			h2 {
				font-size: 20px;
			}

			.quote {
				font-size: 14px;
			}

			.author {
				font-size: 16px;
			}
		}
	}
</style>