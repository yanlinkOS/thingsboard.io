---
import SmartImage from '@components/SmartImage.astro';
import ReadMoreLink from './ReadMoreLink.astro';

interface LinkItem {
	href: string;
	text?: string;
	ariaLabel?: string;
	srOnlySuffix?: string;
	target?: string;
}

interface Props {
	heading: string;
	/** Heading level for the feature heading (3 = h3 default, 4 = h4) */
	headingLevel?: 3 | 4;
	description: string;
	links: LinkItem[];
	imageSrc: string;
	imageAlt: string;
	imageWidth?: number;
	imageHeight?: number;
	/** If true, image is placed before the text (image on left) */
	imageFirst?: boolean;
	/** Dark background variant (#262C28) */
	dark?: boolean;
	/** Background element ID (e.g. "background-white-labeling") — renders a real DOM background div */
	bgId?: string;
	/** Child div class names for the background element (e.g. ['main1', 'small1', 'small2', 'small3']) */
	bgDivs?: string[];
	/** Read-more link color variant */
	variant?: 'default' | 'light' | 'pe';
	/** Show "PE only" badge next to heading */
	peOnly?: boolean;
	/** Add shadow and border-radius to the image */
	imageShadow?: boolean;
	/** Use flex: 1 on the image (equal width with text, instead of the default flex: 2) */
	imageEqual?: boolean;
	/** Responsive image widths for srcset generation */
	imageWidths?: number[];
	/** sizes attribute to pair with srcset */
	imageSizes?: string;
	/** Optional decorative side icon (absolute positioned) */
	listIconSrc?: string;
	listIconAlt?: string;
	listIconWidth?: number;
	listIconHeight?: number;
	/** Horizontal offset in px from viewport center (positive = right, negative = left) */
	listIconLeft?: number;
	/** Vertical offset in px from section top */
	listIconTop?: number;
	id?: string;
}

const {
	heading,
	headingLevel = 3,
	description,
	links,
	imageSrc,
	imageAlt,
	imageWidth,
	imageHeight,
	imageFirst = false,
	dark = false,
	bgId,
	bgDivs,
	variant = 'default',
	listIconSrc,
	listIconAlt = '',
	listIconWidth,
	listIconHeight,
	listIconLeft = 460,
	listIconTop = 180,
	id,
	peOnly = false,
	imageShadow = false,
	imageEqual = false,
	imageWidths,
	imageSizes,
} = Astro.props;

const linkVariant = variant !== 'default' ? variant : dark ? 'light' : 'default';
const hasPseudoBg = dark && !bgId;
const HeadingTag = `h${headingLevel}` as 'h3' | 'h4';
---

<section class:list={['feature-block-section', { dark, 'has-pseudo-bg': hasPseudoBg }]} {id}>
	{listIconSrc && (
		<div class="list-icon" style={`--icon-left:${listIconLeft}px;--icon-top:${listIconTop}px;`}>
			<SmartImage
				src={listIconSrc}
				alt={listIconAlt}
				width={listIconWidth}
				height={listIconHeight}
				loading="lazy"
			/>
		</div>
	)}
	<div class="main-div">
		{bgId && (
			<div id={bgId} aria-hidden="true">
				{bgDivs?.map((cls) => <div class={cls} />)}
			</div>
		)}
		<div class="block">
			{imageFirst && (
				<SmartImage
					class:list={["preview", imageShadow && "shadow", imageEqual && "equal"]}
					src={imageSrc}
					alt={imageAlt}
					width={imageWidth}
					height={imageHeight}
					widths={imageWidths}
					sizes={imageSizes}
					loading="lazy"
				/>
			)}
			<div class="feature-des">
				<div class="heading-wrap">
					<HeadingTag class="phrase-heading">{heading}</HeadingTag>
					{peOnly && <span class="pe-badge">PE only</span>}
				</div>
				<p>{description}</p>
				<div class="links">
					{links.map((link) => (
						<ReadMoreLink href={link.href} text={link.text} ariaLabel={link.ariaLabel} srOnlySuffix={link.srOnlySuffix} variant={linkVariant} target={link.target} />
					))}
				</div>
			</div>
			{!imageFirst && (
				<SmartImage
					class:list={["preview", imageShadow && "shadow", imageEqual && "equal"]}
					src={imageSrc}
					alt={imageAlt}
					width={imageWidth}
					height={imageHeight}
					widths={imageWidths}
					sizes={imageSizes}
					loading="lazy"
				/>
			)}
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	.feature-block-section {
		position: relative;
		width: 100%;
		overflow: visible;

		// Full-width dark background (no skew) — only when no bgId DOM div is provided
		&.has-pseudo-bg::before {
			content: '';
			position: absolute;
			inset: 0;
			width: 100vw;
			left: 50%;
			z-index: 0;
			transform: translateX(-50%);
			background-color: #262c28;
		}

		.main-div {
			position: relative;
			z-index: 1;
			max-width: 1200px;
			margin: 0 auto;
			padding: 5rem 1.875rem;

			@media screen and (min-width: 1500px) {
				max-width: 1400px;
				padding: 5rem 6.25rem;
			}

			@media screen and (max-width: 768px) {
				padding: 3rem 1.25rem;
			}
		}

		.block {
			display: flex;
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			gap: 60px;

			.preview {
				flex: 2;
				min-width: 0;
				max-width: 100%;
				height: auto;
			}

			:global(.preview.equal) {
				flex: 1;
			}

			:global(.preview.shadow) {
				border-radius: 12px;
				box-shadow: 0 2px 12px 0 rgba(0, 0, 0, 0.12);
			}

			@media screen and (max-width: 768px) {
				flex-direction: column;
				gap: 32px;
			}
		}

		.feature-des {
			flex: 1;

			.heading-wrap {
				display: flex;
				align-items: center;
				gap: 12px;
				flex-wrap: wrap;
				margin-bottom: 1.25rem;
			}

			.pe-badge {
				display: inline-flex;
				align-items: center;
				padding: 4px 8px;
				font-size: 12px;
				font-weight: $font-weight-medium;
				line-height: 20px;
				border-radius: 6px;
				color: $color-white;
				background: #1f8b4d;
				border: 1px solid #1a7340;
				white-space: nowrap;
				flex-shrink: 0;
			}

			.phrase-heading {
				font-size: $font-size-4xl;
				font-weight: $font-weight-semibold;
				color: $color-text-primary;
				margin: 0;
				line-height: 1.3;

				@media screen and (max-width: 768px) {
					font-size: $font-size-3xl;
				}
			}

			p {
				font-size: $font-size-lg;
				line-height: 1.7;
				color: #6b6b72;
				margin: 0;
			}

			.links {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem 2rem;
				margin-top: 1rem;
			}
		}

		&.dark .feature-des {
			.phrase-heading {
				color: $color-white;
			}

			p {
				color: #9e9e9e;
			}
		}

		.list-icon {
			position: absolute;
			left: calc(50% + var(--icon-left, 460px));
			top: var(--icon-top, 180px);
			pointer-events: none;
			z-index: 2;

			:global(img) {
				border-radius: $radius-md;
				box-shadow:
					0 50px 50px -20px rgba(0, 0, 0, 0.15),
					0 0 30px 0 rgba(0, 0, 0, 0.1);
			}

			@media screen and (max-width: 1280px) {
				display: none;
			}
		}
	}
</style>
