---
interface Props {
  /**
   * Override title content
   */
  title?: string;
  /**
   * Override description content
   */
  description?: string;
  /**
   * Link in title
   */
  titleLink?: {
    text: string;
    href: string;
  };
}

const {
  title,
  description,
  titleLink = { text: 'ThingsBoard', href: '/docs/getting-started-guides/what-is-thingsboard/' }
} = Astro.props;
---

<section id="intro" class="intro-section">
  <div class="main-div">
    <h2 class="intro-section__title">
      <a class="heading-1" href={titleLink.href}>{titleLink.text}</a>
      {title || ' is an open-source IoT platform for data collection, processing, visualization, and device management'}
    </h2>
    <p class="intro-section__text">
      {description || 'It enables device connectivity via industry standard IoT protocols - MQTT, CoAP and HTTP and supports both cloud and on-premises deployments. ThingsBoard combines scalability, fault-tolerance and performance so you will never lose your data.'}
    </p>
    <slot />
  </div>
</section>

<style lang="scss">
  @use '../../styles/variables' as *;

  .intro-section {
    margin-bottom: 178px;
    padding-top: $spacing-20;

    @include media-down(md) {
      margin-bottom: 70px;
      padding-top: $spacing-12;
    }

    &__title {
      font-weight: $font-weight-semibold;
      font-size: $font-size-5xl;
      line-height: 54px;
      text-align: center;
      margin-bottom: $spacing-12;
      color: $color-text-primary;

      @include media-down(md) {
        font-size: $font-size-4xl;
        line-height: 1.3;
        margin-bottom: $spacing-8;
      }

      a {
        @include heading-1();
        &:hover {
          text-decoration: underline;
        }
      }
    }

    &__text {
      color: $color-text-light;
      text-align: center;
      font-size: $font-size-xl;
      font-weight: $font-weight-normal;
      line-height: 27px;
      margin: $spacing-1 0 $spacing-4;
      margin-left: auto;
      margin-right: auto;

      @include media-down(md) {
        font-size: $font-size-lg;
      }
    }
  }
</style>
