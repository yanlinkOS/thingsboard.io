---
import Icon from '~/components/starlight/Icon.astro';

export interface Props {
	icon?: string;
	title: string;
	/** Heading level for the card title. Defaults to 2. Use 3+ when the card sits under a ## section. */
	headingLevel?: 2 | 3 | 4 | 5 | 6;
}

const { icon, title, headingLevel = 2 } = Astro.props;
const HeadingTag = `h${headingLevel}` as 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
---

<div class="card--fullwidth">
	<article class="card sl-flex">
		<HeadingTag class="title sl-flex">
			{icon && <Icon name={icon} class="icon" size="1.333em" />}
			<Fragment set:html={title} />
		</HeadingTag>
		<div class="body">
			<div class="split">
				<slot />
			</div>
		</div>
	</article>
</div>

<style>
	.card--fullwidth {
		--card-bg: rgba(23, 25, 30, 0.8);
		grid-column: 1 / -1;
	}
	:global(:root[data-theme='light']) .card--fullwidth {
		--card-bg: rgba(255, 255, 255, 0.8);
	}

	.split {
		margin-top: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0 1rem;
		color: var(--sl-color-white);
	}

	/* Starlight Card baseline (kept because this component no longer delegates to <StarlightCard>) */
	.card--fullwidth .card {
		border: 1px solid var(--sl-color-gray-5);
		padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem);
		flex-direction: column;
		gap: clamp(0.5rem, calc(0.125rem + 1vw), 1rem);
		background:
			radial-gradient(var(--sl-color-orange-low), transparent 70%) no-repeat 50% -25% / 120% 300%,
			var(--card-bg);
		position: relative;
		overflow: hidden;
		color: var(--sl-color-white);
	}
	.card--fullwidth .title {
		font-weight: 600;
		font-size: var(--sl-text-h4);
		color: var(--sl-color-white);
		line-height: var(--sl-line-height-headings);
		gap: 1rem;
		align-items: center;
		margin: 0;
	}
	.card--fullwidth .card .icon {
		border: 1px solid var(--sl-card-border, var(--sl-color-orange));
		background-color: var(--sl-card-bg, var(--sl-color-orange-low));
		padding: 0.2em;
		border-radius: 0.25rem;
		flex-shrink: 0;
	}
	.card--fullwidth .card .body {
		margin: 0;
		font-size: clamp(var(--sl-text-sm), calc(0.5rem + 1vw), var(--sl-text-body));
	}

	@media screen and (min-width: 78rem) {
		.split {
			flex-direction: row;
			gap: 2.5rem;
		}
		.split > :global(*) {
			margin-top: 0 !important;
			flex: 1;
		}
	}
</style>
