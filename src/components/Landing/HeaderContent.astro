---
import Navigation from './Navigation.astro';
import GitHubButton from './GitHubButton.astro';
import NButton from './NButton.astro';
import SearchButton from '../SearchButton.astro';
import ThemeToggle from '../ThemeToggle.astro';
import SmartImage from '@components/SmartImage.astro';

interface Props {
	githubLink?: string;
	githubLabel?: string;
	platformQuery?: string;
}

const { platformQuery = '' } = Astro.props;
---

<div class="logo-burger">
	<a href="https://u24.gov.ua/" target="_blank" class="support-ukraine">
		<SmartImage
			src="/src/assets/images/support-ukraine-banner.webp"
			alt="Stand with Ukraine flag"
			width="48"
			height="31"
		/>
	</a>
	<a href="/" class="logo" aria-label="Link to homepage"></a>
	<button onclick="Burger()" class="burger" aria-label="Burger menu"></button>
	<GitHubButton />
</div>

<Navigation platformQuery={platformQuery} />
<div class="head-buttons">
	<SearchButton />
	<ThemeToggle />
	<NButton id="Menu_Pricing" href="/pricing/" variant="text" class="price gtm_button"
		>Pricing</NButton
	>
	<NButton id="Menu_TryItNow" href="/installations/" variant="filled" class="try gtm_button"
		>Try it now</NButton
	>
</div>

<script>
	// Burger menu toggle
	function Burger() {
		const header = document.querySelector('header.header');
		const body = document.body;

		if (header?.classList.contains('opened-burger')) {
			header.classList.remove('opened-burger');
			const subMenus = document.querySelectorAll(
				'nav.head-menu > ul > li > div.centered-sub > ul.sub-menu'
			);
			subMenus.forEach((menu) => menu.classList.remove('open-sub'));
			body.style.overflow = '';
		} else {
			header?.classList.add('opened-burger');
			body.style.overflow = 'hidden';
		}
	}

	// Make function available globally
	(window as any).Burger = Burger;
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	header.header {
		position: fixed;
		top: 0;
		left: 0;
		transition-duration: 0.3s;
		width: 100%;
		height: $header-height;
		z-index: 8888;
		border-bottom: none;
		background-color: var(--sl-color-bg-nav);
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 30px;

		@media screen and (min-width: 1500px) {
			padding: 0 20px;
		}

		.logo-burger {
			display: flex;
			height: 100%;
			align-items: center;
		}

		.head-buttons {
			display: flex;
			flex-direction: row;
			align-items: center;
			gap: 10px;

			.n-button {
				width: 110px;
				padding: 0;
				display: flex;
				align-items: center;
				justify-content: center;
			}
		}

		.support-ukraine {
			padding-right: 20px;
			img {
				height: 31px;
			}
		}

		.logo {
			position: relative;
			float: left;
			display: block;
			width: 140px;
			height: 60px;
			top: 0;
			left: 0;
			transform: none;
			background-image: url(https://img.thingsboard.io/thingsboard_logo_b.svg);
			background-size: contain;
			background-position: center center;
			background-repeat: no-repeat;
			filter: unset;

			[data-theme='dark'] & {
				filter: invert(100%) sepia(68%) saturate(0%) hue-rotate(350deg) brightness(113%)
					contrast(101%);
			}

			@media screen and (min-width: 1025px) {
				width: 180px;
			}
		}
	}

	.burger {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		right: 22px;
		display: none;
		filter: unset;
		background-image: url(https://img.thingsboard.io/burger-icon.svg);
		height: 47px;
		width: 47px;
		background-size: cover;
		border: none;
		background-color: inherit;

		@media screen and (max-width: 1024px) {
			height: 37px;
			width: 37px;
			background-image: url(https://img.thingsboard.io/s-burger-icon.svg);
		}

		&:focus {
			outline: none;
		}
	}

	// Responsive styles
	@media screen and (max-width: 1280px) {
		header.header {
			padding: 9px 30px;
			display: unset;
			height: unset !important;
			transition-property: height;

			&.opened-burger {
				height: 100% !important;
				z-index: 10000;

				.logo-burger {
					height: $header-height;
					position: fixed;
					z-index: 2;
					background-color: #fff;
					box-shadow: 0 1px 0 rgba(48, 86, 128, 0.07);
					width: 100%;
					margin: -9px 0 0 -30px;
					padding: 9px 30px;
				}

				.burger {
					background-image: url(https://img.thingsboard.io/close-icon.svg);
					@media screen and (max-width: 1024px) {
						background-image: url(https://img.thingsboard.io/s-close-icon.svg);
					}
				}

				.head-buttons {
					display: flex;
					flex-wrap: wrap;
					justify-content: center;
				}
			}

			.burger {
				display: block;
			}

			.head-buttons {
				display: none;
			}

			.n-button {
				display: none;
				margin: 40px 0 40px 8px;
			}
		}
	}

	// ============================================
	// PAGE-SPECIFIC HEADER STYLES
	// ============================================

	// Landing pages with transparent header
	#home,
	#thingsboard-paas,
	#thingsboard-pe,
	#thingsboard-edge,
	#mqtt-broker {
		header.header {
			background-color: transparent;
			box-shadow: none;

			.support-ukraine p {
				color: $color-white;
			}

			.logo,
			.burger {
				filter: invert(100%) sepia(68%) saturate(0%) hue-rotate(350deg) brightness(113%)
					contrast(101%);
			}

			.n-button {
				&.price {
					color: $color-white;
					transition-duration: 0s;
					border: none;
					background-color: rgba(255, 255, 255, 0.05);

					&:hover {
						text-decoration: none;
						color: $color-text-primary;
						background-color: $color-white;
					}
				}

				&.try:hover {
					color: $color-primary;
					box-shadow: none;
					background-color: $color-white;
				}
			}
		}
	}

	// Scrolled header state (flip-nav)
	#home,
	#thingsboard-paas,
	#thingsboard-pe,
	#trendz,
	#partners,
	#thingsboard-edge,
	#mqtt-broker,
	#pricing {
		&.flip-nav header.header {
			transition: all $transition-base;
			background-color: $color-white;
			box-shadow: var(--shadow-header);

			.support-ukraine p {
				color: $color-black;
			}

			.logo,
			.burger {
				filter: none;
			}

			.n-button {
				&.price {
					border: 1px solid $color-border;
					color: $color-text-primary;
					background-color: transparent;

					&:hover {
						border: 2px solid $color-text-primary;
					}
				}

				&.try:hover {
					color: $color-white;
					background-color: $color-primary;
					box-shadow: var(--shadow-primary);
				}
			}
		}
	}

	// Mobile burger opened state for landing pages
	#home,
	#docs,
	#common,
	#thingsboard-paas,
	#thingsboard-pe,
	#trendz,
	#thingsboard-edge,
	#mqtt-broker {
		.opened-burger {
			.burger {
				background-image: url(https://img.thingsboard.io/close-icon.svg);

				@include media-down(lg) {
					background-image: url(https://img.thingsboard.io/s-close-icon.svg);
				}
			}

			transition: all $transition-base;
			background-color: $color-white;
			box-shadow: var(--shadow-header);

			.support-ukraine p {
				color: $color-black;
			}

			.logo,
			.burger {
				filter: none;
			}

			.head-buttons {
				display: flex;
			}

			.n-button {
				&.price {
					border: 1px solid $color-border;
					color: $color-text-primary;
					background-color: transparent;

					&:hover {
						border: 2px solid $color-text-primary;
					}
				}

				&.try:hover {
					color: $color-white;
					background-color: $color-primary;
					box-shadow: var(--shadow-primary);
				}
			}
		}
	}

	// Hide search and theme toggle on landing pages
	#home,
	#thingsboard-paas,
	#thingsboard-pe,
	#trendz,
	#partners,
	#thingsboard-edge,
	#mqtt-broker,
	#pricing,
	#docs,
	#common {
		search-button,
		theme-toggle {
			display: none;
		}
	}

	// Show theme toggle on 404 page
	#common {
		theme-toggle {
			display: flex;
		}
	}

	// Show header border only on docs and 404 pages
	html:not([id]),
	#common {
		header.header {
			border-bottom: 1px solid var(--sl-color-hairline-shade);
		}
	}
</style>
