---
import Navigation from '@components/Landing/Navigation.astro';
import GitHubButton from '@components/Landing/GitHubButton.astro';
import NButton from '@components/Landing/NButton.astro';
import SearchButton from '@components/SearchButton.astro';
import ThemeToggle from '@components/ThemeToggle.astro';
import SmartImage from '@components/SmartImage.astro';
import { Icon } from 'astro-icon/components';
import { Products } from '@models/site.models';

interface Props {
	platformQuery?: string;
	gitHubPlatform?: Products;
}

const { platformQuery = '', gitHubPlatform } = Astro.props;
---

<div class="logo-burger">
	<a href="https://u24.gov.ua/" target="_blank" class="support-ukraine">
		<SmartImage
			src="/src/assets/images/support-ukraine-banner.webp"
			alt="Stand with Ukraine flag"
			width="48"
			height="31"
		/>
	</a>
	<a href="/" class="logo" aria-label="Link to homepage"></a>
	<div class="burger-group">
		<div class="icon-buttons">
			<ThemeToggle />
			<SearchButton />
		</div>
		<div class="divider"></div>
		<button onclick="Burger()" class="burger" aria-label="Burger menu">
			<Icon name="tabler:menu-2" class="icon-open" />
			<Icon name="tabler:x" class="icon-close" />
		</button>
	</div>
	<GitHubButton platform={gitHubPlatform} />
</div>

<!-- head-buttons is rendered BEFORE Navigation in the source so it parses
     and paints quickly. <Navigation> ships ~125 KiB of inline submenu
     markup; with that between <nav> and the right-side buttons, slow CPUs
     paint the centred nav before head-buttons exists, which made flexbox
     `space-between` pin the nav to the right edge and shift it left once
     head-buttons finally arrived (≈0.012 CLS). Visual order is restored
     with `order` in the header layout below. -->
<div class="head-buttons">
	<div class="icon-buttons">
		<ThemeToggle />
		<SearchButton />
	</div>
	<div class="divider"></div>
	<NButton id="Menu_Pricing" href="/pricing/" variant="text" class="price gtm_button"
		>Pricing</NButton
	>
	<NButton id="Menu_TryItNow" href="/installations/" variant="filled" class="try gtm_button"
		>Try it now</NButton
	>
</div>

<Navigation platformQuery={platformQuery} />

<script>
	// Burger menu toggle
	function Burger() {
		const header = document.querySelector('header.header');
		const body = document.body;

		if (header?.classList.contains('opened-burger')) {
			header.classList.remove('opened-burger');
			const subMenus = document.querySelectorAll(
				'nav.head-menu > ul > li > div.centered-sub > ul.sub-menu'
			);
			subMenus.forEach((menu) => menu.classList.remove('open-sub'));
			body.style.overflow = '';
		} else {
			header?.classList.add('opened-burger');
			body.style.overflow = 'hidden';
		}
	}

	// Make function available globally
	(window as any).Burger = Burger;

	// Swipe to open/close mobile menus:
	//   Starlight sidebar — swipe RIGHT from left edge to open, swipe LEFT to close
	//   Burger menu      — swipe LEFT from right edge to open, swipe RIGHT to close
	(function () {
		const OPEN_EDGE = 30; // px from screen edge that starts an open gesture
		const MIN_DIST = 60; // minimum horizontal travel to trigger
		const MAX_ANGLE = 35; // max degrees from horizontal (avoids triggering on scrolls)

		let startX = 0;
		let startY = 0;
		let tracking: 'sidebar' | 'burger' | null = null;

		function isSidebarOpen() {
			return document.body.hasAttribute('data-mobile-menu-expanded');
		}

		function isBurgerOpen() {
			return document.querySelector('header.header')?.classList.contains('opened-burger') ?? false;
		}

		function triggerSidebar() {
			(document.querySelector('starlight-menu-button button') as HTMLElement)?.click();
		}

		function triggerBurger() {
			(window as any).Burger?.();
		}

		document.addEventListener(
			'touchstart',
			(e) => {
				const t = e.touches[0];
				startX = t.clientX;
				startY = t.clientY;

				if (isSidebarOpen()) tracking = 'sidebar';
				else if (isBurgerOpen()) tracking = 'burger';
				else if (startX <= OPEN_EDGE) tracking = 'sidebar';
				else if (startX >= window.innerWidth - OPEN_EDGE) tracking = 'burger';
				else tracking = null;
			},
			{ passive: true }
		);

		document.addEventListener(
			'touchend',
			(e) => {
				const which = tracking;
				tracking = null;
				if (!which) return;

				const t = e.changedTouches[0];
				const dx = t.clientX - startX;
				const dy = t.clientY - startY;

				if (Math.abs(dx) < MIN_DIST) return;

				const angle = Math.abs(Math.atan2(Math.abs(dy), Math.abs(dx)) * (180 / Math.PI));
				if (angle > MAX_ANGLE) return;

				if (which === 'sidebar') {
					if (!isSidebarOpen() && dx > 0) triggerSidebar(); // swipe right → open
					else if (isSidebarOpen() && dx < 0) triggerSidebar(); // swipe left → close
				} else {
					if (!isBurgerOpen() && dx < 0) triggerBurger(); // swipe left from right edge → open
					else if (isBurgerOpen() && dx > 0) triggerBurger(); // swipe right → close
				}
			},
			{ passive: true }
		);
	})();
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	header.header {
		position: fixed;
		top: 0;
		left: 0;
		transition-duration: 0.3s;
		width: 100%;
		height: $header-height;
		z-index: 8888;
		border-bottom: none;
		background-color: var(--sl-color-bg-sidebar);
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 20px;


		.logo-burger {
			position: relative;
			display: flex;
			height: 100%;
			align-items: center;
			gap: 0.875rem;
		}

		.head-buttons {
			// head-buttons is placed before <Navigation /> in DOM order to avoid
			// the centred-nav layout shift on slow CPUs. `order: 1` keeps it
			// visually after the nav (which keeps the default order: 0).
			order: 1;
			display: flex;
			flex-direction: row;
			align-items: center;
			gap: 0.875rem;

			.icon-buttons {
				display: flex;
				align-items: center;
				gap: 0;
			}

			.divider {
				width: 1px;
				height: 32px;
				background-color: var(--sl-color-hairline-light);
				flex-shrink: 0;

				@media screen and (min-width: 1281px) and (max-width: 1499px) {
					display: none;
				}
			}

			.n-button {
				width: 90px;
				padding: 0;
				display: flex;
				align-items: center;
				justify-content: center;

				@media screen and (min-width: 1500px) {
					width: 110px;
				}

				&.price {
					color: var(--sl-color-white);
					border: 1px solid transparent;
				}
			}
		}

		.support-ukraine {
			display: flex;
			align-items: center;
			img {
				height: 31px;
				width: auto;
			}

			// Laptop widths — shrink the flag so the nav row doesn't wrap.
			@media screen and (min-width: 1281px) and (max-width: 1599px) {
				img {
					height: 20px;
				}
			}
		}

		.logo {
			position: relative;
			display: block;
			width: 140px;
			height: 60px;
			background-image: url(../../assets/images/landings/thingsboard-logo.svg);
			background-size: contain;
			background-position: center center;
			background-repeat: no-repeat;

			[data-theme='dark'] & {
				filter: invert(100%) sepia(68%) saturate(0%) hue-rotate(350deg) brightness(113%)
					contrast(101%);
			}

			@media screen and (min-width: 1025px) {
				width: 180px;
			}

			// Laptop widths — smaller logo to keep the nav row from wrapping.
			@media screen and (min-width: 1281px) and (max-width: 1599px) {
				width: 120px;
			}
		}
	}

	.burger-group {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		right: 0;
		display: none;
		align-items: center;
		gap: 0.875rem;

		.icon-buttons {
			display: flex;
			align-items: center;
			gap: 0;
		}

		.divider {
			width: 1px;
			height: 32px;
			background-color: var(--sl-color-hairline-light);
			flex-shrink: 0;
		}
	}

	.burger {
		display: none;
		border: none;
		background: none;
		padding: 0;
		cursor: pointer;
		color: inherit;
		width: 32px;
		height: 32px;
		align-items: center;
		justify-content: center;

		svg {
			width: 28px;
			height: 28px;
		}

		.icon-close {
			display: none;
		}

		&:focus {
			outline: none;
		}
	}

	.opened-burger .burger {
		.icon-open {
			display: none;
		}

		.icon-close {
			display: block;
		}
	}

	// Responsive styles
	@media screen and (max-width: 1280px) {
		header.header {
			display: unset;
			height: unset !important;
			transition-property: height;

			.logo-burger {
				height: $header-height;
			}

			&.opened-burger {
				height: 100% !important;
				z-index: 10000;
				display: flex !important;
				flex-direction: column;
				align-items: stretch;

				.logo-burger {
					box-shadow: 0 1px 0 rgba(48, 86, 128, 0.07);
					flex-shrink: 0;
				}

				.head-buttons {
					display: flex;
					flex-shrink: 0;
					gap: 0.875rem;
					padding: 20px 0;

					.icon-buttons {
						display: none;
					}

					.divider {
						display: none;
					}

					.n-button {
						display: flex;
						margin: 0;
						width: 110px;
					}
				}
			}

			.burger-group {
				display: flex;
			}

			.burger {
				display: flex;
			}

			.head-buttons {
				display: none;
			}

			.n-button {
				display: none;
			}
		}
	}

	// ============================================
	// PAGE-SPECIFIC HEADER STYLES
	// ============================================

	// Products pages with always-solid header — persistent box-shadow.
	// `#services` is intentionally excluded so its header uses a hairline
	// border (defined in the use-cases / case-studies group above) instead
	// of a drop shadow — matches the page design.
	#products,
	#development-services,
	#trainings,
	#trendz,
	#mobile-app,
	#mobile-pe,
	#products-form,
	#contact-us,
	#company,
	#mediakit,
	#careers,
	#installations,
	#choose-region,
	#google-iot-core-alternative {
		header.header {
			box-shadow: 0 0 20px rgba(0, 0, 0, 0.1), 0 0 40px rgba(0, 0, 0, 0.1);
		}
	}

	// Landing pages with transparent header
	#home,
	#thingsboard-paas,
	#thingsboard-pe,
	#thingsboard-edge,
	#mqtt-broker {
		header.header {
			background-color: transparent;
			box-shadow: none;

			.support-ukraine p {
				color: $color-white;
			}

			.logo,
			.burger {
				filter: invert(100%) sepia(68%) saturate(0%) hue-rotate(350deg) brightness(113%)
					contrast(101%);
			}

			.burger {
				color: $color-black;
			}

			.divider {
				display: none;
			}

			.n-button {
				width: 110px;

				&.price {
					color: $color-white;
					transition-duration: 0s;
					border: none;
					background-color: rgba(255, 255, 255, 0.05);

					&:hover {
						text-decoration: none;
						color: var(--color-text);
						background-color: var(--color-bg-surface);
					}
				}

				&.try {
					background-color: $color-primary;
					color: $color-white;

					&:hover {
						color: $color-primary;
						box-shadow: none;
						background-color: var(--color-bg-surface);
					}
				}
			}
		}
	}

	// Mobile app pages, trendz, services, and product forms — non-transparent header, but hide divider + style buttons
	#products,
	#services,
	#development-services,
	#trainings,
	#trendz,
	#mobile-app,
	#mobile-pe,
	#products-form,
	#contact-us,
	#company,
	#mediakit,
	#careers,
	#installations,
	#choose-region,
	#google-iot-core-alternative {
		header.header {
			.divider {
				display: none;
			}

			.n-button {
				&.price {
					border: 1px solid var(--color-border);
					color: var(--color-text);
					background-color: transparent;

					&:hover {
						border: 2px solid var(--color-text);
					}
				}

				&.try {
					background-color: $color-primary;
					color: $color-white;

					&:hover {
						color: $color-primary;
						box-shadow: none;
						// Theme-aware: in light mode this resolves to white, in
						// dark mode to the dark surface — avoids a glaring
						// white pill on a dark header bg. On no-dark pages the
						// `:where(...)` re-emit forces the light value, so the
						// hover keeps its original look.
						background-color: var(--color-bg-surface);
					}
				}
			}
		}
	}

	// Pages that opt into the docs-accent primary token for header buttons
	// instead of the legacy brand blue. `:is()` matches both the default
	// page state and the scrolled `.flip-nav` state — the `.flip-nav`
	// variant in the list also bumps specificity so this rule beats the
	// `#pricing.flip-nav header.header .n-button.try` rule above. Other
	// marketing pages keep their brand-blue Try-it-now button.
	html:is(#contact-us, #pricing, #pricing.flip-nav) header.header .n-button {
		&.try {
			background-color: var(--color-primary);
			color: var(--sl-color-text-invert);

			&:hover {
				background-color: var(--color-primary-hover);
				color: var(--sl-color-text-invert);
			}
		}
	}

	// Pricing page: transparent header by default, opaque on hover and scroll
	#pricing header.header {
		background-color: transparent;
		transition: background-color 0.3s ease, box-shadow 0.3s ease;

		&:hover {
			background-color: var(--color-bg-surface);
		}
	}

	#home,
	#thingsboard-paas,
	#thingsboard-pe,
	#thingsboard-edge,
	#mqtt-broker {
		&.flip-nav header.header {
			.logo,
			.burger {
				filter: none;
			}
		}
	}

	// Scrolled header state (flip-nav)
	#home,
	#thingsboard-paas,
	#thingsboard-pe,
	#trendz,
	#partners,
	#thingsboard-edge,
	#mqtt-broker,
	#pricing {
		&.flip-nav header.header {
			transition: all $transition-base;
			background-color: var(--color-bg-surface);
			box-shadow: var(--shadow-header);

			.support-ukraine p {
				color: $color-black;
			}

			.n-button {
				&.price {
					border: 1px solid var(--color-border);
					color: var(--color-text);
					background-color: transparent;

					&:hover {
						border: 2px solid var(--color-text);
					}
				}

				&.try {
					background-color: $color-primary;
					color: $color-white;

					&:hover {
						background-color: $color-primary;
						color: $color-white;
						box-shadow: var(--shadow-primary);
					}
				}
			}
		}
	}

	// Dark-mode opened burger background — covers pages whose <html> id
	// isn't enumerated in the landing-page list below (docs, device library,
	// blog, etc.). Without this they fall back to Starlight's
	// `--sl-color-bg-sidebar` (`hsl(224 14% 16%)` ≈ `#23262f`) and the drawer
	// reads as the same dark shade as page-level cards. Use the brightest
	// project surface token so the drawer is visibly elevated above both the
	// page bg (`#141517`) and card surfaces (`--color-bg-surface` `#1e1f23`).
	html[data-theme='dark'] header.header.opened-burger {
		background-color: var(--color-bg-light);
	}

	// Mobile burger opened state for landing pages
	#home,
	#docs,
	#common,
	#thingsboard-paas,
	#thingsboard-pe,
	#products,
	#services,
	#development-services,
	#trainings,
	#trendz,
	#thingsboard-edge,
	#mqtt-broker,
	#products-form,
	#contact-us,
	#company,
	#mediakit,
	#careers,
	#installations,
	#choose-region,
	#google-iot-core-alternative {
		header.header.opened-burger {
			transition: all $transition-base;
			background-color: var(--color-bg-light);
			box-shadow: var(--shadow-header);

			.support-ukraine p {
				color: $color-black;
			}

			.logo,
			.burger {
				filter: none;
			}

			.head-menu ul {
				a,
				a:not([href]),
				span.main-menu-link {
					color: var(--color-text);
				}

				li:hover a,
				li:hover span.main-menu-link {
					color: $color-primary;
				}
			}

			.n-button {
				&.price {
					border: 1px solid var(--color-border);
					color: var(--color-text);
					background-color: transparent;

					&:hover {
						border: 2px solid var(--color-text);
					}
				}

				&.try {
					background-color: $color-primary;
					color: $color-white;

					&:hover {
						background-color: $color-primary;
						color: $color-white;
						box-shadow: var(--shadow-primary);
					}
				}
			}
		}
	}

	// Hide search and theme toggle on landing pages
	#home,
	#thingsboard-paas,
	#thingsboard-pe,
	#products,
	#services,
	#development-services,
	#trainings,
	#trendz,
	#partners,
	#thingsboard-edge,
	#mqtt-broker,
	#mobile-app,
	#mobile-pe,
	#pricing,
	#docs,
	#common,
	#products-form,
	#company,
	#mediakit,
	#careers,
	#installations,
	#choose-region,
	#google-iot-core-alternative {
		search-button,
		theme-toggle {
			display: none;
		}
	}

	// Hide divider on pages where theme toggle is hidden but not already handled above
	#trendz,
	#partners,
	#pricing,
	#docs {
		header.header {
			.divider {
				display: none;
			}
		}
	}

	// Show theme toggle on 404 and pricing pages
	#common,
	#pricing {
		theme-toggle {
			display: flex;
		}
	}

	// Show header border only on docs and 404 pages
	html:not([id]),
	#common {
		header.header {
			border-bottom: 1px solid var(--sl-color-hairline-shade);
		}
	}

	// Starlight mobile sidebar: 90% width, toggle button left when closed / right edge when open
	@media (max-width: 50rem) {
		#starlight__sidebar {
			width: 90%;
		}

		starlight-menu-button button {
			inset-inline-end: auto;
			inset-inline-start: var(--sl-nav-pad-x);
			top: calc(var(--header-height) + 0.75rem);
		}

		starlight-menu-button[aria-expanded='true'] button {
			inset-inline-start: 90%;
		}

		// On pages with a TOC, the sidebar toggle is embedded inside the TOC bar
		html[data-has-toc] starlight-menu-button button {
			display: none;
		}
		// But when the sidebar is open it covers the TOC bar, so restore the close button
		html[data-has-toc] starlight-menu-button[aria-expanded='true'] button {
			display: flex;
		}
	}

	// Use-case & case-study pages: white background + bottom border
	// (Services follows the same dark-mode pattern.)
	#use-cases,
	#case-studies,
	#hardware-partner-detail,
	#blog,
	#services {
		header.header {
			background-color: var(--color-bg-surface);
			border-bottom: 1px solid var(--color-border);
		}
	}

	// Pages that don't support dark theme — the theme toggle is hidden on
	// these. Listed once and reused below in both the force-light scope
	// (`:where(...)`) and the dark-tinting scope (`:not(:where(...))`) so a
	// new product page only has to be added in one place.
	$no-dark-pages: '#home, #thingsboard-paas, #thingsboard-pe, #products, #development-services, #trainings, #trendz, #partners, #thingsboard-edge, #mqtt-broker, #mobile-app, #mobile-pe, #products-form, #company, #mediakit, #careers, #installations, #choose-region, #google-iot-core-alternative';

	// Force light-theme styling for the header on pages that don't support
	// dark theme. The theme toggle is hidden on these pages, but a user who
	// switched to dark on a supported page would otherwise see the menu in
	// dark mode here. We re-emit the light values for theme-aware tokens so
	// the header (and its dropdown sub-menus) renders light, while leaving
	// the global `[data-theme]` setting alone so it persists when the user
	// navigates back to a dark-supporting page.
	html[data-theme='dark']:where(#{$no-dark-pages}) header.header {
		color-scheme: light;

		// Re-emit light values for project theme tokens used by header + nav
		--color-text: #{$color-text-primary};
		--color-text-secondary: #{$color-text-secondary};
		--color-text-muted: #{$color-text-muted};
		--color-text-light: #{$color-text-light};
		--color-bg: #{$color-bg-white};
		--color-bg-surface: #{$color-bg-white};
		--color-bg-light: #{$color-bg-light};
		--color-bg-muted: #{$color-bg-muted};
		--color-border: #{$color-border};
		--color-border-light: #{$color-border-light};
		--shadow-header: 0 0 20px rgba(0, 0, 0, 0.1), 0 0 40px rgba(0, 0, 0, 0.1);
		// Force the nav-icon tint back to the light brand-blue too, so dropdown
		// icons match the rest of the force-light header on no-dark pages.
		--menu-icon-color: #{$color-primary};

		// Re-emit light values for Starlight tokens used by the header
		--sl-color-white: hsl(224, 10%, 10%);
		--sl-color-gray-1: hsl(224, 14%, 16%);
		--sl-color-gray-2: hsl(224, 10%, 23%);
		--sl-color-gray-3: hsl(224, 7%, 36%);
		--sl-color-gray-5: hsl(224, 6%, 77%);
		--sl-color-gray-6: hsl(224, 20%, 94%);
		--sl-color-gray-7: hsl(224, 19%, 97%);
		--sl-color-bg-sidebar: #{$color-bg-white};
		--sl-color-hairline-light: #{$color-border};
		--sl-color-hairline-shade: #{$color-border-light};
	}

	// Dark-theme tinting for the menu's dropdown content. Only applies on
