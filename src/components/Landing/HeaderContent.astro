---
import Navigation from '@components/Landing/Navigation.astro';
import HeaderScrollWatch from '@components/Landing/HeaderScrollWatch.astro';
import HeaderIcons from '@components/Landing/HeaderIcons.astro';
import GitHubButton from '@components/Landing/GitHubButton.astro';
import NButton from '@components/Landing/NButton.astro';
import SmartImage from '@components/SmartImage.astro';
import { Icon } from 'astro-icon/components';
import { Products } from '@models/site.models';
import type { HeaderConfig } from '@util/header-config';

interface Props {
	platformQuery?: string;
	gitHubPlatform?: Products;
	// Always supplied by the only caller, starlight/Header.astro.
	headerConfig: HeaderConfig;
}

const { platformQuery = '', gitHubPlatform, headerConfig } = Astro.props;
const { variant, cta, showSearch, showThemeToggle } = headerConfig;

// Ship the scroll-flip script only on the variants that go transparent.
const needsScrollState = variant === 'transparent' || variant === 'transparent-hover';
---

<div class="logo-burger" data-header-variant={variant} data-header-cta={cta}>
	<a href="https://u24.gov.ua/" target="_blank" class="support-ukraine">
		<SmartImage
			src="/src/assets/images/support-ukraine-banner.webp"
			alt="Stand with Ukraine flag"
			width="48"
			height="31"
		/>
	</a>
	<a href="/" class="logo" aria-label="Link to homepage"></a>
	<div class="burger-group">
		<HeaderIcons showSearch={showSearch} showThemeToggle={showThemeToggle} />
		<button onclick="Burger()" class="burger" aria-label="Burger menu">
			<Icon name="tabler:menu-2" class="icon-open" />
			<Icon name="tabler:x" class="icon-close" />
		</button>
	</div>
	<GitHubButton platform={gitHubPlatform} />
</div>

<!-- head-buttons is rendered BEFORE Navigation in the source so it parses
     and paints quickly. <Navigation> ships ~125 KiB of inline submenu
     markup; with that between <nav> and the right-side buttons, slow CPUs
     paint the centred nav before head-buttons exists, which made flexbox
     `space-between` pin the nav to the right edge and shift it left once
     head-buttons finally arrived (≈0.012 CLS). Visual order is restored
     with `order` in the header layout below. -->
<div class="head-buttons" data-header-variant={variant} data-header-cta={cta}>
	<HeaderIcons showSearch={showSearch} showThemeToggle={showThemeToggle} />
	<NButton id="Menu_Pricing" href="/pricing/" variant="text" class="price gtm_button">Pricing</NButton>
	<NButton id="Menu_TryItNow" href="/installations/" variant="filled" class="try gtm_button">Try it now</NButton>
</div>

<Navigation platformQuery={platformQuery} />

{needsScrollState && <HeaderScrollWatch />}

<script>
	// Burger menu toggle
	function Burger() {
		const header = document.querySelector('header.header');
		const body = document.body;

		if (header?.classList.contains('opened-burger')) {
			header.classList.remove('opened-burger');
			const subMenus = document.querySelectorAll('nav.head-menu > ul > li > div.centered-sub > ul.sub-menu');
			subMenus.forEach((menu) => menu.classList.remove('open-sub'));
			body.style.overflow = '';
		} else {
			header?.classList.add('opened-burger');
			body.style.overflow = 'hidden';
		}
	}

	// Make function available globally
	(window as any).Burger = Burger;

	// Swipe to open/close mobile menus:
	//   Starlight sidebar — swipe RIGHT from left edge to open, swipe LEFT to close
	//   Burger menu      — swipe LEFT from right edge to open, swipe RIGHT to close
	(function () {
		const OPEN_EDGE = 30; // px from screen edge that starts an open gesture
		const MIN_DIST = 60; // minimum horizontal travel to trigger
		const MAX_ANGLE = 35; // max degrees from horizontal (avoids triggering on scrolls)

		let startX = 0;
		let startY = 0;
		let tracking: 'sidebar' | 'burger' | null = null;

		function isSidebarOpen() {
			return document.body.hasAttribute('data-mobile-menu-expanded');
		}

		function isBurgerOpen() {
			return document.querySelector('header.header')?.classList.contains('opened-burger') ?? false;
		}

		function triggerSidebar() {
			(document.querySelector('starlight-menu-button button') as HTMLElement)?.click();
		}

		function triggerBurger() {
			(window as any).Burger?.();
		}

		document.addEventListener(
			'touchstart',
			(e) => {
				const t = e.touches[0];
				startX = t.clientX;
				startY = t.clientY;

				if (isSidebarOpen()) tracking = 'sidebar';
				else if (isBurgerOpen()) tracking = 'burger';
				else if (startX <= OPEN_EDGE) tracking = 'sidebar';
				else if (startX >= window.innerWidth - OPEN_EDGE) tracking = 'burger';
				else tracking = null;
			},
			{ passive: true }
		);

		document.addEventListener(
			'touchend',
			(e) => {
				const which = tracking;
				tracking = null;
				if (!which) return;

				const t = e.changedTouches[0];
				const dx = t.clientX - startX;
				const dy = t.clientY - startY;

				if (Math.abs(dx) < MIN_DIST) return;

				const angle = Math.abs(Math.atan2(Math.abs(dy), Math.abs(dx)) * (180 / Math.PI));
				if (angle > MAX_ANGLE) return;

				if (which === 'sidebar') {
					if (!isSidebarOpen() && dx > 0)
						triggerSidebar(); // swipe right → open
					else if (isSidebarOpen() && dx < 0) triggerSidebar(); // swipe left → close
				} else {
					if (!isBurgerOpen() && dx < 0)
						triggerBurger(); // swipe left from right edge → open
					else if (isBurgerOpen() && dx > 0) triggerBurger(); // swipe right → close
				}
			},
			{ passive: true }
		);
	})();
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	// Bordered Pricing button — used on marketing and scrolled-transparent headers,
	// where the rest-state white Pricing text would vanish on the solid surface.
	@mixin marketing-price {
		&.price {
			border: 1px solid var(--color-border);
			color: var(--color-text);
			background-color: transparent;

			&:hover {
				border: 2px solid var(--color-text);
			}
		}
	}

	header.header {
		position: fixed;
		// Sits below the promo banner; tracks the live offset so it slides to
		// top:0 as the banner collapses on scroll (--promo-cur → 0).
		top: var(--promo-cur, var(--promo-h, 0px));
		left: 0;
		// No `filter` here: the header itself never gets one (only .logo/.burger
		// do), and a filter would make it the containing block for the fixed promo
		// banner inside it, breaking the banner's viewport anchoring on docs.
		// Transition is scoped to the flip properties only — a blanket `all` would
		// also ease `top`, making the header lag behind the scroll-tied offset.
		transition:
			background-color 0.3s ease,
			box-shadow 0.3s ease;
		width: 100%;
		height: $header-height;
		z-index: 8888;
		// Reset Starlight's default border (variants opt back in); else it shows
		// through the transparent header.
		border-bottom: none;
		// Page-independent; else the header inherits Starlight's body line-height
		// (1.75 docs / 1.5 marketing) and its text renders taller on docs.
		line-height: $line-height-base;
		background-color: var(--sl-color-bg-sidebar);
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 20px;

		.logo-burger {
			position: relative;
			display: flex;
			height: 100%;
			align-items: center;
			gap: 0.875rem;
		}

		.head-buttons {
			// head-buttons is placed before <Navigation /> in DOM order to avoid
			// the centred-nav layout shift on slow CPUs. `order: 1` keeps it
			// visually after the nav (which keeps the default order: 0).
			order: 1;
			display: flex;
			flex-direction: row;
			align-items: center;
			gap: 0.875rem;

			.icon-buttons {
				display: flex;
				align-items: center;
			}

			.divider {
				width: 1px;
				height: 32px;
				background-color: var(--sl-color-hairline-light);
				flex-shrink: 0;

				@media screen and (min-width: 1281px) and (max-width: 1499px) {
					display: none;
				}
			}

			.n-button {
				width: 90px;
				padding: 0;
				display: flex;
				align-items: center;
				justify-content: center;

				@media screen and (min-width: 1500px) {
					width: 110px;
				}

				&.price {
					color: var(--sl-color-white);
					border: 1px solid transparent;
				}

				// Brand-indigo "Try it now" — one fill everywhere; hover darkens via
				// NButton's filled overlay, like the pricing "Get started" buttons.
				&.try {
					background-color: var(--color-brand);
					color: var(--color-brand-contrast);

					&:hover {
						color: var(--color-brand-contrast);
					}
				}
			}
		}

		.support-ukraine {
			display: flex;
			align-items: center;
			img {
				height: 31px;
				width: auto;
			}

			// Laptop widths — shrink the flag so the nav row doesn't wrap.
			@media screen and (min-width: 1281px) and (max-width: 1599px) {
				img {
					height: 20px;
				}
			}
		}

		.logo {
			position: relative;
			display: block;
			width: 140px;
			height: 60px;
			background-image: url(../../assets/images/landings/thingsboard-logo.svg);
			background-size: contain;
			background-position: center center;
			background-repeat: no-repeat;

			[data-theme='dark'] & {
				filter: invert(100%) sepia(68%) saturate(0%) hue-rotate(350deg) brightness(113%) contrast(101%);
			}

			@media screen and (min-width: 1025px) {
				width: 180px;
			}

			// Laptop widths — smaller logo to keep the nav row from wrapping.
			@media screen and (min-width: 1281px) and (max-width: 1599px) {
				width: 120px;
			}

			// Small phones — shrink so the wordmark doesn't collide with the icons.
			@media screen and (max-width: 480px) {
				width: 110px;
			}
		}
	}

	.burger-group {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		right: 0;
		display: none;
		align-items: center;
		gap: 0.875rem;

		.icon-buttons {
			display: flex;
			align-items: center;
		}

		.divider {
			width: 1px;
			height: 32px;
			background-color: var(--sl-color-hairline-light);
			flex-shrink: 0;
		}
	}

	.burger {
		display: none;
		border: none;
		background: none;
		padding: 0;
		cursor: pointer;
		color: inherit;
		width: 32px;
		height: 32px;
		align-items: center;
		justify-content: center;

		svg {
			width: 28px;
			height: 28px;
		}

		.icon-close {
			display: none;
		}

		&:focus {
			outline: none;
		}
	}

	.opened-burger .burger {
		.icon-open {
			display: none;
		}

		.icon-close {
			display: block;
		}
	}

	// Responsive styles
	@media screen and (max-width: 1280px) {
		header.header {
			display: block; // stays position:fixed (base rule); block keeps it a proper box — `unset` would resolve to inline and break it
			height: unset !important;
			transition-property: height; // `top` follows --promo-cur; don't transition it here

			.logo-burger {
				height: $header-height;
			}

			&.opened-burger {
				// Anchor the drawer where the bar already sits (top stays at --promo-cur,
				// below the banner) and fill to the viewport bottom, so opening at the top
				// shifts nothing. The banner stays visible above the drawer.
				bottom: 0;
				z-index: 10000;
				display: flex !important;
				flex-direction: column;
				align-items: stretch;

				.logo-burger {
					box-shadow: 0 1px 0 rgba(48, 86, 128, 0.07);
					flex-shrink: 0;
				}

				.head-buttons {
					display: flex;
					flex-shrink: 0;
					gap: 0.875rem;
					padding: 20px 0;

					.icon-buttons {
						display: none;
					}

					.divider {
						display: none;
					}

					.n-button {
						display: flex;
						margin: 0;
						width: 110px;
					}
				}

				// Slide + fade the drawer content in on open. The bar (.logo-burger)
				// stays put and top/height are pinned, so the menu glides down into
				// place with no banner-height jump. Enter only; closing is instant.
				.head-menu,
				.head-buttons {
					opacity: 1;
					transform: translateY(0);
					transition:
						opacity 0.22s ease,
						transform 0.22s ease,
						display 0.22s allow-discrete;

					@starting-style {
						opacity: 0;
						transform: translateY(-8px);
					}
				}

				@media (prefers-reduced-motion: reduce) {
					.head-menu,
					.head-buttons {
						transition: none;
						transform: none;
					}
				}
			}

			.burger-group {
				display: flex;
			}

			.burger {
				display: flex;
			}

			.head-buttons {
				display: none;
			}

			.n-button {
				display: none;
			}
		}
	}

	// ============================================
	// PAGE-SPECIFIC HEADER STYLES
	// ============================================

	// Solid marketing header with a drop shadow (no border). `services` is
	// solid-border instead, per the design.
	header.header:has([data-header-variant='solid-shadow']) {
		// Same surface bg as solid-border so all marketing headers match.
		background-color: var(--color-bg-surface);
		box-shadow:
			0 0 20px rgba(0, 0, 0, 0.1),
			0 0 40px rgba(0, 0, 0, 0.1);
	}

	// Transparent header over a hero (transparent variant).
	header.header:has([data-header-variant='transparent']) {
		background-color: transparent;
		box-shadow: none;

		.logo,
		.burger {
			filter: invert(100%) sepia(68%) saturate(0%) hue-rotate(350deg) brightness(113%) contrast(101%);
		}

		.burger {
			color: $color-black;
		}

		.n-button {
			width: 110px;

			// Translucent Pricing button unique to the transparent (over-hero) header.
			&.price {
				color: $color-white;
				transition-duration: 0s;
				border: none;
				background-color: rgba(255, 255, 255, 0.05);

				&:hover {
					text-decoration: none;
					color: var(--color-text);
					background-color: var(--color-bg-surface);
				}
			}
		}
	}

	// Marketing CTA buttons (`cta='marketing'` — solid-shadow pages + services).
	header.header:has([data-header-cta='marketing']) .n-button {
		@include marketing-price;
	}

	// Transparent header overlays the hero → no header clearance, BUT still
	// reserve the promo-banner band so the hero starts below the banner (the
	// transparent nav then floats over the hero as before). Without this the
	// fixed banner would overlay the top of the hero / crowd the hero title.
	.page:has(header.header [data-header-variant='transparent']) .main-frame,
	.page:has(header.header [data-header-variant='transparent-hover']) .main-frame {
		padding-top: var(--promo-h, 0px);
	}

	// Transparent, opaque on hover + scroll (transparent-hover — pricing, affiliate).
	header.header:has([data-header-variant='transparent-hover']) {
		background-color: transparent;
		// Quick opaque flip synced with the banner.
		transition:
			background-color 0.15s ease,
			box-shadow 0.15s ease;

		&:hover {
			background-color: var(--color-bg-surface);
		}
	}

	// Scrolled transparent header: un-invert the logo/burger.
	header.header[data-header-scrolled]:has([data-header-variant='transparent']) {
		.logo,
		.burger {
			filter: none;
		}
	}

	// Scrolled state: solid surface for the transparent family.
	header.header[data-header-scrolled]:has([data-header-variant='transparent']),
	header.header[data-header-scrolled]:has([data-header-variant='transparent-hover']) {
		// Quick flip synced with the banner.
		transition: all 0.12s ease;
		background-color: var(--color-bg-surface);
		box-shadow: var(--shadow-header);
	}

	// Scrolled onto the solid surface: give the Pricing button a readable border
	// (its rest-state white text would vanish on the light bg). Transparent also
	// elevates the Try button.
	header.header[data-header-scrolled]:has([data-header-variant='transparent']) .n-button {
		@include marketing-price;
	}

	header.header[data-header-scrolled]:has([data-header-variant='transparent-hover']) .n-button {
		@include marketing-price;
	}

	// Mobile burger drawer — identical on every page. `--color-bg-light` is the
	// brightest surface per theme, so it sits above the page bg in dark too.
	header.header.opened-burger {
		// Don't reposition on open — the bar stays put (the mobile block fills the
		// drawer downward from there), so there is no jump at the banner position.
		// Only bg + shadow ease.
		transition:
			background-color $transition-base,
			box-shadow $transition-base;
		background-color: var(--color-bg-light);
		box-shadow: var(--shadow-header);

		.logo,
		.burger {
			filter: none;
		}

		.head-menu ul {
			a,
			a:not([href]),
			span.main-menu-link {
				color: var(--color-text);
			}

			li:hover a,
			li:hover span.main-menu-link {
				color: $color-primary;
			}
		}

		.n-button {
			@include marketing-price;
		}
	}

	// Docs / 404 default header — hairline bottom border.
	header.header:has([data-header-variant='docs']),
	header.header:has([data-header-variant='common']) {
		border-bottom: 1px solid var(--sl-color-hairline-shade);
	}

	// Starlight mobile sidebar: 90% width, toggle button left when closed / right edge when open
	@media (max-width: 50rem) {
		#starlight__sidebar {
			width: 90%;
		}

		starlight-menu-button button {
			inset-inline-end: auto;
			inset-inline-start: var(--sl-nav-pad-x);
			// Just below the header bottom (= --promo-cur + header height); tracks the banner up as it hides.
			top: calc(var(--promo-cur, var(--promo-h, 0px)) + var(--header-height) + 0.75rem);
		}

		starlight-menu-button[aria-expanded='true'] button {
			inset-inline-start: 90%;
		}

		// On pages with a TOC, the sidebar toggle is embedded inside the TOC bar
		html[data-has-toc] starlight-menu-button button {
			display: none;
		}
		// But when the sidebar is open it covers the TOC bar, so restore the close button
		html[data-has-toc] starlight-menu-button[aria-expanded='true'] button {
			display: flex;
		}
	}

	// Use-cases / case-studies / partners / blog / services etc.:
	// surface background + bottom border (solid-border variant).
	header.header:has([data-header-variant='solid-border']) {
		background-color: var(--color-bg-surface);
		border-bottom: 1px solid var(--color-border);
	}

	// Dark-mode dropdown tinting. `!important` beats Navigation's per-brand rules
	// (light keeps its brand colours; only dark flattens to primary). Force-light
	// pages are locked to light, so they never match — no exclusion needed.
	html[data-theme='dark'] header.header {
		.head-menu .sub-menu .group-name {
			color: var(--color-primary) !important;
		}

		.head-menu .sub-menu a:hover .sub-text span.item-heading {
			color: var(--color-primary) !important;
		}

		// Top-level main menu link hover
		.head-menu ul li:hover a,
		.head-menu ul li:hover span.main-menu-link,
		.head-menu ul li a:not([href]):hover,
		.head-menu ul li span.main-menu-link:hover {
			color: var(--color-primary) !important;
		}

		// Active-tab indicator (the underline + arrow under the hovered top item)
		.head-menu .indicator .head-arrow {
			border-bottom-color: var(--color-primary) !important;
		}
		.head-menu .indicator .line {
			background-color: var(--color-primary) !important;
		}
	}
</style>
