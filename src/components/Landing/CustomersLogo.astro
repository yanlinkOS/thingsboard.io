---
import { defaultCustomersLogos, type CustomerLogo } from '../../data/customersLogo';

interface Props {
  /**
   * Product tag for styling: 'ce' | 'pe' | 'paas' | 'edge' | etc.
   */
  productTag?: string;
  /**
   * Custom logos array. If not provided, uses default logos.
   */
  logos?: CustomerLogo[];
}

const { productTag = 'ce', logos = defaultCustomersLogos } = Astro.props;
---

<section id="tb-customers" class:list={['customers-logo', productTag]}>
  <div class="customers-logo__content">
    {logos.map((logo) => (
      <a href={logo.href} class="customers-logo__item">
        <object data={logo.src} aria-label={logo.ariaLabel}></object>
      </a>
    ))}
  </div>
</section>

<style lang="scss">
  @use '../../styles/variables' as *;

  .customers-logo {
    max-width: 1800px;
    margin: 0 auto;
    padding: $spacing-12 0;
    text-align: justify;
    text-align-last: justify;
    display: none;

    @include media-up(lg) {
      display: block;
    }

    img {
      height: 60px;
      margin-bottom: $spacing-5;
    }

    &__content {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: space-around;
      gap: $spacing-12;
      width: 100%;
      align-items: center;
      padding: 0 60px;
    }

    &__item {
      display: block;

      object {
        pointer-events: none;
      }
    }

    // CE (Community Edition) - blue/gray filter
    &.ce .customers-logo__item object {
      filter: invert(86%) sepia(5%) saturate(530%) hue-rotate(171deg) brightness(237%) contrast(86%);
    }

    // PE (Professional Edition) - green filter
    &.pe .customers-logo__item object {
      filter: invert(79%) sepia(25%) saturate(246%) hue-rotate(93deg) brightness(185%) contrast(82%);
    }

    // PaaS (Cloud) - blue filter
    &.paas .customers-logo__item object {
      filter: invert(87%) sepia(3%) saturate(664%) hue-rotate(176deg) brightness(237%) contrast(82%);
    }

    // Edge - teal filter
    &.edge .customers-logo__item object {
      filter: invert(79%) sepia(25%) saturate(246%) hue-rotate(130deg) brightness(185%) contrast(82%);
    }
  }
</style>
