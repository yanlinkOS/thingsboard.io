---
export interface AdvantageCard {
	/** Path to SVG icon (e.g. /src/assets/images/advantages/security.svg) */
	icon: string;
	title: string;
	description: string;
	href: string;
	linkText?: string;
}

interface Props {
	cards: AdvantageCard[];
	loop?: boolean;
	class?: string;
}

const { cards, loop = true, class: className = '' } = Astro.props;
const carouselId = `adv-${Math.random().toString(36).slice(2, 9)}`;

// Load SVG icons as raw HTML so they render inline
const svgModules = import.meta.glob<string>('/src/assets/**/*.svg', { eager: true, query: '?raw', import: 'default' });
---

<div class:list={['adv-carousel', className]} data-carousel-id={carouselId} data-loop={loop.toString()}>
	<div class="adv-viewport" id={carouselId}>
		<div class="adv-container">
			{
				cards.map((card, index) => (
					<div class:list={['adv-slide', { 'is-active': index === 0 }]}>
						<div class="adv-card">
							<div class="adv-card__icon" set:html={svgModules[card.icon] || ''} />
							<h3 class="adv-card__title">{card.title}</h3>
							<p class="adv-card__desc">{card.description}</p>
							<a href={card.href} class="adv-card__link">
								{card.linkText || 'Learn more'}
							</a>
						</div>
					</div>
				))
			}
		</div>
	</div>

	<div class="adv-controls">
		<div class="adv-arrows">
			<button class="adv-arrow adv-arrow--prev" type="button" aria-label="Previous">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
					<path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</button>
			<button class="adv-arrow adv-arrow--next" type="button" aria-label="Next">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
					<path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</button>
		</div>
		<div class="adv-dots">
			{cards.map((_, i) => <button class:list={['adv-dot', { active: i === 0 }]} data-index={i} aria-label={`Go to slide ${i + 1}`} />)}
		</div>
	</div>
</div>

<style lang="scss">
	@use '../../styles/variables' as *;

	.adv-carousel {
		position: relative;
	}

	.adv-viewport {
		overflow: hidden;
	}

	.adv-container {
		display: flex;
		user-select: none;
		-webkit-touch-callout: none;
		-webkit-tap-highlight-color: transparent;
	}

	/* Each slide — sized to show ~3 cards with peek on desktop */
	.adv-slide {
		flex: 0 0 30%;
		min-width: 0;
		padding: 0 $spacing-3;
		transition: opacity 0.3s ease;
		opacity: 0.4;

		&.is-active {
			opacity: 1;
		}

		@include media-down(lg) {
			flex: 0 0 44%;
		}

		@include media-down(md) {
			flex: 0 0 80%;
		}
	}

	/* Card */
	.adv-card {
		background: $color-white;
		border: 1px solid $color-border;
		border-radius: $radius-lg;
		padding: $spacing-6;
		height: 100%;
		display: flex;
		flex-direction: column;
		transition:
			border-color 0.3s ease,
			box-shadow 0.3s ease;

		.is-active & {
			border-color: $color-primary;
			box-shadow: var(--shadow-lg);
		}
	}

	.adv-card__icon {
		width: 54px;
		height: 54px;
		margin-bottom: $spacing-5;
		flex-shrink: 0;

		:global(svg) {
			width: 100%;
			height: 100%;
		}
	}

	.adv-card__title {
		@include card-title-sm;
		color: $color-text-primary;
		margin: 0 0 $spacing-3;
	}

	.adv-card__desc {
		@include text-s;
		margin: 0 0 $spacing-5;
		flex: 1;
	}

	.adv-card__link {
		@include action-link;
		color: $color-primary;
		text-decoration: none;
		margin-top: auto;

		&:hover {
			text-decoration: underline;
		}
	}

	/* Controls row: arrows left, dots right */
	.adv-controls {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: $spacing-8;
		padding: 0 $spacing-3;
	}

	.adv-arrows {
		display: flex;
		gap: $spacing-2;
	}

	.adv-arrow {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		border: 1.5px solid $color-border-light;
		background: transparent;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		color: $color-text-secondary;
		transition:
			border-color 0.2s ease,
			color 0.2s ease;
		padding: 0;

		&:hover {
			border-color: $color-primary;
			color: $color-primary;
		}

		&:disabled {
			opacity: 0.3;
			cursor: not-allowed;
		}
	}

	.adv-dots {
		display: flex;
		gap: $spacing-2;
		align-items: center;
	}

	.adv-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		border: 1.5px solid $color-border-light;
		background: transparent;
		cursor: pointer;
		padding: 0;
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease;

		&:hover {
			border-color: $color-text-secondary;
		}

		&.active {
			background: $color-text-primary;
			border-color: $color-text-primary;
			transform: scale(1.25);
		}
	}

	@include media-down(md) {
		.adv-arrows {
			display: none;
		}

		.adv-controls {
			justify-content: center;
		}
	}
</style>

<script>
	import EmblaCarousel from 'embla-carousel';
	import type { EmblaCarouselType } from 'embla-carousel';

	function initAdvCarousels() {
		const wrappers = document.querySelectorAll<HTMLElement>('.adv-carousel');

		wrappers.forEach((wrapper) => {
			const carouselId = wrapper.dataset.carouselId;
			if (!carouselId) return;

			const viewport = document.getElementById(carouselId);
			if (!viewport) return;

			const loop = wrapper.dataset.loop === 'true';

			const embla = EmblaCarousel(viewport, {
				loop,
				align: 'center',
				containScroll: false,
			});

			const slides = wrapper.querySelectorAll<HTMLElement>('.adv-slide');
			const dots = wrapper.querySelectorAll<HTMLButtonElement>('.adv-dot');
			const prevBtn = wrapper.querySelector<HTMLButtonElement>('.adv-arrow--prev');
			const nextBtn = wrapper.querySelector<HTMLButtonElement>('.adv-arrow--next');

			function updateActive(api: EmblaCarouselType) {
				const selected = api.selectedScrollSnap();
				slides.forEach((slide, i) => slide.classList.toggle('is-active', i === selected));
				dots.forEach((dot, i) => dot.classList.toggle('active', i === selected));

				if (!loop && prevBtn && nextBtn) {
					prevBtn.disabled = !api.canScrollPrev();
					nextBtn.disabled = !api.canScrollNext();
				}
			}

			embla.on('init', updateActive);
			embla.on('select', updateActive);

			if (prevBtn) prevBtn.addEventListener('click', () => embla.scrollPrev());
			if (nextBtn) nextBtn.addEventListener('click', () => embla.scrollNext());

			dots.forEach((dot) => {
				dot.addEventListener('click', () => {
					const index = parseInt(dot.dataset.index || '0', 10);
					embla.scrollTo(index);
				});
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initAdvCarousels);
	document.addEventListener('astro:page-load', initAdvCarousels);
</script>
