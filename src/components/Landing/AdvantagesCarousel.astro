---
import { Icon } from 'astro-icon/components';

export interface AdvantageCard {
	/** Iconify icon name (e.g. `tabler:shield`). */
	icon: string;
	title: string;
	description: string;
	/** Optional color theme for the icon box. If omitted, cards rotate through the palette. */
	color?: 'blue' | 'red' | 'purple' | 'green' | 'yellow' | 'orange';
	/** @deprecated kept for backwards-compat; the Figma card design no longer renders a link inside the card. */
	href?: string;
	/** @deprecated kept for backwards-compat; the Figma card design no longer renders a link inside the card. */
	linkText?: string;
}

interface Props {
	cards: AdvantageCard[];
	/** Section title — when set, rendered in the carousel's header row alongside the arrow buttons (matches Figma layout). */
	title?: string;
	loop?: boolean;
	class?: string;
}

const { cards, title, loop = true, class: className = '' } = Astro.props;
const carouselId = `adv-${Math.random().toString(36).slice(2, 9)}`;

const COLOR_CYCLE = ['blue', 'red', 'purple', 'green', 'orange'] as const;
---

<div class:list={['adv-carousel', className]} data-carousel-id={carouselId} data-loop={loop.toString()}>
	<header class:list={['adv-header', { 'adv-header--no-title': !title }]}>
		{title && <h2 class="adv-title">{title}</h2>}
			<div class="adv-arrows">
				<button class="adv-arrow adv-arrow--prev" type="button" aria-label="Previous">
					<Icon name="tabler:chevron-left" width={20} height={20} />
				</button>
				<button class="adv-arrow adv-arrow--next" type="button" aria-label="Next">
					<Icon name="tabler:chevron-right" width={20} height={20} />
				</button>
			</div>
	</header>
	<div class="adv-viewport" id={carouselId}>
		<div class="adv-container">
			{
				cards.map((card, index) => (
					<div class="adv-slide">
						<article class="adv-card">
							<header class="adv-card__head">
								<span
									class:list={[
										'adv-card__icon-box',
										`is-${card.color || COLOR_CYCLE[index % COLOR_CYCLE.length]}`,
									]}
								>
									<Icon name={card.icon} class="adv-card__icon" />
								</span>
								<h3 class="adv-card__title">{card.title}</h3>
							</header>
							<p class="adv-card__desc">{card.description}</p>
						</article>
					</div>
				))
			}
		</div>
	</div>

</div>

<style lang="scss">
	@use '../../styles/variables' as *;

	.adv-carousel {
		position: relative;
	}

	/* Header row — title on the left, arrows on the right (Figma layout) */
	.adv-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: $spacing-6;
		margin-bottom: $spacing-6;

		&--no-title {
			justify-content: flex-end;
		}

		@include media-down(md) {
			flex-direction: row;
			align-items: center;
		}
	}

	.adv-title {
		@include section-title;
		color: var(--color-text);
		margin: 0;
	}

	.adv-viewport {
		overflow: hidden;
		// Tiny padding so the cards' inset-border + box-shadow aren't
		// clipped at the viewport edges (left of first card / right of
		// last card / bottom of all cards).
		padding: 2px;
		margin: -2px;
	}

	.adv-container {
		display: flex;
		// Don't use `gap` — Embla's loop mode translates wrapped slides
		// individually, and a flex gap doesn't travel with a slide
		// across the loop boundary (so the gap visually disappears
		// between the last and first card on wrap). Instead we put the
		// 24px gutter as `margin-right` on each slide; that margin moves
		// with the slide regardless of where Embla repositions it.
		backface-visibility: hidden;
		-webkit-backface-visibility: hidden;
		user-select: none;
		-webkit-touch-callout: none;
		-webkit-tap-highlight-color: transparent;
	}

	/* Each slide — sized to show ~3 cards on desktop, with the 24px
	   gutter included as right-margin so it survives loop wrap. */
	.adv-slide {
		flex: 0 0 calc(33.333% - 16px);
		min-width: 0;
		margin-right: $spacing-6; // 24px gutter; persists across loop boundary

		@include media-down(lg) {
			flex: 0 0 calc(50% - 12px);
		}

		@include media-down(md) {
			flex: 0 0 calc(100% - 8px);
		}
	}

	/* Card — Figma "advantage" tile: icon-in-box + title row, then description.
	   Uses inset box-shadow as the border instead of `border: 1px` so the
	   stroke isn't clipped by the viewport's overflow:hidden at the
	   carousel's left/right/bottom edges. */
	.adv-card {
		background: var(--color-bg-surface);
		box-shadow: inset 0 0 0 1px var(--color-border);
		border-radius: $radius-md; // 12px
		padding: $spacing-10; // 40px
		height: 100%;
		display: flex;
		flex-direction: column;
		gap: $spacing-4; // 16px
		transition:
			box-shadow 0.2s ease,
			transform 0.2s ease;

		@include media-down(md) {
			padding: $spacing-6;
		}
	}

	.adv-card__head {
		display: flex;
		align-items: center;
		gap: $spacing-4; // 16px
	}

	.adv-card__icon-box {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		padding: $spacing-2; // 8px
		border-radius: $radius-sm; // 4px
		border: 1px solid;
		flex-shrink: 0;
		box-sizing: border-box;

		// Color variants — tinted background + darker border using Starlight's
		// `*-low` (light tint) and `*-high` (dark tint) tokens. Icon glyph uses
		// `--color-text` so it stays as primary text color (black in light mode,
		// white in dark mode) and reads cleanly on the tinted backplate.
		color: var(--color-text);

		&.is-blue {
			background: var(--sl-color-blue-low);
			border-color: var(--sl-color-blue-high);
		}
		&.is-red {
			background: var(--sl-color-red-low);
			border-color: var(--sl-color-red-high);
		}
		&.is-purple {
			background: var(--sl-color-purple-low);
			border-color: var(--sl-color-purple-high);
		}
		&.is-green {
			background: var(--sl-color-green-low);
			border-color: var(--sl-color-green-high);
		}
		&.is-orange {
			background: var(--sl-color-orange-low);
			border-color: var(--sl-color-orange-high);
		}
		&.is-yellow {
			background: var(--sl-color-orange-low);
			border-color: var(--sl-color-orange-high);
		}
	}

	.adv-card__icon {
		display: block;
		width: 22px;
		height: 22px;
		color: inherit;
	}

	.adv-card__title {
		@include card-title-sm;
		color: var(--color-text);
		margin: 0;
		line-height: 1.2;
	}

	.adv-card__desc {
		@include text-s;
		color: var(--color-text);
		margin: 0;
		flex: 1;
		line-height: 1.72;
	}

	.adv-arrows {
		display: flex;
		gap: $spacing-2;
		flex-shrink: 0;
	}

	.adv-arrow {
		width: 44px;
		height: 44px;
		border-radius: 99px;
		border: 1px solid var(--color-border);
		background: transparent;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-text);
		transition: all 0.2s ease;
		padding: 0;

		&:hover:not(:disabled) {
			border-color: var(--sl-color-accent);
			color: var(--sl-color-accent);
		}

		&:disabled {
			opacity: 0.4;
			cursor: not-allowed;

			&:hover {
				border-color: var(--color-border);
				color: var(--color-text);
			}
		}
	}
</style>

<script>
	import type { EmblaCarouselType } from 'embla-carousel';

	type EmblaCarouselFn = typeof import('embla-carousel').default;
	type AutoplayFn = typeof import('embla-carousel-autoplay').default;
	let emblaPromise: Promise<[EmblaCarouselFn, AutoplayFn]> | null = null;
	const loadEmbla = () =>
		(emblaPromise ??= Promise.all([
			import('embla-carousel').then((m) => m.default),
			import('embla-carousel-autoplay').then((m) => m.default),
		]));

	async function initAdvCarousels() {
		const wrappers = document.querySelectorAll<HTMLElement>('.adv-carousel');
		if (!wrappers.length) return;

		const [EmblaCarousel, Autoplay] = await loadEmbla();

		wrappers.forEach((wrapper) => {
			const carouselId = wrapper.dataset.carouselId;
			if (!carouselId) return;

			const viewport = document.getElementById(carouselId);
			if (!viewport) return;

			const loop = wrapper.dataset.loop === 'true';

			const embla = EmblaCarousel(
				viewport,
				{
					loop,
					align: 'start',
					containScroll: 'trimSnaps',
				},
				[
					Autoplay({
						delay: 5000,
						stopOnInteraction: false,
						stopOnMouseEnter: true,
					}),
				]
			);

			const prevBtn = wrapper.querySelector<HTMLButtonElement>('.adv-arrow--prev');
			const nextBtn = wrapper.querySelector<HTMLButtonElement>('.adv-arrow--next');

			function updateButtons(api: EmblaCarouselType) {
				if (loop || !prevBtn || !nextBtn) return;
				prevBtn.disabled = !api.canScrollPrev();
				nextBtn.disabled = !api.canScrollNext();
			}

			embla.on('init', updateButtons);
			embla.on('select', updateButtons);
			embla.on('reInit', updateButtons);

			if (prevBtn) prevBtn.addEventListener('click', () => embla.scrollPrev());
			if (nextBtn) nextBtn.addEventListener('click', () => embla.scrollNext());
		});
	}

	document.addEventListener('DOMContentLoaded', initAdvCarousels);
	document.addEventListener('astro:page-load', initAdvCarousels);
</script>
