---
import { Icon } from 'astro-icon/components';
import Carousel from '@components/Carousel/Carousel.astro';
import CarouselSlide from '@components/Carousel/CarouselSlide.astro';

export interface AdvantageCard {
	/** Iconify icon name (e.g. `tabler:shield`). */
	icon: string;
	title: string;
	description: string;
	/** Optional color theme for the icon box. If omitted, cards rotate through the palette. */
	color?: 'blue' | 'red' | 'purple' | 'green' | 'yellow' | 'orange';
	/** Optional "Learn more" deep link rendered at the bottom of the card. */
	href?: string;
	/** Label for the deep link — defaults to "Learn more" if omitted but href is set. */
	linkText?: string;
}

interface Props {
	cards: AdvantageCard[];
	/** Section title — when set, rendered in the carousel's header row alongside the arrow buttons (matches the design layout). */
	title?: string;
	loop?: boolean;
	class?: string;
}

const { cards, title, loop = true, class: className = '' } = Astro.props;

const COLOR_CYCLE = ['blue', 'red', 'purple', 'green', 'orange'] as const;
---

<div class:list={['adv-carousel', className]}>
	<Carousel
		arrowPlacement="header"
		title={title}
		showDots={false}
		autoplay={true}
		loop={loop}
		layout="multi"
		bleed={true}
		ariaLabel={title || 'Advantages'}
	>
		{
			cards.map((card, index) => (
				<CarouselSlide index={index} total={cards.length}>
					<article class="adv-card">
						<header class="adv-card__head">
							<span
								class:list={[
									'adv-card__icon-box',
									`is-${card.color || COLOR_CYCLE[index % COLOR_CYCLE.length]}`,
								]}
							>
								<Icon name={card.icon} class="adv-card__icon" />
							</span>
							<h3 class="adv-card__title">{card.title}</h3>
						</header>
						<p class="adv-card__desc">{card.description}</p>
						{card.href && (
							<a class="adv-card__link" href={card.href}>
								{card.linkText || 'Learn more'}
							</a>
						)}
					</article>
				</CarouselSlide>
			))
		}
	</Carousel>
</div>

<style lang="scss">
	@use '../../styles/variables' as *;

	.adv-carousel {
		// Section spacing comes from the host (e.g. AdvantagesSection)
		--carousel-margin: 0;
	}

	/* Card — the design "advantage" tile: icon-in-box + title row, then description.
	   Uses inset box-shadow as the border instead of `border: 1px` so the
	   stroke isn't clipped by the viewport's overflow:hidden at the
	   carousel's left/right/bottom edges. */
	.adv-card {
		background: var(--color-bg-surface);
		box-shadow: inset 0 0 0 1px var(--color-border);
		border-radius: $radius-md; // 12px
		padding: $spacing-10; // 40px
		height: 100%;
		display: flex;
		flex-direction: column;
		gap: $spacing-4; // 16px
		transition:
			box-shadow 0.2s ease,
			transform 0.2s ease;

		@include media-down(md) {
			padding: $spacing-6;
		}
	}

	.adv-card__head {
		display: flex;
		align-items: center;
		gap: $spacing-4; // 16px
	}

	.adv-card__icon-box {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		padding: $spacing-2; // 8px
		border-radius: $radius-sm; // 4px
		border: 1px solid;
		flex-shrink: 0;
		box-sizing: border-box;

		// Color variants — tinted background + darker border using Starlight's
		// `*-low` (light tint) and `*-high` (dark tint) tokens. Icon glyph uses
		// `--color-text` so it stays as primary text color (black in light mode,
		// white in dark mode) and reads cleanly on the tinted backplate.
		color: var(--color-text);

		&.is-blue {
			background: var(--sl-color-blue-low);
			border-color: var(--sl-color-blue-high);
		}
		&.is-red {
			background: var(--sl-color-red-low);
			border-color: var(--sl-color-red-high);
		}
		&.is-purple {
			background: var(--sl-color-purple-low);
			border-color: var(--sl-color-purple-high);
		}
		&.is-green {
			background: var(--sl-color-green-low);
			border-color: var(--sl-color-green-high);
		}
		&.is-orange {
			background: var(--sl-color-orange-low);
			border-color: var(--sl-color-orange-high);
		}
		&.is-yellow {
			background: var(--sl-color-orange-low);
			border-color: var(--sl-color-orange-high);
		}
	}

	.adv-card__icon {
		display: block;
		width: 22px;
		height: 22px;
		color: inherit;
	}

	.adv-card__title {
		@include card-title-sm;
		color: var(--color-text);
		margin: 0;
		line-height: 1.2;
	}

	.adv-card__desc {
		@include text-s;
		color: var(--color-text);
		margin: 0;
		flex: 1;
		line-height: 1.72;
	}

	.adv-card__link {
		@include text-s;
		display: inline-block;
		align-self: flex-start;
		color: var(--color-primary);
		text-decoration: underline;
		text-underline-offset: 2px;
		line-height: 1.72;
		transition: color 0.2s ease;

		&:hover {
			color: var(--color-primary-hover, var(--color-primary));
			text-decoration-thickness: 2px;
		}
	}
</style>
