---
import SmartImage from '@components/SmartImage.astro';
interface Props {
  /**
   * Product/feature name
   */
  name: string;
  /**
   * Short description
   */
  description: string;
  /**
   * Icon URL
   */
  icon: string;
  /**
   * Link URL
   */
  href: string;
  /**
   * Link text
   */
  linkText?: string;
  class?: string;
}

const {
  name,
  description,
  icon,
  href,
  linkText = 'Read more',
  class: className = ''
} = Astro.props;
---

<div class:list={['ecosystem-card', className]}>
  <h3 class="ecosystem-card__title">{name}</h3>
  <p class="ecosystem-card__description">{description}</p>
  <SmartImage src={icon} alt={name} class="ecosystem-card__icon" loading="lazy" width="100" height="100" />
  <a href={href} class="ecosystem-card__link">
    {linkText}
    <span class="visually-hidden">about ThingsBoard {name}</span>
  </a>
</div>

<style lang="scss">
  @use '../../styles/variables' as *;

  .ecosystem-card {
    color: $color-text-primary;
    background-color: $color-white;
    box-shadow: var(--shadow-lg);
    border-radius: $radius-md;
    padding: $spacing-10;
    text-align: center;
    min-width: 291px;

    @include media-down(md) {
      min-width: unset;
    }

    &__title {
      font-size: $font-size-3xl;
      font-weight: $font-weight-semibold;
      line-height: 1.5;
      margin-bottom: $spacing-4;
    }

    &__description {
      font-size: $font-size-base;
      color: $color-text-primary;
      margin: 0;
    }

    &__icon {
      display: block;
      margin: 50px auto;
      width: 32%;
      max-width: 100px;
      height: auto;
    }

    &__link {
      color: $color-primary;
      font-weight: $font-weight-medium;
      font-size: $font-size-lg;
      text-decoration: none;

      &:hover {
        text-decoration: underline;
      }
    }
  }

  // Visually hidden helper for accessibility
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
