---
const cards = [
	{
		icon: '/src/assets/images/landings/edge/opensource-icon.svg',
		title: '100% Open-source',
		content:
			'Licensed under Apache 2.0. Use freely in commercial products, host as SaaS/PaaS, or modify to fit your needs.',
	},
	{
		icon: '/src/assets/images/landings/edge/customizable-icon.svg',
		title: 'Customizable',
		content:
			'Flexible rule engine and customizable dashboards let you tailor Edge to your specific workflow and business requirements.',
	},
	{
		icon: '/src/assets/images/landings/edge/robust-icon.svg',
		title: 'Robust and Reliable',
		content:
			'Handles up to 1,000 devices per Edge instance while ensuring zero data loss through persistent local storage and automatic sync.',
	},
	{
		icon: '/src/assets/images/landings/edge/scalable-icon.svg',
		title: 'Scalable',
		content:
			'Deploy thousands of Edge instances across distributed sites for horizontal scalability and distributed data processing.',
	},
	{
		icon: '/src/assets/images/landings/edge/visualization-icon.svg',
		title: 'Real-Time',
		content:
			'Instant access to critical data enables immediate decision-making. Local alarms trigger on-site without server connectivity.',
	},
	{
		icon: '/src/assets/images/landings/edge/offline-edge.svg',
		title: 'Offline Capable',
		content:
			'Operates independently when disconnected. Stores data locally and auto-syncs when connection restores—zero data loss.',
	},
	{
		icon: '/src/assets/images/landings/edge/low-latency.svg',
		title: 'Responsive',
		content:
			'Local processing delivers sub-second response times, critical for industrial automation and real-time control systems.',
	},
	{
		icon: '/src/assets/images/landings/edge/engine-icon.svg',
		title: 'Logic-Driven',
		content:
			'Drag-and-drop rule chain designer lets you define custom logic for data processing, external integrations, and alarm notifications.',
	},
	{
		icon: '/src/assets/images/landings/edge/friendly-icon.svg',
		title: 'User-Friendly',
		content:
			'Intuitive interface and multi-protocol support (MQTT, CoAP, HTTP) enable fast deployment across diverse device ecosystems.',
	},
];
---

<section id="bottom-features">
	<div class="main-div">
		<div class="background">
			<div class="main3"></div>
			<div class="small8"></div>
		</div>
		<div class="main-content">
			<h2>Why Edge Works</h2>
			<div class="features-grid">
				{
					cards.map((card) => (
						<div class="feature-card">
							<div class="feature-header">
								<div class="feature-icon">
									<img src={card.icon} alt={card.title} width="58" height="58" loading="lazy" />
								</div>
								<h3 class="feature-title">{card.title}</h3>
								<svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none">
									<path
										d="M6 9L12 15L18 9"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							</div>
							<div class="feature-content">
								<p>{card.content}</p>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>

<script>
	function toggleFeature(header: HTMLElement) {
		const card = header.closest('.feature-card') as HTMLElement;
		const allCards = Array.from(document.querySelectorAll<HTMLElement>('#bottom-features .feature-card'));

		if (window.innerWidth <= 1000) {
			allCards.forEach((c) => {
				if (c !== card) {
					c.classList.remove('open', 'active');
				}
			});
			card.classList.toggle('open');
			card.classList.toggle('active');
		} else {
			const cardIndex = allCards.indexOf(card);
			const rowIndex = Math.floor(cardIndex / 3);
			const rowCards = allCards.slice(rowIndex * 3, rowIndex * 3 + 3);
			const isRowOpen = rowCards.some((c) => c.classList.contains('open'));

			rowCards.forEach((c) => {
				if (isRowOpen) {
					c.classList.remove('open');
				} else {
					c.classList.add('open');
				}
			});

			allCards.forEach((c) => c.classList.remove('active'));
			if (!isRowOpen) {
				card.classList.add('active');
			}
		}
	}

	document.querySelectorAll<HTMLElement>('#bottom-features .feature-header').forEach((header) => {
		header.addEventListener('click', () => toggleFeature(header));
	});
</script>

<style lang="scss">
	#bottom-features {
		padding: 20px;
		position: relative;
		z-index: 2;
	}

	.main-div {
		position: relative;
		z-index: 1;
	}

	.background {
		z-index: -1;
		position: absolute;
		top: 0;
		left: 50%;

		div {
			position: absolute;
			transform: skewY(-6deg);
			width: 436px;
			height: 90px;
		}

		.main3 {
			top: -108px;
			width: 2560px;
			height: 848px;
			left: -1280px;
			background-color: #effaf9;
		}

		.small8 {
			top: -249px;
			left: 756px;
			border: 4px solid #185b55;
		}
	}

	.main-content {
		max-width: 1400px;
		margin: 0 auto;
		position: relative;
	}

	h2 {
		text-align: center;
		margin-bottom: 48px;
		font-size: 42px;
		font-weight: 600;
		color: #212529;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		grid-auto-rows: min-content;
		align-items: start;
		gap: 24px;
	}

	.feature-card {
		background: white;
		border: 2px solid #e8ebf0;
		border-radius: 12px;
		overflow: hidden;
		transition: all 0.3s ease;
		cursor: pointer;

		&:hover {
			border-color: #009688;
			box-shadow: 0 4px 12px rgba(0, 150, 136, 0.15);
		}

		&.active {
			border-color: #009688;

			.chevron {
				transform: rotate(180deg);
			}
		}

		&.open {
			.chevron {
				transform: rotate(180deg);
			}

			.feature-content {
				max-height: 500px;
				padding: 0 24px 24px;
				opacity: 1;
			}
		}
	}

	.feature-header {
		display: flex;
		align-items: center;
		gap: 16px;
		padding: 24px;
		transition: background 0.2s ease;
	}

	.feature-icon {
		flex: 0 0 68px;
		width: 68px;
		height: 68px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: #f0f8f7;
		border-radius: 8px;

		img {
			width: 58px;
			height: 58px;
		}
	}

	h3.feature-title {
		flex: 1;
		font-size: 18px;
		font-weight: 600;
		color: #212529;
		margin: 0 !important;
	}

	.chevron {
		flex: 0 0 20px;
		color: #757c76;
		transition: transform 0.3s ease;
	}

	.feature-content {
		max-height: 0;
		overflow: hidden;
		opacity: 0;
		padding: 0 24px;
		transition:
			max-height 0.4s ease,
			opacity 0.4s ease,
			padding-bottom 0.4s ease;

		p {
			font-size: 16px;
			line-height: 24px;
			color: #3d3d3d;
			margin: 0;
		}
	}

	@media screen and (max-width: 1000px) {
		.features-grid {
			grid-template-columns: 1fr;
		}
	}

	@media screen and (max-width: 750px) {
		#bottom-features {
			padding: 40px 16px;
		}

		h2 {
			font-size: 28px;
			margin-bottom: 36px;
		}

		.feature-header {
			padding: 18px 16px;
		}

		.feature-icon {
			flex: 0 0 52px;
			width: 52px;
			height: 52px;

			img {
				width: 42px;
				height: 42px;
			}
		}

		.feature-title {
			font-size: 15px;
		}
	}
</style>