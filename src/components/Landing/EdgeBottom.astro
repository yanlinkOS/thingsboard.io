<section id="bottom">
	<div class="contact-us-banner">
		<div class="contact-us-banner-content">
			<h2>Ready to bring intelligence to the network edge?</h2>
			<div class="contact-us-banner-buttons">
				<a
					id="Products_Edge_TryEdgeNow"
					href="/docs/edge/getting-started/"
					class="bottom-button gtm_button"
				>
					Get started now
				</a>
			</div>
		</div>
		<img
			src="/src/assets/images/landings/edge/offline-edge.svg"
			alt="Edge icon"
			width="280"
			height="280"
			loading="lazy"
		/>
	</div>
</section>

<style lang="scss">
	#bottom {
		padding: 80px 20px;
		position: relative;
		z-index: 2;
		background: transparent;
	}

	.contact-us-banner {
		max-width: 1400px;
		margin: 0 auto;
		background: white;
		border: 2px solid #009688;
		border-radius: 24px;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 10px 60px;
		gap: 60px;
		overflow: hidden;
		opacity: 0;
		transform: translateY(50px);
		animation: slideUp 0.8s ease-out forwards;
	}

	.contact-us-banner-content {
		flex: 1;

		h2 {
			font-size: 32px;
			font-weight: 500;
			color: #212529;
			margin: 0 0 32px;
			line-height: 1.2;
		}
	}

	.contact-us-banner-buttons {
		display: flex;
		gap: 16px;
	}

	.bottom-button {
		display: inline-block;
		padding: 16px 40px;
		background: #009688;
		color: white;
		font-size: 20px;
		font-weight: 500;
		text-decoration: none;
		border-radius: 8px;
		transition: all 0.3s ease;

		&:hover {
			background: #1eb7a9;
			transform: translateY(-2px);
			box-shadow: 0 4px 12px rgba(0, 150, 136, 0.4);
			text-decoration: none;
			color: white;
		}
	}

	img {
		flex: 0 0 280px;
		width: 280px;
		height: auto;
		opacity: 0.9;
		-webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 100%);
		mask-image: linear-gradient(to bottom, black 0%, transparent 100%);
	}

	@keyframes slideUp {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media screen and (max-width: 750px) {
		#bottom {
			padding: 60px 16px;
		}

		.contact-us-banner {
			padding: 24px 20px;
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: 24px;
		}

		.contact-us-banner-content {
			flex: none;
			order: 2;

			h2 {
				font-size: 24px;
				margin-bottom: 20px;
			}
		}

		.contact-us-banner-buttons {
			order: 3;
			flex-direction: column;
			align-items: center;
			width: 100%;
			gap: 12px;
		}

		.bottom-button {
			font-size: 18px;
			padding: 14px 32px;
			width: 100%;
			max-width: 280px;
			text-align: center;
		}

		img {
			flex: 0 0 auto;
			width: 100px;
			order: 1;
		}
	}
</style>