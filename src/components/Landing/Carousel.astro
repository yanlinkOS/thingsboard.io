---
import { Icon } from 'astro-icon/components';
import SmartImage from '@components/SmartImage.astro';
export interface CarouselItem {
	src: string;
	alt: string;
	title: string;
	description?: string;
	linkLabel?: string;
	href: string;
	width: string | number;
	height: string | number;
}

interface Props {
	items: CarouselItem[];
	variant?: 'default' | 'usecase' | 'simple';
	showDots?: boolean;
	showArrows?: boolean;
	autoplay?: boolean;
	autoplayInterval?: number;
	loop?: boolean;
	class?: string;
}

const {
	items,
	variant = 'default',
	showDots = true,
	showArrows = true,
	autoplay = false,
	autoplayInterval = 5000,
	loop = true,
	class: className = '',
} = Astro.props;

const carouselId = `carousel-${Math.random().toString(36).substring(2, 9)}`;
---

<div
	class:list={['carousel-wrapper', `carousel-${variant}`, className]}
	data-carousel-id={carouselId}
	data-autoplay={autoplay.toString()}
	data-autoplay-interval={autoplayInterval.toString()}
	data-loop={loop.toString()}
>
	<div class="carousel-viewport" id={carouselId}>
		<div class="carousel-container">
			{
				items.map((item) => (
					<div class="carousel-slide">
						{variant === 'usecase' ? (
							<div class="carousel-item-flex-row">
								<div class="carousel-text">
									<h3>{item.title}</h3>
									{item.description && <p>{item.description}</p>}
									<a href={item.href} class="carousel-link">
										{item.linkLabel || 'Learn more'}
										<span class="arrow-container">
											<Icon name="fa-solid:chevron-right" class="arrow first" />
											<Icon name="fa-solid:chevron-right" class="arrow second" />
											<Icon name="fa-solid:chevron-right" class="arrow third" />
										</span>
									</a>
								</div>
								<div class="carousel-image">
									<a href={item.href}>
										<SmartImage
											src={item.src}
											alt={item.alt}
											width={item.width}
											height={item.height}
											loading="lazy"
										/>
										<div class="overlay">
											<div class="eye">
												<Icon name="fa-regular:eye" class="icon" />
												See more about {item.title}
											</div>
										</div>
									</a>
								</div>
							</div>
						) : variant === 'simple' ? (
							<div class="carousel-item-simple">
								<a href={item.href}>
									<SmartImage
										src={item.src}
										alt={item.alt}
										width={item.width}
										height={item.height}
										loading="lazy"
									/>
								</a>
								{item.title && <p class="carousel-caption">{item.title}</p>}
							</div>
						) : (
							<div class="carousel-item-default">
								<a href={item.href}>
									<SmartImage
										src={item.src}
										alt={item.alt}
										width={item.width}
										height={item.height}
										loading="lazy"
									/>
								</a>
								{item.title && <p class="carousel-caption">{item.title}</p>}
							</div>
						)}
					</div>
				))
			}
		</div>
	</div>

	{
		showArrows && (
			<div class="carousel-buttons">
				<button class="carousel-button carousel-button-prev" aria-label="Previous slide">
					<svg
						width="17"
						height="50"
						viewBox="0 0 17 50"
						fill="none"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path
							d="M15 2L3 25L15 48"
							stroke="currentColor"
							stroke-width="3"
							stroke-linecap="round"
						/>
					</svg>
				</button>
				<button class="carousel-button carousel-button-next" aria-label="Next slide">
					<svg
						width="17"
						height="50"
						viewBox="0 0 17 50"
						fill="none"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path
							d="M2 2L14 25L2 48"
							stroke="currentColor"
							stroke-width="3"
							stroke-linecap="round"
						/>
					</svg>
				</button>
			</div>
		)
	}

	{
		showDots && (
			<div class="carousel-dots">
				{items.map((_, index) => (
					<button
						class:list={['carousel-dot', { active: index === 0 }]}
						data-index={index}
						aria-label={`Go to slide ${index + 1}`}
					/>
				))}
			</div>
		)
	}
</div>

<style lang="scss">
	@use '../../styles/variables' as *;

	.carousel-wrapper {
		position: relative;
		margin: $spacing-16 0 $spacing-6;
		--carousel-gap: #{$spacing-5};
	}

	.carousel-viewport {
		overflow: hidden;
	}

	.carousel-container {
		display: flex;
		gap: var(--carousel-gap);
		user-select: none;
		-webkit-touch-callout: none;
		-khtml-user-select: none;
		-webkit-tap-highlight-color: transparent;
	}

	.carousel-slide {
		flex: 0 0 100%;
		min-width: 0;
	}

	// Default variant
	.carousel-item-default,
	.carousel-item-simple {
		text-align: center;
	}

	.carousel-item-default img,
	.carousel-item-simple img {
		max-width: 100%;
		height: auto;
		border-radius: var(--imageBorderRadius, $radius-xl);
	}

	.carousel-caption {
		@include action-link;
		margin-top: $spacing-4;
		color: $color-text-primary;
	}

	// Usecase variant
	.carousel-usecase .carousel-item-flex-row {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		gap: $spacing-10;
		padding: 0 50px;
	}

	.carousel-usecase .carousel-text {
		width: 30%;
		display: flex;
		flex-direction: column;
		gap: $spacing-4;
	}

	.carousel-usecase .carousel-text h3 {
		@include section-title;
		color: $color-text-primary;
		margin: 0;
		text-align: left;
	}

	.carousel-usecase .carousel-text p {
		@include text-m;
		margin: 0;
	}

	.carousel-usecase .carousel-link {
		@include action-link;
		display: inline-block;
		position: relative;
		color: $color-primary;
		text-decoration: none;
		transition: color $transition-base;
	}

	.carousel-usecase .carousel-link:hover {
		text-decoration: none;
	}

	.carousel-usecase .arrow-container {
		position: relative;
		display: inline-block;
		margin-left: 12px;
		width: 50px;
		height: 20px;
		vertical-align: middle;
	}

	.carousel-usecase .arrow {
		position: absolute;
		top: 4px;
		left: 0;
		font-size: 13px;
		transition: transform $transition-base;
		color: $color-primary;
	}

	.carousel-usecase .arrow.first {
		opacity: 0.2;
	}

	.carousel-usecase .arrow.second {
		opacity: 0.5;
	}

	.carousel-usecase .arrow.third {
		opacity: 1;
	}

	.carousel-usecase .carousel-link:hover .arrow.first {
		transform: translateX(10px);
	}

	.carousel-usecase .carousel-link:hover .arrow.second {
		transform: translateX(20px);
	}

	.carousel-usecase .carousel-link:hover .arrow.third {
		transform: translateX(30px);
	}

	.carousel-usecase .carousel-image {
		width: 66%;
		position: relative;
	}

	.carousel-usecase .carousel-image img {
		width: 100%;
		height: auto;
		border-radius: $radius-md;
		box-shadow: var(--shadow-lg);
		display: block;
	}

	.carousel-usecase .carousel-image a {
		display: block;
		position: relative;
	}

	.carousel-usecase .carousel-image .overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(0deg, rgba($color-dark-alt, 0.8) 0%, rgba($color-dark-alt, 0.6) 100%);
		border-radius: $radius-md;
		opacity: 0;
		transition: opacity $transition-base;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		padding-bottom: 10%;
	}

	.carousel-usecase .carousel-image a:hover .overlay {
		opacity: 1;
	}

	.carousel-usecase .carousel-image .eye {
		color: $color-white;
		font-size: $font-size-base;
		display: flex;
		align-items: center;
		gap: 10px;
		transform: translateY(20px);
		transition: transform $transition-base;
	}

	.carousel-usecase .carousel-image a:hover .eye {
		transform: translateY(0);
	}

	.carousel-usecase .carousel-image .eye .icon {
		font-size: $font-size-2xl;
	}

	// Navigation buttons
	.carousel-buttons {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 0;
		right: 0;
		display: flex;
		justify-content: space-between;
		align-items: center;
		pointer-events: none;
	}

	.carousel-button {
		width: 17px;
		height: 50px;
		background: transparent;
		border: none;
		cursor: pointer;
		pointer-events: auto;
		color: $color-border-light;
		transition: color $transition-base;
		padding: 0;
		flex-shrink: 0;
	}

	.carousel-button:hover {
		color: $color-primary;
	}

	.carousel-button:disabled {
		opacity: 0.3;
		cursor: not-allowed;
	}

	.carousel-button svg {
		display: block;
		width: 17px;
		height: 50px;
	}

	// Dots
	.carousel-dots {
		display: flex;
		justify-content: center;
		gap: $spacing-6;
		margin-top: $spacing-8;
	}

	.carousel-dot {
		width: 72px;
		height: 4px;
		border: none;
		border-radius: $radius-sm;
		background: $color-border-light;
		cursor: pointer;
		padding: 0;
		transition: background $transition-base;
	}

	.carousel-dot:hover,
	.carousel-dot.active {
		background: $color-primary;
	}

	// Responsive
	@include media-down(lg) {
		.carousel-usecase .carousel-item-flex-row {
			flex-direction: column;
			gap: $spacing-8;
			padding: 0;
		}

		.carousel-usecase .carousel-text,
		.carousel-usecase .carousel-image {
			width: 100%;
		}

		.carousel-usecase .carousel-text h3 {
			text-align: center;
		}

		.carousel-usecase .carousel-text {
			text-align: center;
			align-items: center;
		}

		.carousel-buttons {
			display: none;
		}
	}

	@include media-down(md) {
		.carousel-dot {
			width: 10px;
			height: 10px;
			border-radius: 50%;
		}

		.carousel-dots {
			gap: $spacing-3;
		}

		.carousel-usecase .arrow-container {
			display: none;
		}
	}
</style>

<script>
	import EmblaCarousel from 'embla-carousel';
	import type { EmblaCarouselType } from 'embla-carousel';

	function initCarousels() {
		const carouselWrappers = document.querySelectorAll<HTMLElement>('.carousel-wrapper');

		carouselWrappers.forEach((wrapper) => {
			const carouselId = wrapper.dataset.carouselId;
			if (!carouselId) return;

			const viewport = document.getElementById(carouselId);
			if (!viewport) return;

			const loop = wrapper.dataset.loop === 'true';
			const autoplay = wrapper.dataset.autoplay === 'true';
			const autoplayInterval = parseInt(wrapper.dataset.autoplayInterval || '5000', 10);

			const embla = EmblaCarousel(viewport, {
				loop,
				align: 'start',
				containScroll: 'trimSnaps',
			});

			// Navigation buttons
			const prevButton = wrapper.querySelector('.carousel-button-prev');
			const nextButton = wrapper.querySelector('.carousel-button-next');

			if (prevButton) {
				prevButton.addEventListener('click', () => embla.scrollPrev());
			}

			if (nextButton) {
				nextButton.addEventListener('click', () => embla.scrollNext());
			}

			// Dots
			const dots = wrapper.querySelectorAll<HTMLButtonElement>('.carousel-dot');

			const updateDots = (emblaApi: EmblaCarouselType) => {
				const selectedIndex = emblaApi.selectedScrollSnap();
				dots.forEach((dot, index) => {
					dot.classList.toggle('active', index === selectedIndex);
				});
			};

			dots.forEach((dot) => {
				dot.addEventListener('click', () => {
					const index = parseInt(dot.dataset.index || '0', 10);
					embla.scrollTo(index);
				});
			});

			embla.on('select', updateDots);
			embla.on('init', updateDots);

			// Update button states
			const updateButtons = (emblaApi: EmblaCarouselType) => {
				if (prevButton) {
					(prevButton as HTMLButtonElement).disabled = !emblaApi.canScrollPrev();
				}
				if (nextButton) {
					(nextButton as HTMLButtonElement).disabled = !emblaApi.canScrollNext();
				}
			};

			if (!loop) {
				embla.on('select', updateButtons);
				embla.on('init', updateButtons);
			}

			// Autoplay
			if (autoplay) {
				let autoplayTimer: ReturnType<typeof setInterval>;

				const startAutoplay = () => {
					autoplayTimer = setInterval(() => {
						if (embla.canScrollNext()) {
							embla.scrollNext();
						} else {
							embla.scrollTo(0);
						}
					}, autoplayInterval);
				};

				const stopAutoplay = () => {
					clearInterval(autoplayTimer);
				};

				embla.on('init', startAutoplay);
				embla.on('pointerDown', stopAutoplay);
				embla.on('pointerUp', startAutoplay);

				wrapper.addEventListener('mouseenter', stopAutoplay);
				wrapper.addEventListener('mouseleave', startAutoplay);
			}
		});
	}

	// Initialize on page load
	document.addEventListener('DOMContentLoaded', initCarousels);
	document.addEventListener('astro:page-load', initCarousels);
</script>
