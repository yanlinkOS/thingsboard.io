---
import SocialNetworks from './SocialNetworks.astro';
import NButton from './NButton.astro';
import SmartImage from '@components/SmartImage.astro';

const currentYear = new Date().getFullYear();
---

<footer>
	<div class="light-text main-div">
		<div class="newsletterSubsContainer">
			<div class="newsletter-left">
				<NButton id="Footer_SignUpForNews" class="subscribe gtm_button">
					Sign up for ThingsBoard news
				</NButton>
				<div
					id="mlb2-7341216"
					class="ml-subscribe-form ml-subscribe-form-7341216"
					style="display: none; max-width: 100%;"
				>
				<div class="ml-vertical-align-center">
					<div class="subscribe-form ml-block-success" style="display: none;">
						<div class="form-section">
							<p>Thank you for your interest in ThingsBoard!<br />Have a great day!</p>
						</div>
					</div>
					<form
						class="ml-block-form gtm_form"
						id="Footer_SignUpForNewsForm"
						action="https://static.mailerlite.com/webforms/submit/r9r9x7"
						data-id="708170"
						data-code="r9r9x7"
						method="POST"
						target="_blank"
					>
						<div class="subscribe-form horizontal">
							<div class="form-section horizontal">
								<div class="form-group ml-field-email ml-validate-required ml-validate-email">
									<input
										type="email"
										name="fields[email]"
										class="form-control"
										placeholder="Email address*"
										value=""
										autocomplete="email"
										x-autocompletetype="email"
										spellcheck="false"
										autocapitalize="off"
										autocorrect="off"
									/>
								</div>
							</div>
							<input type="hidden" name="ml-submit" value="1" />
							<div class="form-section horizontal ml-button-position">
								<NButton
									id="Footer_SignUpForNews_Subscribe"
									type="submit"
									class="primary subscribe gtm_button"
								>
									Subscribe
								</NButton>
								<NButton disabled class="loading" style="display: none;" />
							</div>
							<p>By subscribing you agree to receive newsletters from ThingsBoard, Inc.</p>
						</div>
					</form>
				</div>
			</div>
			</div>
			<div class="footer-top-img-section">
				<SmartImage
					src="/src/assets/images/landings/footer/crozdesk-2.webp"
					alt="ThingsBoard achievement - Crozdesk Quality Choice Top-Ranked Solution 2025"
					height="80"
					width="80"
				/>
				<SmartImage
					src="/src/assets/images/landings/footer/crozdesk-1.webp"
					alt="ThingsBoard achievement - Crozdesk Trusted Vendor High Market Presence 2025"
					height="80"
					width="80"
				/>
				<SmartImage
					src="/src/assets/images/landings/footer/supplier-retail.webp"
					alt="ThingsBoard achievement - Top Supplier in Retail 2024"
					height="80"
					width="55"
				/>
			</div>
		</div>

		<hr />

		<div class="deeper">
			<a href="/" class="footer-logo" aria-label="Link to homepage"></a>
			<nav>
				<a href="/docs/getting-started/">Get Started</a>
				<a href="/docs/">Documentation</a>
				<a href="/use-cases/">Use cases</a>
				<a href="/blog/">Blog</a>
				<a href="/services/">Services</a>
				<a href="/contact-us/">Contact us</a>
			</nav>
		</div>

		<div class="deepmost">
			<div class="copyright">&copy; {currentYear} The ThingsBoard Authors</div>
			<SocialNetworks />
		</div>
	</div>
</footer>

<script>
	const btn = document.getElementById('Footer_SignUpForNews');
	btn?.addEventListener('click', (event) => {
		event.stopPropagation();

		const script = document.createElement('script');
		script.setAttribute('type', 'text/javascript');
		script.setAttribute(
			'src',
			'https://static.mailerlite.com/js/w/webforms.min.js?v28bf44f740701752bfc6767bc7e171d4'
		);
		document.getElementsByTagName('head')[0].appendChild(script);

		btn.style.display = 'none';

		const form = document.getElementById('mlb2-7341216');
		if (form) {
			form.style.display = 'block';
		}
	});
</script>

<style lang="scss">
	@use '../../styles/variables' as *;

	footer {
		width: 100%;
		background-color: #0f161d;
		padding-left: 1.875rem;
		padding-right: 1.875rem;

		@media screen and (min-width: 1500px) {
			padding-left: 6.25rem;
			padding-right: 6.25rem;
		}

		.main-div {
			padding: 5.75rem 0 4.875rem;
			max-width: 1200px;
			margin: 0 auto;

			@media screen and (min-width: 1500px) {
				max-width: 1400px !important;
			}

			@media screen and (max-width: 768px) {
				padding: 3.75rem 0 2.5rem;
			}

			hr {
				border: none;
				border-top: 2px solid white;
				opacity: 0.1;
				margin: 3.375rem 0 1rem;
			}

			.deeper {
				margin-bottom: 3.75rem;
				display: flex;
				justify-content: space-between;

				@media screen and (max-width: 1024px) {
					justify-content: flex-end;

					.footer-logo {
						display: none;
					}
				}

				@media screen and (max-width: 768px) {
					justify-content: center;

					nav {
						display: block !important;

						a {
							width: 100%;
							text-align: center !important;
							margin: 1.125rem 0 0 !important;
						}
					}
				}

				.footer-logo {
					background-image: url(../../assets/images/landings/thingsboard-logo.svg);
					filter: invert(100%) sepia(68%) saturate(0%) hue-rotate(350deg) brightness(113%)
						contrast(101%);
					width: 180px;
					height: 60px;
					background-size: contain;
					background-position: center center;
					background-repeat: no-repeat;
				}

				nav {
					display: flex;
					align-items: center;
					justify-content: right;

					a {
						text-align: right;
						display: inline-block;
						margin: 0 0.875rem;
						font-size: 1rem;
						color: white;
						transition: 300ms;

						&:hover {
							color: white;
							text-decoration: underline;
						}

						&:last-child {
							margin-right: 0;
						}

						&:first-child {
							margin-left: 0;
						}
					}
				}
			}
		}

		.newsletterSubsContainer {
			min-height: 6.625rem;
			width: 100%;
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 1.875rem;

			@media screen and (max-width: 900px) {
				flex-wrap: wrap;
				justify-content: center;

				.primary.subscribe {
					height: unset;
					width: 100%;
				}
			}

			@media screen and (max-width: 768px) {
				flex-direction: column;
				align-items: center;
			}

			.newsletter-left {
				flex: 1;
				min-width: 0;
			}

			.footer-top-img-section {
				display: flex;
				gap: 2.5rem;
				flex-shrink: 0;
			}

			.loading {
				margin: 0;
				height: 2.9375rem;
				padding: 0 1.125rem;
			}

			.subscribe {
				margin: 0;
				height: fit-content;
				padding: 0.8125rem 1.25rem;
				background-color: $color-primary;
				color: $color-white;
				transition-duration: unset;

				&:hover {
					transition-duration: unset;
					box-shadow: unset;
					background-color: $color-primary-hover;
					color: $color-white;
				}

				&:focus {
					outline: none;
				}
			}

			#mlb2-7341216 {
				.subscribe-form {
					background: none !important;
					border: none !important;
					padding: 0;
					max-width: 520px;
					width: 100% !important;

					@media (max-width: 900px) {
						max-width: 100%;
					}

					&.horizontal {
						padding-bottom: 0;
						display: flex;
						flex-wrap: wrap;
					}
				}

				.form-section {
					p {
						line-height: 150%;
						padding: 0 !important;
						margin: 0 0 0.625rem 0;
					}

					&.mb10 {
						margin-bottom: 0.625rem;
						float: left;
					}

					&.horizontal {
						float: left;
						margin-bottom: 0.625rem;
						width: 70%;

						@media (max-width: 768px) {
							float: none;
							width: 100%;
							padding: 0;
						}

						&.ml-button-position {
							width: 30%;
							padding: 0;

							@media (max-width: 768px) {
								float: none;
								width: 100%;
								padding: 0;
								margin-bottom: 1.25rem;

								.button {
									width: 100%;
								}
							}
						}

						.form-group {
							float: left;
							width: 100%;
							padding-right: 0.375rem;
							box-sizing: border-box;
							margin: 0;

							@media (max-width: 768px) {
								padding: 0;
							}
						}
					}
				}
			}

			#mlb2-7341216.ml-subscribe-form {
				.form-group {
					&.ml-error {
						.form-control {
							border-color: red !important;
						}
					}

					.form-control {
						background-color: white !important;
						height: 2.9375rem;
						width: 100%;
						font-size: 1.125rem;
						line-height: 1rem;
						font-weight: 400;
						color: #212529;
						border: 1px solid #fff;
						transition: 0.3s;
						padding: 0.625rem 0.9375rem;
						border-radius: 0.25rem;

						&::-webkit-input-placeholder {
							color: #999 !important;
						}

						&::-moz-placeholder {
							color: #999 !important;
						}

						&:-ms-input-placeholder {
							color: #999 !important;
						}

						&:-moz-placeholder {
							color: #999 !important;
						}
					}
				}
			}

			p {
				color: #6d7175;
				font-weight: 400;
			}
		}

		.deepmost {
			display: flex;
			justify-content: space-between;

			@media screen and (max-width: 768px) {
				display: block;

				.copyright {
					text-align: center;
				}

				:global(.social) {
					justify-content: center;
					width: 100%;
					padding-top: 3rem;
				}
			}

			.copyright {
				color: #8e8292;
				font-size: 0.875rem;
			}
		}
	}
</style>
