---
import { Icon } from 'astro-icon/components';

interface Column {
	/** Column header label. Use \n for line breaks. */
	label: string;
	/** Accent color used for text and (if highlight=false) border. */
	accentColor: string;
	/** Decorative bg column border color. Defaults to accentColor. */
	borderColor?: string;
	/** Solid fill header + box-shadow on bg column. */
	highlight?: boolean;
}

interface Row {
	label: string;
	/** When provided, wraps label in a link with a help icon. */
	href?: string;
	/** One value per column: true = check, false = ✗, string = text. */
	values: (boolean | string)[];
}

interface Props {
	title?: string;
	columns: Column[];
	rows: Row[];
	/** Remove the default 60px top margin (use when matrix is directly below another section). */
	noTopMargin?: boolean;
}

const { title, columns, rows, noTopMargin = false } = Astro.props;

const numCols = columns.length;
const colWidthPct = (100 - 40) / numCols;
// when noTopMargin and no title: backgrounds start at 0 (table also has margin-top:0)
const colTopOffset = title ? 127 : (noTopMargin ? 0 : 64);
const colHeight = 152 + rows.length * 64 + 44;

function colBgImage(col: Column): string {
	const border = col.borderColor ?? col.accentColor;
	if (col.highlight) {
		return `linear-gradient(to bottom, ${col.accentColor} 108px, transparent 108px)`;
	}
	return `linear-gradient(to bottom, transparent 108px, ${border} 108px, ${border} 110px, transparent 110px)`;
}
---

<section id="matrix" class:list={[{ 'no-top-margin': noTopMargin }]}>
	<div class="matrix-inner">
		<div class="backg-matrix" aria-hidden="true">
			{
				columns.map((col, i) => {
					const border = col.borderColor ?? col.accentColor;
					const rightPct = (numCols - 1 - i) * colWidthPct;
					const shadow = col.highlight
						? '0 50px 50px -20px rgba(0,0,0,0.15),0 0 30px 0 rgba(0,0,0,0.1)'
						: 'none';
					return (
						<div
							style={`width:${colWidthPct}%;position:absolute;z-index:0;top:${colTopOffset}px;right:${rightPct}%;padding:0 7px;`}
						>
							<div
								style={`height:${colHeight}px;border-radius:12px;border:2px solid ${border};background-image:${colBgImage(col)};background-origin:border-box;box-shadow:${shadow};`}
							/>
						</div>
					);
				})
			}
		</div>

		{title && <h2>{title}</h2>}

		<table>
			<thead>
				<tr>
					<td style="width:40%" />
					{
						columns.map((col) => {
							const lines = col.label.split('\n');
							return (
								<th
									scope="col"
									class:list={[{ 'col-highlighted': col.highlight }]}
									style={`width:${colWidthPct}%;text-align:center;--col-color:${col.highlight ? '#fff' : col.accentColor};--col-color-mobile:${col.accentColor};--col-accent:${col.accentColor};`}
								>
									{lines.map((line, li) =>
										li < lines.length - 1 ? (
											<>
												{line}
												<br />
											</>
										) : (
											line
										)
									)}
								</th>
							);
						})
					}
				</tr>
			</thead>
			<tbody>
				{
					rows.map((row) => (
						<tr>
							<th scope="row">
								{row.href ? (
									<a href={row.href}>
										{row.label}
										<Icon
											name="tabler:help-circle-filled"
											class="faq-icon"
											aria-hidden="true"
										/>
									</a>
								) : (
									row.label
								)}
							</th>
							{row.values.map((val, i) => {
								const col = columns[i];
								return (
									<td style={`--col-color:${col.accentColor};`}>
										{val === true && (
											<Icon name="tabler:check" aria-label="Available" />
										)}
										{val === false && (
											<Icon
												name="tabler:x"
												class="disabled"
												aria-label="Not available"
											/>
										)}
										{typeof val === 'string' && val}
									</td>
								);
							})}
						</tr>
					))
				}
			</tbody>
		</table>
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	#matrix {
		margin: 60px calc(-50vw + 50%) 0;
		padding: 72px max(calc(50vw - 50%), 1.25rem) 112px;
		position: relative;

		&.no-top-margin {
			margin-top: 0;
			padding-top: 20px;

			table {
				margin-top: 0;
			}
		}
	}

	.matrix-inner {
		position: relative;
		max-width: 1400px;
		margin: 0 auto;
	}

	h2 {
		color: $color-dark;
		font-weight: $font-weight-semibold;
		font-size: 22px;
		line-height: 40px;
		margin: 0;
		position: relative;
		z-index: 1;

		@include media-up(md) {
			font-size: $font-size-6xl;
			line-height: 63px;
		}
	}

	// ── Decorative column backgrounds ─────────────────────────────
	.backg-matrix {
		position: relative;
		margin: 0 -20px;
		width: calc(100% + 40px);

		@include media-down(md) {
			display: none;
		}
	}

	// ── Table ─────────────────────────────────────────────────────
	table {
		width: calc(100% + 40px);
		margin: 64px -20px 16px;
		table-layout: fixed;
		border: none;
		border-collapse: collapse;
		position: relative;
		z-index: 1;

		@include media-down(md) {
			width: 100%;
			margin-left: 0;
			margin-right: 0;
		}

		:global(svg) {
			font-size: 25px;
			width: 25px;
			height: 25px;

			&.disabled {
				opacity: 0.2;
			}

			@include media-down(md) {
				width: 18px;
				height: 18px;
			}
		}
	}

	thead tr {
		height: 152px;

		@include media-down(md) {
			height: 80px;
		}

		td {
			width: 40%;
		}

		th {
			color: var(--col-color);
			text-align: center;
			vertical-align: middle;
			font-weight: $font-weight-semibold;
			font-size: 11px;
			padding: 0 0 40px;

			@include media-up(md) {
				font-size: 20px;

				&.col-highlighted {
					border-radius: 12px 12px 0 0;
				}
			}

			@include media-down(md) {
				color: var(--col-color-mobile);
				padding: 0 4px 16px;
				font-size: 10px;
				line-height: 1.3;
			}
		}
	}

	tbody tr {
		background-color: transparent;
		height: 64px;

		@include media-down(md) {
			height: auto;
			min-height: 48px;
		}

		th {
			font-weight: $font-weight-semibold;
			font-size: 12px;
			padding-left: 20px;
			padding-right: 12px;
			text-align: left;
			color: $color-dark;
			word-wrap: break-word;

			a {
				color: $color-dark;
				text-decoration: none;

				&:hover {
					text-decoration: underline;
				}

				:global(.faq-icon) {
					display: inline-block;
					width: 16px;
					height: 16px;
					font-size: 16px;
					vertical-align: super;
					margin-left: 3px;
					opacity: 0.5;
				}
			}

			@include media-up(md) {
				font-size: 18px;
				padding-right: 48px;
			}

			@include media-down(md) {
				padding: 8px;
				font-size: 11px;
			}
		}

		td {
			color: var(--col-color);
			text-align: center;
			font-weight: $font-weight-semibold;
			font-size: 11px;

			@include media-up(md) {
				font-size: 20px;
			}

			@include media-down(md) {
				font-size: 11px;
				padding: 8px 2px;
			}
		}
	}
</style>
