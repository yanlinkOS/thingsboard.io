---
import { Icon } from 'astro-icon/components';

interface Props {
	href: string;
	text?: string;
	ariaLabel?: string;
	srOnlySuffix?: string;
	/**
	 * Variant: 'default' for blue arrows, 'light' for white arrows (dark backgrounds)
	 */
	variant?: 'default' | 'light' | 'pe';
	class?: string;
	target?: string;
}

const { href, text = 'Read more', ariaLabel, srOnlySuffix, variant = 'default', class: className = '', target } = Astro.props;
---

<a href={href} class:list={['read-more-link', `read-more-link--${variant}`, className]} aria-label={ariaLabel} target={target} rel={target === '_blank' ? 'noopener noreferrer' : undefined}>
	{text}
	{srOnlySuffix && <span class="sr-only">{srOnlySuffix}</span>}
	<span class="arrow-container">
		<Icon name="tabler:chevron-right" class="arrow first" />
		<Icon name="tabler:chevron-right" class="arrow second" />
		<Icon name="tabler:chevron-right" class="arrow third" />
	</span>
</a>

<style lang="scss">
	@use '../../styles/variables' as *;

	.read-more-link {
		@include action-link;
		display: inline-flex;
		align-items: center;
		position: relative;
		color: var(--color-primary);
		text-decoration: none;
		transition: color $transition-base;

		&:hover {
			text-decoration: none;
		}

		.arrow-container {
			position: relative;
			display: inline-block;
			margin-left: 12px;
			width: 50px;
			height: 20px;
		}

		.arrow {
			position: absolute;
			top: 3px;
			left: 0;
			font-size: 16px;
			transition: transform $transition-base;
			color: var(--color-primary);

			&.first {
				opacity: 0.2;
			}

			&.second {
				opacity: 0.5;
			}

			&.third {
				opacity: 1;
			}
		}

		&:hover {
			.first {
				transform: translateX(10px);
			}

			.second {
				transform: translateX(20px);
			}

			.third {
				transform: translateX(30px);
			}
		}

		// Light variant for dark backgrounds
		&--light {
			color: $color-white;

			.arrow {
				color: $color-white;
			}
		}

		// PE variant – accessible dark green (5.89:1 on white)
		&--pe {
			color: $color-pe-link;

			.arrow {
				color: $color-pe-link;
			}

			&:hover {
				color: $color-pe-dark;

				.arrow {
					color: $color-pe-dark;
				}
			}
		}

		// Hide arrows on mobile
		@include media-down(md) {
			.arrow-container {
				display: none;
			}
		}
	}
</style>
