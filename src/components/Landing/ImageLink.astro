---
import { Icon } from 'astro-icon/components';
import SmartImage from '@components/SmartImage.astro';

interface Props {
	/**
	 * Link URL
	 */
	href: string;
	/**
	 * Image source URL
	 */
	src: string;
	/**
	 * Image alt text
	 */
	alt: string;
	/**
	 * Overlay text (shown on hover)
	 */
	overlayText?: string;
	/**
	 * Image width
	 */
	width: string | number;
	/**
	 * Image height
	 */
	height: string | number;
	/**
	 * Whether to show overlay on hover
	 */
	showOverlay?: boolean;
	class?: string;
}

const {
	href,
	src,
	alt,
	overlayText,
	width,
	height,
	showOverlay = true,
	class: className = '',
} = Astro.props;
---

<a href={href} class:list={['image-link', className]}>
	<SmartImage
		src={src}
		alt={alt}
		width={width}
		height={height}
		class="image-link__img"
		loading="lazy"
	/>
	{
		showOverlay && (
			<div class="image-link__overlay">
				<div class="image-link__overlay-content">
					<Icon name="tabler:eye" class="image-link__icon" />
					{overlayText && <span>{overlayText}</span>}
				</div>
			</div>
		)
	}
</a>

<style lang="scss">
	@use '../../styles/variables' as *;

	.image-link {
		display: block;
		position: relative;
		border-radius: $radius-md;
		overflow: hidden;

		&__img {
			width: 100%;
			height: auto;
			display: block;
			border-radius: $radius-md;
			box-shadow: var(--shadow-lg);
			transition: transform $transition-base;
		}

		&__overlay {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: linear-gradient(0deg, rgba(37, 38, 40, 0.8) 0%, rgba(37, 38, 40, 0.6) 100%);
			border-radius: $radius-md;
			opacity: 0;
			transition: opacity $transition-base;
			display: flex;
			align-items: flex-end;
			justify-content: center;
			padding-bottom: 10%;
		}

		&__overlay-content {
			color: $color-white;
			font-size: $font-size-base;
			display: flex;
			align-items: center;
			gap: $spacing-2;
			transform: translateY(20px);
			transition: transform $transition-base;
		}

		&__icon {
			font-size: 24px;
		}

		&:hover {
			.image-link__overlay {
				opacity: 1;
			}

			.image-link__overlay-content {
				transform: translateY(0);
			}
		}
	}
</style>
