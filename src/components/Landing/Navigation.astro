---
import { mainNavItems, allSubmenus, type SubMenu, type SubMenuItem } from '@data/navigation';
import SubMenuLink from '@components/Landing/SubMenuLink.astro';
---

<nav class="head-menu">
	<ul>
		{
			mainNavItems.map((item) => (
				<li
					class={`nav-${item.submenuId?.replace('nav-', '') || item.label.toLowerCase().replace(' ', '-')}`}
					data-submenu-id={item.submenuId}
				>
					{item.href ? (
						<a
							class="main-menu-link"
							id={item.submenuId === 'nav-cases' ? 'use-cases-link' : undefined}
							href={item.href}
						>
							{item.label}
						</a>
					) : (
						<span class="main-menu-link">{item.label}</span>
					)}
				</li>
			))
		}
	</ul>

	<div class="indicator">
		<div class="head-arrow"></div>
		<div class="line"></div>
	</div>

	<div class="sub-menu-container">
		{
			allSubmenus.map((submenu: SubMenu) => (
				<div id={submenu.id} class="centered-sub">
					<ul class={`sub-menu ${submenu.className}`}>
						<li class="sub-groups">
							{submenu.groups.map((group, groupIndex) => (
								<div class="group">
									{submenu.className === 'products' && (submenu.id === 'nav-products' || submenu.id === 'nav-docs') ? (
										// Products submenu — three columns, larger (32px) icons.
										groupIndex === 0 ? (
											<>
												<div class="column">
													<p class="group-name">IoT platforms</p>
													{group.items.slice(0, 1).map((item: SubMenuItem) => (
														<SubMenuLink item={item} iconSize={32} />
													))}
												</div>
												<div class="column">
													<p class="group-name">&nbsp;</p>
													{group.items.slice(1, 2).map((item: SubMenuItem) => (
														<SubMenuLink item={item} iconSize={32} />
													))}
												</div>
												<div class="column">
													<p class="group-name">&nbsp;</p>
													{group.items.slice(2).map((item: SubMenuItem) => (
														<SubMenuLink item={item} iconSize={32} />
													))}
												</div>
											</>
										) : (
											<>
												<div class="column">
													<p class="group-name">Product ecosystem</p>
													{group.items.slice(0, 2).map((item: SubMenuItem) => (
														<SubMenuLink item={item} iconSize={32} />
													))}
												</div>
												<div class="column">
													<p class="group-name">&nbsp;</p>
													{group.items.slice(2, 4).map((item: SubMenuItem) => (
														<SubMenuLink item={item} iconSize={32} />
													))}
												</div>
												<div class="column">
													<p class="group-name">&nbsp;</p>
													{group.items.slice(4).map((item: SubMenuItem) => (
														<SubMenuLink item={item} iconSize={32} />
													))}
												</div>
											</>
										)
									) : submenu.className === 'cases' && submenu.id === 'nav-cases' ? (
										// Use Cases submenu — first group is a 3-column list, the
										// rest (SCADA) is a 3-column labelled group.
										groupIndex === 0 ? (
											<>
												<div class="column">
													{group.items.slice(0, 5).map((item: SubMenuItem) => (
														<SubMenuLink item={item} />
													))}
												</div>
												<div class="column">
													{group.items.slice(5, 10).map((item: SubMenuItem) => (
														<SubMenuLink item={item} />
													))}
												</div>
												<div class="column">
													{group.items.slice(10).map((item: SubMenuItem) => (
														<SubMenuLink item={item} />
													))}
												</div>
											</>
										) : (
											<>
												<div class="column">
													<p class="group-name">{group.name}</p>
													{group.items.slice(0, 1).map((item: SubMenuItem) => (
														<SubMenuLink item={item} />
													))}
												</div>
												<div class="column">
													<p class="group-name">&nbsp;</p>
													{group.items.slice(1, 2).map((item: SubMenuItem) => (
														<SubMenuLink item={item} />
													))}
												</div>
												<div class="column">
													<p class="group-name">&nbsp;</p>
													{group.items.slice(2).map((item: SubMenuItem) => (
														<SubMenuLink item={item} />
													))}
												</div>
											</>
										)
									) : (
										// Generic submenu — single column.
										<div class="column">
											{group.name && <p class="group-name">{group.name}</p>}
											{group.items.map((item: SubMenuItem) => (
												<SubMenuLink item={item} />
											))}
										</div>
									)}
								</div>
							))}
						</li>
					</ul>
				</div>
			))
		}
	</div>
</nav>

<script>
	import { lockScroll, unlockScroll } from '@util/scroll-lock';

	// Burger menu shows at <=1280px (single source of truth for the breakpoint).
	const MOBILE_QUERY = window.matchMedia('(max-width: 1280px)');

	// Expand/collapse one submenu section inline in the burger drawer.
	function listburg(subMenuId: string) {
		if (!MOBILE_QUERY.matches) return;

		const targetSubMenu = document.querySelector(
			`nav.head-menu > ul > li > div.centered-sub#${subMenuId} > ul.sub-menu`
		);
		const isOpen = targetSubMenu?.classList.contains('open-sub');
		const subMenus = document.querySelectorAll('nav.head-menu > ul > li > div.centered-sub > ul.sub-menu');
		subMenus.forEach((menu) => menu.classList.remove('open-sub'));

		if (!isOpen) {
			targetSubMenu?.classList.add('open-sub');
		}
	}

	// Desktop submenu handling
	document.addEventListener('DOMContentLoaded', () => {
		const menuElement = document.querySelector('nav.head-menu > ul');
		const submenuContainer = document.querySelector('nav.head-menu > div.sub-menu-container');
		const menuItems = document.querySelectorAll('nav.head-menu > ul > li');
		const indicator = document.querySelector('nav.head-menu > ul + div.indicator');
		let subMenuActive = false;

		menuElement?.addEventListener('mouseleave', (event) => {
			const relatedTarget = (event as MouseEvent).relatedTarget as Element;
			if (!relatedTarget?.closest('div.sub-menu-container')) {
				setTimeout(() => {
					if (!submenuContainer?.matches(':hover')) {
						subMenuActive = false;
						submenuContainer?.classList.remove('active', 'bounds-transition');
						document
							.querySelectorAll('nav.head-menu > div.sub-menu-container > div')
							.forEach((el) => el.classList.remove('open'));
						menuItems.forEach((item) => item.classList.remove('active'));
						indicator?.classList.remove('left-transition', 'active');
					}
				}, 200);
			}
		});

		submenuContainer?.addEventListener('mouseleave', (event) => {
			const relatedTarget = (event as MouseEvent).relatedTarget as Element;
			if (!relatedTarget?.closest('nav.head-menu > ul')) {
				subMenuActive = false;
				submenuContainer?.classList.remove('active', 'bounds-transition');
				menuItems.forEach((item) => item.classList.remove('active'));
				indicator?.classList.remove('left-transition', 'active');
				document
					.querySelectorAll('nav.head-menu > div.sub-menu-container > div')
					.forEach((el) => el.classList.remove('open'));
			}
		});

		menuItems.forEach((item) => {
			const subMenuId = item.getAttribute('data-submenu-id');

			item.addEventListener('mouseenter', () => {
				setTimeout(() => {
					if (item.matches(':hover')) {
						const submenus = document.querySelectorAll('nav.head-menu > div.sub-menu-container > div');
						submenus.forEach((el) => el.classList.remove('open'));
						menuItems.forEach((menuItem) => menuItem.classList.remove('active'));
						item.classList.add('active');

						if (subMenuId) {
							const targetSubMenu = document.querySelector(`nav.head-menu > div.sub-menu-container > div#${subMenuId}`);
							targetSubMenu?.classList.add('open');

							if (
								submenuContainer instanceof HTMLElement &&
								indicator instanceof HTMLElement &&
								targetSubMenu instanceof HTMLElement
							) {
								// First, make submenu visible to get correct dimensions
								submenuContainer.style.overflow = 'visible';

								// Activate container first so we can measure dimensions
								const wasActive = subMenuActive;
								if (!subMenuActive) {
									submenuContainer.classList.add('active');
									indicator.classList.add('active');
									subMenuActive = true;
								}

								// Use requestAnimationFrame to ensure element is rendered before measuring
								requestAnimationFrame(() => {
									// Calculate center position relative to the nav item
									const itemRect = item.getBoundingClientRect();
									const menuRect = (menuElement as HTMLElement).getBoundingClientRect();
									const submenuWidth = targetSubMenu.clientWidth;
									const submenuHeight = targetSubMenu.clientHeight;

									// Center the submenu under the nav item
									const itemCenterX = itemRect.left + itemRect.width / 2;
									let left = itemCenterX - menuRect.left - submenuWidth / 2;

									// Check right edge overflow
									const rightOverflow = menuRect.left + left + submenuWidth - window.innerWidth;
									if (rightOverflow > 0) {
										left -= rightOverflow + 10; // 10px padding from edge
									}

									// Check left edge overflow
									const absoluteLeft = menuRect.left + left;
									if (absoluteLeft < 10) {
										left = 10 - menuRect.left; // 10px padding from edge
									}

									indicator.style.opacity = '1';
									submenuContainer.style.left = `${left}px`;

									if (wasActive) {
										submenuContainer.classList.add('bounds-transition');
										indicator.classList.add('left-transition');
									}

									indicator.style.left = `${(item as HTMLElement).offsetLeft}px`;
									indicator.style.width = `${item.clientWidth}px`;
									submenuContainer.style.height = `${submenuHeight}px`;
									submenuContainer.style.width = `${submenuWidth}px`;
									submenuContainer.style.overflow = 'hidden';
								});
							}
						} else {
							if (subMenuActive && submenuContainer) {
								submenuContainer.classList.remove('active');
								subMenuActive = false;
							}
							if (indicator instanceof HTMLElement) {
								indicator.style.opacity = '0';
							}
						}
					}
				}, 100);
			});
		});

		// Mobile submenu initialization
		let isMobile = MOBILE_QUERY.matches;

		function initMobileSubmenu() {
			const header = document.querySelector('header');
			if (header?.classList.contains('opened-burger')) {
				lockScroll();
			}

			const targetSubMenus = document.querySelectorAll('nav.head-menu > div.sub-menu-container > div');
			targetSubMenus.forEach((el) => {
				(el as HTMLElement).style.display = 'block';
			});

			const container = document.querySelector<HTMLElement>('nav.head-menu > div.sub-menu-container');
			container?.classList.remove('active');
			if (container) container.style.display = 'none';

			targetSubMenus.forEach((subMenu) => {
				const subMenuId = subMenu.getAttribute('id');
				const parent = document.querySelector(`nav.head-menu > ul > li.${subMenuId}`);
				parent?.appendChild(subMenu);
			});
		}

		function restoreDesktopSubmenu() {
			// Crossing to desktop closes the burger drawer — clear its open state and
			// release the scroll lock, but ONLY if the burger actually held it: the
			// util's lock is shared, so unlocking unconditionally would release a
			// lock held by another open overlay (e.g. an ImageGallery lightbox).
			const header = document.querySelector('header.header');
			if (header?.classList.contains('opened-burger')) {
				header.classList.remove('opened-burger');
				unlockScroll();
			}
			const targetSubMenus = document.querySelectorAll('nav.head-menu > ul > li > div');
			targetSubMenus.forEach((el) => {
				(el as HTMLElement).style.display = '';
			});

			const container = document.querySelector<HTMLElement>('nav.head-menu > div.sub-menu-container');
			container?.classList.remove('active');
			if (container) container.style.display = 'block';

			menuItems.forEach((item) => item.classList.remove('active'));

			targetSubMenus.forEach((subMenu) => {
				container?.appendChild(subMenu);
			});
		}

		if (isMobile) {
			initMobileSubmenu();
		}

		// Use Cases is the only item with both an href and a submenu. On mobile
		// (no hover) the tap would just navigate away, so intercept it and expand
		// the section inline instead.
		const useCasesLink = document.getElementById('use-cases-link');
		useCasesLink?.addEventListener('click', (e) => {
			if (!isMobile) return;
			e.preventDefault();
			listburg('nav-cases');
		});

		// Non-href top-level items (Products / Services / …) toggle their submenu
		// inline on mobile. Delegated click — no inline onclick / global needed.
		menuElement?.addEventListener('click', (event) => {
			const link = (event.target as Element).closest('span.main-menu-link');
			if (!link) return;
			const id = link.closest('li')?.getAttribute('data-submenu-id');
			if (id) listburg(id);
		});

		// Re-init when crossing the mobile breakpoint (fires only on change).
		MOBILE_QUERY.addEventListener('change', (e) => {
			isMobile = e.matches;
			if (isMobile) {
				initMobileSubmenu();
			} else {
				restoreDesktopSubmenu();
			}
		});
	});
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.head-menu {
		height: inherit;
		position: relative;
		display: flex;
		justify-content: center;

		.sub-menu-container {
			position: absolute;
			top: $header-height + 4px;
			left: 0;
			transition:
				visibility,
				opacity ease-in-out;
			transition-duration: 0.3s;
			border-radius: 4px;
			box-shadow:
				0 30px 60px -30px rgba(0, 0, 0, 0.3),
				0 50px 100px -20px rgba(0, 0, 0, 0.25);
			background-color: var(--color-bg-surface);
			visibility: hidden;
			opacity: 0;

			&.active {
				visibility: visible;
				opacity: 1;
				background-color: var(--color-bg-light);

				&.bounds-transition {
					transition:
						left ease-in-out 0.4s,
						width ease-in-out 0.4s,
						height ease-in-out 0.4s;
				}

				& > div.open {
					opacity: 1;
					display: block;
					transition-property: display, opacity;
					transition-duration: 0.4s;
					transition-behavior: allow-discrete;
					@starting-style {
						opacity: 0;
					}
				}
			}

			& > div {
				opacity: 0;
				display: none;
			}

			div#nav-cases {
				.group:last-child {
					.column {
						min-width: 320px;
					}
				}
			}
		}

		.sub-menu-container,
		ul {
			.centered-sub {
				width: max-content;
				.sub-menu {
					width: max-content;
					display: block;
					z-index: 1;
					padding: 0;

					li {
						padding: 0;
					}

					.sub-groups {
						display: flex;
						flex-direction: column;
						align-items: stretch;

						.group {
							display: flex;
							padding: 32px;
							gap: 36px;
							margin: 5px 5px 0;

							&:first-child {
								border-radius: 4px;
								background-color: var(--color-bg-surface);
							}

							&:first-child:last-child {
								margin: 0;
								.column {
									width: 100%;
									min-width: unset;
								}
							}

							&:not(:only-child) {
								.column {
									min-width: 250px;
								}
							}

							.column {
								display: flex;
								flex-direction: column;
								gap: 24px;

								.group-name {
									text-transform: uppercase;
									font-weight: 500;
									color: var(--color-primary);
									font-size: 14px;
									line-height: normal;
								}
							}
						}
					}

					a {
						text-align: left;
						display: flex;

						&:hover {
							.sub-text {
								span.item-heading {
									color: var(--color-primary);
								}
								p {
									color: var(--color-text);
								}
							}
						}

						// Per-product heading colour on hover (theme-aware brand tokens).
						&.prof-lnk:hover .sub-text span.item-heading,
						&.mobile-pe-lnk:hover .sub-text span.item-heading,
						&.mqtt-broker-lnk:hover .sub-text span.item-heading {
							color: var(--brand-pe);
						}

						&.com-lnk:hover .sub-text span.item-heading,
						&.mobile-lnk:hover .sub-text span.item-heading {
							color: var(--brand-ce);
						}

						&.edge-lnk:hover .sub-text span.item-heading {
							color: var(--brand-edge);
						}

						&.gateway-lnk:hover .sub-text span.item-heading {
							color: var(--brand-gateway);
						}

						&.trendz-lnk:hover .sub-text span.item-heading {
							color: var(--brand-trendz);
						}

						&:last-child {
							margin-bottom: 0;
						}

						.sub-text {
							max-width: 284px;

							span.item-heading {
								color: var(--color-text);
								font-size: 16px;
								font-weight: 400;
								line-height: 24px;
							}

							p {
								color: var(--color-text-secondary);
								font-size: 14px;
								font-weight: 400;
								line-height: 24px;
								white-space: nowrap;
							}
						}

						img,
						svg.nav-icon {
							margin-right: 12px;
							flex-shrink: 0;
						}

						// Default icon tint (unbranded links); `--menu-icon-color`
						// switches per theme.
						svg.nav-icon {
							color: var(--menu-icon-color);
						}

						// Per-product icon hues. `--brand-*` tokens switch per theme
						// (see _theme.scss), so no dark-mode override is needed.
						&.com-lnk svg.nav-icon,
						&.mobile-lnk svg.nav-icon {
							color: var(--brand-ce);
						}
						&.cloud-lnk svg.nav-icon {
							color: var(--brand-cloud);
						}
						&.prof-lnk svg.nav-icon,
						&.mobile-pe-lnk svg.nav-icon,
						&.mqtt-broker-lnk svg.nav-icon {
							color: var(--brand-pe);
						}
						&.edge-lnk svg.nav-icon {
							color: var(--brand-edge);
						}
						&.gateway-lnk svg.nav-icon {
							color: var(--brand-gateway);
						}
						&.trendz-lnk svg.nav-icon {
							color: var(--brand-trendz);
						}

						&.small-link {
							.sub-text {
								padding: 0;
								span.item-heading {
									font-weight: 400;
									white-space: nowrap;
								}
							}
							&:last-child {
								margin-bottom: 0;
							}
						}
					}
				}
			}
		}

		ul {
			display: flex;
			padding: 0;

			li {
				cursor: default;
				display: flex;
				padding: 10px 12px 14px;
				align-items: center;
				height: calc(100% + 4px);

				a,
				span.main-menu-link {
					text-align: center;
				}

				&:hover a {
					color: var(--color-primary);
				}
			}

			a,
			span.main-menu-link {
				display: block;
				color: var(--sl-color-white);
				font-size: 1rem;
				font-weight: normal;
				text-decoration: none;
			}

			a:not([href]),
			span.main-menu-link {
				color: var(--sl-color-white);

				&:hover {
					color: var(--color-primary);
				}
			}
		}
	}

	.indicator {
		width: 0;
		left: 0;
		border-radius: 2px;
		position: absolute;
		height: 4px;
		bottom: -4px;
		transition-delay: 0s;
		transition-duration: 0.2s;
		z-index: -1;
		padding: 0 14px;
		transition-property: none;

		&.left-transition {
			transition-property: left;
		}

		&.active {
			transition-delay: 0s;
			transition-duration: 0.2s;

			.line {
				transition-delay: 0s;
				transition-duration: 0.2s;
				width: 100%;
				left: 0;
				opacity: 1;
			}

			.head-arrow {
				transition-delay: 0.1s;
				transition-duration: 0.2s;
				opacity: 1;
			}
		}

		.head-arrow {
			position: absolute;
			border-left: 4px solid transparent;
			border-right: 4px solid transparent;
			border-bottom: 4px solid var(--color-primary);
			width: 8px;
			height: 100%;
			left: calc(50% - 4px);
			bottom: 4px;
			opacity: 0;
			transition-delay: 0s;
			transition-duration: 0.2s;
		}

		.line {
			position: relative;
			background-color: var(--color-primary);
			width: 0;
			height: 100%;
			left: 50%;
			opacity: 0;
			transition-duration: 0.2s;
		}
	}

	// Responsive styles for navigation
	@media screen and (min-width: 1280px) {
		header .head-menu ul li:hover {
			.centered-sub {
				opacity: 1;
				transition-duration: 0.6s;
				z-index: 2;
				.sub-menu {
					top: $header-height;
					transition-delay: 0s;
				}
			}
		}
	}

	@media screen and (min-width: 1281px) and (max-width: 1599px) {
		.head-menu {
			ul {
				li {
					padding: 10px 6px 14px;

					a,
					span.main-menu-link {
						font-size: 0.9375rem;
					}
				}
			}
		}
	}

	@media screen and (max-width: 1280px) {
		header {
			&.opened-burger {
				.head-menu {
					display: block;
					overflow-y: auto;
					flex: 1;
					min-height: 0;
					padding: 16px 20px 0;

					// Hide the inner-drawer scrollbar — the drawer is already
					// the only scrollable region on the page when the burger
					// is open (body has overflow-x: clip, the page itself
					// can't scroll behind a full-height drawer), so the
					// scrollbar visual just clutters dark mode and reads as
					// "this menu has more content than fits" — which is true
					// but not something we need to surface via UA chrome.
					// Scrolling still works via touch / wheel / drag.
					scrollbar-width: none;
					&::-webkit-scrollbar {
						display: none;
					}

					// On the desktop dropdown the first product column is
					// highlighted with `background-color: var(--color-bg-surface)`
					// to distinguish "IoT Platforms" from "Product Ecosystem".
