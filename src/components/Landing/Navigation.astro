---
import { mainNavItems, allSubmenus, type SubMenu, type SubMenuItem } from '../../data/navigation';
import SmartImage from '@components/SmartImage.astro';

interface Props {
  platformQuery?: string;
}

const { platformQuery = '' } = Astro.props;
---

<nav class="head-menu">
  <ul>
    {mainNavItems.map((item) => (
      <li class={`nav-${item.submenuId?.replace('nav-', '') || item.label.toLowerCase().replace(' ', '-')}`} data-submenu-id={item.submenuId}>
        {item.href ? (
          <a
            class="main-menu-link"
            id={item.submenuId === 'nav-cases' ? 'use-cases-link' : item.label === 'Device Library' ? 'devices-link' : item.label === 'Blog' ? 'blog-link' : undefined}
            href={item.label === 'Device Library' ? `/device-library/${platformQuery}` : item.href}
            data-platform-query={item.label === 'Device Library' ? platformQuery : undefined}
            style="cursor: pointer;"
          >
            {item.label}
          </a>
        ) : (
          <span class="main-menu-link" onclick={`listburg('${item.submenuId}')`}>
            {item.label}
          </span>
        )}
      </li>
    ))}
  </ul>

  <div class="indicator">
    <div class="head-arrow"></div>
    <div class="line"></div>
    <div class="sub-background"></div>
  </div>

  <div class="sub-menu-container">
    {allSubmenus.map((submenu: SubMenu) => (
      <div id={submenu.id} class="centered-sub">
        <ul class={`sub-menu ${submenu.className}`}>
          <li class="sub-groups">
            {submenu.groups.map((group, groupIndex) => (
              <div class="group">
                {submenu.className === 'products' && (submenu.id === 'nav-products' || submenu.id === 'nav-docs') ? (
                  // Products submenu has specific column layout
                  groupIndex === 0 ? (
                    <>
                      <div class="column">
                        <p class="group-name">IoT platforms</p>
                        {group.items.slice(0, 1).map((item: SubMenuItem) => (
                          <a class={item.linkClass} href={item.href}>
                            {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="32" height="32" loading="lazy" />}
                            <div class="sub-text">
                              <span class="item-heading">{item.heading}</span>
                              {item.description && <p>{item.description}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                      <div class="column">
                        <p class="group-name">&nbsp;</p>
                        {group.items.slice(1, 2).map((item: SubMenuItem) => (
                          <a class={item.linkClass} href={item.href}>
                            {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="32" height="32" loading="lazy" />}
                            <div class="sub-text">
                              <span class="item-heading">{item.heading}</span>
                              {item.description && <p>{item.description}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                      <div class="column">
                        <p class="group-name">&nbsp;</p>
                        {group.items.slice(2).map((item: SubMenuItem) => (
                          <a class={item.linkClass} href={item.href}>
                            {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="32" height="32" loading="lazy" />}
                            <div class="sub-text">
                              <span class="item-heading">{item.heading}</span>
                              {item.description && <p>{item.description}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                    </>
                  ) : (
                    <>
                      <div class="column">
                        <p class="group-name">Product ecosystem</p>
                        {group.items.slice(0, 2).map((item: SubMenuItem) => (
                          <a class={item.linkClass} href={item.href}>
                            {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="32" height="32" loading="lazy" />}
                            <div class="sub-text">
                              <span class="item-heading">{item.heading}</span>
                              {item.description && <p>{item.description}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                      <div class="column">
                        <p class="group-name">&nbsp;</p>
                        {group.items.slice(2, 4).map((item: SubMenuItem) => (
                          <a class={item.linkClass} href={item.href}>
                            {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="32" height="32" loading="lazy" />}
                            <div class="sub-text">
                              <span class="item-heading">{item.heading}</span>
                              {item.description && <p>{item.description}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                      <div class="column">
                        <p class="group-name">&nbsp;</p>
                        {group.items.slice(4).map((item: SubMenuItem) => (
                          <a class={item.linkClass} href={item.href}>
                            {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="32" height="32" loading="lazy" />}
                            <div class="sub-text">
                              <span class="item-heading">{item.heading}</span>
                              {item.description && <p>{item.description}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                    </>
                  )
                ) : submenu.className === 'cases' && submenu.id === 'nav-cases' ? (
                  // Use Cases submenu has specific column layout
                  groupIndex === 0 ? (
                    <>
                      <div class="column">
                        {group.items.slice(0, 5).map((item: SubMenuItem) => (
                          <a class={item.linkClass} href={item.href}>
                            {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="24" height="24" loading="lazy" />}
                            <div class="sub-text">
                              <span class="item-heading">{item.heading}</span>
                              {item.description && <p>{item.description}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                      <div class="column">
                        {group.items.slice(5, 10).map((item: SubMenuItem) => (
                          <a class={item.linkClass} href={item.href}>
                            {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="24" height="24" loading="lazy" />}
                            <div class="sub-text">
                              <span class="item-heading">{item.heading}</span>
                              {item.description && <p>{item.description}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                      <div class="column">
                        {group.items.slice(10).map((item: SubMenuItem) => (
                          <a class={item.linkClass} href={item.href}>
                            {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="24" height="24" loading="lazy" />}
                            <div class="sub-text">
                              <span class="item-heading">{item.heading}</span>
                              {item.description && <p>{item.description}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                    </>
                  ) : (
                    // SCADA group with 3 columns
                    <>
                      <div class="column">
                        <p class="group-name">{group.name}</p>
                        {group.items.slice(0, 1).map((item: SubMenuItem) => (
                          <a class={item.linkClass} href={item.href}>
                            {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="24" height="24" loading="lazy" />}
                            <div class="sub-text">
                              <span class="item-heading">{item.heading}</span>
                              {item.description && <p>{item.description}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                      <div class="column">
                        <p class="group-name">&nbsp;</p>
                        {group.items.slice(1, 2).map((item: SubMenuItem) => (
                          <a class={item.linkClass} href={item.href}>
                            {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="24" height="24" loading="lazy" />}
                            <div class="sub-text">
                              <span class="item-heading">{item.heading}</span>
                              {item.description && <p>{item.description}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                      <div class="column">
                        <p class="group-name">&nbsp;</p>
                        {group.items.slice(2).map((item: SubMenuItem) => (
                          <a class={item.linkClass} href={item.href}>
                            {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="24" height="24" loading="lazy" />}
                            <div class="sub-text">
                              <span class="item-heading">{item.heading}</span>
                              {item.description && <p>{item.description}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                    </>
                  )
                ) : (
                  // Generic submenu layout
                  <div class="column">
                    {group.name && <p class="group-name">{group.name}</p>}
                    {group.items.map((item: SubMenuItem) => (
                      <a class={item.linkClass} href={item.href}>
                        {item.icon && <SmartImage src={item.icon} alt={`${item.heading} icon`} width="24" height="24" loading="lazy" />}
                        <div class="sub-text">
                          <span class="item-heading">{item.heading}</span>
                          {item.description && <p>{item.description}</p>}
                        </div>
                      </a>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </li>
        </ul>
      </div>
    ))}
  </div>
</nav>

<script>
  // Mobile submenu toggle
  function listburg(subMenuId: string) {
    const burger = document.querySelector('button.burger');
    const isMobile = burger && window.getComputedStyle(burger).display === 'block';

    if (isMobile) {
      const targetSubMenu = document.querySelector(`nav.head-menu > ul > li > div.centered-sub#${subMenuId} > ul.sub-menu`);
      const isOpen = targetSubMenu?.classList.contains('open-sub');
      const subMenus = document.querySelectorAll('nav.head-menu > ul > li > div.centered-sub > ul.sub-menu');
      subMenus.forEach(menu => menu.classList.remove('open-sub'));

      if (!isOpen) {
        targetSubMenu?.classList.add('open-sub');
      }
    }
  }

  // Make function available globally
  (window as any).listburg = listburg;

  // Desktop submenu handling
  document.addEventListener('DOMContentLoaded', () => {
    const menuElement = document.querySelector('nav.head-menu > ul');
    const submenuContainer = document.querySelector('nav.head-menu > div.sub-menu-container');
    const menuItems = document.querySelectorAll('nav.head-menu > ul > li');
    const indicator = document.querySelector('nav.head-menu > ul + div.indicator');
    let subMenuActive = false;

    menuElement?.addEventListener('mouseleave', (event) => {
      const relatedTarget = (event as MouseEvent).relatedTarget as Element;
      if (!relatedTarget?.closest('div.sub-menu-container')) {
        setTimeout(() => {
          if (!submenuContainer?.matches(':hover')) {
            subMenuActive = false;
            submenuContainer?.classList.remove('active', 'bounds-transition');
            document.querySelectorAll('nav.head-menu > div.sub-menu-container > div').forEach(el => el.classList.remove('open'));
            menuItems.forEach(item => item.classList.remove('active'));
            indicator?.classList.remove('left-transition', 'active');
          }
        }, 200);
      }
    });

    submenuContainer?.addEventListener('mouseleave', (event) => {
      const relatedTarget = (event as MouseEvent).relatedTarget as Element;
      if (!relatedTarget?.closest('nav.head-menu > ul')) {
        subMenuActive = false;
        submenuContainer?.classList.remove('active', 'bounds-transition');
        menuItems.forEach(item => item.classList.remove('active'));
        indicator?.classList.remove('left-transition', 'active');
        document.querySelectorAll('nav.head-menu > div.sub-menu-container > div').forEach(el => el.classList.remove('open'));
      }
    });

    menuItems.forEach((item) => {
      const subMenuId = item.getAttribute('data-submenu-id');

      item.addEventListener('mouseenter', () => {
        setTimeout(() => {
          if (item.matches(':hover')) {
            const submenus = document.querySelectorAll('nav.head-menu > div.sub-menu-container > div');
            submenus.forEach(el => el.classList.remove('open'));
            menuItems.forEach(menuItem => menuItem.classList.remove('active'));
            item.classList.add('active');

            if (subMenuId) {
              const targetSubMenu = document.querySelector(`nav.head-menu > div.sub-menu-container > div#${subMenuId}`);
              targetSubMenu?.classList.add('open');

              if (submenuContainer instanceof HTMLElement && indicator instanceof HTMLElement && targetSubMenu instanceof HTMLElement) {
                // First, make submenu visible to get correct dimensions
                submenuContainer.style.overflow = 'visible';

                // Activate container first so we can measure dimensions
                const wasActive = subMenuActive;
                if (!subMenuActive) {
                  submenuContainer.classList.add('active');
                  indicator.classList.add('active');
                  subMenuActive = true;
                }

                // Use requestAnimationFrame to ensure element is rendered before measuring
                requestAnimationFrame(() => {
                  // Calculate center position relative to the nav item
                  const itemRect = item.getBoundingClientRect();
                  const menuRect = (menuElement as HTMLElement).getBoundingClientRect();
                  const submenuWidth = targetSubMenu.clientWidth;
                  const submenuHeight = targetSubMenu.clientHeight;

                  // Center the submenu under the nav item
                  const itemCenterX = itemRect.left + itemRect.width / 2;
                  let left = itemCenterX - menuRect.left - submenuWidth / 2;

                  // Check right edge overflow
                  const rightOverflow = (menuRect.left + left + submenuWidth) - window.innerWidth;
                  if (rightOverflow > 0) {
                    left -= rightOverflow + 10; // 10px padding from edge
                  }

                  // Check left edge overflow
                  const absoluteLeft = menuRect.left + left;
                  if (absoluteLeft < 10) {
                    left = 10 - menuRect.left; // 10px padding from edge
                  }

                  indicator.style.opacity = '1';
                  submenuContainer.style.left = `${left}px`;

                  if (wasActive) {
                    submenuContainer.classList.add('bounds-transition');
                    indicator.classList.add('left-transition');
                  }

                  indicator.style.left = `${(item as HTMLElement).offsetLeft}px`;
                  indicator.style.width = `${item.clientWidth}px`;
                  submenuContainer.style.height = `${submenuHeight}px`;
                  submenuContainer.style.width = `${submenuWidth}px`;
                  submenuContainer.style.overflow = 'hidden';
                });
              }
            } else {
              if (subMenuActive && submenuContainer) {
                submenuContainer.classList.remove('active');
                subMenuActive = false;
              }
              if (indicator instanceof HTMLElement) {
                indicator.style.opacity = '0';
              }
            }
          }
        }, 100);
      });
    });

    // Mobile submenu initialization
    const burger = document.querySelector('button.burger');
    let isMobile = burger && window.getComputedStyle(burger).display === 'block';

    function initMobileSubmenu() {
      const header = document.querySelector('header');
      if (header?.classList.contains('opened-burger')) {
        document.body.style.overflow = 'hidden';
      }

      const targetSubMenus = document.querySelectorAll('nav.head-menu > div.sub-menu-container > div');
      targetSubMenus.forEach(el => {
        (el as HTMLElement).style.display = 'block';
      });

      const container = document.querySelector('nav.head-menu > div.sub-menu-container');
      container?.classList.remove('active');
      (container as HTMLElement).style.display = 'none';

      targetSubMenus.forEach((subMenu) => {
        const subMenuId = subMenu.getAttribute('id');
        const parent = document.querySelector(`nav.head-menu > ul > li.${subMenuId}`);
        parent?.appendChild(subMenu);
      });
    }

    function restoreDesktopSubmenu() {
      document.body.style.overflow = '';
      const targetSubMenus = document.querySelectorAll('nav.head-menu > ul > li > div');
      targetSubMenus.forEach(el => {
        (el as HTMLElement).style.display = '';
      });

      const container = document.querySelector('nav.head-menu > div.sub-menu-container');
      container?.classList.remove('active');
      (container as HTMLElement).style.display = 'block';

      menuItems.forEach(item => item.classList.remove('active'));

      targetSubMenus.forEach((subMenu) => {
        container?.appendChild(subMenu);
      });
    }

    if (isMobile) {
      initMobileSubmenu();
    }

    window.addEventListener('resize', () => {
      const newIsMobile = burger && window.getComputedStyle(burger).display === 'block';
      if (isMobile !== newIsMobile) {
        isMobile = newIsMobile;
        if (isMobile) {
          initMobileSubmenu();
        } else {
          restoreDesktopSubmenu();
        }
      }
    });
  });
</script>

<style lang="scss" is:global>
  @use '../../styles/variables' as *;

  .head-menu {
    height: inherit;
    position: relative;
    display: flex;
    justify-content: center;

    .sub-menu-container {
      position: absolute;
      top: $header-height + 4px;
      left: 0;
      transition: visibility, opacity ease-in-out;
      transition-duration: .3s;
      border-radius: 4px;
      box-shadow: 0 30px 60px -30px rgba(0, 0, 0, .3), 0 50px 100px -20px rgba(0, 0, 0, 0.25);
      background-color: #fff;
      visibility: hidden;
      opacity: 0;

      &.active {
        visibility: visible;
        opacity: 1;
        background-color: #f7f9fe;

        &.bounds-transition {
          transition: left ease-in-out .4s, width ease-in-out .4s, height ease-in-out .4s;
        }

        & > div.open {
          opacity: 1;
          display: block;
          transition-property: display, opacity;
          transition-duration: .4s;
          transition-behavior: allow-discrete;
          @starting-style {
            opacity: 0;
          }
        }
      }

      & > div {
        opacity: 0;
        display: none;
      }

      div#nav-cases {
        .group:last-child {
          .column {
            min-width: 320px;
          }
        }
      }
    }

    .sub-menu-container, ul {
      .centered-sub {
        width: max-content;
        .sub-menu {
          width: max-content;
          display: block;
          z-index: 1;
          padding: 0;

          li {
            padding: 0;
          }

          .sub-groups {
            display: flex;
            flex-direction: column;
            align-items: stretch;

            .group {
              display: flex;
              padding: 32px;
              gap: 36px;
              margin: 5px 5px 0;

              &:first-child {
                border-radius: 4px;
                background-color: #fff;
              }

              &:first-child:last-child {
                margin: 0;
                .column {
                  width: 100%;
                  min-width: unset;
                }
              }

              &:not(:only-child) {
                .column {
                  min-width: 250px;
                }
              }

              .column {
                display: flex;
                flex-direction: column;
                gap: 24px;

                .group-name {
                  text-transform: uppercase;
                  font-weight: 500;
                  color: #305680;
                  font-size: 14px;
                  line-height: normal;
                }
              }
            }
          }

          a {
            text-align: left;
            display: flex;

            &:hover {
              .sub-text {
                span.item-heading {
                  color: #2A7DEC;
                }
                p {
                  color: #212529;
                }
              }
            }

            &.prof-lnk:hover .sub-text span.item-heading {
              color: #1F8B4D;
            }

            &.com-lnk:hover .sub-text span.item-heading {
              color: #305680;
            }

            &.edge-lnk:hover .sub-text span.item-heading {
              color: #009688;
            }

            &.gateway-lnk:hover .sub-text span.item-heading {
              color: #7A4DC3;
            }

            &.trendz-lnk:hover .sub-text span.item-heading {
              color: #2696F3;
            }

            &.mobile-lnk:hover .sub-text span.item-heading {
              color: #305680;
            }

            &.mobile-pe-lnk:hover .sub-text span.item-heading {
              color: #1F8B4D;
            }

            &.mqtt-broker-lnk:hover .sub-text span.item-heading {
              color: #1F8B4D;
            }

            &:last-child {
              margin-bottom: 0;
            }

            .sub-text {
              max-width: 284px;

              h1, span.item-heading {
                color: #212529;
                font-size: 16px;
                font-weight: 400;
                line-height: 24px;
              }

              p {
                color: #899AAB;
                font-size: 14px;
                font-weight: 400;
                line-height: 24px;
                white-space: nowrap;
              }
            }

            img {
              margin-right: 12px;
              height: fit-content;
            }

            &.small-link {
              .sub-text {
                padding: 0;
                h1, span.item-heading {
                  font-weight: 400;
                  white-space: nowrap;
                }
              }
              &:last-child {
                margin-bottom: 0;
              }
            }
          }
        }
      }
    }

    ul {
      display: flex;

      li {
        cursor: default;
        display: flex;
        padding: 10px 14px 14px;
        align-items: center;
        height: calc(100% + 4px);

        a, span.main-menu-link {
          text-align: center;
        }

        &:hover a {
          color: #2A7DEC;
        }
      }

      a, span.main-menu-link {
        display: block;
        color: var(--sl-color-white);
        font-size: 16px;
        font-weight: normal;
        text-decoration: none;
      }

      a:not([href]), span.main-menu-link {
        color: var(--sl-color-white);

        &:hover {
          color: #2A7DEC;
        }
      }
    }
  }

  .indicator {
    width: 0;
    left: 0;
    border-radius: 2px;
    position: absolute;
    height: 4px;
    bottom: -4px;
    transition-delay: 0s;
    transition-duration: 0.2s;
    z-index: -1;
    padding: 0 14px;
    transition-property: none;

    &.left-transition {
      transition-property: left;
    }

    &.active {
      transition-delay: 0s;
      transition-duration: 0.2s;

      .line {
        transition-delay: 0s;
        transition-duration: 0.2s;
        width: 100%;
        left: 0;
        opacity: 1;
      }

      .head-arrow {
        transition-delay: 0.1s;
        transition-duration: 0.2s;
        opacity: 1;
      }
    }

    .head-arrow {
      position: absolute;
      border-left: 4px solid transparent;
      border-right: 4px solid transparent;
      border-bottom: 4px solid #2A7DEC;
      width: 8px;
      height: 100%;
      left: calc(50% - 4px);
      bottom: 4px;
      opacity: 0;
      transition-delay: 0s;
      transition-duration: 0.2s;
    }

    .line {
      position: relative;
      background-color: #2A7DEC;
      width: 0;
      height: 100%;
      left: 50%;
      opacity: 0;
      transition-duration: 0.2s;
    }
  }

  // Responsive styles for navigation
  @media screen and (min-width: 1280px) {
    header .head-menu ul li:hover {
      .centered-sub {
        opacity: 1;
        transition-duration: 0.6s;
        z-index: 2;
        .sub-menu {
          top: $header-height;
          transition-delay: 0s;
        }
      }
    }
  }

  @media screen and (min-width: 1281px) and (max-width: 1400px) {
    .head-menu {
      ul {
        li {
          padding: 10px 6px 14px;

          a, span.main-menu-link {
            font-size: 15px;
          }
        }
      }
    }
  }

  @media screen and (max-width: 1280px) {
    header {
      &.opened-burger {
        .head-menu {
          display: block;
          overflow-y: auto;
          height: calc(100% - 182px);
          margin: 70px -30px 0;
          padding: 16px 30px 0;

          .centered-sub {
            justify-content: left;
            opacity: 1;
            width: 100%;

            .sub-menu {
              display: none;
              top: unset;
            }
          }
        }
      }

      .head-menu {
        display: none;
        margin-top: 80px;

        ul {
          display: unset;

          li {
            height: unset;
            width: 100% !important;

            a, span.main-menu-link {
              text-align: left;
              &:focus {
                .centered-sub {
                  margin: 0;
                  .sub-menu {
                    display: block;
                  }
                }
              }
            }
            display: block;

            .centered-sub {
              margin: 0;
