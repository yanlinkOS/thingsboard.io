---
import HeaderContent from '@components/Landing/HeaderContent.astro';
import { Products } from '@models/site.models';

interface Props {
	githubLink?: string;
	githubLabel?: string;
	platformQuery?: string;
	gitHubPlatform?: Products;
}

const { platformQuery = '', gitHubPlatform } = Astro.props;
---

<header class="header">
	<HeaderContent platformQuery={platformQuery} gitHubPlatform={gitHubPlatform} />
</header>
