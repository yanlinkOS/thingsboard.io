---
import { Icon } from 'astro-icon/components';

interface MatrixRow {
	label: string;
	labelHref?: string;
	labelExtra?: { text: string; href: string };
	gateway: boolean | string;
	edge: boolean | string;
	server: boolean | string;
}

const rows: MatrixRow[] = [
	{ label: 'ThingsBoard Server Required', gateway: true, edge: true, server: 'N/A' },
	{
		label: 'Data Collection',
		labelHref: '/docs/reference/architecture/performance/',
		gateway: true,
		edge: true,
		server: true,
	},
	{
		label: 'Core Protocols Support (MQTT, HTTP, CoAP, etc.)',
		labelHref: '/docs/apis-and-sdks/',
		gateway: true,
		edge: true,
		server: true,
	},
	{
		label: 'Peripheral Infrastructure Protocols Support (Modbus, BACNet, BLE, etc.)',
		labelHref: '/docs/iot-gateway/',
		gateway: true,
		edge: false,
		server: false,
	},
	{
		label: 'Data Processing and Analysis',
		labelHref: '/docs/recipes/',
		gateway: false,
		edge: true,
		server: true,
	},
	{
		label: 'Real-Time HMI Dashboards',
		labelHref: '/docs/user-guide/dashboards/',
		labelExtra: { text: 'SCADA-like HMI Dashboards', href: '/docs/user-guide/scada/' },
		gateway: false,
		edge: true,
		server: true,
	},
	{
		label: 'Alarms & Notifications',
		labelHref: '/docs/user-guide/alarms/',
		gateway: false,
		edge: true,
		server: true,
	},
	{
		label: 'Asset Management',
		labelHref: '/docs/user-guide/assets/',
		gateway: false,
		edge: true,
		server: true,
	},
	{
		label: 'Offline Data Computing and Storage (Remote Site Scenarios)',
		labelHref: '/docs/edge/key-concepts/edge-instance/',
		gateway: 'Data Collection',
		edge: true,
		server: false,
	},
	{
		label: 'Multi-Tenancy Support',
		labelHref: '/docs/user-guide/multi-tenancy/',
		gateway: false,
		edge: false,
		server: true,
	},
	{ label: 'Hardware Resources Usage', gateway: 'Low', edge: 'Medium to Low', server: 'High to Medium' },
];
---

<section id="matrix">
	<div class="main-content">
		<h2>Which ThingsBoard Product Is Right for You?</h2>

		<table>
			<colgroup>
				<col class="col-feature" />
				<col class="col-gateway" />
				<col class="col-edge" />
				<col class="col-server" />
			</colgroup>
			<thead>
				<tr>
					<td></td>
					<th class="gateway" scope="col">IoT<br />Gateway</th>
					<th class="edge" scope="col">ThingsBoard<br />Edge</th>
					<th class="server" scope="col">ThingsBoard<br />Server</th>
				</tr>
			</thead>
			<tbody>
				{
					rows.map((row) => (
						<tr>
							<th scope="row">
								{row.labelHref ? (
									<>
										<a href={row.labelHref}>{row.label}</a>
										{row.labelExtra && (
											<>
												{' '}and{' '}
												<a href={row.labelExtra.href}>{row.labelExtra.text}</a>
											</>
										)}
									</>
								) : (
									row.label
								)}
							</th>
							{(['gateway', 'edge', 'server'] as const).map((col) => {
								const val = row[col];
								return (
									<td>
										{val === true && <Icon name="tabler:check" aria-label="Available" />}
										{val === false && (
											<Icon name="tabler:x" class="disabled" aria-label="Not available" />
										)}
										{typeof val === 'string' && val}
									</td>
								);
							})}
						</tr>
					))
				}
			</tbody>
		</table>
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	#matrix {
		max-width: 1400px;
		margin: 0 auto;
		padding: 60px 20px 88px;
	}

	.main-content {
		position: relative;
	}

	h2 {
		text-align: center;
		margin-bottom: 48px;
		font-size: 42px;
		font-weight: 600;
		color: #212529;
	}

	table {
		width: 100%;
		border-collapse: separate;
		border-spacing: 16px 0;
		table-layout: fixed;
		border: none;

		.col-feature {
			width: 40%;
		}

		.col-gateway,
		.col-edge,
		.col-server {
			width: 20%;
		}
	}

	thead {
		background: white;

		td {
			border: none;
			background: transparent;
		}

		th {
			padding: 20px 12px;
			text-align: center;
			vertical-align: middle;
			font-weight: 600;
			font-size: 18px;
			line-height: 1.3;
			color: white;
			border: none;

			&.gateway {
				background: #7a4dc3;
				border-radius: 12px 12px 0 0;
				box-shadow: 0 -2px 8px rgba(122, 77, 195, 0.15);
			}

			&.edge {
				background: #009688;
				border-radius: 12px 12px 0 0;
				box-shadow: 0 -2px 8px rgba(0, 150, 136, 0.15);
			}

			&.server {
				background: #2a7dec;
				border-radius: 12px 12px 0 0;
				box-shadow: 0 -2px 8px rgba(42, 125, 236, 0.15);
			}
		}
	}

	tbody {
		th {
			font-weight: 600;
			font-size: 16px;
			line-height: 1.4;
			padding: 16px 12px 16px 0;
			color: #212529;
			text-align: left;
			border: none;
			background: white;

			a {
				color: #212529;
				font-weight: 600;
				font-size: 16px;
				text-decoration: none;

				&:hover {
					color: #009688;
					text-decoration: underline;
				}
			}
		}

		td {
			text-align: center;
			vertical-align: middle;
			font-weight: 600;
			font-size: 15px;
			padding: 16px 8px;
			background: white;
			border: none;

			:global(svg) {
				width: 20px;
				height: 20px;

				&.disabled {
					opacity: 0.3;
				}
			}

			&:nth-child(2) {
				color: #7a4dc3;
				border-left: 2px solid #7a4dc3;
				border-right: 2px solid #7a4dc3;

				:global(svg) {
					color: #7a4dc3;
				}
			}

			&:nth-child(3) {
				color: #009688;
				border-left: 2px solid #009688;
				border-right: 2px solid #009688;

				:global(svg) {
					color: #009688;
				}
			}

			&:nth-child(4) {
				color: #2a7dec;
				border-left: 2px solid #2a7dec;
				border-right: 2px solid #2a7dec;

				:global(svg) {
					color: #2a7dec;
				}
			}
		}

		tr:last-child td {
			&:nth-child(2) {
				border-bottom: 3px solid #7a4dc3;
				border-radius: 0 0 12px 12px;
			}

			&:nth-child(3) {
				border-bottom: 3px solid #009688;
				border-radius: 0 0 12px 12px;
			}

			&:nth-child(4) {
				border-bottom: 3px solid #2a7dec;
				border-radius: 0 0 12px 12px;
			}
		}
	}

	@media screen and (max-width: 1000px) {
		#matrix {
			padding: 40px 12px 60px;
		}

		h2 {
			font-size: 26px;
			line-height: 38px;
			margin-bottom: 24px;
		}

		table {
			border-spacing: 10px 0;
		}

		thead th {
			padding: 12px 4px;
			font-size: 13px;
		}

		tbody {
			th {
				font-size: 13px;
				padding: 10px 6px 10px 0;

				a {
					font-size: 13px;
				}
			}

			td {
				font-size: 12px;
				padding: 10px 4px;

				:global(svg) {
					width: 16px;
					height: 16px;
				}
			}
		}
	}

	@media screen and (max-width: 576px) {
		#matrix {
			padding: 20px 6px 40px;
		}

		h2 {
			font-size: 20px;
			line-height: 28px;
			margin-bottom: 16px;
		}

		table {
			border-spacing: 6px 0;
		}

		thead th {
			padding: 8px 2px;
			font-size: 10px;
			line-height: 1.3;
		}

		tbody {
			th {
				font-size: 10px;
				padding: 8px 4px 8px 0;

				a {
					font-size: 10px;
				}
			}

			td {
				font-size: 10px;
				padding: 8px 2px;

				:global(svg) {
					width: 14px;
					height: 14px;
				}
			}
		}
	}
</style>