---
import { socialNetworks } from '../../data/socialNetworks';
import { Icon } from 'astro-icon/components';
import SmartImage from '@components/SmartImage.astro';
---

{socialNetworks.map((network) => (
  <a href={network.href} aria-label={network.ariaLabel} class={network.iconClass || network.icon}>
    {network.icon ? (
        <Icon name={network.icon} size="20" style="color: #847989"></Icon>
    ) : (
      <SmartImage src={network.src as string} alt={network.ariaLabel} width="18" height="18" loading="lazy" />
    )}
  </a>
))}
