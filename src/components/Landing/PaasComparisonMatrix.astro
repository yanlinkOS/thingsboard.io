---
import ComparisonMatrix from './ComparisonMatrix.astro';

const columns = [
	{ label: 'Community\nEdition', accentColor: '#305680', borderColor: '#acbbcc' },
	{ label: 'Professional\nEdition', accentColor: '#27ae60', borderColor: '#a9dfbf' },
	{ label: 'Cloud', accentColor: '#2a7dec', highlight: true },
];

const rows = [
	{ label: 'Asset management & Data collection', values: [true, true, true] },
	{ label: 'End-user real-time dashboards', values: [true, true, true] },
	{ label: 'Customizable rule chains, widgets', values: [true, true, true] },
	{ label: 'MQTT, HTTP, CoAP, OPC-UA transport', values: [true, true, true] },
	{ label: 'Integrations with BigData systems', values: [true, true, true] },
	{ label: 'NB-IoT, SigFox, LoRaWAN support', values: ['Basic', 'Advanced', 'Advanced'] },
	{
		label: 'Rule Engine: Components',
		href: '/docs/user-guide/rule-engine-2-0/overview/',
		values: ['Basic', 'Advanced', 'Advanced'],
	},
	{
		label: 'Entity groups',
		href: '/docs/user-guide/groups/',
		values: [false, true, true],
	},
	{
		label: 'Advanced RBAC for IoT',
		href: '/docs/user-guide/rbac/',
		values: [false, true, true],
	},
	{
		label: 'Scheduler',
		href: '/docs/user-guide/scheduler/',
		values: [false, true, true],
	},
	{
		label: 'Reporting',
		href: '/docs/paas/user-guide/reporting/reporting-key-concepts/',
		values: [false, true, true],
	},
	{
		label: 'White-labeling',
		href: '/docs/user-guide/white-labeling/',
		values: [false, true, true],
	},
	{
		label: 'CSV/XLS data export',
		href: '/docs/user-guide/csv-xls-data-export/',
		values: [false, true, true],
	},
	{
		label: 'Platform Integrations',
		href: '/docs/user-guide/integrations/',
		values: [false, true, true],
	},
	{
		label: 'Domain management',
		href: '/docs/paas/domains/',
		values: [false, false, true],
	},
];
---

<ComparisonMatrix title="Feature Comparison Matrix" columns={columns} rows={rows} />