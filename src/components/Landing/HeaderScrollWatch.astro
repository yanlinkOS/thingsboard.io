---
// Toggles `data-header-scrolled` on the header once scrolled past 50px (lets a
// transparent header flip to solid). The sentinel is appended to <body> so it
// sits in the page flow even though this component renders in the fixed header.
---

<script is:inline>
	(function () {
		const header = document.querySelector('header.header');
		if (!header) return;

		const sentinel = document.createElement('div');
		sentinel.setAttribute('aria-hidden', 'true');
		sentinel.style.cssText =
			'position:absolute;top:50px;left:0;width:1px;height:1px;pointer-events:none;visibility:hidden';
		document.body.prepend(sentinel);

		new IntersectionObserver(
			function (entries) {
				header.toggleAttribute('data-header-scrolled', !entries[0].isIntersecting);
			},
			{ threshold: 0 }
		).observe(sentinel);
	})();
</script>
