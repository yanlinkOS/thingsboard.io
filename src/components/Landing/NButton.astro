---
interface Props {
	variant?: 'filled' | 'outlined' | 'text' | 'elevated' | 'tonal';
	color?: 'primary' | 'warning' | 'danger' | 'success' | 'white';
	size?: 'sm' | 'md' | 'lg';
	href?: string;
	type?: 'button' | 'submit' | 'reset';
	disabled?: boolean;
	id?: string;
	class?: string;
	pill?: boolean;
	fullWidth?: boolean;
	target?: string;
	ariaLabel?: string;
	[key: string]: any;
}

const {
	variant = 'filled',
	color = 'primary',
	size = 'md',
	href,
	type = 'button',
	disabled = false,
	id,
	class: className,
	pill = false,
	fullWidth = false,
	target,
	ariaLabel,
	...attrs
} = Astro.props;

const classes = [
	'n-button',
	`n-button--${variant}`,
	`n-button--${color}`,
	`n-button--${size}`,
	pill && 'n-button--pill',
	fullWidth && 'n-button--full-width',
	disabled && 'n-button--disabled',
	className,
]
	.filter(Boolean)
	.join(' ');
---

{
	href ? (
		<a href={href} id={id} class={classes} target={target} aria-label={ariaLabel} {...attrs}>
			<slot />
		</a>
	) : (
		<button
			type={type}
			id={id}
			class={classes}
			disabled={disabled}
			aria-label={ariaLabel}
			{...attrs}
		>
			<slot />
		</button>
	)
}

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.n-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-weight: $font-weight-normal;
		text-align: center;
		text-decoration: none;
		border-radius: $radius-sm;
		border: none;
		transition: all $transition-base;
		cursor: pointer;
		box-sizing: border-box;

		// ---- Color tokens (default: primary / accent) ----
		--_btn-color: var(--sl-color-text-accent);
		--_btn-color-hover: var(--sl-color-accent);
		--_btn-color-contrast: var(--sl-color-black);
		--_btn-color-tonal-bg: var(--sl-color-accent-low);
		--_btn-color-tonal-hover: var(--sl-color-accent-low);
		--_btn-shadow: var(--shadow-primary);

		// ---- Sizes ----
		&--sm {
			font-size: $font-size-sm;
			padding: 8px 16px;
			height: 36px;
		}

		&--md {
			font-size: $font-size-base;
			padding: 11px 20px;
			height: 47px;
		}

		&--lg {
			font-size: $font-size-lg;
			padding: 14px 28px;
			height: 54px;
		}

		// ---- Colors ----
		&--primary {
			--_btn-color: var(--sl-color-text-accent);
			--_btn-color-hover: var(--sl-color-accent);
			--_btn-color-contrast: var(--sl-color-black);
			--_btn-color-tonal-bg: var(--sl-color-accent-low);
			--_btn-color-tonal-hover: var(--sl-color-accent-low);
			--_btn-shadow: var(--shadow-primary);
		}

		&--warning {
			--_btn-color: var(--sl-color-orange-high);
			--_btn-color-hover: var(--sl-color-orange);
			--_btn-color-contrast: var(--sl-color-black);
			--_btn-color-tonal-bg: var(--sl-color-orange-low);
			--_btn-color-tonal-hover: var(--sl-color-orange-low);
			--_btn-shadow: none;
		}

		&--danger {
			--_btn-color: var(--sl-color-red-high);
			--_btn-color-hover: var(--sl-color-red);
			--_btn-color-contrast: var(--sl-color-black);
			--_btn-color-tonal-bg: var(--sl-color-red-low);
			--_btn-color-tonal-hover: var(--sl-color-red-low);
			--_btn-shadow: none;
		}

		&--success {
			--_btn-color: var(--sl-color-green-high);
			--_btn-color-hover: var(--sl-color-green);
			--_btn-color-contrast: var(--sl-color-black);
			--_btn-color-tonal-bg: var(--sl-color-green-low);
			--_btn-color-tonal-hover: var(--sl-color-green-low);
			--_btn-shadow: none;
		}

		&--white {
			--_btn-color: var(--sl-color-white);
			--_btn-color-hover: var(--sl-color-gray-1);
			--_btn-color-contrast: var(--sl-color-black);
			--_btn-color-tonal-bg: var(--sl-color-gray-6);
			--_btn-color-tonal-hover: var(--sl-color-gray-5);
			--_btn-shadow: none;
		}

		// ---- Variants ----
		&--filled {
			background-color: var(--_btn-color);
			color: var(--_btn-color-contrast);

			&:hover {
				background-color: var(--_btn-color);
				box-shadow: var(--_btn-shadow);
				text-decoration: none;
				color: var(--_btn-color-contrast);
			}

			&:active {
				background-color: var(--_btn-color-hover);
				transition-duration: 0s;
			}
		}

		&--outlined {
			background-color: transparent;
			color: var(--_btn-color);
			border: 1px solid var(--sl-color-hairline-shade);

			&:hover {
				border-color: var(--_btn-color);
				text-decoration: none;
			}
		}

		&--text {
			background-color: transparent;
			color: var(--_btn-color);

			&:hover {
				background-color: var(--_btn-color-tonal-bg);
				text-decoration: none;
			}
		}

		&--elevated {
			background-color: var(--_btn-color);
			color: var(--_btn-color-contrast);
			box-shadow: var(--shadow-sm);

			&:hover {
				box-shadow: var(--shadow-md);
				text-decoration: none;
				color: var(--_btn-color-contrast);
			}
		}

		&--tonal {
			background-color: var(--_btn-color-tonal-bg);
			color: var(--_btn-color);

			&:hover {
				background-color: var(--_btn-color-tonal-hover);
				text-decoration: none;
			}
		}

		// ---- Modifiers ----
		&--pill {
			border-radius: $radius-full;
		}

		&--full-width {
			width: 100%;
		}

		&--disabled {
			opacity: 0.5;
			pointer-events: none;
			cursor: not-allowed;
		}
	}
</style>
