---
import SearchButton from '@components/SearchButton.astro';
import ThemeToggle from '@components/ThemeToggle.astro';

interface Props {
	showSearch: boolean;
	showThemeToggle: boolean;
}

const { showSearch, showThemeToggle } = Astro.props;

// The divider separates a full icon cluster from what follows, so show it only
// when both icons render — a lone toggle (pricing / 404) gets no divider.
const showDivider = showSearch && showThemeToggle;
---

{
	(showSearch || showThemeToggle) && (
		<div class="icon-buttons">
			{showThemeToggle && <ThemeToggle />}
			{showSearch && <SearchButton />}
		</div>
	)
}
{showDivider && <div class="divider" />}
