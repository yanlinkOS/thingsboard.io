---
import { Icon } from 'astro-icon/components';
import GifVideo from '@components/GifVideo.astro';
import ReadMoreLink from './ReadMoreLink.astro';
---

<section id="rule-engine">
	<div class="main-div">
		<div class="rule">
			<a class="rule-button img-button" href="/docs/user-guide/rule-engine/">
				<div class="overlay">
					<div class="eye">
						<Icon name="tabler:eye" class="icon" />
						See more about IoT Rule Engine
					</div>
				</div>
				<GifVideo
					height="375"
					width="890"
					srcMp4="/videos/send-email-rule-chain.mp4"
					srcWebm="/videos/send-email-rule-chain.webm"
				/>
			</a>
			<div class="feature-des des">
				<h3>IoT Rule Engine</h3>
				<p>
					ThingsBoard allows you to create complex <a
						href="/docs/user-guide/rule-engine/">Rule Chains</a
					> to process data from your devices and match your application specific use cases.
				</p>
				<ReadMoreLink
					href="/docs/user-guide/rule-engine/"
					text="Read more about rule engine"
				/>
			</div>
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	#rule-engine {
		margin-bottom: 148px;
		background-color: var(--color-bg-light);

		@include media-down(md) {
			margin-bottom: $spacing-20;
		}

		a:not(.img-button) {
			color: #1a6fd4;
			text-decoration: underline;
		}

		:global(a.read-more-link) {
			color: #1a6fd4;
		}

		:global(a.read-more-link .arrow) {
			color: #1a6fd4;
		}

		p {
			color: var(--color-text);
		}
	}

	// Rule engine two-column layout
	.rule {
		justify-content: space-between;
		display: flex;
		align-items: center;
		flex-direction: column;

		@include media-up(lg) {
			flex-direction: row;
		}
	}

	// Video/image button with hover overlay
	a.img-button {
		order: 2;
		width: 100%;
		position: relative;

		@include media-up(lg) {
			order: unset;
			width: calc(65% - 20px);
		}

		:global(video) {
			display: block;
			width: 100%;
			// Without `height: auto`, the HTML `height="375"` attribute keeps
			// the element 375px tall on narrow viewports while the video
			// content scales down to fit width — letterboxing the content and
			// stretching the absolutely-positioned `.overlay` (height: 100%)
			// above and below the visible video rectangle. `auto` lets the
			// video element honour the intrinsic 890:375 aspect ratio.
			height: auto;
			border-radius: $radius-md;
			box-shadow: var(--shadow-lg);
		}

		.overlay {
			color: $color-white;
			z-index: $z-fixed;
			display: block;
			width: 100%;
			position: absolute;
			font-weight: $font-weight-normal;
			height: 100%;
			opacity: 0;
			background: linear-gradient(0deg, rgba(37, 38, 40, 0.8) 0%, rgba(37, 38, 40, 0.6) 100%);
			transition: opacity $transition-base;
			border-radius: $radius-md;
			top: 0;
			left: 0;

			&:hover {
				opacity: 1;

				.eye {
					bottom: 14%;
				}
			}

			.eye {
				transition: bottom $transition-base;
				position: absolute;
				bottom: 0;
				left: 33%;
				display: flex;

				.icon {
					font-size: 24px;
					margin-right: $spacing-2;
				}
			}
		}
	}

	// Description sidebar
	.des {
		order: 1;
		width: 100%;
		margin-bottom: $spacing-8;

		@include media-up(lg) {
			order: unset;
			width: calc(35% - 60px);
			margin: 0;
		}
	}

	// Feature description spacing
	.feature-des {
		h3,
		.phrase-heading {
			margin-bottom: 0.25rem;
		}

		:global(.read-more-link) {
			margin-top: 1.125rem;
		}
	}
</style>
