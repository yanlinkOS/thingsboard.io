---
import SmartImage from '@components/SmartImage.astro';

interface ComparisonRow {
	label: string;
	href?: string;
	ce?: boolean;
	pe?: boolean;
	ceText?: string;
	peText?: string;
	ceLinkHref?: string;
	peLinkHref?: string;
}

interface ComparisonGroup {
	category: string;
	rows: ComparisonRow[];
}

interface Props {
	title?: string;
	groups?: ComparisonGroup[];
	peColor?: string;
	centerTitle?: boolean;
	bgColor?: string;
	noSkew?: boolean;
	fixedMaxWidth?: boolean;
}

const {
	title = 'Feature comparison',
	groups: propGroups,
	peColor = '#038f7e',
	centerTitle = false,
	bgColor = '#f4f4f4',
	noSkew = false,
	fixedMaxWidth = false,
} = Astro.props;

const defaultGroups: ComparisonGroup[] = [
	{
		category: 'Platform Core',
		rows: [
			{ label: 'Scalability (Clustering)', href: '/docs/pe/reference/architecture/microservices/', ce: true, pe: true },
			{ label: 'Rule Engine & Data Processing', href: '/docs/pe/user-guide/rule-engine/', ce: true, pe: true },
			{ label: 'AI Models and AI Rule nodes', href: '/docs/pe/user-guide/ai-models/', ce: true, pe: true },
			{ label: 'Dashboards and Visualization', href: '/iot-data-visualization/', ce: true, pe: true },
			{ label: 'Mobile Application', href: '/docs/mobile/pe/', ce: true, pe: true },
		],
	},
	{
		category: 'Device Management',
		rows: [
			{ label: 'Device & Asset Modeling', href: '/docs/pe/user-guide/devices/', ce: true, pe: true },
			{ label: 'Device Claiming & Provisioning API', href: '/docs/pe/user-guide/claiming/', ce: true, pe: true },
			{ label: 'Bulk Device and Asset Provisioning via CSV', href: '/docs/pe/user-guide/provisioning/#bulk-provisioning', ce: true, pe: true },
			{ label: 'OTA Updates', href: '/docs/pe/user-guide/ota-updates/', ce: true, pe: true },
		],
	},
	{
		category: 'Connectivity',
		rows: [
			{ label: 'Standard IoT Protocols (MQTT/CoAP/HTTP/SNMP/LWM2M)', href: '/docs/pe/user-guide/connectivity-guide/', ce: true, pe: true },
			{ label: 'Industrial IoT Gateway (Modbus, OPC-UA, BACnet, etc.)', href: '/docs/iot-gateway/', ce: true, pe: true },
			{ label: 'LPWAN Integrations (LoRaWAN, Sigfox)', href: '/docs/pe/user-guide/integrations/', ce: false, pe: true },
			{ label: 'System Integrations (AWS IoT, Azure IoT, PubSub, Kafka)', href: '/docs/pe/user-guide/integrations/', ce: false, pe: true },
		],
	},
	{
		category: 'Security & Admin',
		rows: [
			{ label: 'User Management', href: '/docs/pe/user-guide/users/', ce: true, pe: true },
			{ label: 'Audit Logging', href: '/docs/pe/user-guide/security/audit-log/', ce: true, pe: true },
			{ label: 'Advanced Role-Based Access Control (RBAC)', href: '/docs/pe/user-guide/roles/', ce: false, pe: true },
			{ label: 'Single Sign-On (SSO) / OAuth2', href: '/docs/pe/user-guide/security/oauth-2-support/', ce: false, pe: true },
			{ label: 'Secrets Storage', href: '/docs/pe/user-guide/security/secrets-storage/', ce: false, pe: true },
		],
	},
	{
		category: 'Go-to-Market',
		rows: [
			{ label: 'White-Labeling', href: '/docs/pe/user-guide/white-labeling/', ce: false, pe: true },
			{ label: 'Custom menu', href: '/docs/pe/user-guide/white-labeling-menu/', ce: false, pe: true },
			{ label: 'Custom translation', href: '/docs/pe/user-guide/white-labeling-translation/', ce: false, pe: true },
			{ label: 'Reporting & Scheduling', href: '/docs/pe/user-guide/reporting/report-templates/', ce: false, pe: true },
			{ label: 'Solution Templates', href: '/docs/pe/recipes/solution-templates/overview/', ce: false, pe: true },
			{ label: 'Device Payload Codec Library (400+)', href: 'https://github.com/thingsboard/data-converters', ce: false, pe: true },
		],
	},
	{
		category: 'Deployment Options',
		rows: [
			{ label: 'Self-Managed (On-premise/Cloud)', href: '/pricing/?product=thingsboard-pe', ce: true, pe: true },
			{ label: 'Managed Public Cloud', href: '/pricing/?product=thingsboard-cloud', ce: false, pe: true },
			{ label: 'Managed Private Cloud', href: '/pricing/?product=thingsboard-private-cloud', ce: false, pe: true },
		],
	},
	{
		category: 'Support',
		rows: [
			{
				label: 'Support Model',
				ceText: 'Community',
				ceLinkHref: '/services/support/?section=community-support',
				peText: 'Advanced + SLA',
				peLinkHref: '/pricing/?section=thingsboard-pe-options&product=thingsboard-pe&faqSection=supportAndAssistance#pe-pay-as-you-go-support-included',
			},
		],
	},
];

const groups = propGroups ?? defaultGroups;
---

<section
	class="comparison-table"
	style={`--comparison-pe-color: ${peColor}; --comparison-bg-color: ${bgColor}`}
	data-center-title={centerTitle ? 'true' : undefined}
	data-no-skew={noSkew ? 'true' : undefined}
	data-fixed-max-width={fixedMaxWidth ? 'true' : undefined}
>
	<div class:list={['comparison-inner', { 'comparison-inner--fixed': fixedMaxWidth }]}>
		<h2 class="comparison-title">{title}</h2>

		<div class="comparison-header">
			<div class="col-feature">Features</div>
			<div class="col-ce">
				<span class="long">Community Edition</span>
				<span class="short">CE</span>
			</div>
			<div class="col-pe">
				<span class="long">Professional Edition</span>
				<span class="short">PE</span>
			</div>
		</div>

		{groups.map((group) => (
			<div class="comparison-group">
				<div class="group-header">
					<span>{group.category}</span>
				</div>
				{group.rows.map((row) => {
					const Tag = row.href ? 'a' : 'div';
					return (
						<Tag
							href={row.href}
							target={row.href?.startsWith('http') ? '_blank' : undefined}
							rel={row.href?.startsWith('http') ? 'noopener noreferrer' : undefined}
							class="comparison-row"
						>
							<div class="col-feature">{row.label}</div>
							<div class="col-ce">
								{row.ceText ? (
									row.ceLinkHref ? (
										<a href={row.ceLinkHref} target="_blank" rel="noopener noreferrer" class="cell-link">{row.ceText}</a>
									) : (
										<span>{row.ceText}</span>
									)
								) : row.ce ? (
									<SmartImage
										src="/src/assets/images/landings/pe/blue-mark.svg"
										alt="Available in Community Edition"
										width="20"
										height="20"
									/>
								) : (
									<span class="empty" aria-hidden="true">&nbsp;</span>
								)}
							</div>
							<div class="col-pe">
								{row.peText ? (
									row.peLinkHref ? (
										<a href={row.peLinkHref} target="_blank" rel="noopener noreferrer" class="cell-link pe-link">{row.peText}</a>
									) : (
										<span>{row.peText}</span>
									)
								) : row.pe ? (
									<SmartImage
										src="/src/assets/images/landings/pe/green-mark.svg"
										alt="Available in Professional Edition"
										width="20"
										height="20"
									/>
								) : (
									<span class="empty" aria-hidden="true">&nbsp;</span>
								)}
							</div>
						</Tag>
					);
				})}
			</div>
		))}
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	.comparison-table {
		position: relative;
		width: 100%;
		padding: 100px 1.875rem 6rem;
		padding-top: 200px;
		background-color: transparent;

		&[data-no-skew] {
			padding-top: 100px;
		}

		// Background (renders above section's default background)
		&::before {
			content: '';
			position: absolute;
			width: 100vw;
			height: 103%;
			background-color: var(--comparison-bg-color, #f4f4f4);
			z-index: 0;
			left: 49.4%;
			transform: translateX(-50%) skewY(-6deg);
			top: -67px;
		}

		&[data-no-skew]::before {
			transform: translateX(-50%);
			top: 0;
			height: 100%;
		}

		@media screen and (min-width: 1500px) {
			padding-left: 6.25rem;
			padding-right: 6.25rem;
		}

		@media screen and (max-width: 768px) {
			padding: 3rem 1.25rem;
		}
	}

	.comparison-inner {
		position: relative;
		z-index: 1;
		max-width: 1200px;
		margin: 0 auto;

		@media screen and (min-width: 1500px) {
			max-width: 1400px;
		}

		&--fixed {
			@media screen and (min-width: 1500px) {
				max-width: 1200px;
			}
		}
	}

	.comparison-title {
		font-size: $font-size-4xl;
		font-weight: $font-weight-medium;
		line-height: 1.33;
		color: #202020;
		margin: 0 0 2rem;
		text-align: left;

		[data-center-title] & {
			text-align: center;
		}

		@media screen and (max-width: 900px) {
			font-size: $font-size-3xl;
		}
	}

	.comparison-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		background-color: $color-white;
		border-radius: 4px;
		height: 84px;
		margin-bottom: 4px;

		.col-feature {
			flex: 1;
			font-size: $font-size-2xl;
			font-weight: $font-weight-medium;
			line-height: 2.25rem;
			color: $color-text-primary;
			padding-left: 1.25rem;

			@media screen and (max-width: 900px) {
				margin-left: 0;
				text-align: left;
			}
		}

		.col-ce {
			flex: 1;
			text-align: center;
			font-size: $font-size-2xl;
			font-weight: $font-weight-medium;
			line-height: 2.25rem;
			color: #0d417b;

			@media screen and (max-width: 900px) {
				flex: 0.3;
			}

			@media screen and (max-width: 500px) {
				flex: 0.2;
			}
		}

		.col-pe {
			flex: 1;
			text-align: center;
			font-size: $font-size-2xl;
			font-weight: $font-weight-medium;
			line-height: 2.25rem;
			color: var(--comparison-pe-color, #038f7e);

			@media screen and (max-width: 900px) {
				flex: 0.3;
			}

			@media screen and (max-width: 500px) {
				flex: 0.2;
			}
		}

		.short {
			display: none;
		}

		@media screen and (max-width: 900px) {
			.long {
				display: none;
			}
			.short {
				display: inline;
			}
		}
	}

	.comparison-group {
		background-color: $color-white;
		border-radius: 4px;
		padding: 4px;
		margin-bottom: 4px;
	}

	.group-header {
		display: flex;
		align-items: center;
		padding: 0.625rem 1.25rem;
		font-weight: $font-weight-medium;
		font-size: 1.125rem;
		line-height: 1.875rem;
		color: #3b3c3c;
		background-color: #f5f9f8;
		border-bottom: none;
	}

	.comparison-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 12px 20px;
		max-height: 50px;
		border-bottom: 2px solid #e0e0e0;
		text-decoration: none;
		text-decoration-color: #212121;
		position: relative;
		transition: background $transition-base;

		&:last-child {
			border-bottom: none;
			max-height: 48px;
		}

		&[href]:hover {
			background-color: #f9f9f9;
			text-decoration: underline;
			text-decoration-color: #212121;

			&::before {
				content: '';
				height: 44px;
				display: block;
				border: 1px solid #00695c;
				position: absolute;
				left: 0;
			}

			.col-feature {
				font-size: 15px;
				line-height: 28px;
			}

			.col-ce,
			.col-pe {
				:global(img) {
					width: 24px;
					height: 24px;
				}
			}
		}

		.col-feature {
			flex: 1;
			font-size: $font-size-sm;
			font-weight: $font-weight-normal;
			line-height: 1.5rem;
			color: #212121;
			transition: font-size 0.3s;

			@media screen and (max-width: 900px) {
				padding-right: 0;
			}

			@media screen and (max-width: 500px) {
				font-size: 12px;
			}
		}

		.col-ce,
		.col-pe {
			flex: 1;
			display: flex;
			align-items: center;
			justify-content: center;

			:global(img) {
				width: 20px;
				height: 20px;
			}

			@media screen and (max-width: 900px) {
				flex: 0.3;
			}

			@media screen and (max-width: 500px) {
				flex: 0.17;
			}
		}

		.cell-link {
			font-size: $font-size-sm;
			color: $color-primary;
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}

			&.pe-link {
				color: var(--comparison-pe-color, #{$color-pe});
			}
		}
	}
</style>
