---
import NavIcon from '@components/Landing/NavIcon.astro';
import type { SubMenuItem } from '@data/navigation';

interface Props {
	item: SubMenuItem;
	/** Icon box size — 32 in the Products dropdown, 24 everywhere else. */
	iconSize?: number;
}

const { item, iconSize = 24 } = Astro.props;
---

<a class={item.linkClass} href={item.href}>
	{item.icon && <NavIcon src={item.icon} size={iconSize} alt={`${item.heading} icon`} />}
	<div class="sub-text">
		<span class="item-heading">{item.heading}</span>
		{item.description && <p>{item.description}</p>}
	</div>
</a>
