---
import { docsLink, type Products } from '~/models/site.models';

export interface Props {
	product: Products;
}

const { product } = Astro.props;
const href = docsLink(product, 'reference/widgets/widget-library/');
---

<a href={href} class="back-link not-content">‹ Widgets Library</a>

<style>
	.back-link {
		display: inline-block;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
		text-decoration: none;
		margin-bottom: 1.25rem;
	}

	.back-link:hover {
		color: var(--sl-color-text-accent);
	}
</style>
