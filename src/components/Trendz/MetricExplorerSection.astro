---
import YouTubeVideo from '../YouTubeVideo.astro';
---

<section id="trendz-metric-explorer">
	<div class="me-layout">
		<div class="me-text">
			<h2 class="me-title">Elevate Your IoT Data Analytics with Metric Explorer</h2>
			<p class="me-body">
				This is your no-code engine for deep data analytics in IoT. Explore telemetry, slice data in seconds, and reveal
				hidden patterns using AI-assisted tools. Build complex business logic and metrics instantly — without writing a
				single line of code.
			</p>
			<a class="me-btn" href="/docs/trendz/metric/overview/" target="_blank" rel="noopener noreferrer"
				>More about Metric Explorer</a
			>
		</div>

		<div class="me-video">
			<YouTubeVideo videoId="r2pqMzdXEHE" title="Trendz Metric Explorer" />
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/trendz' as *;

	#trendz-metric-explorer {
		background: #fff;
		padding: 0 20px 32px;
		box-sizing: border-box;

		@include media-up(sm) {
			padding: 0 50px 60px;
		}

		@include media-up(xl) {
			padding: 100px 50px;
		}
	}

	.me-layout {
		display: flex;
		flex-direction: column;
		gap: 40px;
		max-width: 1400px;
		margin: 0 auto;

		@include media-up(xl) {
			flex-direction: row;
			align-items: flex-start;
			gap: 32px;
		}
	}

	.me-text {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 24px;
	}

	.me-title {
		@include trendz-h2;
		color: var(--color-trendz-text-primary);
		margin: 0;

		@include media-down(sm) {
			@include trendz-h3;
		}
	}

	.me-body {
		@include trendz-body-s;
		color: var(--color-trendz-text-secondary);
		margin: 0;
	}

	.me-btn {
		display: inline-block;
		padding: 12px 24px;
		border-radius: 4px;
		background: var(--color-trendz-accent);
		color: #fff;
		@include trendz-body-m-medium;
		text-align: center;
		text-decoration: none;
		transition: background 0.3s;
		white-space: nowrap;
		width: 100%;

		@include media-up(sm) {
			width: auto;
		}

		&:hover {
			background: var(--color-trendz-accent-hover);
			color: #fff;
		}
	}

	.me-video {
		flex: 1;
		min-width: 0;
		background: #0f1117;
		border-radius: 16px;
		padding: 16px;
		box-sizing: border-box;

		@include media-up(lg) {
			padding: 24px;
		}

		:global(.yt-video) {
			margin: 0;
			border-radius: 8px;
		}
	}
</style>
