---
import { getImage } from 'astro:assets';

const imgPredictScreen = await getImage({ src: (await import('/src/assets/images/landings/trendz/predict-screen.png')).default, width: 651, quality: 85 });
const imgAnomaliesScreen = await getImage({ src: (await import('/src/assets/images/landings/trendz/anomalies-screen.png')).default, width: 651, quality: 85 });
const imgDashboardScreen = await getImage({ src: (await import('/src/assets/images/landings/trendz/dashboard-screen.png')).default, width: 651, quality: 85 });
const imgMultipleDonut = await getImage({ src: (await import('/src/assets/images/landings/trendz/multiple-donut.png')).default, quality: 85 });
const imgLineChart = await getImage({ src: (await import('/src/assets/images/landings/trendz/line-chart.png')).default, quality: 85 });
const imgPieChart = await getImage({ src: (await import('/src/assets/images/landings/trendz/pie-chart.png')).default, quality: 85 });
const imgDonutChart = await getImage({ src: (await import('/src/assets/images/landings/trendz/donut-chart.png')).default, quality: 85 });
const imgSphere = await getImage({ src: (await import('/src/assets/images/landings/trendz/sphere.png')).default, quality: 85 });
const imgBars = await getImage({ src: (await import('/src/assets/images/landings/trendz/bars.png')).default, quality: 85 });
---

<section class="trendz-features">

	<!-- Block 1 (odd → row-reverse): image LEFT, text RIGHT -->
	<div class="main-bg">
		<div class="container">
			<div class="content">
				<h3 class="header">Predict failures and forecast utilization</h3>
				<div class="mobile-img">
					<img src={imgPredictScreen.src} alt="predict screen" width="651" height="328" loading="lazy" decoding="async" />
				</div>
				<p class="text">
					For better decision making, resource planning and reducing cost business requires answers
					to 3 main questions: What will happen, When, and Why?
				</p>
				<p class="accent-text">Trendz provides an answer</p>
				<a id="Products_TA_StartAnalysis1" href="/docs/trendz/prediction/" class="try-pe"
					>Start Analysis</a
				>
			</div>
			<div class="image-block screenshot-block">
				<div class="image-wrapper screenshot" id="prediction" style={`--screen-bg: url(${imgPredictScreen.src})`}>
					<img src={imgPredictScreen.src} alt="predict screen" width="651" height="328" loading="lazy" decoding="async" />
				</div>
			</div>
		</div>
	</div>

	<!-- Block 2 (even → row): text LEFT, chart RIGHT -->
	<div class="main-bg">
		<div class="container">
			<div class="content">
				<h3 class="header">Define KPI using calculated fields</h3>
				<p class="text">
					Calculated fields are one of the most powerful features for KPI monitoring and prediction.
					Based on the input data, calculated fields allow you to run statistical functions and
					create new data items by applying calculations.
				</p>
				<a id="Products_TA_LearnMore1" href="/docs/trendz/calculations/overview/" class="try-pe"
					>Learn More<span class="sr-only"> about calculated fields</span></a
				>
			</div>
			<div class="image-block">
				<div class="image-wrapper chart-wrapper pie-chart" style={`--pie-chart-bg: url(${imgPieChart.src}); --sphere-bg: url(${imgSphere.src}); --donut-chart-bg: url(${imgDonutChart.src}); --bars-bg: url(${imgBars.src})`}>
					<div class="donut-chart chart-icon"></div>
					<div class="sphere chart-icon"></div>
					<div class="bar-chart chart-icon"></div>
				</div>
			</div>
		</div>
	</div>

	<!-- Block 3 (odd → row-reverse): image LEFT, text RIGHT -->
	<div class="main-bg">
		<div class="container">
			<div class="content">
				<h3 class="header">Detection Anomalies</h3>
				<div class="mobile-img">
					<img src={imgAnomaliesScreen.src} alt="anomalies screen" width="651" height="328" loading="lazy" decoding="async" />
				</div>
				<p class="text">
					Detect anomalies with automated tools based on built-in machine learning algorithms.
					Prioritise them and focus on real problems with anomaly scoring.
				</p>
				<a
					id="Products_TA_StartAnalysis2"
					href="/docs/trendz/anomaly/anomaly-detection-overview/"
					class="try-pe">Start Analysis</a
				>
			</div>
			<div class="image-block screenshot-block">
				<div class="image-wrapper screenshot" id="anomalies" style={`--screen-bg: url(${imgAnomaliesScreen.src})`}>
					<img src={imgAnomaliesScreen.src} alt="anomalies screen" width="651" height="328" loading="lazy" decoding="async" />
				</div>
			</div>
		</div>
	</div>

	<!-- Block 4 (even → row): text LEFT, chart RIGHT -->
	<div class="main-bg">
		<div class="container accent-circle">
			<div class="content">
				<h3 class="header">Connect Data</h3>
				<p class="text">
					Connect Trendz to the ThingsBoard in few clicks with automatic Topology Discovery.
				</p>
				<p class="text">
					Trendz works with all ThingsBoard products, including Open Source ThingsBoard Community
					Edition and ThingsBoard Professional Edition.
				</p>
				<a id="Products_TA_LearnMore2" href="/docs/trendz/connect-thingsboard/" class="try-pe"
					>Learn More<span class="sr-only"> about connecting ThingsBoard</span></a
				>
			</div>
			<div class="image-block">
				<div class="image-wrapper chart-wrapper multiple-chart" style={`--multiple-donut-bg: url(${imgMultipleDonut.src}); --sphere-bg: url(${imgSphere.src})`}>
					<div class="sphere right-sphere chart-icon"></div>
					<div class="sphere left-sphere chart-icon"></div>
					<div class="sphere bottom-sphere chart-icon"></div>
				</div>
			</div>
		</div>
	</div>

	<!-- Block 5 (odd → row-reverse): image LEFT, text RIGHT -->
	<div class="main-bg">
		<div class="container">
			<div class="content">
				<h3 class="header">Share securely</h3>
				<div class="mobile-img">
					<img src={imgDashboardScreen.src} alt="dashboard screen" width="651" height="392" loading="lazy" decoding="async" />
				</div>
				<div class="text">
					<span>Share visualized insights with your users by:</span>
					<ul>
						<li>Adding them on ThingsBoard dashboards</li>
						<li>Embedding on 3rd party web sites</li>
						<li>Exporting data into spreadsheets and images</li>
					</ul>
				</div>
				<p class="text">All with respect to ThingsBoard user permissions.</p>
				<a id="Products_TA_LearnMore3" href="/docs/trendz/embed-visuals/" class="try-pe"
					>Learn More<span class="sr-only"> about embedding visuals</span></a
				>
			</div>
			<div class="image-block screenshot-block">
				<div class="image-wrapper screenshot" id="dashboard" style={`--screen-bg: url(${imgDashboardScreen.src})`}>
					<img src={imgDashboardScreen.src} alt="dashboard screen" width="651" height="392" loading="lazy" decoding="async" />
				</div>
			</div>
		</div>
	</div>

	<!-- Block 6 (even → row): text LEFT, chart RIGHT -->
	<div class="main-bg">
		<div class="container">
			<div class="content">
				<h3 class="header">Plot and aggregate your data with any granularity</h3>
				<p class="text">
					See your data, like total resource consumption on any levels starting from country level
					and deep dive into concrete meter level. Clear dataset in real-time by grouping and
					filtering on dimensions that you are interested in.
				</p>
				<a
					id="Products_TA_StartAnalysis3"
					href="/docs/trendz/telemetry-aggregation/"
					class="try-pe">Start Analysis</a
				>
			</div>
			<div class="image-block accent-circle accent-circle-center">
				<div class="image-wrapper chart-wrapper line-chart" style={`--line-chart-bg: url(${imgLineChart.src})`}></div>
			</div>
		</div>
	</div>
</section>

<style lang="scss">
	.trendz-features {
		background-color: #f8f9fd;
		overflow-x: hidden;
	}

	.main-bg {
		padding: 20px 0;
	}

	.container {
		display: flex;
		gap: 30px;
		justify-content: center;
		padding: 0 20px;
		// all blocks column-reverse on mobile
		flex-direction: column-reverse;
	}

	.content {
		flex: 1 1 50%;
		line-height: 1.5;

		.mobile-img {
			margin-bottom: 20px;

			img {
				width: 100%;
			}
		}
	}

	.header {
		margin: 0 0 20px;
		font-size: 20px;
		font-weight: 600;
		color: #434343;
	}

	.text {
		font-size: 16px;
		color: #666666;
		margin: 0 0 16px;

		ul {
			list-style: inside;
			margin: 8px 0 0;
		}
	}

	.accent-text {
		font-weight: 600;
		font-size: 14px;
		line-height: 1.5;
		color: #5555ff;
		text-transform: uppercase;
		margin-bottom: 20px;
	}

	.try-pe {
		display: inline-block;
		font-size: 16px;
		font-weight: 500;
		line-height: 1.5;
		width: 100%;
		padding: 13px 0;
		text-align: center;
		cursor: pointer;
		border: 1px solid #5555ff;
		border-radius: 4px;
		background-color: transparent;
		transition: 0.6s;
		color: #5555ff;
		text-decoration: none;
		box-sizing: border-box;

		&:hover {
			background: #5555ff;
			color: #ffffff;
		}
	}

	.image-block {
		display: flex;
		justify-content: center;
		align-items: center;
		height: 300px;
	}

	.screenshot-block {
		display: none;
	}

	.image-wrapper {
		position: relative;
		z-index: 0; // creates stacking context so ::before(z-index:-1) stays inside, not behind parent bg
		width: 90%;

		img {
			width: 90%;
			height: auto;
		}
	}

	// Chart icon wrappers
	.chart-wrapper {
		width: 90%;
		height: 90%;

		.chart-icon {
			position: absolute;
			width: 120px;
			height: 120px;
		}
	}

	.pie-chart {
		background: var(--pie-chart-bg) no-repeat center / contain;

		.sphere {
			width: 100px;
			height: 100px;
			background: var(--sphere-bg) no-repeat center / contain;
			top: -35px;
			right: 15px;
		}

		.donut-chart {
			background: var(--donut-chart-bg) no-repeat center / contain;
			left: -25px;
		}

		.bar-chart {
			background: var(--bars-bg) no-repeat center / contain;
			right: 17px;
			bottom: -5px;
		}
	}

	.multiple-chart {
		background: var(--multiple-donut-bg) no-repeat center / contain;

		.sphere {
			width: 80px;
			height: 80px;
			background: var(--sphere-bg) no-repeat center / contain;
		}

		.right-sphere {
			width: 60px;
			height: 60px;
			right: 0;
		}

		.left-sphere {
			left: -30px;
		}

		.bottom-sphere {
			bottom: -25px;
		}
	}

	.line-chart {
		background: var(--line-chart-bg) no-repeat center / contain;
	}

	// Shadow/echo effect behind screenshot images
	.screenshot::before {
		content: '';
		display: block;
		width: 100%;
		height: 100%;
		position: absolute;
		top: -25%;
		left: -7%;
		z-index: -1;
		background-repeat: no-repeat;
		background-position: left;
		background-size: contain;
	}

	#prediction::before {
		background-image: var(--screen-bg);
	}

	#anomalies::before {
		background-image: var(--screen-bg);
	}

	#dashboard::before {
		background-image: var(--screen-bg);
	}

	// Accent blur circle decoration
	.accent-circle {
		position: relative;

		&::before {
			content: '';
			display: block;
			position: absolute;
			left: 0;
			top: 0;
			transform: translate(-50%, -50%);
			width: 400px;
			height: 400px;
			background: rgba(85, 85, 255, 0.06);
			filter: blur(50px);
			pointer-events: none;
		}
	}

	.accent-circle-center::before {
		left: 50%;
		top: 50%;
	}

	// 750px — layout goes horizontal
	@media screen and (min-width: 750px) {
		.main-bg {
			padding: 70px 0;
		}

		.container {
			padding: 0 40px;
		}

		// odd blocks: image LEFT, text RIGHT
		.main-bg:nth-child(odd) .container {
			flex-direction: row-reverse;
		}

		// even blocks: text LEFT, chart RIGHT
		.main-bg:nth-child(even) .container {
			flex-direction: row;
		}

		.content {
			.mobile-img {
				display: none;
			}
		}

		.image-block {
			flex: 1 1 50%;
		}

		.screenshot-block {
			display: flex;
		}

		.try-pe {
			width: auto;
			padding: 13px 41px;
		}
	}

	// 1025px — larger gaps, bigger image block
	@media screen and (min-width: 1025px) {
		.main-bg {
			padding: 90px 0;
		}

		.container {
			gap: 60px;
			align-items: center;
			width: calc(100% - 100px);
			margin: 0 auto;
			padding: 0;
		}

		.image-block {
			min-height: 350px;

			.image-wrapper {
				width: 100%;
				height: 100%;
			}

			.screenshot {
				height: auto;
			}
		}

		.pie-chart {
			.sphere {
				width: 200px;
				height: 200px;
				top: -60px;
			}

			.donut-chart {
				width: 240px;
				height: 240px;
				top: -15%;
			}

			.bar-chart {
				width: 240px;
				height: 240px;
				bottom: -50px;
			}
		}

		.multiple-chart {
			.sphere {
				width: 160px;
				height: 160px;
			}
		}
	}

	// 1250px — more padding
	@media screen and (min-width: 1250px) {
		.main-bg {
			padding: 120px 0;
		}
	}

	// 1500px — max container, largest fonts
	@media screen and (min-width: 1500px) {
		.container {
			max-width: 1400px;
		}

		.header {
			font-size: 24px;
		}

		.text {
			font-size: 19px;
			line-height: 1.7;
		}

		.accent-text {
			font-size: 18px;
		}

		.try-pe {
			font-size: 24px;
		}
	}

	// Animation for first block only (Predict failures)
	// text: fadeInRight, image: fadeInLeft — matches original Animate.css behavior
	@media screen and (min-width: 750px) {
		.main-bg:nth-child(1) {
			.content {
				opacity: 0;
				animation-duration: 1s;
				animation-fill-mode: both;
			}

			.image-block {
				opacity: 0;
				animation-duration: 1s;
				animation-fill-mode: both;
			}

			&.in-view {
				.content {
					animation-name: fadeInRight;
				}

				.image-block {
					animation-name: fadeInLeft;
				}
			}
		}
	}

	// Animation for second block (Define KPI): text fadeInLeft, chart icons fly in
	@media screen and (min-width: 750px) {
		.main-bg:nth-child(2) {
			.content {
				opacity: 0;
				animation-duration: 1s;
				animation-fill-mode: both;
			}

			&.in-view .content {
				animation-name: fadeInLeft;
			}
		}
	}

	// Chart icon initial state (hidden) — animated when in-view
	.main-bg:nth-child(2) {
		.chart-icon {
			opacity: 0;
			animation-duration: 1.2s;
			animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
			animation-fill-mode: forwards;
		}

		&.in-view {
			.pie-chart .sphere {
				animation-name: fromTopRight;
			}

			.pie-chart .donut-chart {
				animation-name: fromTopLeft;
			}

			.pie-chart .bar-chart {
				animation-name: fromBottomRight;
			}
		}
	}

	@keyframes fadeInLeft {
		from {
			opacity: 0;
			transform: translate3d(-100%, 0, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}

	@keyframes fadeInRight {
		from {
			opacity: 0;
			transform: translate3d(100%, 0, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}

	@keyframes fromTopRight {
		from {
			opacity: 0;
			transform: translate(200px, -200px);
		}
		to {
			opacity: 1;
			transform: translate(0, 0);
		}
	}

	@keyframes fromTopLeft {
		from {
			opacity: 0;
			transform: translate(-200px, -200px);
		}
		to {
			opacity: 1;
			transform: translate(0, 0);
		}
	}

	@keyframes fromBottomRight {
		from {
			opacity: 0;
			transform: translate(200px, 200px);
		}
		to {
			opacity: 1;
			transform: translate(0, 0);
		}
	}

	@keyframes fromBottomLeft {
		from {
			opacity: 0;
			transform: translate(-200px, 200px);
		}
		to {
			opacity: 1;
			transform: translate(0, 0);
		}
	}

	// Block 3 (Detection Anomalies) — even in original: content fadeInRight, image fadeInLeft
	// Block 5 (Share securely)      — even in original: content fadeInRight, image fadeInLeft
	@media screen and (min-width: 750px) {
		.main-bg:nth-child(3),
		.main-bg:nth-child(5) {
			.content {
				opacity: 0;
				animation-duration: 1s;
				animation-fill-mode: both;
			}

			.image-block {
				opacity: 0;
				animation-duration: 1s;
				animation-fill-mode: both;
			}

			&.in-view {
				.content {
					animation-name: fadeInRight;
				}

				.image-block {
					animation-name: fadeInLeft;
				}
			}
		}
	}

	// Block 4 (Connect Data) — odd in original: content fadeInLeft + multiple-chart icons
	// Block 6 (Plot)         — odd in original: content fadeInLeft
	@media screen and (min-width: 750px) {
		.main-bg:nth-child(4),
		.main-bg:nth-child(6) {
			.content {
				opacity: 0;
				animation-duration: 1s;
				animation-fill-mode: both;
			}

			&.in-view .content {
				animation-name: fadeInLeft;
			}
		}
	}

	// Block 4 (Connect Data) — multiple-chart icon animations
	.main-bg:nth-child(4) {
		.chart-icon {
			opacity: 0;
			animation-duration: 1.2s;
			animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
			animation-fill-mode: forwards;
		}

		&.in-view {
			.multiple-chart .right-sphere {
				animation-name: fromTopRight;
			}

			.multiple-chart .left-sphere {
				animation-name: fromTopLeft;
			}

			.multiple-chart .bottom-sphere {
				animation-name: fromBottomLeft;
			}
		}
	}
</style>

<script>
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('in-view');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.25 },
	);

	document
		.querySelectorAll('.trendz-features .main-bg')
		.forEach((block) => observer.observe(block));
</script>