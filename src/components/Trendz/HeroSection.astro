<section id="trendz-hero">
	<div class="hero-container">
		<div id="hero-content">
			<p class="pe-title">Trendz Analytics Platform</p>
			<h1 class="pe-heading fade-in-left">Driving more revenue with IoT Data Analytics</h1>
			<p class="pe-subTitle">Turn data into insights and make better decisions</p>
			<div class="btn-block">
				<div>
					<a
						id="Products_TA_GetADemo1"
						href="/products/trendz/trndz-request-demo/"
						class="btn-accent">Get a demo</a
					>
				</div>
				<div>
					<a
						id="Products_TA_GetStarted"
						href="/pricing/?section=trendz-options&product=trendz-self-managed&solution=trendz-pay-as-you-go"
						class="btn-outline">Get started</a
					>
				</div>
			</div>
		</div>

		<div class="hero-image">
			<div class="image-wrapper"></div>
		</div>

		<div class="sphere-icon" id="upper-icon-left"></div>
		<div class="sphere-icon" id="upper-icon-center"></div>
		<div class="sphere-icon" id="upper-icon-right"></div>
		<div class="sphere-icon" id="down-icon-left"></div>
		<div class="sphere-icon" id="down-icon-right"></div>
	</div>
</section>

<style lang="scss">
	#trendz-hero {
		width: 100%;
		height: 100vh;
		padding-top: 100px;
		background-color: #f8f9fd;
		overflow: hidden;
		box-sizing: border-box;

		.hero-container {
			height: 100%;
			display: flex;
			position: relative;
			margin: 0 20px;

			#hero-content {
				height: 100%;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: flex-start;
				text-align: initial;
				flex: 1;
				z-index: 1;

				.pe-title {
					font-size: 14px;
					font-weight: 600;
					color: #5555ff;
					text-transform: uppercase;
					margin: 0 0 8px;
				}

				.pe-heading {
					font-size: 24px;
					line-height: 1.5;
					font-weight: 600;
					color: #434343;
					margin: 0 0 10px;
				}

				.pe-subTitle {
					color: #666666;
					font-size: 16px;
					margin: 0 0 24px;
					line-height: 1.5;
				}

				.btn-block {
					display: flex;
					align-items: center;
					justify-content: center;
					gap: 10px;
					padding: 0 20px;
					width: 100%;
					flex-direction: column;

					div {
						width: 100%;
					}
				}
			}

			.hero-image {
				display: flex;
				align-items: center;
				width: 100%;
				height: 100%;
				position: absolute;

				&::before {
					background-color: rgba(85, 85, 255, 0.1);
					filter: blur(50px);
					display: block;
					content: '';
					position: absolute;
					height: 400px;
					width: 400px;
					top: 50%;
					left: 50%;
					transform: translate(-50%, -50%);
				}

				.image-wrapper {
					background: url('/products/trendz/hero-img.png') no-repeat center / contain;
					width: 100%;
					height: 100%;
					visibility: hidden;
				}
			}

			.sphere-icon {
				position: absolute;
				opacity: 0;
				background: url('/products/trendz/sphere.png') no-repeat center / contain;
				animation-duration: 1.2s;
				animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
				animation-fill-mode: forwards;
			}

			#upper-icon-left {
				display: block;
				width: 100px;
				height: 100px;
				top: 50%;
				left: -70px;
				animation-name: fromRight;
			}

			#upper-icon-center {
				display: block;
				animation-name: fromTopLeft;
			}

			#upper-icon-right {
				display: block;
				width: 100px;
				height: 100px;
				right: 0;
				top: 10%;
				animation-name: fromBottomRight;
			}

			#down-icon-left {
				display: none;
				animation-name: fromBottomLeft;
			}

			#down-icon-right {
				display: none;
				animation-name: fromBottomRight;
			}
		}
	}

	.btn-accent {
		display: block;
		background: #5555ff;
		border-radius: 4px;
		line-height: 1.5;
		padding: 13px 0;
		font-size: 16px;
		font-weight: 500;
		color: #ffffff;
		width: 100%;
		text-align: center;
		border: 1px solid #5555ff;
		text-decoration: none;
		transition: 0.3s;

		&:hover {
			background-color: #452cdc;
			border-color: #452cdc;
			color: #ffffff;
		}
	}

	.btn-outline {
		display: block;
		font-size: 16px;
		font-weight: 500;
		line-height: 1.5;
		width: 100%;
		padding: 13px 0;
		text-align: center;
		cursor: pointer;
		border: 1px solid #5555ff;
		border-radius: 4px;
		background-color: transparent;
		transition: 0.6s;
		color: #5555ff;
		text-decoration: none;

		&:hover {
			background: #5555ff;
			color: #ffffff;
		}
	}

	// Heading slides in from left on page load (matches Animate.css fadeInLeft)
	.fade-in-left {
		opacity: 0;
		animation-name: fadeInLeft;
		animation-duration: 1s;
		animation-fill-mode: both;
	}

	// 750px — hero image becomes visible, buttons go horizontal
	@media screen and (min-width: 750px) {
		#trendz-hero .hero-container {
			margin: 0 40px;

			#hero-content {
				flex: 1 1 55%;

				.pe-title {
					font-size: 20px;
				}

				.pe-heading {
					font-size: 30px;
				}

				.pe-subTitle {
					margin-bottom: 40px;
					font-size: 20px;
				}

				.btn-block {
					padding: 0;
					flex-direction: row;
					width: unset;

					div {
						width: unset;
					}
				}
			}

			.hero-image {
				flex: 1 1 40%;
				position: relative;

				.image-wrapper {
					visibility: visible;
				}
			}

			#upper-icon-left {
				width: 90px;
				height: 90px;
				top: 30%;
				left: 50%;
			}

			#upper-icon-right {
				width: 90px;
				height: 90px;
				top: 25%;
			}

			#down-icon-left {
				display: block;
				width: 120px;
				height: 120px;
				bottom: 22%;
				right: 10%;
			}
		}

		.btn-accent {
			font-size: 20px;
			width: auto;
			padding: 13px 50px;
		}

		.btn-outline {
			font-size: 20px;
			width: auto;
			padding: 13px 50px;
		}
	}

	// 1025px — max-width container, larger fonts, more icons appear
	@media screen and (min-width: 1025px) {
		#trendz-hero .hero-container {
			margin: auto;
			width: calc(100% - 100px);
			max-width: 1200px;

			#hero-content {
				.pe-heading {
					font-size: 40px;
				}
			}

			.hero-image {
				flex: 1 1 40%;
			}

			#upper-icon-left {
				width: 100px;
				height: 100px;
				left: 25%;
				top: 20%;
			}

			#upper-icon-center {
				width: 90px;
				height: 90px;
				top: 18%;
				left: 54%;
			}

			#upper-icon-right {
				top: 25%;
				right: -5%;
				width: 100px;
				height: 100px;
			}

			#down-icon-left {
				width: 200px;
				height: 200px;
				bottom: 15%;
				left: 40%;
			}

			#down-icon-right {
				display: block;
				width: 200px;
				height: 200px;
				bottom: 20%;
				right: 0;
			}
		}

		.btn-accent {
			padding: 13px 46px;
		}

		.btn-outline {
			padding: 13px 41px;
		}
	}

	// 1250px — hero padding shrinks, image gets more space
	@media screen and (min-width: 1250px) {
		#trendz-hero {
			padding-top: 80px;

			.hero-container .hero-image {
				flex: 1 1 50%;
			}
		}
	}

	// 1500px — max container width, largest fonts
	@media screen and (min-width: 1500px) {
		#trendz-hero .hero-container {
			max-width: 1400px;

			#hero-content {
				.pe-heading {
					font-size: 50px;
					padding-right: 10%;
				}

				.pe-subTitle {
					font-size: 24px;
				}
			}

			#down-icon-left {
				bottom: 5px;
			}
		}

		.btn-accent {
			font-size: 24px;
		}

		.btn-outline {
			font-size: 24px;
		}
	}

	@keyframes fadeInLeft {
		from {
			opacity: 0;
			transform: translate3d(-100%, 0, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}

	@keyframes fromTopLeft {
		from {
			opacity: 0;
			transform: translate(-200px, -200px);
		}
		to {
			opacity: 1;
			transform: translate(0, 0);
		}
	}

	@keyframes fromBottomRight {
		from {
			opacity: 0;
			transform: translate(200px, 200px);
		}
		to {
			opacity: 1;
			transform: translate(0, 0);
		}
	}

	@keyframes fromBottomLeft {
		from {
			opacity: 0;
			transform: translate(-200px, 200px);
		}
		to {
			opacity: 1;
			transform: translate(0, 0);
		}
	}

	@keyframes fromRight {
		from {
			opacity: 0;
			transform: translateX(-200px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}
</style>