---
import { getImage } from 'astro:assets';
import ProjectScreenFrame from '../Services/ProjectScreenFrame.astro';
import TrendzChip from './TrendzChip.astro';
const posterImg = await getImage({
	src: (await import('/src/assets/images/landings/trendz/trendz-hero-video-preview.webp')).default,
	quality: 85,
});
---

<section id="trendz-hero">
	<div class="hero-container">
		<div id="hero-content">
			<h1 class="pe-heading fade-in-left">
				<TrendzChip label="Trendz Analytics" />
				The <span class="no-break">AI-Powered</span>
				<span class="title-break">IoT Data Analytics Workspace</span>
			</h1>
			<p class="pe-subTitle">
				Trendz Analytics is an add-on for ThingsBoard that turns telemetry into business KPIs and actionable insights.
			</p>
			<div class="btn-block">
				<div>
					<a id="Products_TA_GetADemo1" href="/products/trendz/request-demo/" class="btn-accent" data-trendz-open-modal
						>Talk to an Expert</a
					>
				</div>
				<div>
					<a
						id="Products_TA_GetStarted"
						href="/docs/trendz/activation/how-to/"
						class="btn-outline"
						target="_blank"
						rel="noopener noreferrer"
					>
						Activate Trendz in ThingsBoard
					</a>
				</div>
			</div>
		</div>

		<div class="hero-image">
			<ProjectScreenFrame variant="hero" class="hero-screen-frame">
				<video
					width="857"
					height="426"
					autoplay
					muted
					loop
					playsinline
					preload="metadata"
					poster={posterImg.src}
					aria-label="Trendz Analytics dashboard demo"
				>
					<source src="https://video.thingsboard.io/trendz-hero-video.webm" type="video/webm" />
					<source src="https://video.thingsboard.io/trendz-hero-video.mp4" type="video/mp4" />
				</video>
			</ProjectScreenFrame>
		</div>
	</div>
</section>

<script>
	const section = document.getElementById('trendz-hero');
	const video = section?.querySelector('video');
	if (section && video instanceof HTMLVideoElement) {
		new IntersectionObserver(
			([entry]) => {
				if (entry.isIntersecting) {
					video.play().catch(() => {});
				} else {
					video.pause();
				}
			},
			{ threshold: 0 }
		).observe(section);
	}
</script>

<style lang="scss">
	@use '../../styles/trendz' as *;

	// Shared layout for the two hero CTA buttons; each adds its own color/border/transition.
	@mixin hero-btn-base {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 4px;
		height: 48px;
		min-width: 88px;
		width: 100%;
		padding: 8px 48px;
		border-radius: 6px;
		box-sizing: border-box;
		text-decoration: none;

		@include media-down(sm) {
			padding-left: 16px;
			padding-right: 16px;
		}
	}

	#trendz-hero {
		width: 100%;
		height: auto;
		padding-top: 40px;
		background-color: var(--color-trendz-surface);
		box-sizing: border-box;

		.hero-container {
			height: 100%;
			display: flex;
			flex-direction: column;
			position: relative;
			margin: 0 20px;

			#hero-content {
				height: 100%;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: flex-start;
				text-align: initial;
				flex: 1;
				z-index: 1;

				:global(.trendz-chip) {
					display: flex;
					width: fit-content;
					margin-bottom: 12px;
				}

				.title-break {
					display: block;
				}

				.no-break {
					white-space: nowrap;
				}

				.pe-heading {
					@include trendz-h1-responsive;
					color: var(--color-trendz-text-primary);
					margin: 0 0 10px;
				}

				.pe-subTitle {
					@include trendz-h5-responsive;
					color: var(--color-trendz-text-secondary);
					margin: 0 0 24px;
				}

				.btn-block {
					display: flex;
					align-items: center;
					justify-content: center;
					gap: 10px;
					width: 100%;
					flex-direction: column;

					div {
						width: 100%;
					}
				}
			}

			.hero-image {
				display: flex;
				align-items: center;
				width: 100%;
				position: relative;
				visibility: visible;
				padding: 5% 0 10% 0;
				box-sizing: border-box;
				--psf-fill: var(--color-trendz-surface-accent);

				:global(video) {
					border: 1px solid #e6e6e6;
					box-shadow:
						0 0 12px 0 rgba(83, 92, 115, 0.02),
						0 24px 36px 0 rgba(83, 92, 115, 0.07);
				}
			}
		}
	}

	.btn-accent {
		@include hero-btn-base;
		@include trendz-body-m-medium;
		background: var(--color-trendz-accent);
		color: #ffffff;
		border: 1px solid var(--color-trendz-accent);
		transition: 0.3s;

		&:hover {
			background-color: var(--color-trendz-accent-hover);
			border-color: var(--color-trendz-accent-hover);
			color: #ffffff;
		}
	}

	.btn-outline {
		@include hero-btn-base;
		cursor: pointer;
		border: 1px solid var(--color-trendz-accent);
		background-color: transparent;
		transition: 0.6s;
		color: var(--color-trendz-accent);

		&:hover {
			background: var(--color-trendz-accent);
			color: #ffffff;
		}
	}

	// Heading slides in from left on page load (matches Animate.css fadeInLeft)
	.fade-in-left {
		opacity: 0;
		animation-name: fadeInLeft;
		animation-duration: 1s;
		animation-fill-mode: both;
	}

	@include media-down(sm) {
		#trendz-hero .hero-container #hero-content {
			align-items: center;
			text-align: center;

			padding: 20px 0;

			:global(.trendz-chip) {
				margin-left: auto;
				margin-right: auto;
			}
		}
	}

	@include media-up(sm) {
		#trendz-hero .hero-container {
			margin: 0 40px;

			#hero-content {
				flex: none;
				height: auto;

				.pe-subTitle {
					margin-bottom: 40px;
				}
			}

			.hero-image {
				width: 100%;
			}
		}
	}

	// 1024px+ — max-width container, larger fonts
	@include media-up(lg) {
		#trendz-hero .hero-container {
			margin: auto;
			width: calc(100% - 100px);
			max-width: 1200px;

			#hero-content {
				.btn-block {
					padding: 0;
					flex-direction: row;
					width: unset;

					div {
						width: unset;
					}
				}
			}

			.hero-image {
				padding: 12% 4% 10% 4%;
			}
		}

		.btn-accent {
			width: auto;
		}

		.btn-outline {
			width: auto;
		}
	}

	// 1280px+ — side-by-side layout, max container width
	@include media-up(xl) {
		#trendz-hero {
			height: calc(min(100vh, 1000px) - var(--header-height, 80px) - var(--promo-h, 0px));
			padding-top: unset;
			overflow: hidden;
		}

		#trendz-hero .hero-container {
			max-width: 1520px;
			flex-direction: row;

			#hero-content {
				flex: 1 1 50%;
				height: 100%;

				.pe-heading {
					padding-right: 10%;
				}
			}

			.hero-image {
				flex: 1 1 50%;
				height: 100%;
				padding: 0 0 0 40px;
			}
		}
	}

	@keyframes fadeInLeft {
		from {
			opacity: 0;
			transform: translate3d(-100%, 0, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}
</style>
