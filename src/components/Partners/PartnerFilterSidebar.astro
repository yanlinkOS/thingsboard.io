---
import { Icon } from 'astro-icon/components';

interface FilterGroup {
	name: string;
	key: string;
	values: { value: string; count: number }[];
}

interface Props {
	filters: FilterGroup[];
}

const { filters } = Astro.props;
---

<div class="filter-overlay" id="filter-overlay" hidden></div>

<aside class="filter-sidebar" id="filter-sidebar">
	<div class="filter-header">
		<h2>Filters</h2>
		<div class="filter-header-actions">
			<button type="button" class="clear-filters" id="clear-filters">
				Clear all
			</button>
			<button type="button" class="mobile-filter-close" id="mobile-filter-close" aria-label="Close filters">
				<Icon name="tabler:x" />
			</button>
		</div>
	</div>

	<div class="filter-groups-wrapper">
	{
		filters.map((group) => (
			<div class="filter-group" data-filter-key={group.key}>
				<h3 class="filter-group-title">{group.name}</h3>
				{group.values.length > 6 && (
					<div class="filter-search-wrapper">
						<Icon name="tabler:search" class="filter-search-icon" />
						<input
							type="text"
							class="filter-search"
							placeholder={`Search ${group.name.toLowerCase()}...`}
							aria-label={`Search ${group.name.toLowerCase()}`}
							autocomplete="off"
						/>
					</div>
				)}
				<div class="filter-options">
					{group.values.map((item) => (
						<label
							class="filter-option"
							data-filter-key={group.key}
							data-filter-value={item.value}
						>
							<input type="checkbox" name={group.key} value={item.value} />
							<span class="filter-label">{item.value}</span>
							<span class="filter-count">({item.count})</span>
						</label>
					))}
				</div>
			</div>
		))
	}
	</div>
</aside>

<script>
	function initFilterSearch() {
		document.querySelectorAll('.filter-search').forEach((input) => {
			input.addEventListener('input', () => {
				const query = (input as HTMLInputElement).value.toLowerCase();
				const group = input.closest('.filter-group');
				if (!group) return;

				group.querySelectorAll('.filter-option').forEach((option) => {
					const label = option.querySelector('.filter-label')?.textContent?.toLowerCase() || '';
					(option as HTMLElement).style.display = label.includes(query) ? '' : 'none';
				});
			});
		});
	}

	function initMobileFilterToggle() {
		const toggleBtn = document.getElementById('mobile-filter-toggle');
		const closeBtn = document.getElementById('mobile-filter-close');
		const sidebar = document.getElementById('filter-sidebar');
		const overlay = document.getElementById('filter-overlay');
		const badge = document.getElementById('filter-badge');

		if (!toggleBtn || !closeBtn || !sidebar || !overlay) return;

		function openFilters() {
			sidebar!.classList.add('open');
			overlay!.hidden = false;
			document.body.style.overflow = 'hidden';
		}

		function closeFilters() {
			sidebar!.classList.remove('open');
			overlay!.hidden = true;
			document.body.style.overflow = '';
		}

		function updateBadge() {
			if (!badge) return;
			const count = sidebar!.querySelectorAll<HTMLInputElement>(
				'input[type="checkbox"]:checked'
			).length;
			if (count > 0) {
				badge.textContent = String(count);
				badge.hidden = false;
			} else {
				badge.hidden = true;
			}
		}

		toggleBtn.addEventListener('click', openFilters);
		closeBtn.addEventListener('click', closeFilters);
		overlay.addEventListener('click', closeFilters);

		sidebar.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((cb) => {
			cb.addEventListener('change', updateBadge);
		});

		const clearBtn = document.getElementById('clear-filters');
		clearBtn?.addEventListener('click', () => {
			setTimeout(updateBadge, 0);
		});
	}

	initFilterSearch();
	initMobileFilterToggle();
	document.addEventListener('astro:page-load', () => {
		initFilterSearch();
		initMobileFilterToggle();
	});
</script>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.filter-overlay {
		display: none;
	}

	.mobile-filter-close {
		display: none;
		align-items: center;
		justify-content: center;
		background: none;
		border: none;
		color: var(--color-text);
		cursor: pointer;
		padding: 0.25rem;

		:global(svg) {
			width: 20px;
			height: 20px;
		}
	}

	.filter-header-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.filter-sidebar {
		width: 100%;
		max-width: 280px;
		position: sticky;
		top: 5rem;
		max-height: calc(100vh - 6rem);
		padding: 1rem;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: 0.5rem;
		overflow-y: auto;
	}

	.filter-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--color-border);
	}

	.filter-header h2 {
		@include text-m;
		font-weight: $font-weight-semibold;
		margin: 0;
	}

	.clear-filters {
		@include text-s;
		background: none;
		border: none;
		color: var(--color-primary);
		cursor: pointer;
		padding: 0;
	}

	.clear-filters:hover {
		text-decoration: underline;
	}

	.filter-group {
		margin-bottom: 1.25rem;
	}

	.filter-group-title {
		@include text-s;
		font-weight: $font-weight-semibold;
		margin: 0 0 0.5rem 0;
	}

	.filter-search-wrapper {
		position: relative;
		display: flex;
		align-items: center;
		margin-bottom: 0.5rem;
	}

	.filter-search-icon {
		position: absolute;
		left: 0.5rem;
		width: 14px;
		height: 14px;
		color: var(--color-text-muted);
		pointer-events: none;
	}

	.filter-search {
		width: 100%;
		padding: 0.375rem 0.5rem 0.375rem 1.75rem;
		font-size: $font-size-sm;
		border: 1px solid var(--color-border);
		border-radius: 0.375rem;
		background: var(--color-bg);
		color: var(--color-text);
		transition:
			border-color 0.2s,
			box-shadow 0.2s;
	}

	.filter-search::placeholder {
		color: var(--color-text-muted);
	}

	.filter-search:focus {
		outline: none;
		border-color: var(--color-primary);
		box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 20%, transparent);
	}

	.filter-options {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.filter-option {
		@include text-s;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		cursor: pointer;
	}

	.filter-option.is-disabled {
		cursor: not-allowed;

		.filter-label,
		.filter-count {
			color: var(--color-text-muted);
			opacity: 0.6;
		}
	}

	.filter-option input[type='checkbox'] {
		width: 1rem;
		height: 1rem;
		cursor: pointer;
		accent-color: var(--color-primary);
	}

	.filter-option input[type='checkbox']:disabled {
		cursor: not-allowed;
	}

	.filter-label {
		flex: 1;
		color: var(--color-text);
	}

	.filter-count {
		color: var(--color-text-muted);
		font-size: $font-size-xs;
	}

	@include media-down(md) {
		.mobile-filter-close {
			display: flex;
		}

		.filter-overlay {
			position: fixed;
			inset: 0;
			background: rgba(0, 0, 0, 0.4);
			z-index: 10001;
		}

		.filter-overlay[hidden] {
			display: none;
		}

		.filter-sidebar {
			display: none;
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
			max-width: 100%;
			max-height: 100%;
			border: none;
			border-radius: 0;
			z-index: 10002;
			padding: 0;
			background: var(--color-bg);
			overflow-y: hidden;
		}

		.filter-sidebar.open {
			display: flex;
			flex-direction: column;
		}

		.filter-header {
			flex-shrink: 0;
			padding: 1.25rem 1.25rem 0.75rem;
			margin-bottom: 0;
			border-bottom: 1px solid var(--color-border);
		}

		.filter-header h2 {
			font-size: 1.5rem;
		}

		.filter-sidebar.open .filter-groups-wrapper {
			overflow-y: auto;
			flex: 1;
			padding: 1.25rem;
		}
	}
</style>
