---
import { Icon } from 'astro-icon/components';
import PartnerCard from './PartnerCard.astro';
import PartnerFilterSidebar from './PartnerFilterSidebar.astro';
import SearchBar from '../DeviceLibrary/SearchBar.astro';
import Pagination from '../DeviceLibrary/Pagination.astro';
import type { HardwarePartner } from '~/data/partners/types';

interface Props {
	partners: HardwarePartner[];
}

const { partners } = Astro.props;

const PAGE_SIZE = 12;

function getFilterValues(key: keyof HardwarePartner): { value: string; count: number }[] {
	const counts = new Map<string, number>();
	partners.forEach((partner) => {
		const values = partner[key];
		if (Array.isArray(values)) {
			values.forEach((v) => {
				const str = typeof v === 'string' ? v : String(v);
				counts.set(str, (counts.get(str) || 0) + 1);
			});
		}
	});
	return Array.from(counts.entries())
		.map(([value, count]) => ({ value, count }))
		.sort((a, b) => a.value.localeCompare(b.value));
}

const filterGroups = [
	{ name: 'Hardware Types', key: 'hardwareTypes', values: getFilterValues('hardwareTypes') },
	{ name: 'Connectivity', key: 'connectivity', values: getFilterValues('connectivity') },
	{ name: 'Industry', key: 'industry', values: getFilterValues('industry') },
	{ name: 'Use Cases', key: 'useCase', values: getFilterValues('useCase') },
];

---

<div class="partner-library" data-page-size={PAGE_SIZE}>
	<PartnerFilterSidebar filters={filterGroups} />

	<div class="partner-library-main">
		<div class="partner-library-header">
			<button type="button" class="mobile-filter-toggle" id="mobile-filter-toggle">
				<Icon name="tabler:filter" />
				<span>Filters</span>
				<span class="filter-badge" id="filter-badge" hidden></span>
			</button>
			<SearchBar placeholder="Search partners..." />
			<div class="partner-count">
				<span id="partner-count">{partners.length}</span>
				partners found
			</div>
		</div>

		<div class="partner-grid" id="partner-grid">
			{
				partners.map((partner, index) => (
					<PartnerCard
						name={partner.name}
						slug={partner.slug}
						logo={partner.logo}
						description={partner.description}
						connectivity={partner.connectivity}
						industry={partner.industry}
						useCase={partner.useCase}
						hardwareTypes={partner.hardwareTypes}
						href={`/partners/hardware/${partner.slug}/`}
						hidden={index >= PAGE_SIZE}
					/>
				))
			}
		</div>

		<div class="no-results" id="no-results" hidden>
			No partners match your filters.
		</div>

		<Pagination translations={{ previous: 'Previous', next: 'Next', page: 'Page', of: 'of' }} />
	</div>
</div>

<script>
	type FilterKey = 'connectivity' | 'industry' | 'useCase' | 'hardwareTypes';

	const FILTER_KEYS: FilterKey[] = ['connectivity', 'industry', 'useCase', 'hardwareTypes'];

	interface CardInfo {
		el: HTMLElement;
		slug: string;
		name: string;
		description: string;
		connectivity: string[];
		industry: string[];
		useCase: string[];
		hardwareTypes: string[];
		searchText: string;
	}

	interface FilterOption {
		label: HTMLLabelElement;
		checkbox: HTMLInputElement;
		countEl: HTMLElement | null;
		key: string;
		value: string;
	}

	interface SearchParams {
		search: string;
		filters: Record<string, string[]>;
		page: number;
		pageSize: number;
	}

	interface SearchResult {
		cards: CardInfo[];
		total: number;
		totalPages: number;
		currentPage: number;
	}

	function readCards(grid: HTMLElement): CardInfo[] {
		return Array.from(grid.querySelectorAll<HTMLElement>('.partner-card')).map((el) => {
			const name = el.dataset.name || '';
			const description = el.dataset.description || '';
			const connectivity = JSON.parse(el.dataset.connectivity || '[]');
			const industry = JSON.parse(el.dataset.industry || '[]');
			const useCase = JSON.parse(el.dataset.useCase || '[]');
			const hardwareTypes = JSON.parse(el.dataset.hardwareTypes || '[]');
			return {
				el,
				slug: el.dataset.partnerSlug || '',
				name,
				description,
				connectivity,
				industry,
				useCase,
				hardwareTypes,
				searchText: [name, description, ...connectivity, ...industry, ...useCase, ...hardwareTypes]
					.join(' ')
					.toLowerCase(),
			};
		});
	}

	function readFilterOptions(sidebar: Element): FilterOption[] {
		return Array.from(
			sidebar.querySelectorAll<HTMLLabelElement>('.filter-option[data-filter-key]')
		).map((label) => ({
			label,
			checkbox: label.querySelector<HTMLInputElement>('input[type="checkbox"]')!,
			countEl: label.querySelector<HTMLElement>('.filter-count'),
			key: label.dataset.filterKey || '',
			value: label.dataset.filterValue || '',
		}));
	}

	function matchesSearch(card: CardInfo, query: string): boolean {
		return !query || card.searchText.includes(query);
	}

	function matchesFilters(
		card: CardInfo,
		filters: Record<string, string[]>,
		exceptKey?: FilterKey
	): boolean {
		for (const [key, values] of Object.entries(filters)) {
			if (key === exceptKey) continue;
			const cardValues = card[key as FilterKey] || [];
			if (!values.some((v) => cardValues.includes(v))) return false;
		}
		return true;
	}

	function searchCards(allCards: CardInfo[], params: SearchParams): SearchResult {
		const query = params.search.toLowerCase();
		const filtered = allCards.filter(
			(card) => matchesSearch(card, query) && matchesFilters(card, params.filters)
		);
		const total = filtered.length;
		const totalPages = Math.ceil(total / params.pageSize) || 1;
		const currentPage = Math.min(Math.max(1, params.page), totalPages);
		const startIndex = (currentPage - 1) * params.pageSize;
		const cards = filtered.slice(startIndex, startIndex + params.pageSize);
		return { cards, total, totalPages, currentPage };
	}

	function computeFacetCounts(
		allCards: CardInfo[],
		filters: Record<string, string[]>,
		query: string
	): Record<string, Map<string, number>> {
		const result: Record<string, Map<string, number>> = {};
		for (const key of FILTER_KEYS) {
			const selection = new Set(filters[key] || []);
			const hasSelection = selection.size > 0;

			const counts = new Map<string, number>();
			for (const card of allCards) {
				if (!matchesSearch(card, query) || !matchesFilters(card, filters, key)) continue;
				const cardMatchesSelection =
					hasSelection && card[key].some((v) => selection.has(v));
				for (const value of card[key]) {
					// Unselected value in a card already part of the current OR-set adds nothing
					if (hasSelection && !selection.has(value) && cardMatchesSelection) continue;
					counts.set(value, (counts.get(value) || 0) + 1);
				}
			}
			result[key] = counts;
		}
		return result;
	}

	function updateFacets(
		options: FilterOption[],
		counts: Record<string, Map<string, number>>,
		filters: Record<string, string[]>
	) {
		for (const opt of options) {
			const count = counts[opt.key]?.get(opt.value) ?? 0;
			const selection = filters[opt.key] || [];
			const isDelta = selection.length > 0 && !selection.includes(opt.value);
			if (opt.countEl) opt.countEl.textContent = isDelta ? `(+${count})` : `(${count})`;
			const shouldDisable = count === 0 && !opt.checkbox.checked;
			opt.checkbox.disabled = shouldDisable;
			opt.label.classList.toggle('is-disabled', shouldDisable);
		}
	}

	function initPartnerLibrary() {
		const container = document.querySelector('.partner-library');
		if (!container) return;

		const partnerGrid = container.querySelector('#partner-grid') as HTMLElement;
		const partnerCountEl = container.querySelector('#partner-count') as HTMLElement;
		const noResultsEl = container.querySelector('#no-results') as HTMLElement;
		const clearFiltersBtn = container.querySelector('#clear-filters');
		const sidebar = container.querySelector('.filter-sidebar') as HTMLElement;
		const filterCheckboxes = container.querySelectorAll<HTMLInputElement>(
			'.filter-sidebar input[type="checkbox"]'
		);
		const searchInput = container.querySelector('#device-search') as HTMLInputElement;
		const searchClearBtn = container.querySelector('#search-clear') as HTMLButtonElement;
		const pagination = container.querySelector('#pagination') as HTMLElement;
		const paginationPages = container.querySelector('#pagination-pages') as HTMLElement;
		const paginationPrev = container.querySelector('#pagination-prev') as HTMLButtonElement;
		const paginationNext = container.querySelector('#pagination-next') as HTMLButtonElement;
		const paginationInfo = container.querySelector('#pagination-info') as HTMLElement;
		const paginationCurrent = container.querySelector('#pagination-current') as HTMLElement;
		const paginationTotal = container.querySelector('#pagination-total') as HTMLElement;

		if (!partnerGrid || !partnerCountEl || !searchInput || !sidebar) return;

		const pageSize = parseInt(container.getAttribute('data-page-size') || '12', 10);
		let currentPage = 1;
		let debounceTimer: ReturnType<typeof setTimeout>;

		function getActiveFilters(): Record<string, string[]> {
			const filters: Record<string, string[]> = {};
			filterCheckboxes.forEach((checkbox) => {
				if (checkbox.checked) {
					const key = checkbox.name;
					if (!filters[key]) filters[key] = [];
					filters[key].push(checkbox.value);
				}
			});
			return filters;
		}

		function renderPagination(currentPage: number, totalPages: number) {
			if (totalPages <= 1) {
				pagination.hidden = true;
				paginationInfo.hidden = true;
				return;
			}

			pagination.hidden = false;
			paginationInfo.hidden = false;

			paginationPrev.disabled = currentPage <= 1;
			paginationNext.disabled = currentPage >= totalPages;

			paginationCurrent.textContent = String(currentPage);
			paginationTotal.textContent = String(totalPages);

			const pages: (number | string)[] = [];
			const maxVisible = 5;

			if (totalPages <= maxVisible) {
				for (let i = 1; i <= totalPages; i++) pages.push(i);
			} else {
				pages.push(1);
				if (currentPage > 3) pages.push('...');
				const start = Math.max(2, currentPage - 1);
				const end = Math.min(totalPages - 1, currentPage + 1);
				for (let i = start; i <= end; i++) {
					if (!pages.includes(i)) pages.push(i);
				}
				if (currentPage < totalPages - 2) pages.push('...');
				if (!pages.includes(totalPages)) pages.push(totalPages);
			}

			paginationPages.innerHTML = pages
				.map((p) =>
					typeof p === 'number'
						? `<button type="button" class="page-btn${p === currentPage ? ' active' : ''}" data-page="${p}">${p}</button>`
						: `<span class="page-ellipsis">${p}</span>`
				)
				.join('');
		}

		const allCards = readCards(partnerGrid);
		const filterOptions = readFilterOptions(sidebar);

		function updateDisplay() {
			const filters = getActiveFilters();
			const query = searchInput.value.trim().toLowerCase();
			const result = searchCards(allCards, {
				search: searchInput.value.trim(),
				filters,
				page: currentPage,
				pageSize,
			});

			partnerCountEl.textContent = String(result.total);

			const visibleSlugs = new Set(result.cards.map((c) => c.slug));
			allCards.forEach((card) => {
				card.el.classList.toggle('is-hidden', !visibleSlugs.has(card.slug));
			});
			noResultsEl.hidden = result.cards.length > 0;

			updateFacets(filterOptions, computeFacetCounts(allCards, filters, query), filters);

			currentPage = result.currentPage;
			renderPagination(result.currentPage, result.totalPages);
			searchClearBtn.hidden = !searchInput.value;
		}

		function resetAndUpdate() {
			currentPage = 1;
			updateDisplay();
		}

		filterCheckboxes.forEach((checkbox) => {
			checkbox.addEventListener('change', resetAndUpdate);
		});

		clearFiltersBtn?.addEventListener('click', () => {
			filterCheckboxes.forEach((checkbox) => {
				checkbox.checked = false;
			});
			resetAndUpdate();
		});

		searchInput.addEventListener('input', () => {
			clearTimeout(debounceTimer);
			debounceTimer = setTimeout(resetAndUpdate, 300);
		});

		searchClearBtn?.addEventListener('click', () => {
			searchInput.value = '';
			resetAndUpdate();
			searchInput.focus();
		});

		paginationPrev?.addEventListener('click', () => {
			if (currentPage > 1) {
				currentPage--;
				updateDisplay();
				partnerGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		});

		paginationNext?.addEventListener('click', () => {
			currentPage++;
			updateDisplay();
			partnerGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
		});

		paginationPages?.addEventListener('click', (e) => {
			const target = e.target as HTMLElement;
			if (target.classList.contains('page-btn')) {
				const page = parseInt(target.dataset.page || '1', 10);
				if (page !== currentPage) {
					currentPage = page;
					updateDisplay();
					partnerGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
				}
			}
		});

		const initialTotalPages = Math.ceil(allCards.length / pageSize);
		renderPagination(1, initialTotalPages);
	}

	initPartnerLibrary();
	document.addEventListener('astro:page-load', initPartnerLibrary);
</script>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.partner-library {
		display: flex;
		gap: 2rem;
		align-items: flex-start;
	}

	.partner-library-main {
		flex: 1;
		min-width: 0;
	}

	.partner-library-header {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.mobile-filter-toggle {
		display: none;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		background: var(--color-primary);
		border: none;
		border-radius: var(--radius-md);
		@include text-s;
		font-weight: $font-weight-semibold;
		color: #fff;
		cursor: pointer;
		white-space: nowrap;

		:global(svg) {
			width: 16px;
			height: 16px;
		}

		:global([data-theme='dark']) & {
			color: #1a1a2e;
		}
	}

	.filter-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.25rem;
		height: 1.25rem;
		padding: 0 0.25rem;
		background: #fff;
		color: var(--color-primary);
		border-radius: 1rem;
		@include text-xs;
		font-weight: $font-weight-bold;
	}

	.filter-badge[hidden] {
		display: none;
	}

	.partner-count {
		@include text-s;
		color: var(--color-text-secondary);
	}

	.partner-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.no-results {
		text-align: center;
		padding: 3rem 1rem;
		color: var(--color-text-secondary);
		@include text-m;
	}

	.no-results[hidden] {
		display: none;
	}

	@include media-down(md) {
		.partner-library {
			flex-direction: column;
		}

		.mobile-filter-toggle {
			display: inline-flex;
		}

		.partner-library-header {
			flex-direction: row;
			align-items: center;
			flex-wrap: nowrap;
		}

		.partner-grid {
			grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
		}
	}
</style>

