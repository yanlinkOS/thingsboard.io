const rawWidgets = bundleMap[bundle] ?? [];
const widgets = rawWidgets.map((w) => ({
	...w,
	href: w.path ? docsLink(product, w.path) : undefined,
}));
---

<ul class="widget-grid not-content">
	{
		widgets.map(({ name, image, description, href }) => (
			<li class:list={['widget-card', { 'widget-card--linked': !!href }]}>
				{href ? (
					<a href={href} class="widget-card-inner">
						<div class="widget-img">
							<img src={image} alt={name} loading="lazy" />
						</div>
						<div class="widget-info">
							<strong class="widget-name">{name}</strong>
							<p class="widget-desc">{description}</p>
						</div>
					</a>
				) : (
					<div class="widget-card-inner">
						<div class="widget-img">
							<img src={image} alt={name} loading="lazy" />
						</div>
						<div class="widget-info">
							<strong class="widget-name">{name}</strong>
							<p class="widget-desc">{description}</p>
						</div>
					</div>
				)}
			</li>
		))
	}
</ul>

<style>
	.widget-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1rem;
		padding: 0;
		margin-block: 1.5rem 0;
		list-style: none;
	}

	@media (max-width: 72rem) {
		.widget-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 50rem) {
		.widget-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 30rem) {
		.widget-grid {
			grid-template-columns: 1fr;
		}
	}

	.widget-card {
		border: 1px solid var(--sl-color-hairline-light);
		border-radius: 0.5rem;
		overflow: hidden;
		transition: border-color 0.2s;
	}

	.widget-card--linked {
		position: relative;
	}

	.widget-card--linked:hover,
	.widget-card--linked:focus-within {
		border-color: var(--sl-color-text-accent);
		background-color: var(--sl-color-gray-6);
	}

	.widget-card-inner {
		display: flex;
		flex-direction: column;
		height: 100%;
		text-decoration: none;
		color: inherit;
	}

	.widget-card--linked a.widget-card-inner::before {
		content: '';
		position: absolute;
		inset: 0;
	}

	.widget-card--linked a:focus {
		outline: none;
	}

	.widget-img {
		background-color: var(--sl-color-bg-nav);
		border-bottom: 1px solid var(--sl-color-hairline-light);
		display: flex;
		align-items: center;
		justify-content: center;
		height: 130px;
		padding: 0.75rem;
		overflow: hidden;
	}

	.widget-img img {
		max-width: 100%;
		max-height: 100%;
		width: auto;
		height: auto;
		object-fit: contain;
	}

	.widget-info {
		padding: 0.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.widget-name {
		font-size: var(--sl-text-sm);
		font-weight: 600;
		line-height: var(--sl-line-height-headings);
		color: var(--sl-color-white);
	}

	.widget-desc {
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
		line-height: 1.4;
		margin: 0;
	}
</style>
