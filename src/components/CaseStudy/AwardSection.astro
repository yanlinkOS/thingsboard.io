---
import type { AwardData } from '@data/case-studies/types.ts';

type Props = AwardData;

const { image, imageAlt, imageWidth, imageHeight, title, titleHref, description } = Astro.props;
---

<section class="cs-award cs-section">
	<div class="cs-award-image">
		{titleHref ? (
			<a href={titleHref}><img src={image} alt={imageAlt} width={imageWidth} height={imageHeight} loading="lazy" decoding="async" /></a>
		) : (
			<img src={image} alt={imageAlt} width={imageWidth} height={imageHeight} loading="lazy" decoding="async" />
		)}
	</div>
	<div class="cs-award-text">
		<h3>
			{titleHref ? (
				<a href={titleHref}>{title}</a>
			) : (
				title
			)}
		</h3>
		<p set:html={description} />
	</div>
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.cs-award {
		display: flex;
		align-items: center;
		gap: $spacing-10;
		padding: $spacing-10 0;

		@include media-down(lg) {
			flex-direction: column;
			gap: $spacing-6;
		}

		.cs-award-image {
			flex-shrink: 0;

			img {
				max-width: 228px;
				height: auto;
			}

			a {
				display: block;
			}
		}

		.cs-award-text {
			flex: 1;

			h3 {
				@include card-title;
				color: var(--color-text);
				margin: 0 0 $spacing-4;

				a {
					color: var(--color-primary);
					text-decoration: none;

					&:hover {
						text-decoration: underline;
					}
				}
			}

			p {
				@include text-s;
				margin: 0 0 $spacing-3;

				&:last-child {
					margin-bottom: 0;
				}
			}
		}
	}
</style>
