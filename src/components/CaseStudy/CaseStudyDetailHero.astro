---
interface Props {
	category: string;
	heading: string;
	paragraphs: string[];
	logo: string;
	logoAlt: string;
	backgroundImage: string;
}

const { category, heading, paragraphs, logo, logoAlt, backgroundImage } = Astro.props;
---

<section class="cs-hero">
	<div class="cs-hero-card">
		<div class="cs-hero-text">
			<p class="cs-hero-category">{category}</p>
			<h1 class="cs-hero-heading">{heading}</h1>
			<div class="cs-hero-image-inner" style={`background-image: url('${backgroundImage}')`}>
				<div class="cs-hero-logo-wrap">
					<img src={logo} alt={logoAlt} fetchpriority="high" loading="eager" decoding="async" />
				</div>
			</div>
			{paragraphs.map((p) => <p class="cs-hero-paragraph" set:html={p} />)}
		</div>
		<div class="cs-hero-image-large" style={`background-image: url('${backgroundImage}')`}>
			<div class="cs-hero-logo-wrap">
				<img src={logo} alt={logoAlt} fetchpriority="high" loading="eager" decoding="async" />
			</div>
		</div>
	</div>
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.cs-hero {
		margin-bottom: $spacing-12;
	}

	.cs-hero-card {
		display: flex;
		gap: $spacing-8;
		align-items: center;

		@include media-down(lg) {
			flex-direction: column;
		}
	}

	.cs-hero-text {
		flex: 1;

		.cs-hero-category {
			@include text-s;
			font-weight: $font-weight-semibold;
			text-transform: uppercase;
			color: var(--color-primary);
			letter-spacing: 0.5px;
			margin: 0 0 $spacing-4;
		}

		.cs-hero-heading {
			@include section-title;
			color: var(--color-text);
			margin: 0 0 $spacing-6;
		}

		.cs-hero-paragraph {
			@include text-s;
			margin: 0 0 $spacing-3;

			&:last-child {
				margin-bottom: 0;
			}
		}
	}

	.cs-hero-logo-wrap {
		width: 200px;
		height: 140px;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;

		img {
			max-width: 100%;
			max-height: 100%;
			width: auto;
			height: auto;
			object-fit: contain;
		}
	}

	.cs-hero-image-inner {
		display: none;
		background-size: cover;
		background-position: center;
		border-radius: $radius-xl;
		padding: $spacing-10;
		margin-bottom: $spacing-6;
		min-height: 200px;
		align-items: center;
		justify-content: center;

		@include media-down(lg) {
			display: flex;
		}
	}

	.cs-hero-image-large {
		flex: 0 0 420px;
		height: 400px;
		background-size: cover;
		background-position: center;
		border-radius: $radius-xl;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: $spacing-8;

		@include media-down(lg) {
			display: none;
		}
	}
</style>
