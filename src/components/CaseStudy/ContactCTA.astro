---
interface Props {
	companyLogo: string;
	companyLogoAlt: string;
	companyLogoWidth?: number;
	companyLogoHeight?: number;
}

const { companyLogo, companyLogoAlt, companyLogoWidth, companyLogoHeight } = Astro.props;
---

<section class="cs-contact-cta">
	<div class="cs-contact-bg" style="background-image: linear-gradient(0deg, rgba(0, 0, 0, 0.30) 0%, rgba(0, 0, 0, 0.30) 100%), url(https://img.thingsboard.io/case-studies/handshake.webp)">
		<div class="cs-contact-outer-frame">
			<div class="cs-contact-inner-frame">
				<img class="cs-contact-logo-tb" src="https://img.thingsboard.io/case-studies/thingsboard.svg" alt="ThingsBoard logo" width="298" height="56" />
				<img class="cs-contact-logo-company" src={companyLogo} alt={companyLogoAlt} width={companyLogoWidth} height={companyLogoHeight} />
			</div>
		</div>
	</div>
	<p class="cs-contact-text">Real stories, real impact — share your experience with ThingsBoard!</p>
	<a target="_blank" href="/contact-us/" class="cs-contact-button">Contact us</a>
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.cs-contact-cta {
		text-align: center;
		margin-top: $spacing-16;
	}

	.cs-contact-bg {
		background-size: cover;
		background-position: center;
		border-radius: $radius-xl;
		padding: $spacing-10;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 340px;
		margin-bottom: $spacing-8;

		@include media-down(md) {
			padding: $spacing-6;
			min-height: 260px;
		}
	}

	// Outer frame — full rectangle border
	.cs-contact-outer-frame {
		border: 2px solid rgba(255, 255, 255, 1);
		padding: 20px;
		max-width: 728px;
		width: 100%;

		@include media-down(md) {
			padding: 14px;
		}
	}

	// Inner frame — corner brackets via pseudo-elements
	.cs-contact-inner-frame {
		position: relative;
		padding: 30px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: space-between;
		min-height: 260px;

		@include media-down(md) {
			padding: 20px;
			min-height: 200px;
		}

		// Top-right corner bracket
		&::before {
			content: '';
			position: absolute;
			top: 0;
			right: 0;
			width: 300px;
			height: 150px;
			border-top: 2px solid rgba(255, 255, 255, 1);
			border-right: 2px solid rgba(255, 255, 255, 1);
			pointer-events: none;

			@include media-down(md) {
				width: 200px;
				height: 100px;
			}
		}

		// Bottom-left corner bracket
		&::after {
			content: '';
			position: absolute;
			bottom: 0;
			left: 0;
			width: 300px;
			height: 150px;
			border-bottom: 2px solid rgba(255, 255, 255, 1);
			border-left: 2px solid rgba(255, 255, 255, 1);
			pointer-events: none;

			@include media-down(md) {
				width: 200px;
				height: 100px;
			}
		}
	}

	// ThingsBoard logo — top-right
	.cs-contact-logo-tb {
		align-self: flex-end;
		max-height: 48px;
		width: auto;
		max-width: 260px;
		z-index: 1;
		filter: brightness(0) invert(1);

		@include media-down(md) {
			max-height: 36px;
			max-width: 180px;
		}
	}

	// Company logo — bottom-left
	.cs-contact-logo-company {
		align-self: flex-start;
		max-height: 80px;
		width: auto;
		max-width: 300px;
		z-index: 1;
		filter: brightness(0) invert(1);

		@include media-down(md) {
			max-height: 50px;
			max-width: 200px;
		}
	}

	.cs-contact-text {
		@include text-m;
		margin: 0 0 $spacing-6;
	}

	.cs-contact-button {
		@include button-primary;
		text-decoration: none;
	}
</style>
