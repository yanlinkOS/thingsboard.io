---
import { Icon } from 'astro-icon/components';
import SectionBadge from '../SectionBadge.astro';

interface Props {
	badge?: string;
	description?: string;
	challenges: string[];
	results: string[];
}

const { badge, description, challenges, results } = Astro.props;
---

<section class="cs-problem cs-section">
	<div class="cs-problem-header">
		<SectionBadge text={badge || 'Challenges & results'} color="#8B6914" borderColor="#c4992e" />
		<h2>What problem did they face?</h2>
		{description && <p set:html={description} />}
	</div>
	<div class="cs-problem-cards">
		<div class="cs-problem-card cs-problem-card--challenges">
			<h3>Challenges</h3>
			<ul>
				{challenges.map((item) => (
					<li>
						<Icon name="tabler:help-circle" />
						<p set:html={item} />
					</li>
				))}
			</ul>
		</div>
		<div class="cs-problem-card cs-problem-card--results">
			<h3>Key results</h3>
			<ul>
				{results.map((item) => (
					<li>
						<Icon name="tabler:circle-check" />
						<p set:html={item} />
					</li>
				))}
			</ul>
		</div>
	</div>
</section>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.cs-problem-header {
		margin-bottom: $spacing-8;

		.section-badge {
			margin-bottom: $spacing-3;
		}

		h2 {
			@include section-title;
			color: var(--color-text);
			margin: 0 0 $spacing-4;
		}

		p {
			@include text-m;
			margin: 0;
		}
	}

	.cs-problem-cards {
		display: flex;
		gap: $spacing-6;

		@include media-down(lg) {
			flex-direction: column;
		}
	}

	.cs-problem-card {
		flex: 1;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: $radius-xl;
		padding: $spacing-8;

		h3 {
			@include card-title;
			color: var(--color-text);
			margin: 0 0 $spacing-6;
		}

		ul {
			list-style: none;
			padding: 0;
			margin: 0;
		}

		li {
			display: flex;
			gap: $spacing-3;
			margin-bottom: $spacing-4;
			align-items: flex-start;

			&:last-child {
				margin-bottom: 0;
			}

			> svg,
			> [data-icon] {
				flex-shrink: 0;
				margin-top: 2px;
				width: 20px;
				height: 20px;
			}

			p {
				@include text-s;
				margin: 0;
			}
		}

		&--challenges {
			svg {
				color: var(--color-warning);
			}
		}

		&--results {
			svg {
				color: var(--color-success);
			}
		}
	}
</style>
