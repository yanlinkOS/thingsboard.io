---
import fs from 'node:fs';
import { join } from 'node:path';
import { docsLink, type Products } from '~/models/site.models';

export interface Props {
	product: Products;
	group: string;
}

const groups: Record<string, { name: string; icon: string; path: string }[]> = {
	'standard-protocols': [
		{ name: 'HTTP', icon: 'http', path: 'user-guide/integrations/http/' },
		{ name: 'MQTT', icon: 'mqtt', path: 'user-guide/integrations/mqtt/' },
		{ name: 'CoAP', icon: 'coap', path: 'user-guide/integrations/coap/' },
		{ name: 'TCP', icon: 'tcp', path: 'user-guide/integrations/tcp/' },
		{ name: 'UDP', icon: 'udp', path: 'user-guide/integrations/udp/' },
	],
	'lorawan-servers': [
		{ name: 'ChirpStack', icon: 'chirpstack', path: 'user-guide/integrations/chirpstack/' },
		{ name: 'TheThingsStack Community', icon: 'ttn', path: 'user-guide/integrations/ttn/' },
		{ name: 'TheThingsStack Industries', icon: 'things-stack-industries', path: 'user-guide/integrations/tti/' },
		{ name: 'Loriot', icon: 'loriot', path: 'user-guide/integrations/loriot/' },
		{ name: 'ThingPark', icon: 'thingpark', path: 'user-guide/integrations/thingpark/' },
		{ name: 'ThingPark Enterprise', icon: 'thingpark-enterprise', path: 'user-guide/integrations/thingparkenterprise/' },
		{ name: 'KPN Things', icon: 'kpn-things', path: 'user-guide/integrations/kpn-things/' },
	],
	'cloud-iot': [
		{ name: 'AWS IoT', icon: 'aws-iot', path: 'user-guide/integrations/aws-iot/' },
		{ name: 'Azure IoT Hub', icon: 'azure-iot-hub', path: 'user-guide/integrations/azure-iot-hub/' },
		{ name: 'Particle', icon: 'particle', path: 'user-guide/integrations/particle/' },
	],
	'message-brokers': [
		{ name: 'Kafka', icon: 'kafka', path: 'user-guide/integrations/kafka/' },
		{ name: 'Apache Pulsar', icon: 'apache-pulsar', path: 'user-guide/integrations/apache-pulsar/' },
		{ name: 'RabbitMQ', icon: 'rabbitmq', path: 'user-guide/integrations/rabbitmq/' },
		{ name: 'AWS Kinesis', icon: 'aws-kinesis', path: 'user-guide/integrations/aws-kinesis/' },
		{ name: 'AWS SQS', icon: 'aws-sqs', path: 'user-guide/integrations/aws-sqs/' },
		{ name: 'Azure Event Hub', icon: 'azure-event-hub', path: 'user-guide/integrations/azure-event-hub/' },
		{ name: 'Azure Service Bus', icon: 'azure-service-bus', path: 'user-guide/integrations/azure-service-bus/' },
		{ name: 'Pub/Sub', icon: 'pub-sub', path: 'user-guide/integrations/pub-sub/' },
	],
	'industrial-opc': [
		{ name: 'OPC-UA', icon: 'opc-ua', path: 'user-guide/integrations/opc-ua/' },
	],
	'nb-iot-cellular': [
		{ name: 'SigFox', icon: 'sigfox', path: 'user-guide/integrations/sigfox/' },
{ name: 'IoT Creators', icon: 'iotcreators', path: 'user-guide/integrations/iotcreators/' },
	],
	'consumer-iot': [
		{ name: 'Tuya', icon: 'tuya', path: 'user-guide/integrations/tuya/' },
	],
	'custom': [
		{ name: 'Custom', icon: 'custom', path: 'user-guide/integrations/custom/' },
	],
};

const { product, group } = Astro.props;

const items = (groups[group] ?? []).map((item) => {
	const svgPath = join(process.cwd(), 'public', 'logos', 'integration', `${item.icon}.svg`);
	let svg = '';
	try {
		svg = fs.readFileSync(svgPath, 'utf-8');
	} catch {
		/* file not found — svg stays empty */
	}
	return { ...item, href: docsLink(product, item.path), svg };
});
---

<ul class="integrations-grid not-content">
	{
		items.map(({ name, svg, href }) => (
			<li class="card">
				<a href={href}>
					<div class="logo" set:html={svg} />
					<span>{name}</span>
				</a>
			</li>
		))
	}
</ul>

<style>
	.integrations-grid {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 1.5rem 0.75rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	@media (max-width: 56rem) {
		.integrations-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	@media (max-width: 40rem) {
		.integrations-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 24rem) {
		.integrations-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.card {
		position: relative;
		padding: 0.75rem;
		display: grid;
		grid-template-columns: 1fr;
		justify-items: center;
		text-align: center;
		border-radius: 0.5rem;
	}

	.card:hover,
	.card:focus-within {
		background-color: var(--sl-color-gray-6);
		outline: 1px solid var(--sl-color-text-accent);
	}

	@media (forced-colors: active) {
		.card:hover,
		.card:focus-within {
			outline: 1px solid LinkText;
		}
	}

	a {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: var(--sl-color-white);
	}

	.card a::before {
		content: '';
		position: absolute;
		inset: 0;
	}

	.card a:focus {
		outline: none;
	}

	.logo {
		display: flex;
		place-content: center;
		align-items: center;
		width: 4rem;
		height: 4rem;
		background-color: var(--sl-color-gray-7, var(--sl-color-gray-6));
		border: 1px solid var(--sl-color-hairline-light);
		outline: 1px solid transparent;
		border-radius: 50%;
		overflow: hidden;
		color: var(--sl-color-white);
	}

	.logo :global(svg) {
		width: 2.25rem;
		height: 2.25rem;
	}

	span {
		font-size: var(--sl-text-body);
		font-weight: 600;
		line-height: var(--sl-line-height-headings);
	}
</style>
