---
import '@docsearch/css/dist/modal.css';
import './starlight/Search/variables.css';
---

<search-button>
	<button type="button" class="search-toggle-btn" aria-label="Search">
		<svg
			width="20"
			height="20"
			viewBox="0 0 20 20"
			fill="none"
			stroke="currentColor"
			stroke-linecap="round"
			stroke-linejoin="round"
			stroke-width="2"
		>
			<path
				d="M14.386 14.386l4.0877 4.0877-4.0877-4.0877c-2.9418 2.9419-7.7115 2.9419-10.6533 0-2.9419-2.9418-2.9419-7.7115 0-10.6533 2.9418-2.9419 7.7115-2.9419 10.6533 0 2.9419 2.9418 2.9419 7.7115 0 10.6533z"
			></path>
		</svg>
	</button>
</search-button>

<script>
	let initialized = false;

	async function initDocSearch() {
		if (initialized) return;
		initialized = true;

		const { default: docsearch } = await import('@docsearch/js');

		const searchContainer = document.createElement('div');
		searchContainer.id = 'docsearch-container';
		searchContainer.style.cssText = 'position:fixed;left:-9999px;top:-9999px;';
		document.body.appendChild(searchContainer);

		docsearch({
			container: '#docsearch-container',
			appId: '7AFBU8EPJU',
			indexName: 'astro',
			apiKey: '4440670147c44d744fd8da35ff652518',
			searchParameters: {
				facetFilters: [[`lang:${location.pathname.split('/')[1]}`]],
				attributesToHighlight: ['hierarchy.lvl0'],
			},
			insights: true,
			transformItems: (items) => {
				return items.map((item) => {
					const url = new URL(item.url);
					if (url.hash === '#_top') url.hash = '';
					return {
						...item,
						url: url.href.replace(url.origin, ''),
					};
				});
			},
		});

		// Wait for DocSearch to render its button, then click it
		setTimeout(() => {
			document.querySelector<HTMLButtonElement>('#docsearch-container .DocSearch-Button')?.click();
		}, 50);
	}

	document.querySelectorAll('search-button button').forEach((btn) => {
		btn.addEventListener('click', initDocSearch);
	});
</script>

<style lang="scss">
	@use '../styles/variables' as *;

	.search-toggle-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		padding: 0;
		border: none;
		border-radius: $radius-sm;
		background: transparent;
		cursor: pointer;
		color: var(--sl-color-white);
		transition: color $transition-base;

		&:hover {
			opacity: 0.7;
		}

		&:focus {
			outline: none;
		}

		svg {
			width: 20px;
			height: 20px;
		}
	}
</style>
