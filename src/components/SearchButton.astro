---
---

<search-button>
	<button type="button" class="search-toggle-btn" aria-label="Search">
		<svg
			width="20"
			height="20"
			viewBox="0 0 20 20"
			fill="none"
			stroke="currentColor"
			stroke-linecap="round"
			stroke-linejoin="round"
			stroke-width="2"
		>
			<path
				d="M14.386 14.386l4.0877 4.0877-4.0877-4.0877c-2.9418 2.9419-7.7115 2.9419-10.6533 0-2.9419-2.9418-2.9419-7.7115 0-10.6533 2.9418-2.9419 7.7115-2.9419 10.6533 0 2.9419 2.9418 2.9419 7.7115 0 10.6533z"
			></path>
		</svg>
	</button>
</search-button>

<script>
	// Guard: component renders twice (mobile + desktop header), script deduplicates — runs once.
	// Use window flag to avoid re-init across navigations.
	if (!(window as any).__tbSearch) {
		(window as any).__tbSearch = true;

		// Lazy-load Google CSE on first interaction with the search button.
		// Loading it eagerly costs ~170 KiB of JS and ~200 ms of main-thread time
		// on every page even if the user never opens search.
		//
		// Critical: cse.js scans the DOM for `.gcse-search` elements once at
		// execute-time (default `parsetags=onload`). The modal containing that
		// element MUST be in the DOM before cse.js executes — otherwise CSE
		// finds nothing and the modal stays empty when the user opens it. So
		// loadCse() and buildModal() are always called together via init().
		let cseLoaded = false;
		const loadCse = () => {
			if (cseLoaded) return;
			cseLoaded = true;
			const script = document.createElement('script');
			script.async = true;
			script.src = 'https://cse.google.com/cse.js?cx=006967103846171422263:o5lnt35mvwq';
			document.head.appendChild(script);
		};

		// Used by init() to detach the hover/focus preload listeners — see
		// the listener registration block below for the full rationale.
		const preloadCtrl = new AbortController();

		const init = () => {
			buildModal();
			loadCse();
			preloadCtrl.abort();
		};

		// Resolve search page URL based on current pathname
		const getSearchPageUrl = (query: string) => {
			const path = window.location.pathname;
			const prefixes: [string, string][] = [
				['/docs/paas/eu/', '/docs/paas/eu/search/'],
				['/docs/edge/pe/', '/docs/edge/pe/search/'],
				['/docs/mqtt-broker/pe/', '/docs/mqtt-broker/pe/search/'],
				['/docs/mobile/pe/', '/docs/mobile/pe/search/'],
				['/docs/pe/', '/docs/pe/search/'],
				['/docs/paas/', '/docs/paas/search/'],
				['/docs/edge/', '/docs/edge/search/'],
				['/docs/trendz/', '/docs/trendz/search/'],
				['/docs/iot-gateway/', '/docs/iot-gateway/search/'],
				['/docs/mqtt-broker/', '/docs/mqtt-broker/search/'],
				['/docs/mobile/', '/docs/mobile/search/'],
				['/docs/license-server/', '/docs/license-server/search/'],
				['/docs/iot-hub/', '/docs/iot-hub/search/'],
			];
			const match = prefixes.find(([prefix]) => path.startsWith(prefix));
			const searchPage = match ? match[1] : '/docs/search/';
			return query ? `${searchPage}?q=${encodeURIComponent(query)}` : searchPage;
		};

		let modal: HTMLElement | null = null;
		let loaderBar: HTMLElement | null = null;

		const close = () => {
			if (!modal) return;
			modal.classList.remove('open');
			document.documentElement.classList.remove('tb-search-open');
			stopFocusRetention();
		};

		const buildModal = (): HTMLElement => {
			if (modal) return modal;
			modal = document.createElement('div');
			modal.id = 'tb-search-modal';
			modal.innerHTML = `
				<div class="tb-search-overlay"></div>
				<div class="tb-search-box">
					<div class="tb-loader-bar"></div>
					<div class="gcse-search"></div>
				</div>
			`;
			document.body.appendChild(modal);

			loaderBar = modal.querySelector<HTMLElement>('.tb-loader-bar');
			const showLoader = () => loaderBar?.classList.add('active');
			const hideLoader = () => loaderBar?.classList.remove('active');

			modal.querySelector('.tb-search-overlay')!.addEventListener('click', close);

			const injectMoreLink = () => {
				const branding = modal!.querySelector('.gcsc-more-maybe-branding-root');
				if (!branding || branding.querySelector('.tb-more-link')) return;
				const query = modal!.querySelector<HTMLInputElement>('input.gsc-input')?.value || '';
				const link = document.createElement('a');
				link.className = 'tb-more-link';
				link.href = getSearchPageUrl(query);
				link.textContent = 'Search more results';
				branding.prepend(link);
			};

			modal.addEventListener('submit', showLoader, true);
			modal.addEventListener('click', (e) => {
				if ((e.target as HTMLElement).closest('.gsc-search-button')) showLoader();
			}, true);
			modal.addEventListener('keydown', (e) => {
				if ((e.target as HTMLElement).classList.contains('gsc-input') && e.key === 'Enter') showLoader();
			}, true);
			new MutationObserver((mutations) => {
				for (const m of mutations) {
					if ((m.target as Element).classList?.contains('gsc-results') ||
						(m.target as Element).closest?.('.gsc-results')) {
						hideLoader();
						break;
					}
				}
				injectMoreLink();
			}).observe(modal, { childList: true, subtree: true });

			return modal;
		};

		const focusInput = (m: HTMLElement) => {
			const input = m.querySelector<HTMLInputElement>('input.gsc-input');
			if (input && document.activeElement !== input) input.focus();
		};

		// Two complementary mechanisms keep the search input focused while
		// the modal is open. Both stop the moment the modal closes — see
		// `stopFocusRetention()`.
		//
		// 1. MutationObserver: Google CSE rebuilds its input element multiple
		//    times during its async mount, so a single focus() right when the
		//    first input appears gets blown away. Re-focus on every DOM
		//    mutation inside the modal.
		// 2. focusout rescue: covers the case where some unrelated late-
		//    arriving script (page-load handler, layout-shift) steals focus
		//    by moving it to <body>/null — i.e. NOT to a specific element
		//    the user clicked. We only restore when relatedTarget is null/
		//    body so a legitimate user click outside the modal still wins.
		let focusObs: MutationObserver | null = null;
		let focusOutHandler: ((e: FocusEvent) => void) | null = null;

		const startFocusRetention = (m: HTMLElement) => {
			focusInput(m);

			focusObs?.disconnect();
			focusObs = new MutationObserver(() => focusInput(m));
			focusObs.observe(m, { childList: true, subtree: true });

			if (focusOutHandler) m.removeEventListener('focusout', focusOutHandler);
			focusOutHandler = (e: FocusEvent) => {
				if (!m.classList.contains('open')) return;
				const input = m.querySelector<HTMLInputElement>('input.gsc-input');
				if (!input || e.target !== input) return;
				const next = e.relatedTarget as Node | null;
				// Focus moving inside the modal — intentional, leave it.
				if (next && m.contains(next)) return;
				// Focus moving to a real element outside the modal — assume
				// the user clicked there deliberately, don't fight them.
				if (next && next !== document.body) return;
				// Focus going to body/null — script-steal pattern. Restore on
				// the next frame to avoid recursive blur/focus loops.
				requestAnimationFrame(() => {
					if (m.classList.contains('open')) input.focus();
				});
			};
			m.addEventListener('focusout', focusOutHandler);
		};

		const stopFocusRetention = () => {
			focusObs?.disconnect();
			focusObs = null;
			if (focusOutHandler && modal) modal.removeEventListener('focusout', focusOutHandler);
			focusOutHandler = null;
		};

		const open = () => {
			init();
			const m = modal!;
			document.documentElement.classList.add('tb-search-open');
			m.classList.add('open');
			// Show loader until CSE finishes mounting its input — only matters on
			// the first open, when cse.js is still being fetched/executed.
			if (!m.querySelector('input.gsc-input')) {
				loaderBar?.classList.add('active');
				const obs = new MutationObserver(() => {
					if (m.querySelector('input.gsc-input')) {
						loaderBar?.classList.remove('active');
						startFocusRetention(m);
						obs.disconnect();
					}
				});
				obs.observe(m, { childList: true, subtree: true });
			} else {
				// Subsequent opens — input already mounted; still need to
				// guard against CSE re-renders that follow a fresh modal open.
				requestAnimationFrame(() => startFocusRetention(m));
			}
		};

		// Esc to close — no-op when modal isn't built yet.
		document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

		// Warm cse.js + modal on hover/focus so the click feels instant. The
		// modal must be built here too (not just preloading the script) — see
		// loadCse comment above for why. Listeners are detached by init()
		// itself (via preloadCtrl.abort()) on the first interaction so we
		// don't keep dispatching on every mouse move for the rest of the page
		// lifetime — `pointerover` capture-phase fires on every element-
		// boundary crossing, which adds up.
		const preload = (e: Event) => {
			if ((e.target as Element)?.closest?.('search-button')) init();
		};
		document.addEventListener('pointerover', preload, { capture: true, passive: true, signal: preloadCtrl.signal });
		document.addEventListener('focusin', preload, { capture: true, signal: preloadCtrl.signal });

		// Attach to all search buttons via delegation
		document.addEventListener('click', (e) => {
			if ((e.target as Element).closest('search-button')) open();
		});
	}
</script>

<style lang="scss">
	@use '../styles/variables' as *;

	.search-toggle-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		padding: 0;
		border: none;
		border-radius: $radius-sm;
		background: transparent;
		cursor: pointer;
		color: var(--sl-color-white);
		transition: opacity $transition-base;

		&:hover { opacity: 0.7; }
		&:focus { outline: none; }

		svg { width: 20px; height: 20px; }
	}
</style>

<style is:global>
	html.tb-search-open {
		overflow: hidden;
		scrollbar-gutter: stable;
	}

	#tb-search-modal {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 9999;
		align-items: flex-start;
		justify-content: center;
		padding-top: 80px;
	}
	#tb-search-modal.open {
		display: flex;
	}
	.tb-search-overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.55);
	}
	.tb-search-box {
		position: relative;
		z-index: 1;
		width: 620px;
		max-width: calc(100vw - 2rem);
		min-height: 110px;
		max-height: calc(100vh - 120px);
		overflow-y: auto;
		background: #fff;
		border-radius: 8px;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
		padding: 1.25rem 1.25rem 1rem;
		scrollbar-width: thin;
		scrollbar-color: transparent transparent;
		&:hover { scrollbar-color: rgba(0,0,0,0.2) transparent; }
	}
	[data-theme='dark'] .tb-search-box {
		background: #1e1e2e;
		&:hover { scrollbar-color: rgba(255,255,255,0.2) transparent; }
	}
	/* Google CSE autocomplete dropdown — rendered at body root, needs high z-index */
	.gssb_c { z-index: 50000 !important; }
	/* Inside modal only: pin to viewport so it sits above the overlay.
	   On regular pages, leave Google's default `position: absolute` alone so
	   the dropdown tracks the input when the page scrolls. */
	html.tb-search-open .gssb_c { position: fixed !important; }

	/* Dark-theme the CSE autocomplete dropdown. It's rendered at body root
	   (not inside .doc-search-widget or .tb-search-box) so we scope on the
	   global [data-theme='dark'] selector and let the rule apply everywhere
	   the dropdown can appear. */
	[data-theme='dark'] .gssb_c {
		background: var(--sl-color-bg) !important;
		border: 1px solid var(--sl-color-hairline) !important;
	}
	[data-theme='dark'] .gssb_c table,
	[data-theme='dark'] .gssb_c tbody,
	[data-theme='dark'] .gssb_c tr,
	[data-theme='dark'] .gssb_c td {
		background: transparent !important;
		color: var(--sl-color-text) !important;
	}
	[data-theme='dark'] .gssb_c .gssb_a,
	[data-theme='dark'] .gssb_c .gsq_a,
	[data-theme='dark'] .gssb_c .gssb_d {
		color: var(--sl-color-text) !important;
	}
	[data-theme='dark'] .gssb_c .gssb_a:hover,
	[data-theme='dark'] .gssb_c .gssb_i {
		background: var(--sl-color-gray-6) !important;
	}
	/* Branding row ("Enhanced by Google") — keep readable but muted */
	[data-theme='dark'] .gssb_c .gssb_p,
	[data-theme='dark'] .gssb_c .gssb_e {
		color: var(--sl-color-gray-3) !important;
	}

	/* Loader — progress bar */
	.tb-loader-bar {
		position: sticky;
		top: -1.25rem;
		left: -1.25rem;
		right: -1.25rem;
		margin: -1.25rem -1.25rem 1.25rem;
		height: 3px;
		border-radius: 8px 8px 0 0;
		overflow: hidden;
		z-index: 2;
	}
	.tb-loader-bar::after {
		content: '';
		display: block;
		height: 100%;
		background: var(--sl-color-text-accent);
		transform: scaleX(0);
		transform-origin: left;
	}
	.tb-loader-bar.active::after {
		animation: tb-progress 1.4s ease-in-out infinite;
	}
	@keyframes tb-progress {
		0%   { transform: scaleX(0); transform-origin: left; }
		45%  { transform: scaleX(1); transform-origin: left; }
		55%  { transform: scaleX(1); transform-origin: right; }
		100% { transform: scaleX(0); transform-origin: right; }
	}

	/* Google CSE overrides */
	.tb-search-box .gsc-control-cse {
		background: transparent !important;
		border: none !important;
		padding: 0 !important;
	}
	.tb-search-box .gsc-input-box { border-radius: 6px !important; }
	.tb-search-box 	.gsc-webResult.gsc-result {
		border-radius: 6px !important;
		padding: 8px !important;
		transition: background 0.15s ease !important;
		cursor: pointer !important;
	}
	.tb-search-box .gsc-webResult.gsc-result:hover {
		background: var(--sl-color-gray-6, #f5f5f5) !important;
	}
	[data-theme='dark'] .tb-search-box .gsc-webResult.gsc-result {
		background: #1e1e2e !important;
		color: rgba(255, 255, 255, 0.75) !important;
		border: none !important;
	}
	[data-theme='dark'] .tb-search-box .gsc-webResult.gsc-result:hover {
		background: rgba(255, 255, 255, 0.06) !important;
	}
	[data-theme='dark'] .tb-search-box .gsc-result .gs-snippet {
		color: rgba(255, 255, 255, 0.65) !important;
	}
	.tb-search-box .gsc-webResult-divider {
		display: block !important;
		border: none !important;
		border-top: 1px solid var(--sl-color-hairline-light) !important;
		margin: 0 !important;
	}
	.tb-search-box .gsc-result .gs-title,
	.tb-search-box .gsc-result a.gs-title,
	.tb-search-box .gsc-result a.gs-title:link,
	.tb-search-box .gsc-result a.gs-title:visited {
		color: var(--sl-color-text-accent) !important;
		display: block !important;
		white-space: nowrap !important;
		overflow: hidden !important;
		text-overflow: ellipsis !important;
		max-width: 100% !important;
		text-decoration: none !important;
	}
	.tb-search-box .gsc-result a.gs-title:link b {
		color: var(--sl-color-text-accent) !important;
	}
	[data-theme='dark'] .tb-search-box .gsc-result a.gs-title:visited,
	[data-theme='dark'] .tb-search-box .gsc-result a.gs-title:visited b {
		color: hsl(224, 70%, 75%) !important;
	}
	.tb-search-box .gsc-result .gs-title a:hover { text-decoration: none !important; }
	.tb-search-box .gsc-table-result {
		display: block !important;
		width: 100% !important;
		overflow: hidden !important;
	}
	.tb-search-box .gsc-table-cell-snippet-close {
		display: block !important;
		width: 100% !important;
		overflow: hidden !important;
	}

	/* Show only title — hide snippet, URL, thumbnail, branding, labels */
	.tb-search-box .gsc-thumbnail-inside,
	.tb-search-box .gsc-url-top,
	.tb-search-box .gsc-url-bottom,
	.tb-search-box .gs-visibleUrl,
	.tb-search-box .gs-visibleUrl-long,
	.tb-search-box .gsc-table-cell-thumbnail,
	.tb-search-box .gsc-cursor-box,
	.tb-search-box .gsc-branding,
	.tb-search-box .gsc-result-info,
	.tb-search-box .gs-per-result-labels,
	.tb-search-box .gs-fileformat,
	.tb-search-box .gcsc-find-more-on-google-root {
		display: none !important;
	}

	.tb-search-box .gcsc-more-maybe-branding-root {
		display: flex !important;
		justify-content: center !important;
		align-items: center !important;
	}
	.tb-search-box .gcsc-more-maybe-branding-root > :not(.tb-more-link) {
		display: none !important;
	}
	.tb-search-box .tb-more-link {
		font-size: 13px;
		color: var(--sl-color-text-accent) !important;
		text-decoration: none;
	}
	.tb-search-box .tb-more-link:hover { text-decoration: underline !important; }
</style>
