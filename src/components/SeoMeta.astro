---
import { SITE_NAME } from '@root/consts';

interface Props {
	title: string;
	description?: string;
	canonicalUrl: string;
	noCanonical?: boolean;
	ogImage?: string;
	ogType?: string;
	ogImageAlt?: string;
	publishedTime?: string;
	modifiedTime?: string;
	noIndex?: boolean;
	jsonLd?: Record<string, unknown>;
}

const {
	title,
	description,
	canonicalUrl,
	noCanonical = false,
	ogImage,
	ogType = 'website',
	ogImageAlt,
	publishedTime,
	modifiedTime,
	noIndex = false,
	jsonLd,
} = Astro.props;

const DEFAULT_OG_IMAGE = '/thingsboard-og.png';
// Resolve against the actual request origin so dev shows localhost and prod shows the site origin.
// In Astro static build, Astro.url.origin equals Astro.site origin, so production output is unchanged.
let ogImagePath = ogImage ?? DEFAULT_OG_IMAGE;
// Astro dev with `trailingSlash: 'always'` requires dynamic-route URLs to end with '/' even when
// they have a file extension (e.g. /open-graph/foo.png 404s, /open-graph/foo.png/ works).
// Production (Cloudflare Pages serving static files) needs the clean .png URL with no trailing slash.
if (import.meta.env.DEV && /\.png$/.test(ogImagePath) && ogImagePath !== DEFAULT_OG_IMAGE) {
	ogImagePath = ogImagePath + '/';
}
const ogImageUrl = new URL(ogImagePath, Astro.url.origin).href;
---

{!noCanonical && <link rel="canonical" href={canonicalUrl} />}

{noIndex && <meta name="robots" content="noindex, follow" />}

{description && <meta name="description" content={description} />}

<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
{ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@thingsboard" />

{jsonLd && (
	<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
