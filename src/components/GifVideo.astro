---
interface Props {
	srcMp4: string;
	srcWebm?: string; // optional, but preferred for Chrome
	poster?: string; // placeholder image
	width?: string | number;
	height?: string | number;
	threshold?: number; // when to start (0.1 = 10%, 0.5 = 50%)
	className?: string; // extra CSS classes
}

const {
	srcMp4,
	srcWebm,
	poster,
	width = '100%',
	height = 'auto',
	threshold = 0.5,
	className = '',
} = Astro.props;
---

<video
	class:list={['lazy-gif-video', className]}
	width={width}
	height={height}
	poster={poster}
	loop
	muted
	playsinline
	data-threshold={threshold}
	style="display: block;"
>
	{/* WebM first since it's lighter (preferred for Chrome/Android) */}
	{srcWebm && <source data-src={srcWebm} type="video/webm" />}

	{/* MP4 fallback for Safari/iOS */}
	<source data-src={srcMp4} type="video/mp4" />
</video>

<script>
	// Init function so it works on first load and on navigation
	const initLazyGifs = () => {
		// Check API support
		if (!('IntersectionObserver' in window)) return;

		const videos = document.querySelectorAll<HTMLVideoElement>('.lazy-gif-video');

		const observerMap = new Map(); // keep one observer per threshold

		videos.forEach((video) => {
			// Skip videos already being handled
			if (video.classList.contains('js-initialized')) return;
			video.classList.add('js-initialized');

			// Read the trigger threshold from the attribute (default 0.5)
			const threshold = parseFloat(video.dataset.threshold || '0.5');

			// Create or reuse the observer for this threshold
			let observer = observerMap.get(threshold);

			if (!observer) {
				observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							const vid = entry.target as HTMLVideoElement;

							if (entry.isIntersecting) {
								// 1. VIDEO ENTERED THE VIEWPORT

								// Load sources on first entry
								const sources = vid.querySelectorAll('source');
								let sourceChanged = false;
								sources.forEach((source) => {
									if (source.dataset.src) {
										source.src = source.dataset.src;
										delete source.dataset.src;
										sourceChanged = true;
									}
								});

								if (sourceChanged) {
									vid.load();
								}

								// Play
								const playPromise = vid.play();
								if (playPromise !== undefined) {
									playPromise.catch((error) => {
										console.log('Auto-play was prevented:', error);
									});
								}
							} else {
								// 2. VIDEO LEFT THE VIEWPORT -> PAUSE
								if (!vid.paused) {
									vid.pause();
								}
							}
						});
					},
					{ threshold: threshold }
				);

				observerMap.set(threshold, observer);
			}

			observer.observe(video);
		});
	};

	// Run on a normal page load
	document.addEventListener('DOMContentLoaded', initLazyGifs);

	// Run on Astro View Transitions (client-side navigation)
	document.addEventListener('astro:page-load', initLazyGifs);
</script>
