---
const CDN_BASE = 'https://img.thingsboard.io/';
const LOCAL_PREFIX = '/src/assets/images/';

interface Props {
	src: string;
	alt: string;
	width: string | number;
	height: string | number;
	class?: string;
	quality?: number | 'low' | 'mid' | 'high' | 'max';
	loading?: 'lazy' | 'eager';
}

const { src, alt, width, height, class: className, loading = 'lazy' } = Astro.props;

// Замінюємо локальний шлях на CDN URL
const cdnSrc = src.startsWith(LOCAL_PREFIX) ? CDN_BASE + src.slice(LOCAL_PREFIX.length) : src;
---

<img
	src={cdnSrc}
	alt={alt}
	width={width}
	height={height}
	class={className}
	loading={loading}
	decoding="async"
/>
