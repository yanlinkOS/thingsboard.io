---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	src: string;
	alt: string;
	width: string | number;
	height: string | number;
	class?: string;
	quality?: number | 'low' | 'mid' | 'high' | 'max';
	loading?: 'lazy' | 'eager';
}

const { src, alt, width, height, class: className, quality = 80, loading = 'lazy' } = Astro.props;

const isSvg = src.endsWith('.svg');
const images = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/images/**/*.{jpeg,jpg,png,webp,avif,svg}'
);

if (!images[src]) {
	throw new Error(`Зображення "${src}" не знайдено у "src/assets/images/".`);
}

// Визначаємо пропорції для уникнення стрибків верстки (CLS)
const aspectRatio = `${width} / ${height}`;

const renderWidth = Number(width) * 2;
const renderHeight = Number(height) * 2;
---

{
	isSvg ? (
		/* Для SVG: використовуємо звичайний <img>, Vite + SVGO очистять його автоматично */
		<img
			src={src}
			alt={alt}
			width={width}
			height={height}
			class={className}
			loading={loading}
			decoding="async"
		/>
	) : (
		/* Для растру: Astro конвертує PNG/JPG у WebP */
		<Image
			src={images[src]()}
			alt={alt}
			width={renderWidth}
			height={renderHeight}
			class={className}
			quality={quality === 'max' ? 100 : quality}
			loading={loading}
			style={{
				aspectRatio,
				width: `${width}px`,
				maxWidth: '100%',
				height: 'auto',
				objectFit: 'cover',
				imageRendering: 'auto',
			}}
		/>
	)
}
