---
import SmartImage from '@components/SmartImage.astro';
import { tbmqNews } from '~/data/tbmqNews';
---

<section id="news">
	<div class="inner">
		<h2 class="heading">TBMQ news</h2>
		<div class="cards">
			{
				tbmqNews.map((item) => (
					<div class="card-wrap">
						<div class="card">
							<div class="image-container">
								<a href={item.href} target="_blank">
									<SmartImage
										src={item.image}
										alt={item.imageAlt}
										loading="lazy"
										class="card-img"
									/>
								</a>
							</div>
							<div class="content">
								<div class="tags">
									<a href={item.tagHref} target="_blank" class="news-tag">
										{item.tag}
									</a>
								</div>
								<a href={item.href} target="_blank" class="title news-title">
									{item.title}
								</a>
								<p>{item.excerpt}</p>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	#news {
		padding-bottom: $spacing-20;
	}

	.inner {
		@include container;
		max-width: 1400px;
		margin-bottom: 24px;
	}

	.heading {
		font-size: 42px;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
		text-align: center;
		padding-top: 80px;
		padding-bottom: 40px;
		margin: 0;
	}

	.cards {
		display: flex;
		flex-direction: column;
		flex-wrap: wrap;
		justify-content: center;
		gap: 48px;

		@include media-up(lg) {
			flex-direction: row;
		}
	}

	.card-wrap {
		width: 100%;

		@include media-up(lg) {
			max-width: 670px;
			flex: 1 1 calc(50% - 24px);
		}
	}

	.card {
		width: 100%;
		height: 100%;
		background: var(--color-bg-surface);
		border-radius: 24px;
		box-shadow: 0 0 18px 0 #cecece;
		display: flex;
		flex-direction: column;
		gap: 24px;
		padding: 0;
	}

	.image-container {
		a {
			display: block;
			width: 100%;
			position: relative;

			&::after {
				content: '';
				position: absolute;
				inset: 0;
				background: rgba(0, 0, 0, 0.08);
				border-top-left-radius: 24px;
				border-top-right-radius: 24px;
				opacity: 0;
				transition: opacity 0.3s;
			}

			&:hover::after {
				opacity: 1;
			}
		}
	}

	:global(#news .card-img) {
		width: 100%;
		max-height: 260px;
		object-fit: cover;
		border-top-left-radius: 24px;
		border-top-right-radius: 24px;
		display: block;
	}

	.content {
		display: flex;
		flex-direction: column;
		gap: 24px;
		padding: 0 24px 24px;
	}

	.tags {
		display: flex;
		gap: 10px;

		a {
			width: fit-content;
			background: rgba(31, 139, 77, 0.06);
			padding: 5px 16px 6px;
			border-radius: 6px;
			font-size: 16px;
			color: #000;
			text-decoration: none;

			&:hover {
				background: rgba(31, 139, 77, 0.12);
			}
		}
	}

	.title {
		font-size: 24px;
		line-height: 32px;
		color: rgba(0, 0, 0, 0.87);
		text-decoration: none;
		display: block;

		&:hover {
			color: #1f8b4d;
			text-decoration: underline;
		}
	}

	p {
		margin: 8px 0 16px;
		font-size: 16px;
		line-height: 1.6;
		color: #757c76;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		text-overflow: ellipsis;
	}
</style>
