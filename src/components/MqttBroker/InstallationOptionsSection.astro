---
import SmartImage from '@components/SmartImage.astro';

const cloudLogos = [
	{ src: '/src/assets/images/landings/mqtt-broker/docker.webp', alt: 'Docker' },
	{ src: '/src/assets/images/landings/mqtt-broker/aws.webp', alt: 'AWS' },
	{ src: '/src/assets/images/landings/mqtt-broker/azure.webp', alt: 'Azure' },
	{ src: '/src/assets/images/landings/mqtt-broker/google-cloud.webp', alt: 'Google Cloud' },
	{ src: '/src/assets/images/landings/mqtt-broker/helm-charts.webp', alt: 'Helm Charts' },
];
---

<section id="installation-options">
	<div class="inner">
		<h2 class="heading">TBMQ management &amp; MQTT protocol</h2>
		<div class="row">
			<div class="text-col">
				<h3>Diverse installation options</h3>
				<p>
					Select the perfect fit for your infrastructure with our Docker-based or K8s-based
					deployments, crafted for seamless integration in both on-premise and cloud environments.
				</p>
				<div class="buttons">
					<a href="/docs/mqtt-broker/install/installation-options/" class="btn">Install TBMQ CE</a>
					<a href="/docs/pe/mqtt-broker/install/installation-options/" class="btn">Install TBMQ PE</a>
				</div>
			</div>
			<div class="logos-col">
				<div class="logos">
					{cloudLogos.map((logo) => (
						<SmartImage src={logo.src} alt={logo.alt} loading="lazy" class="logo" />
					))}
				</div>
			</div>
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	#installation-options {
		margin-bottom: 24px;
	}

	.inner {
		@include container;
		max-width: 1400px;
	}

	.heading {
		font-size: 36px;
		font-weight: $font-weight-medium;
		color: var(--color-text);
		text-align: center;
		padding-top: 100px;
		padding-bottom: 40px;
		margin: 0;
	}

	.row {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: space-between;
		gap: 40px;
		padding-top: 40px;

		@include media-up(xl) {
			flex-direction: row;
			gap: 160px;
		}
	}

	.text-col {
		flex: 2;
		display: flex;
		flex-direction: column;
		gap: 24px;

		h3 {
			font-size: 28px;
			font-weight: $font-weight-medium;
			line-height: 1.5;
			color: var(--color-text);
			margin: 0;
		}

		p {
			font-size: 18px;
			line-height: 1.7;
			color: #757c76;
			margin: 0;
			text-align: justify;
		}
	}

	.buttons {
		display: flex;
		gap: 32px;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-block;
		width: 196px;
		line-height: 40px;
		padding: 3px 24px;
		border-radius: 8px;
		border: 1px solid rgba(0, 0, 0, 0.12);
		background-color: #1f8b4d;
		color: $color-white;
		text-decoration: none;
		font-size: 16px;
		font-weight: $font-weight-medium;
		text-align: center;
		transition: background-color 0.6s;

		&:hover {
			color: $color-white;
			filter: brightness(1.3) contrast(0.9);
		}
	}

	.logos-col {
		flex: 1;
		margin-top: 40px;
	}

	.logos {
		display: flex;
		flex-direction: row;
		flex-wrap: nowrap;
		justify-content: center;
		gap: 40px;

		@media screen and (max-width: 500px) {
			flex-wrap: wrap;
		}
	}

	:global(#installation-options .logo) {
		height: 60px;
		width: auto;
		object-fit: contain;
	}
</style>