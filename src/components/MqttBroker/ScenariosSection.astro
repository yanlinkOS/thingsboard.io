---
import SmartImage from '@components/SmartImage.astro';

const scenarios = [
	{
		title: 'Fan-in',
		titleHref: '/docs/mqtt-broker/reference/100m-connections-performance-test/',
		subtitle: 'Many-to-one messaging using MQTT wildcards.',
		description:
			"Many-to-one communication pattern. Many devices generate a large volume of messages consumed by specific applications. They must be persistent clients with QoS levels set to 1 or 2, capable of retaining all the data even when they're temporarily offline due to restarts or upgrades.",
		image: '/src/assets/images/landings/mqtt-broker/fan-in.svg',
		imageAlt: 'Fan in',
		reverseImage: false,
	},
	{
		title: 'Fan-out',
		titleHref: '/docs/mqtt-broker/reference/3m-throughput-single-node-performance-test/',
		subtitle: 'Broadcast MQTT topics.',
		description:
			'This scenario facilitates one-to-many messaging. It involves numerous devices subscribing to specific updates or notifications that must be delivered. This leads to a few incoming requests that cause a high volume of outgoing data.',
		image: '/src/assets/images/landings/mqtt-broker/fan-out.svg',
		imageAlt: 'Fan out',
		reverseImage: true,
	},
	{
		title: 'Point-to-point',
		titleHref: '/docs/mqtt-broker/reference/1m-throughput-p2p-performance-test/',
		subtitle: 'Targeted MQTT topic communication.',
		description:
			'A targeted messaging pattern, primarily used for one-to-one communication. Achieved through uniquely defined topics, p2p is ideal for use cases such as private messaging or command-based interactions. Persistent clients with QoS levels set to 1 or 2 are often utilized to ensure reliable message delivery, even during temporary disconnections or client downtime.',
		image: '/src/assets/images/landings/mqtt-broker/p2p.svg',
		imageAlt: 'Point to point',
		reverseImage: false,
	},
];
---

<section id="scenarios">
	<div class="inner">
		<div class="scenarios-header">
			<div class="scenarios-title">
				<h2>MQTT broker for real-life IoT scenarios</h2>
			</div>
			<div class="scenarios-details">
				<p>
					Utilize diverse communication patterns effectively, ensuring comprehensive coverage of your
					use cases. TBMQ places particular emphasis on mastering fan-in, fan-out, and
					point-to-point (p2p) messaging.
				</p>
			</div>
		</div>

		<!-- Fan-in: description LEFT, image RIGHT -->
		<div class="scenario-block">
			<div class="description">
				<div class="scenario-title">
					<h3>
						<a href={scenarios[0].titleHref}>{scenarios[0].title}</a>
						<span class="subtitle">{scenarios[0].subtitle}</span>
					</h3>
				</div>
				<div><span>{scenarios[0].description}</span></div>
			</div>
			<div class="image-container">
				<SmartImage src={scenarios[0].image} alt={scenarios[0].imageAlt} loading="lazy" />
			</div>
		</div>

		<!-- Fan-out: image LEFT, description RIGHT (reverse-img moves below on mobile) -->
		<div class="scenario-block">
			<div class="image-container reverse-img">
				<SmartImage src={scenarios[1].image} alt={scenarios[1].imageAlt} loading="lazy" />
			</div>
			<div class="description">
				<div class="scenario-title">
					<h3>
						<a href={scenarios[1].titleHref}>{scenarios[1].title}</a>
						<span class="subtitle">{scenarios[1].subtitle}</span>
					</h3>
				</div>
				<div><span>{scenarios[1].description}</span></div>
			</div>
		</div>

		<!-- P2P: description LEFT, image RIGHT -->
		<div class="scenario-block">
			<div class="description">
				<div class="scenario-title">
					<h3>
						<a href={scenarios[2].titleHref}>{scenarios[2].title}</a>
						<span class="subtitle">{scenarios[2].subtitle}</span>
					</h3>
				</div>
				<div><span>{scenarios[2].description}</span></div>
			</div>
			<div class="image-container">
				<SmartImage src={scenarios[2].image} alt={scenarios[2].imageAlt} loading="lazy" />
			</div>
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	#scenarios {
		background-color: #00240f;
		margin-bottom: 50px;
	}

	.inner {
		@include container;
		max-width: 1400px;
		padding-top: 50px;
		padding-bottom: 50px;

		@include media-up(lg) {
			padding-top: 80px;
		}
	}

	.scenarios-header {
		display: flex;
		flex-direction: column;
		gap: 20px;
		margin-bottom: 40px;

		@include media-up(xl) {
			flex-direction: row;
			align-items: center;
		}
	}

	.scenarios-title {
		flex: 1;

		h2 {
			font-size: 42px;
			font-weight: $font-weight-semibold;
			color: $color-white;
			margin: 0;
			line-height: 1.3;
		}
	}

	.scenarios-details {
		flex: 1;
		padding-bottom: 24px;

		p {
			font-size: 18px;
			line-height: 1.6;
			color: rgba(255, 255, 255, 0.8);
			margin: 0;
		}
	}

	.scenario-block {
		display: flex;
		flex-direction: column;
		gap: 20px;
		justify-content: center;
		align-items: stretch;
		margin-bottom: 40px;

		@include media-up(xl) {
			flex-direction: row;
			align-items: center;
		}
	}

	.image-container {
		flex: 3;

		:global(img) {
			width: 100%;
			height: auto;
		}
	}

	// On mobile: push image below description
	.reverse-img {
		order: 1;

		@include media-up(xl) {
			order: unset;
		}
	}

	.description {
		flex: 2;
		padding: 24px;
		border-radius: 12px;
		background: $color-white;
		text-align: justify;
	}

	.scenario-title {
		margin-bottom: 12px;

		h3 {
			margin: 0;
			line-height: 52px;
		}

		a {
			font-size: 28px;
			font-weight: $font-weight-medium;
			color: #1f8b4d;
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}

		.subtitle {
			font-size: 18px;
			font-weight: $font-weight-medium;
			color: #757c76;
			display: block;
			margin: 0;
		}
	}

	span {
		font-size: 16px;
		line-height: 28px;
		color: rgba(0, 0, 0, 0.54);
		font-weight: $font-weight-normal;
		letter-spacing: 0.15px;
	}
</style>