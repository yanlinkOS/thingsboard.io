---
import SmartImage from '@components/SmartImage.astro';

const features = [
	{
		icon: '/src/assets/images/landings/mqtt-broker/scalability.svg',
		title: 'Scalability',
		html: 'Scale horizontally to manage more than <a href="/docs/mqtt-broker/reference/100m-connections-performance-test/">100M</a> MQTT connections on a single cluster',
	},
	{
		icon: '/src/assets/images/landings/mqtt-broker/performance.svg',
		title: 'Performance',
		html: 'Process <a href="/docs/mqtt-broker/reference/3m-throughput-single-node-performance-test/">millions</a> of messages per second with 1 TBMQ server and single-digit latency',
	},
	{
		icon: '/src/assets/images/landings/mqtt-broker/durability.svg',
		title: 'Durability',
		html: "Guarantee the persistence and replication of your data to ensure it's never lost",
	},
	{
		icon: '/src/assets/images/landings/mqtt-broker/security.svg',
		title: 'Fault tolerance',
		html: 'Prevent single point of failure with masterless nodes in the cluster',
	},
	{
		icon: '/src/assets/images/landings/mqtt-broker/cloud-native.svg',
		title: 'Cloud-Native and K8s-Compliant',
		html: 'Deploy in cloud or on-premise using K8s scripts with ease',
	},
	{
		icon: '/src/assets/images/landings/mqtt-broker/mqtt-version-compatibility.svg',
		title: 'MQTT version compatibility',
		html: 'MQTT 3.x and 5.0 compatible for a seamless and secure connection experience',
	},
];
---

<section id="top-features">
	<div class="inner">
		<h2 class="heading">Core strengths &amp; MQTT server capabilities</h2>
		<div class="cards">
			{
				features.map((f) => (
					<div class="card">
						<SmartImage src={f.icon} alt={f.title} loading="lazy" class="card-icon" />
						<div class="card-body">
							<h3 class="card-title">{f.title}</h3>
							<p class="card-text" set:html={f.html} />
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	#top-features {
		padding: $spacing-12 $spacing-6 $spacing-20;
	}

	.inner {
		@include container;
		max-width: 1400px;
	}

	.heading {
		font-size: 36px;
		font-weight: $font-weight-medium;
		color: var(--color-text);
		text-align: center;
		padding: 20px 0 40px;
		margin: 0;
	}

	.cards {
		display: flex;
		flex-direction: column;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0;

		@include media-up(lg) {
			flex-direction: row;
		}
	}

	.card {
		margin-bottom: 36px;
		box-shadow: 0 7px 32px 0 rgba(0, 0, 0, 0.08);
		border-radius: 24px;
		padding: 46px;
		background: var(--color-bg-surface);
		display: flex;
		flex-direction: column;

		@include media-up(lg) {
			width: calc(50% - 36px);
			margin: 18px;
		}

		@include media-up(xl) {
			width: calc(33.333% - 36px);
		}
	}

	:global(.card-icon) {
		width: 48px;
		height: 48px;
		object-fit: contain;
		border: 1px solid #1f8b4d;
		border-radius: 24px;
		padding: 16px;
		box-sizing: content-box;
		margin-bottom: 18px;
	}

	.card-body {
		display: flex;
		flex-direction: column;
	}

	.card-title {
		font-size: 1.75rem;
		font-weight: $font-weight-medium;
		color: var(--color-text);
		margin: 6px 0;
		line-height: 1.3;
	}

	.card-text {
		font-size: 1rem;
		font-weight: $font-weight-normal;
		color: #757c76;
		line-height: 1.75rem;
		margin: 10px 0 0;
		text-align: justify;

		:global(a) {
			color: var(--color-product-tbmq);
			font-weight: $font-weight-medium;
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}
</style>