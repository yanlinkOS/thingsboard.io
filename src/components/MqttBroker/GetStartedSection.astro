---
import { Icon } from 'astro-icon/components';
---

<section id="get-started">
	<div class="inner">
		<h2>Get started with TBMQ</h2>
		<p>
			Get started with TBMQ today and unlock the full potential of your IoT solutions! With support
			for millions of concurrent connections, robust message handling, and reliable data persistence,
			TBMQ empowers you to build, scale, and secure your IoT applications like never before.
		</p>
		<a href="/docs/mqtt-broker/getting-started/" target="_blank" class="btn">
			Get started
			<Icon name="tabler:arrow-up-right" class="btn-icon" />
		</a>
	</div>
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	#get-started {
		background-color: #00240f;
		padding-top: 150px;
		padding-bottom: 150px;
	}

	.inner {
		@include container;
		max-width: 1400px;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;

		h2 {
			font-size: 42px;
			font-weight: $font-weight-semibold;
			color: $color-white;
			margin: 0 0 48px;
			line-height: 50px;
		}

		p {
			font-size: 18px;
			line-height: 1.7;
			color: rgba(255, 255, 255, 0.8);
			margin: 0 0 24px;
		}
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 4px 24px;
		line-height: 40px;
		border-radius: 8px;
		background-color: $color-white;
		color: #1f8b4d;
		text-decoration: none;
		font-size: 16px;
		font-weight: $font-weight-medium;
		transition: background-color 0.6s;

		&:hover {
			background-color: #e8e8e8;
			color: #1f8b4d;
		}
	}

	:global(.btn-icon) {
		width: 20px;
		height: 20px;
		flex-shrink: 0;
	}
</style>