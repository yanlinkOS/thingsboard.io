---
import FeatureBlockSection from '@components/Landing/FeatureBlockSection.astro';

const features = [
	// imageFirst=false → text LEFT, image RIGHT (nth-child even)
	// imageFirst=true  → image LEFT, text RIGHT (nth-child odd)
	{
		id: 'client-sessions',
		heading: 'Administer client sessions',
		description:
			'Gain full visibility over your IoT ecosystem with the user-friendly session management dashboard, enabling you to monitor vital session attributes. Seamlessly administer your device subscriptions for efficient data communication.',
		links: [
			{ href: '/docs/mqtt-broker/user-guide/ui/sessions/', text: 'TBMQ CE' },
			{ href: '/docs/pe/mqtt-broker/user-guide/ui/sessions/', text: 'TBMQ PE' },
		],
		imageSrc: '/src/assets/images/landings/mqtt-broker/administer-client-session.webp',
		imageAlt: 'Administer client sessions',
		imageFirst: false,
	},
	{
		id: 'client-subscriptions',
		heading: 'Administer client subscriptions',
		description:
			'Efficiently manage subscriptions with a powerful and intuitive interface, ensuring optimal client communication and data flow across your IoT network.',
		links: [
			{ href: '/docs/mqtt-broker/user-guide/ui/subscriptions/', text: 'TBMQ CE' },
			{ href: '/docs/pe/mqtt-broker/user-guide/ui/subscriptions/', text: 'TBMQ PE' },
		],
		imageSrc: '/src/assets/images/landings/mqtt-broker/administer-client-subscriptions.webp',
		imageAlt: 'Administer client subscriptions',
		imageFirst: true,
	},
	{
		id: 'credentials-management',
		heading: 'MQTT client credentials management',
		description:
			'Strengthen your IoT security using the MQTT client credentials management system, crafted to handle both Basic and X.509 Certificate Chain authentication options effortlessly.',
		links: [
			{ href: '/docs/mqtt-broker/user-guide/ui/mqtt-client-credentials/', text: 'TBMQ CE' },
			{ href: '/docs/pe/mqtt-broker/user-guide/ui/mqtt-client-credentials/', text: 'TBMQ PE' },
		],
		imageSrc: '/src/assets/images/landings/mqtt-broker/credentials-management.webp',
		imageAlt: 'MQTT client credentials management',
		imageFirst: false,
	},
	{
		id: 'websocket-connectivity',
		heading: 'MQTT websocket connectivity',
		description:
			'Interact with your IoT devices in real-time through the WebSocket client, offering a streamlined and responsive interface for device messaging and monitoring.',
		links: [
			{ href: '/docs/mqtt-broker/user-guide/ui/websocket-client/', text: 'TBMQ CE' },
			{ href: '/docs/pe/mqtt-broker/user-guide/ui/websocket-client/', text: 'TBMQ PE' },
		],
		imageSrc: '/src/assets/images/landings/mqtt-broker/websocket-client-connectivity.webp',
		imageAlt: 'WebSocket client connectivity',
		imageFirst: true,
	},
	{
		id: 'monitoring',
		heading: 'Real-time MQTT monitoring',
		description:
			"Keep a pulse on your IoT environment by tracking key metrics in real-time, ensuring your network's health and performance are always at their peak.",
		links: [
			{ href: '/docs/mqtt-broker/user-guide/ui/monitoring/', text: 'TBMQ CE' },
			{ href: '/docs/pe/mqtt-broker/user-guide/ui/monitoring/', text: 'TBMQ PE' },
		],
		imageSrc: '/src/assets/images/landings/mqtt-broker/monitor-key-metrics.webp',
		imageAlt: 'Monitor key metrics',
		imageFirst: false,
	},
	{
		id: 'integrations',
		heading: 'External system integrations',
		description:
			'Enable smooth data transmission between IoT devices, the broker, and external platforms with a reliable and scalable solution — all without impacting core broker performance.',
		links: [
			{ href: '/docs/mqtt-broker/integrations/', text: 'TBMQ CE' },
			{ href: '/docs/pe/mqtt-broker/integrations/', text: 'TBMQ PE' },
		],
		imageSrc: '/src/assets/images/landings/mqtt-broker/integrations.webp',
		imageAlt: 'Integrations',
		imageFirst: true,
	},
	{
		id: 'white-labeling',
		heading: 'White labeling',
		description:
			'Rebrand the TBMQ broker web interface with your company or product logo and color scheme in 2 minutes. No coding or service restart required.',
		links: [{ href: '/docs/pe/mqtt-broker/white-labeling/', text: 'Read more' }],
		imageSrc: '/src/assets/images/landings/mqtt-broker/white-labeling.webp',
		imageAlt: 'White labeling',
		imageFirst: false,
		peOnly: true,
		imageShadow: true,
	},
	{
		id: 'rbac',
		heading: 'RBAC',
		description:
			'Advanced user access control with role-based permissions. Manage broker operations with two predefined roles: Admin for full control, and Viewer for read-only access.',
		links: [{ href: '/docs/pe/mqtt-broker/security/rbac/', text: 'Read more' }],
		imageSrc: '/src/assets/images/landings/mqtt-broker/scheme.webp',
		imageAlt: 'RBAC',
		imageFirst: true,
		peOnly: true,
		imageShadow: true,
	},
	{
		id: 'sso',
		heading: 'Single sign-on',
		description:
			"Single Sign-On (SSO) integration for simplified and secure access. Seamlessly authenticate users through your organization's identity provider, reducing password management and strengthening security.",
		links: [{ href: '/docs/pe/mqtt-broker/security/oauth-2-support/', text: 'Read more' }],
		imageSrc: '/src/assets/images/landings/mqtt-broker/login.webp',
		imageAlt: 'Single sign-on',
		imageFirst: false,
		peOnly: true,
		imageShadow: true,
	},
];
---

<section id="middle-features">
	<div class="section-heading-wrap">
		<h2 class="section-heading">MQTT client management &amp; connectivity</h2>
	</div>
	{
		features.map((f) => (
			<div class="feature-row">
				<FeatureBlockSection
					id={f.id}
					heading={f.heading}
					description={f.description}
					links={f.links}
					imageSrc={f.imageSrc}
					imageAlt={f.imageAlt}
					imageFirst={f.imageFirst}
					peOnly={f.peOnly}
					imageShadow={f.imageShadow}
					variant="pe"
				/>
			</div>
		))
	}
</section>

<style lang="scss">
	@use '../../styles/variables' as *;

	#middle-features {
		margin-bottom: 24px;
		padding-top: 100px;
	}

	.section-heading-wrap {
		@include container;
		max-width: 1400px;
		text-align: center;
		margin-bottom: $spacing-12;
	}

	.section-heading {
		font-size: 28px;
		font-weight: $font-weight-medium;
		color: var(--color-text);
		line-height: 1.6;
		margin: 0;
	}

	.feature-row {
		padding: 40px $spacing-6;
	}
</style>