---
---

<div class="thingsboard-colors">
	<h3>Brand colors</h3>
	<p>Our brand palette reflects the versatility and clarity of the ThingsBoard platform.</p>
	<p>Please use these colors consistently when referencing our products or visual identity.</p>
	<p class="mb">Deep blue color used for our Community Edition, Green color represents our Professional Edition.</p>
	<div class="colors-row">
		<div class="color-block">
			<div class="color">CE</div>
			<div class="color-values">
				<p><span class="label">HEX</span><span class="value">#305680</span> <button class="copy-btn" aria-label="Copy HEX value"><img src="/images/mediakit/copy-icon.svg" alt="Copy"></button><span class="tooltip">Copy value</span></p>
				<p><span class="label">RGB</span><span class="value">48, 86, 128</span> <button class="copy-btn" aria-label="Copy RGB value"><img src="/images/mediakit/copy-icon.svg" alt="Copy"></button><span class="tooltip">Copy value</span></p>
				<p><span class="label">CMYK</span><span class="value">62.5, 32.81, 0, 49.8</span> <button class="copy-btn" aria-label="Copy CMYK value"><img src="/images/mediakit/copy-icon.svg" alt="Copy"></button><span class="tooltip cmyk">Copy value</span></p>
			</div>
		</div>
		<div class="color-block">
			<div class="color pe">PE</div>
			<div class="color-values">
				<p><span class="label">HEX</span><span class="value">#00695C</span> <button class="copy-btn" aria-label="Copy HEX value"><img src="/images/mediakit/copy-icon.svg" alt="Copy"></button><span class="tooltip">Copy value</span></p>
				<p><span class="label">RGB</span><span class="value">0, 105, 92</span> <button class="copy-btn" aria-label="Copy RGB value"><img src="/images/mediakit/copy-icon.svg" alt="Copy"></button><span class="tooltip">Copy value</span></p>
				<p><span class="label">CMYK</span><span class="value">100, 0, 12.38, 58.82</span> <button class="copy-btn" aria-label="Copy CMYK value"><img src="/images/mediakit/copy-icon.svg" alt="Copy"></button><span class="tooltip cmyk">Copy value</span></p>
			</div>
		</div>
	</div>
</div>

<style lang="scss">
	.thingsboard-colors {
		max-width: min(1400px, calc(100% - 40px));
		padding: 46px;
		border-radius: 24px;
		box-shadow: -4px 15px 50px -20px rgba(0, 0, 0, 0.15), 0 0 8px 0 rgba(0, 0, 0, 0.08);
		margin: 0 auto 56px;
	}

	h3 {
		color: #212529;
		font-size: 28px;
		font-weight: 500;
		line-height: 44px;
		letter-spacing: 0.249px;
		margin-bottom: 8px;
	}

	p {
		margin-top: 0;
		color: #3d3d3d;
		font-size: 16px;
		font-weight: 400;
		line-height: 28px;

		&.mb { margin-bottom: 32px; }
	}

	.colors-row {
		display: flex;
		gap: 32px;
	}

	.color-block {
		flex: 1;
		border: 1px solid #e0e0e0;
		border-radius: 24px;
		padding: 8px;
		display: flex;
		gap: 12px;
	}

	.color {
		color: #fff;
		background-color: #305680;
		font-size: 28px;
		line-height: 24px;
		padding: 20px 32px;
		border-radius: 18px;
		width: 280px;
		max-width: 100%;
		text-align: center;
		display: flex;
		align-items: center;
		justify-content: center;

		&.pe {
			background-color: #00695c;
		}
	}

	.color-values {
		padding: 0 12px;
		font-size: 14px;
		line-height: 24px;
		font-weight: 400;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 4px;

		p {
			position: relative;
			display: flex;
			align-items: center;
			gap: 0;
			margin: 0;
			font-size: 14px;
			color: #212529;
		}
	}

	.label {
		display: inline-block;
		width: 46px;
		margin-right: 20px;
		flex-shrink: 0;
	}

	.value {
		margin-right: 8px;
	}

	.copy-btn {
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
		display: flex;
		align-items: center;

		img {
			width: 15px;
			height: 15px;
		}

		&:hover + .tooltip {
			visibility: visible;
		}
	}

	.tooltip {
		position: absolute;
		top: -32px;
		left: 111px;
		width: max-content;
		padding: 0 7px;
		visibility: hidden;
		background-color: #0000008f;
		color: #fff;
		text-align: center;
		border-radius: 6px;
		font-size: 12px;
		pointer-events: none;

		&.cmyk {
			left: 156px;
		}
	}

	@media (max-width: 1780px) {
		.thingsboard-colors {
			padding: 32px;
		}

		.colors-row {
			align-items: center;
			justify-content: center;
		}

		.color-block {
			flex: unset;
			flex-direction: column;
		}
	}

	@media (max-width: 720px) {
		.colors-row {
			flex-direction: column;
		}

		.color-block {
			width: 100%;
		}

		.color {
			width: 100%;
		}
	}
</style>

<script>
	document.querySelectorAll('.copy-btn').forEach((btn) => {
		btn.addEventListener('click', (e) => {
			e.stopPropagation();
			const valueEl = (btn as HTMLElement).previousElementSibling as HTMLElement;
			const tooltip = (btn as HTMLElement).nextElementSibling as HTMLElement;
			if (!valueEl || !tooltip) return;

			navigator.clipboard.writeText(valueEl.textContent?.trim() ?? '').then(() => {
				tooltip.textContent = 'Copied';
				tooltip.style.visibility = 'visible';
				setTimeout(() => {
					tooltip.textContent = 'Copy value';
					tooltip.style.visibility = '';
				}, 1500);
			});
		});
	});
</script>
