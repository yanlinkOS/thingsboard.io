<div class="contact-us-banner">
	<div class="contact-us-banner-content">
		<h2>Read more about ThingsBoard</h2>
		<p>ThingsBoard is continuously evolving to deliver more scalable, efficient, and future-proof solutions. Learn more about us and explore how we're helping companies solve real-world challenges and accelerate their IoT transformation.</p>
		<div class="contact-us-banner-buttons">
			<a href="/company/">About company</a>
			<a href="/use-cases/">Use cases</a>
			<a href="/case-studies/">Case studies</a>
		</div>
	</div>
	<img src="/images/mediakit/logo-fade.svg" width="380" height="267" alt="ThingsBoard icon">
</div>

<style lang="scss">
	.contact-us-banner {
		position: relative;
		z-index: 1;
		padding: 46px;
		background: #fff;
		border-radius: 24px;
		box-shadow: -4px 15px 50px -20px rgba(0, 0, 0, 0.15), 0 0 8px 0 rgba(0, 0, 0, 0.08);
		max-width: 1408px;
		width: 100%;
		margin-bottom: 92px;
		overflow: hidden;

		& > img {
			position: absolute;
			right: 46px;
			top: 93px;

			@media (max-width: 1150px) {
				display: none;
			}
		}
	}

	.contact-us-banner-content {
		max-width: 600px;

		h2 {
			font-size: 36px;
			font-weight: 500;
			line-height: 48px;
			margin-bottom: 16px;
			padding: 0;

			@media (max-width: 599px) {
				font-size: 28px;
			}
		}

		p {
			font-size: 18px;
			font-weight: 400;
			line-height: 30px;
			color: rgba(0, 0, 0, 0.76);
			margin-bottom: 32px;
			margin-top: 0;

			@media (max-width: 599px) {
				font-size: 14px;
			}
		}
	}

	.contact-us-banner-buttons {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;

		a {
			color: #2a7dec;
			border: 1px solid #2a7dec;
			text-align: center;
			font-size: 16px;
			font-weight: 500;
			line-height: 28px;
			width: 154px;
			border-radius: 6px;
			padding: 10px 0;
			text-decoration: none;
			display: block;

			@media (max-width: 600px) {
				width: 100%;
			}

			&:hover {
				filter: brightness(1.3) contrast(0.9);
				text-decoration: none;
			}
		}
	}
</style>