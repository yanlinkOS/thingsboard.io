---
import { Code } from '@astrojs/starlight/components';
import { UPGRADE_VERSIONS, getFamilySlug, getUpgradeStepVersions } from '~/models/upgrade-instructions';
import type { Products } from '~/models/site.models';

interface Props {
	product: Products;
	filterFamily?: string;
}

const { product, filterFamily } = Astro.props;
const versions = getUpgradeStepVersions(filterFamily);
const isPE = product === 'PE';

function isNewerVersionScheme(version: string): boolean {
	const parts = version.split('.');
	const major = parseInt(parts[0], 10);
	const minor = parseInt(parts[1], 10);
	return major > 4 || (major === 4 && minor >= 2);
}

function needsCompatibilityCheck(version: string): boolean {
	const parts = version.split('.');
	const major = parseInt(parts[0], 10);
	const minor = parseInt(parts[1], 10);
	return major > 4 || (major === 4 && minor >= 3);
}

function versionTag(ver: string): string {
	return isPE ? `${ver}PE` : ver;
}

// PE versions whose `release-*` branch was deleted from
// thingsboard-pe-docker-compose. For these we render the manifests label as
// plain text instead of a broken link.
const PE_MISSING_MANIFEST_BRANCHES = new Set([
	'3.0', '3.0.1',
	'3.1', '3.1.1',
	'3.2', '3.2.1', '3.2.2',
	'3.3.1',
	'3.4.3',
]);

function repoLink(ver: string): string | null {
	if (isPE) {
		if (PE_MISSING_MANIFEST_BRANCHES.has(ver)) return null;
		// PE docker-compose branches drop the trailing `.0` on X.Y.0 releases
		// (the branch is `release-X.Y`, not `release-X.Y.0`).
		const branch = ver.replace(/\.0$/, '');
		return `https://github.com/thingsboard/thingsboard-pe-docker-compose/tree/release-${branch}`;
	}
	return `https://github.com/thingsboard/thingsboard/tree/v${ver}/docker`;
}
---

{versions.map((v) => {
	const newer = isNewerVersionScheme(v.version);
	const needsCompat = needsCompatibilityCheck(v.version);
	const heading = v.patch && v.baseVersion !== v.displayVersion
		? `Upgrading ThingsBoard${isPE ? ' PE' : ''} to latest ${v.baseVersion} (${v.displayVersion})`
		: `Upgrading ThingsBoard${isPE ? ' PE' : ''} to ${v.displayVersion}`;
	const prevLabel = v.x ? v.upgradableFrom : v.upgradableFrom;
	const prevDisplayLabel = isPE ? `${prevLabel} PE` : prevLabel;
	const prevVersionEntry = v.prevVersionAnchor
		? UPGRADE_VERSIONS.find((v2) => v2.anchor === v.prevVersionAnchor)
		: undefined;
	const prevHref = v.prevVersionAnchor
		? filterFamily && prevVersionEntry && prevVersionEntry.family !== v.family
			? `../${getFamilySlug(prevVersionEntry.family)}/#${v.prevVersionAnchor}`
			: `#${v.prevVersionAnchor}`
		: undefined;
	const tag = versionTag(v.version);
	const manifestsLink = repoLink(v.version);

	return (
		<section>
			<h2 id={v.anchor}>{heading}</h2>

			{(v.baseVersion === '4.3.1' || v.baseVersion === '4.2.2') && (
				<aside class="starlight-aside starlight-aside--caution">
					<p class="starlight-aside__title" aria-hidden="true">Important note before upgrading to ThingsBoard {v.baseVersion}</p>
					<div class="starlight-aside__content">
						<p>Starting with version {v.baseVersion}, the platform uses Angular 20 (upgraded from Angular 18). The core platform remains fully backward compatible and no upgrade scripts are required. However, custom UI code (widgets or custom CSS) that relies on internal component structure or CSS variable names may break. This can affect up to ~1% of users with heavy customizations. We recommend testing custom UI in a staging environment before upgrading.</p>
					</div>
				</aside>
			)}

			{needsCompat && (
				<aside class="starlight-aside starlight-aside--caution">
					<p class="starlight-aside__title" aria-hidden="true">Compatibility check before upgrading</p>
					<div class="starlight-aside__content">
						{isPE ? (
							<p>If you are using Edge PE or Trendz Analytics together with ThingsBoard, verify that your target ThingsBoard version is compatible with the currently installed versions of these components. Upgrade them if required to ensure compatibility.</p>
						) : (
							<p>If you are using Edge together with ThingsBoard, verify that your target ThingsBoard version is compatible with the currently installed Edge version. Upgrade it if required to ensure compatibility.</p>
						)}
						{isPE ? (
							<ul>
								<li><strong>Edge PE:</strong> <a href="/docs/edge/pe/releases/releases-table/">Releases table</a></li>
								<li><strong>Trendz Analytics:</strong> <a href="/docs/trendz/releases/releases-table/">Releases table</a></li>
							</ul>
						) : (
							<ul>
								<li><strong>Edge:</strong> <a href="/docs/edge/releases/releases-table/">Releases table</a></li>
							</ul>
						)}
					</div>
				</aside>
			)}

			{(!newer || v.patch) && (
				<aside class="starlight-aside starlight-aside--note">
					<p class="starlight-aside__title" aria-hidden="true">Note</p>
					<div class="starlight-aside__content">
						<p>
							These upgrade steps are applicable for ThingsBoard version{' '}
							{prevHref ? (
								<a href={prevHref}>{prevDisplayLabel}</a>
							) : prevDisplayLabel}
							{v.patch && <>{' '}or any {v.baseVersion} patch</>}.{' '}
							In order to upgrade to <strong>{isPE ? `${v.displayVersion}PE` : v.displayVersion}</strong> you need to{' '}
							{prevHref ? (
								<><a href={prevHref}><strong>upgrade to {prevDisplayLabel} first</strong></a>.</>
							) : (
								<>upgrade to {prevDisplayLabel} first.</>
							)}
						</p>
					</div>
				</aside>
			)}

			<aside class="starlight-aside starlight-aside--caution">
				<p class="starlight-aside__title" aria-hidden="true">Important</p>
				<div class="starlight-aside__content">
					<p>
						We strongly recommend that you also update your Docker Compose deployment manifests to{' '}
						{manifestsLink ? (
							<a href={manifestsLink}><strong>the corresponding version from GitHub repository</strong></a>
						) : (
							<strong>the corresponding version from GitHub repository</strong>
						)}{' '}
						with every ThingsBoard upgrade. This ensures your ThingsBoard service runs with the latest best-practice parameters and configurations, while also guaranteeing that all required services are correctly deployed to support the newest features introduced in the release.
					</p>
					<p>
						If you are running older releases of ThingsBoard — be aware that the manifests in the <code>master</code> branch of the repository may contain configurations for features that are not available in your specific version. Always ensure that manifests are compatible with your target ThingsBoard version while merging deployment files.
					</p>
				</div>
			</aside>

			<h4>ThingsBoard{isPE ? ' PE' : ''} service upgrade</h4>

			<p>Change the parameter <code>TB_VERSION</code> in the <code>.env</code> file:</p>
			<Code code={`TB_VERSION=${tag}`} lang="bash" />

			<p>Execute the following commands:</p>
			{newer ? (
				<>
					<Code code="./docker-stop-services.sh" lang="bash" />

					<aside class="starlight-aside starlight-aside--caution">
						<p class="starlight-aside__title" aria-hidden="true">Caution</p>
						<div class="starlight-aside__content">
							{v.patch ? (
								<p>If you are upgrading from {v.upgradableFrom}, you <strong>must</strong> run the script below. However, if you are upgrading from version {`${v.baseVersion}.x`}, <strong>DO NOT</strong> run the upgrade script; proceed directly to starting the service.</p>
							) : (
								<p>If you are upgrading from version {v.upgradableFrom}, you must run the script below.</p>
							)}
						</div>
					</aside>

					<Code code="./docker-upgrade-tb.sh" lang="bash" />
					<Code code="./docker-start-services.sh" lang="bash" />
				</>
			) : v.upgrade ? (
				<Code code={'./docker-stop-services.sh\n./docker-upgrade-tb.sh\n./docker-start-services.sh'} lang="bash" />
			) : (
				<Code code={'./docker-stop-services.sh\n./docker-start-services.sh'} lang="bash" />
			)}
		</section>
	);
})}

<style>
	section {
		margin-bottom: 3rem;
	}

	.starlight-aside {
		border-inline-start: 0.25rem solid;
		padding: 0.75rem 1rem;
		margin: 1rem 0;
		border-radius: 0 4px 4px 0;
	}

	.starlight-aside--note {
		border-color: var(--sl-color-blue);
		background: var(--sl-color-blue-low);
	}

	.starlight-aside--caution {
		border-color: var(--sl-color-orange);
		background: var(--sl-color-orange-low);
	}

	.starlight-aside__title {
		font-weight: 700;
		margin: 0 0 0.25rem;
	}

	.starlight-aside__content {
		margin: 0;
	}

	.starlight-aside__content p {
		margin: 0.25rem 0;
	}
</style>
