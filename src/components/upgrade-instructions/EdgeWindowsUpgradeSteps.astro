---
import { Code } from '@astrojs/starlight/components';
import {
	EDGE_UPGRADE_VERSIONS,
	getFamilySlug,
} from '~/models/edge-upgrade-instructions';
import type { EdgeUpgradeVersion } from '~/models/edge-upgrade-instructions';
import type { Products } from '~/models/site.models';

interface Props {
	product: Products;
	filterFamily?: string;
}

const { product, filterFamily } = Astro.props;
const versions = filterFamily
	? EDGE_UPGRADE_VERSIONS.filter((v) => v.family === filterFamily)
	: EDGE_UPGRADE_VERSIONS;

const isPE = product === 'EDGE_PE';

function ceWindowsUrl(v: EdgeUpgradeVersion): string {
	const tag = v.ceGhTagOverride ?? v.linuxPkgSuffix;
	return `https://github.com/thingsboard/thingsboard-edge/releases/download/v${tag}/tb-edge-windows-${v.linuxPkgSuffix}.zip`;
}

function peWindowsUrl(v: EdgeUpgradeVersion): string {
	return `https://dist.thingsboard.io/tb-edge-windows-${v.linuxPkgSuffix}pe.zip`;
}
---

{versions.map((v) => {
	const heading = v.patch
		? `Upgrading Edge${isPE ? ' PE' : ''} to latest ${v.baseVersion} (${v.displayVersion})`
		: `Upgrading Edge${isPE ? ' PE' : ''} to ${v.displayVersion}`;
	const prevDisplayLabel = isPE ? `${v.upgradableFrom} PE` : v.upgradableFrom;
	const prevVersionEntry = v.prevVersionAnchor
		? EDGE_UPGRADE_VERSIONS.find((v2) => v2.anchor === v.prevVersionAnchor)
		: undefined;
	const prevHref = v.prevVersionAnchor
		? filterFamily && prevVersionEntry && prevVersionEntry.family !== v.family
			? `../${getFamilySlug(prevVersionEntry.family)}/#${v.prevVersionAnchor}`
			: `#${v.prevVersionAnchor}`
		: undefined;
	const upgradeFlag = v.manualVersionUpgrade ? ` --fromVersion=${v.upgradableFrom}` : '';
	const dlUrl = isPE ? peWindowsUrl(v) : ceWindowsUrl(v);
	const pkg = isPE
		? `tb-edge-windows-${v.linuxPkgSuffix}pe.zip`
		: `tb-edge-windows-${v.linuxPkgSuffix}.zip`;

	return (
		<section>
			<h2 id={v.anchor}>{heading}</h2>

			<aside class="starlight-aside starlight-aside--caution">
				<p class="starlight-aside__title" aria-hidden="true">Upgrade server first</p>
				<div class="starlight-aside__content">
					<p>Ensure your <strong>ThingsBoard Server is up to date</strong> before upgrading ThingsBoard Edge. If your server version is outdated, <a href={isPE ? `/docs/pe/installation/upgrade-instructions/` : `/docs/installation/upgrade-instructions/`}>upgrade it first</a>.</p>
					<p>These upgrade steps are applicable for ThingsBoard Edge version{' '}
						{prevHref ? (
							<a href={prevHref}>{prevDisplayLabel}</a>
						) : prevDisplayLabel}.
					</p>
				</div>
			</aside>

			<h3>Backup before upgrading</h3>

			<aside class="starlight-aside starlight-aside--note">
				<p class="starlight-aside__title" aria-hidden="true">Note</p>
				<div class="starlight-aside__content">
					<p>Make sure your system has enough free space to store the backup.</p>
				</div>
			</aside>

			<p>Stop the ThingsBoard Edge service:</p>
			<Code code="net stop tb-edge" lang="powershell" />

			<p>Back up the database using pgAdmin:</p>
			<ol>
				<li>Launch <strong>pgAdmin</strong> and log in as the <strong>postgres</strong> superuser.</li>
				<li>In the left sidebar, expand your server and locate the <strong>tb_edge</strong> database.</li>
				<li>Right-click <strong>tb_edge</strong> and select <strong>Backup</strong>.</li>
				<li>In the <strong>Backup Dialog</strong>, specify a filename and location for your backup file.</li>
				<li>Click <strong>Backup</strong>.</li>
			</ol>

			<h3>Download the Edge package</h3>
			<p>Download <a href={dlUrl}>{pkg}</a>.</p>

			<h3>Upgrade the package</h3>

			<p>Back up your configuration directory — copy <code>C:\Program Files (x86)\tb-edge\conf</code> to a safe location.</p>

			<p>Extract the downloaded package and copy its contents to <code>C:\Program Files (x86)\tb-edge</code>, overwriting the existing files. Then compare your old configuration files (from the backup) with the new ones and merge any custom settings.</p>

			{v.patch && (
				<aside class="starlight-aside starlight-aside--note">
					<p class="starlight-aside__title" aria-hidden="true">Note</p>
					<div class="starlight-aside__content">
						<p>If you are upgrading from <strong>{v.upgradableFrom}</strong>, you <strong>must</strong> run the upgrade script below. However, if you are upgrading from version <strong>{v.baseVersion}.x</strong>, do <strong>not</strong> run the upgrade script — proceed directly to starting the service.</p>
					</div>
				</aside>
			)}

			{v.upgrade && (
				<>
					<p>Open <strong>Command Prompt as Administrator</strong> and run the upgrade script:</p>
					<Code code={`cd "C:\\Program Files (x86)\\tb-edge"\nupgrade.bat${upgradeFlag}`} lang="powershell" />
				</>
			)}

			<h3>Start the service</h3>
			<Code code="net start tb-edge" lang="powershell" />
		</section>
	);
})}

<style>
	ol {
		margin: 0.5rem 0 1rem 1.25rem;
	}

	ol li {
		margin-bottom: 0.25rem;
	}

	section {
		margin-bottom: 3rem;
	}

	.starlight-aside {
		border-inline-start: 0.25rem solid;
		padding: 0.75rem 1rem;
		margin: 1rem 0;
		border-radius: 0 4px 4px 0;
	}

	.starlight-aside--note {
		border-color: var(--sl-color-blue);
		background: var(--sl-color-blue-low);
	}

	.starlight-aside--caution {
		border-color: var(--sl-color-orange);
		background: var(--sl-color-orange-low);
	}

	.starlight-aside__title {
		font-weight: 700;
		margin: 0 0 0.25rem;
	}

	.starlight-aside__content {
		margin: 0;
	}

	.starlight-aside__content p {
		margin: 0.25rem 0;
	}
</style>
