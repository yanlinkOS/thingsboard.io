---
import { Code } from '@astrojs/starlight/components';
import { TRENDZ_UPGRADE_VERSIONS } from '~/models/trendz-upgrade-instructions';

interface Props {
	platform: 'ubuntu' | 'centos' | 'windows' | 'docker' | 'kubernetes';
	filterFamily?: string;
}

const { platform, filterFamily } = Astro.props;
const versions = filterFamily
	? TRENDZ_UPGRADE_VERSIONS.filter((v) => v.family === filterFamily)
	: TRENDZ_UPGRADE_VERSIONS;

const pkgExt = platform === 'ubuntu' ? 'deb' : 'rpm';
const installCmd = platform === 'ubuntu' ? 'dpkg -i' : 'rpm -Uvh';

const syncLink =
	platform === 'ubuntu'
		? '/docs/trendz/installation/ubuntu/#step-6-sync-thingsboard-with-trendz'
		: platform === 'centos'
			? '/docs/trendz/installation/rhel/#step-6-sync-thingsboard-with-trendz'
			: platform === 'windows'
				? '/docs/trendz/installation/docker-windows/#sync-trendz-with-thingsboard'
				: platform === 'kubernetes'
					? '/docs/trendz/installation/kubernetes/#sync-trendz-with-thingsboard'
					: '/docs/trendz/installation/docker/#sync-trendz-with-thingsboard';

const java17Link =
	platform === 'centos'
		? '/docs/trendz/installation/rhel/#step-1-install-java-17-openjdk'
		: '/docs/trendz/installation/ubuntu/#step-1-install-java-17-openjdk';
---

{(platform === 'ubuntu' || platform === 'centos') && (
	<section class="prepare-section">
		<h2 id="prepare-for-upgrading-trendz-analytics">Prepare for upgrading Trendz Analytics</h2>
		<h3>Stop Trendz Analytics</h3>
		<p>Check that the Trendz service is stopped.</p>
		<Code code="sudo systemctl stop trendz" lang="bash" />
		<Code code="sudo systemctl status trendz" lang="bash" />
		<h3>Backup database</h3>
		<p>Make a backup of the database before upgrading.</p>
		<Code code={`sudo -u postgres psql -c "SELECT pg_size_pretty( pg_database_size('trendz') );"`} lang="bash" />
		<Code code="df -h /" lang="bash" />
		<p>If there is enough free space, create a backup:</p>
		<Code code="sudo -Hiu postgres pg_dump trendz > trendz.sql.bak" lang="bash" />
	</section>
)}

{platform === 'kubernetes' && (
	<section class="prepare-section">
		<h2 id="prepare-for-upgrading-trendz-analytics">Prepare for upgrading Trendz Analytics</h2>
		<h3>Obtain Trendz Kubernetes scripts</h3>
		<p>Use the Kubernetes configuration files from your original installation. If you no longer have them, re-clone the repository and fill in your configuration values as described in the <a href="/docs/trendz/installation/kubernetes/">installation guide</a>:</p>
		<Code code="git clone https://github.com/thingsboard/trendz-k8s.git --depth 1" lang="bash" />
		<h3>Connect to your Kubernetes cluster</h3>
		<p>Select the correct kube-config context before running any commands:</p>
		<Code code="kubectl config get-contexts" lang="bash" />
		<Code code="kubectl config use-context <your-config-name>" lang="bash" />
	</section>
)}

{versions.map((v) => {
	const heading = v.patch
		? `Upgrading Trendz Analytics to latest ${v.baseVersion} (${v.displayVersion})`
		: `Upgrading Trendz Analytics to ${v.displayVersion}`;
	const debPkg = `trendz-${v.version}.${pkgExt}`;
	const dlUrl = `https://dist.thingsboard.io/${debPkg}`;
	const wgetCmd = `wget ${dlUrl}`;
	const installCmdFull = `sudo ${installCmd} ${debPkg}`;
	const winZipName = v.windowsZipOverride ?? `trendz-windows-${v.version}.zip`;
	const winZipUrl = `https://dist.thingsboard.io/${winZipName}`;
	const upgradeScriptCmd = v.fromVersion
		? `sudo /usr/share/trendz/bin/install/upgrade.sh --fromVersion=${v.fromVersion}`
		: `sudo /usr/share/trendz/bin/install/upgrade.sh`;
	const upgradeBatCmd = v.fromVersion
		? `C:\\trendz> upgrade.bat --fromVersion=${v.fromVersion}`
		: `C:\\trendz> upgrade.bat`;
	const dockerCmds = `docker pull thingsboard/trendz:${v.version}\ndocker compose stop trendz\ndocker compose run --rm -e UPGRADE_TRENDZ=true trendz\ndocker compose up -d`;
	const k8sFlagFileCmd = v.fromVersion
		? `kubectl exec <POD_NAME> -- sh -c "echo '${v.fromVersion}' > /data/.upgradeversion"`
		: '';
	const k8sLogOutput =
		'Upgrading Trendz from version …\n…\nCurrent version is …, upgrade is not needed\n…\nStarted TrendzApplication in …';

	return (
		<section>
			<h2 id={v.anchor}>{heading}</h2>

			{(platform === 'ubuntu' || platform === 'centos') && (
				<aside class="starlight-aside starlight-aside--note">
					<p class="starlight-aside__title" aria-hidden="true">Note</p>
					<div class="starlight-aside__content">
						<p><a href="#prepare-for-upgrading-trendz-analytics"><strong>Prepare</strong></a> for upgrading Trendz Analytics before running the steps below.</p>
					</div>
				</aside>
			)}

			{v.haproxyNote && (platform === 'ubuntu' || platform === 'centos') && (
				<aside class="starlight-aside starlight-aside--caution">
					<p class="starlight-aside__title" aria-hidden="true">HAProxy note</p>
					<div class="starlight-aside__content">
						<p>If you are using Trendz behind <strong>HAProxy</strong>, ensure that paths <code>/trendz/</code> and <code>/apiTrendz/</code> are routed to the Trendz backend (with trailing slash). Adding Trendz to the ThingsBoard HAProxy configuration is also recommended so it is accessible from the same domain.</p>
					</div>
				</aside>
			)}
			{v.haproxyNote && (platform === 'windows' || platform === 'docker') && (
				<aside class="starlight-aside starlight-aside--note">
					<p class="starlight-aside__title" aria-hidden="true">Routing note</p>
					<div class="starlight-aside__content">
						<p>If Trendz is accessed through a reverse proxy, ensure that paths <code>/trendz/</code> and <code>/apiTrendz/</code> are routed to the Trendz backend with a trailing slash.</p>
					</div>
				</aside>
			)}

			{v.java17Warning && (platform === 'ubuntu' || platform === 'centos') && (
				<aside class="starlight-aside starlight-aside--caution">
					<p class="starlight-aside__title" aria-hidden="true">Java 17 required</p>
					<div class="starlight-aside__content">
						<p>Trendz Analytics {v.displayVersion} requires <strong>Java 17</strong>. Before upgrading, update your Java installation to Java 17. Refer to the <a href={java17Link}>Java 17 installation instructions</a> for details.</p>
					</div>
				</aside>
			)}

			{v.pythonExecutorWarning && (platform === 'ubuntu' || platform === 'centos' || platform === 'windows') && (
				<aside class="starlight-aside starlight-aside--caution">
					<p class="starlight-aside__title" aria-hidden="true">Python Executor migration</p>
					<div class="starlight-aside__content">
						<p>Starting from Trendz Analytics {v.displayVersion}, Python Calculation Fields and prediction models require the <strong>Python Executor</strong> Docker service to run. It is not included in the package installation and must be installed separately before upgrading. See the <a href="/docs/trendz/installation/python-executor-configuration/">Python Executor configuration guide</a> for installation steps.</p>
					</div>
				</aside>
			)}

			{(platform === 'ubuntu' || platform === 'centos') && (
				<>
					<h3>Trendz Analytics package download</h3>
					<Code code={wgetCmd} lang="bash" />
					<h3>Trendz Analytics service upgrade</h3>
					<p>Install the latest Trendz Analytics package:</p>
					<Code code={installCmdFull} lang="bash" />
					<aside class="starlight-aside starlight-aside--note">
						<p class="starlight-aside__title" aria-hidden="true">Note</p>
						<div class="starlight-aside__content">
							<p>The package installer may ask you to merge your Trendz configuration. Use the <strong>merge option</strong> to preserve your existing settings.</p>
						</div>
					</aside>
					{v.noUpgradeScript ? (
						<aside class="starlight-aside starlight-aside--note">
							<p class="starlight-aside__title" aria-hidden="true">No upgrade script needed</p>
							<div class="starlight-aside__content">
								<p>No upgrade script is required for this version. Start the service directly after installing the package.</p>
							</div>
						</aside>
					) : (
						<>
							<p>Execute the upgrade script:</p>
							<Code code={upgradeScriptCmd} lang="bash" />
							{v.fromVersion ? (
								<aside class="starlight-aside starlight-aside--note">
									<p class="starlight-aside__title" aria-hidden="true">--fromVersion flag</p>
									<div class="starlight-aside__content">
										<p>Set <code>--fromVersion</code> to the version you are currently running. You can upgrade directly from <strong>any earlier version</strong> — there is no need to step through intermediate releases.</p>
									</div>
								</aside>
							) : (
								<aside class="starlight-aside starlight-aside--note">
									<p class="starlight-aside__title" aria-hidden="true">Upgrading from any version</p>
									<div class="starlight-aside__content">
										<p>No <code>--fromVersion</code> flag is required. You can upgrade directly from <strong>any earlier version</strong>.</p>
									</div>
								</aside>
							)}
						</>
					)}
					<h3>Start the service</h3>
					<Code code="sudo service trendz start" lang="bash" />
				</>
			)}

			{platform === 'windows' && (
				<>
					<h3>Trendz Analytics package download</h3>
					<p>Download the Windows installation archive: <a href={winZipUrl} target="_blank" rel="noopener noreferrer">{winZipName}</a>.</p>
					<h3>Trendz Analytics service upgrade</h3>
					<ol>
						<li>Stop the Trendz service if it is running:<Code code="net stop trendz" lang="powershell" /></li>
						<li>Back up your Trendz configuration directory (e.g. <code>C:\trendz\conf</code>).</li>
						<li>Remove the Trendz install directory.</li>
						<li>Unzip the installation archive to the Trendz install directory.</li>
						<li>Merge your old configuration settings into the new configuration files.</li>
					</ol>
					{v.noUpgradeScript ? (
						<aside class="starlight-aside starlight-aside--note">
							<p class="starlight-aside__title" aria-hidden="true">No upgrade script needed</p>
							<div class="starlight-aside__content">
								<p>No upgrade script is required for this version. Start the service directly after installing the package.</p>
							</div>
						</aside>
					) : (
						<>
							{v.patch && (
								<aside class="starlight-aside starlight-aside--note">
									<p class="starlight-aside__title" aria-hidden="true">Note</p>
									<div class="starlight-aside__content">
										<p>If you are upgrading from version {v.family}.x, <strong>do not</strong> run the upgrade script; start the service directly.</p>
									</div>
								</aside>
							)}
							<p>Run <strong>upgrade.bat</strong> as Administrator:</p>
							<Code code={upgradeBatCmd} lang="powershell" />
							{v.fromVersion ? (
								<aside class="starlight-aside starlight-aside--note">
									<p class="starlight-aside__title" aria-hidden="true">--fromVersion flag</p>
									<div class="starlight-aside__content">
										<p>Set <code>--fromVersion</code> to the version you are currently running. You can upgrade directly from <strong>any earlier version</strong> — there is no need to step through intermediate releases.</p>
									</div>
								</aside>
							) : (
								<aside class="starlight-aside starlight-aside--note">
									<p class="starlight-aside__title" aria-hidden="true">Upgrading from any version</p>
									<div class="starlight-aside__content">
										<p>No <code>--fromVersion</code> flag is required. You can upgrade directly from <strong>any earlier version</strong>.</p>
									</div>
								</aside>
							)}
						</>
					)}
					<h3>Start the service</h3>
					<Code code="net start trendz" lang="powershell" />
				</>
			)}

			{platform === 'docker' && (
				<>
					<h3>Trendz Analytics service upgrade</h3>
					<ol>
						<li>
							<p>Create a database backup:</p>
							<Code code={`docker compose exec postgres sh -c "pg_dump -U postgres trendz > /var/lib/postgresql/data/trendz_dump"`} lang="bash" />
						</li>
						<li>
							<p>Update the version of <code>thingsboard/trendz</code> and <code>thingsboard/trendz-python-executor</code> in your <code>docker-compose.yml</code> to <strong>{v.version}</strong>.</p>
						</li>
						<li>
							<p>Pull the image, run the upgrade, and restart:</p>
							<Code code={dockerCmds} lang="bash" />
						</li>
					</ol>
				</>
			)}

			{platform === 'kubernetes' && (
				<>
					<aside class="starlight-aside starlight-aside--note">
						<p class="starlight-aside__title" aria-hidden="true">Note</p>
						<div class="starlight-aside__content">
							<p><a href="#prepare-for-upgrading-trendz-analytics"><strong>Prepare</strong></a> for upgrading Trendz Analytics before running the steps below.</p>
						</div>
					</aside>

					<h3>Reduce pods count</h3>
					<p>The deployment must have exactly one running pod for the upgrade to succeed:</p>
					<Code code="kubectl scale deployment trendz-app-deployment --replicas=1" lang="bash" />

					{v.fromVersion && (
						<>
							<h3>Create upgrade flag file</h3>
							<p>Get the current pod name:</p>
							<Code code="kubectl get pods -l app=trendz-app-pod-label" lang="bash" />
							<p>Create the <code>.upgradeversion</code> flag file inside the pod, replacing <code>&lt;POD_NAME&gt;</code> with the name from the previous command. Set the version to the one you are currently running:</p>
							<Code code={k8sFlagFileCmd} lang="bash" />
							<aside class="starlight-aside starlight-aside--note">
								<p class="starlight-aside__title" aria-hidden="true">Note</p>
								<div class="starlight-aside__content">
									<p>Set the value to the version you are <strong>currently running</strong>, not the version you are upgrading to. You can upgrade directly from <strong>any earlier version</strong>.</p>
								</div>
							</aside>
						</>
					)}

					<h3>Update image version</h3>
					<p>Open <code>trendz-app-deployment.yml</code> and update the <code>image</code> field to <strong>thingsboard/trendz:{v.version}</strong>:</p>
					<Code code="nano trendz-app-deployment.yml" lang="bash" />

					<h3>Apply the deployment</h3>
					<p>Apply the updated configuration and wait until the pod is ready:</p>
					<Code code="kubectl apply -f trendz-app-deployment.yml" lang="bash" />

					<h3>Verify the upgrade</h3>
					<p>Stream the pod logs to confirm the upgrade ran successfully:</p>
					<Code code="kubectl logs -f <trendz-pod-name>" lang="bash" />
					<p>Look for the following lines:</p>
					<Code code={k8sLogOutput} lang="text" />

					<h3>Restore pods count</h3>
					<p>After the upgrade is complete, restore your preferred replica count:</p>
					<Code code="kubectl scale deployment trendz-app-deployment --replicas=<pod-count>" lang="bash" />
				</>
			)}

			{v.widgetBundleNote ? (
				<>
					<h3>Upload widget bundle to ThingsBoard</h3>
					<p>After the upgrade, upload the latest Trendz widget bundle and JS module to ThingsBoard. See the <a href="/docs/trendz/post-installation-steps/#trendz-widget-bundle-and-js-module">post-installation steps</a> for details.</p>
				</>
			) : v.family === '1.15' ? (
				<>
					<h3>Sync Trendz with ThingsBoard</h3>
					<p>After the upgrade, sync Trendz with ThingsBoard to update widgets and JS modules automatically. See <a href={syncLink}>the sync instructions</a> for details.</p>
				</>
			) : null}
		</section>
	);
})}

<style>
	section {
		margin-bottom: 3rem;
	}

	.prepare-section {
		padding: 1rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 6px;
		margin-bottom: 2rem;
	}

	.starlight-aside {
		border-inline-start: 0.25rem solid;
		padding: 0.75rem 1rem;
		margin: 1rem 0;
		border-radius: 0 4px 4px 0;
	}

	.starlight-aside--note {
		border-color: var(--sl-color-blue);
		background: var(--sl-color-blue-low);
	}

	.starlight-aside--caution {
		border-color: var(--sl-color-orange);
		background: var(--sl-color-orange-low);
	}

	.starlight-aside__title {
		font-weight: 700;
		margin: 0 0 0.25rem;
	}

	.starlight-aside__content {
		margin: 0;
	}

	.starlight-aside__content p {
		margin: 0.25rem 0;
	}
</style>
