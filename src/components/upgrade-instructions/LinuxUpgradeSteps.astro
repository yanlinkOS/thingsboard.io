---
import { UPGRADE_VERSIONS, getFamilySlug } from '~/models/upgrade-instructions';
import type { Products } from '~/models/site.models';
import PrepareSection from './PrepareSection.astro';

interface Props {
	product: Products;
	platform: 'ubuntu' | 'centos';
	filterFamily?: string;
}

const { product, platform, filterFamily } = Astro.props;
const versions = filterFamily ? UPGRADE_VERSIONS.filter((v) => v.family === filterFamily) : UPGRADE_VERSIONS;

const isPE = product === 'PE';
const isUbuntu = platform === 'ubuntu';
const pkgExt = isUbuntu ? 'deb' : 'rpm';
const installCmd = isUbuntu ? 'dpkg -i' : 'rpm -Uvh';
const webReportLink = isUbuntu
	? '/docs/user-guide/install/pe/ubuntu/#step-9-install-thingsboard-webreport-component'
	: '/docs/user-guide/install/pe/rhel/#step-9-install-thingsboard-webreport-component';
const javaGuideLink = isUbuntu
	? '/docs/user-guide/install/ubuntu/#step-1-install-java-17-openjdk'
	: '/docs/user-guide/install/rhel/#step-1-install-java-17-openjdk';
const cassandraGuideLink = isUbuntu
	? '/docs/installation/ubuntu/#step-3-configure-database'
	: '/docs/installation/rhel/#step-3-configure-database';

function pkgName(ver: string): string {
	return isPE ? `thingsboard-${ver}pe.${pkgExt}` : `thingsboard-${ver}.${pkgExt}`;
}

function downloadUrl(ver: string): string {
	if (isPE) {
		return `https://dist.thingsboard.io/${pkgName(ver)}`;
	}
	return `https://github.com/thingsboard/thingsboard/releases/download/v${ver}/${pkgName(ver)}`;
}

function isNewerVersionScheme(version: string): boolean {
	const parts = version.split('.');
	const major = parseInt(parts[0], 10);
	const minor = parseInt(parts[1], 10);
	return major > 4 || (major === 4 && minor >= 2);
}

function needsCompatibilityCheck(version: string): boolean {
	const parts = version.split('.');
	const major = parseInt(parts[0], 10);
	const minor = parseInt(parts[1], 10);
	return major > 4 || (major === 4 && minor >= 3);
}
---

{isPE && <PrepareSection platform={platform} />}

{versions.map((v) => {
	const newer = isNewerVersionScheme(v.version);
	const needsCompat = needsCompatibilityCheck(v.version);
	const heading = v.patch
		? `Upgrading ThingsBoard${isPE ? ' PE' : ''} to latest ${v.baseVersion} (${v.displayVersion})`
		: `Upgrading ThingsBoard${isPE ? ' PE' : ''} to ${v.displayVersion}`;
	const prevLabel = v.x ? v.upgradableFrom : v.upgradableFrom;
	const prevDisplayLabel = isPE ? `${prevLabel} PE` : prevLabel;
	const prevVersionEntry = v.prevVersionAnchor
		? UPGRADE_VERSIONS.find((v2) => v2.anchor === v.prevVersionAnchor)
		: undefined;
	const prevHref = v.prevVersionAnchor
		? filterFamily && prevVersionEntry && prevVersionEntry.family !== v.family
			? `../${getFamilySlug(prevVersionEntry.family)}/#${v.prevVersionAnchor}`
			: `#${v.prevVersionAnchor}`
		: undefined;
	const fromVersion = v.manualVersionUpgradeLabel ?? v.upgradableFrom;
	const upgradeFlag = v.manualVersionUpgrade ? ` --fromVersion=${fromVersion}` : '';
	const pkg = pkgName(v.version);
	const dlUrl = downloadUrl(v.version);

	return (
		<section>
			<h2 id={v.anchor}>{heading}</h2>

			{needsCompat && (
				<aside class="starlight-aside starlight-aside--caution">
					<p class="starlight-aside__title" aria-hidden="true">Compatibility check before upgrading</p>
					<div class="starlight-aside__content">
						{isPE ? (
							<p>If you are using Edge PE or Trendz Analytics together with ThingsBoard, verify that your target ThingsBoard version is compatible with the currently installed versions of these components. Upgrade them if required to ensure compatibility.</p>
						) : (
							<p>If you are using Edge together with ThingsBoard, verify that your target ThingsBoard version is compatible with the currently installed Edge version. Upgrade it if required to ensure compatibility.</p>
						)}
						{isPE ? (
							<ul>
								<li><strong>Edge PE:</strong> <a href="/docs/pe/edge/releases/releases-table/">Releases table</a></li>
								<li><strong>Trendz Analytics:</strong> <a href="/docs/trendz/releases/releases-table/">Releases table</a></li>
							</ul>
						) : (
							<ul>
								<li><strong>Edge:</strong> <a href="/docs/edge/releases/releases-table/">Releases table</a></li>
							</ul>
						)}
					</div>
				</aside>
			)}

			{(!newer || v.patch) && (
				<aside class="starlight-aside starlight-aside--note">
					<p class="starlight-aside__title" aria-hidden="true">Note</p>
					<div class="starlight-aside__content">
						<p>
							These upgrade steps are applicable for ThingsBoard version{' '}
							{prevHref ? (
								<a href={prevHref}>{prevDisplayLabel}</a>
							) : (
								prevDisplayLabel
							)}{v.patch ? <>{' '}or any {v.baseVersion} patch</> : ''}.{' '}
							In order to upgrade to <strong>{isPE ? `${v.displayVersion}PE` : v.displayVersion}</strong> you need to{' '}
							{prevHref ? (
								<><a href={prevHref}><strong>upgrade to {prevDisplayLabel} first</strong></a>.</>
							) : (
								<>upgrade to {prevDisplayLabel} first.</>
							)}
						</p>
						{isPE && (
							<p><a href="#prepare-for-upgrading-thingsboard"><strong>Prepare</strong></a> for upgrading ThingsBoard.</p>
						)}
					</div>
				</aside>
			)}

			{v.version === '3.7.0' && (
				<aside class="starlight-aside starlight-aside--caution">
					<p class="starlight-aside__title" aria-hidden="true">Important note before upgrading to ThingsBoard 3.7</p>
					<div class="starlight-aside__content">
						<p>ThingsBoard backend was migrated to Java 17. Install JDK 17 and ensure that system's default Java version is set to 17.</p>
						<p>Please refer to Step 1 of the corresponding installation guide for detailed instructions: <a href={javaGuideLink}>{isUbuntu ? 'Ubuntu' : 'CentOS/RHEL'}</a></p>
					</div>
				</aside>
			)}

			{v.version === '3.5.0' && (
				<aside class="starlight-aside starlight-aside--caution">
					<p class="starlight-aside__title" aria-hidden="true">Important note before upgrading to ThingsBoard 3.5</p>
					<div class="starlight-aside__content">
						<p>ThingsBoard UI was migrated to Angular 15. You need to re-build your custom widgets and rule nodes (which use UI) on Angular 15.</p>
						<p>We suggest consulting <a href="https://v15.material.angular.io/guide/mdc-migration">this guide</a>.</p>
					</div>
				</aside>
			)}

			{!isUbuntu && v.version === '3.8.0' && !isPE && (
				<>
					<h4>Install PostgreSQL contrib package (CentOS only)</h4>
					<pre><code>sudo dnf install -y postgresql16-contrib</code></pre>
				</>
			)}

			<h4>ThingsBoard{isPE ? ' PE' : ''} package download</h4>
			<pre><code set:text={`wget ${dlUrl}`} /></pre>

			<h4>ThingsBoard{isPE ? ' PE' : ''} service upgrade</h4>

			<ul>
				<li>Stop ThingsBoard service if it is running.</li>
			</ul>
			<pre><code>sudo service thingsboard stop</code></pre>

			{isPE && (
				<ul>
					<li>Install <a href={webReportLink}>ThingsBoard Web Report component</a> as described in the installation guide. Do not forget to change the version according to your ThingsBoard version.</li>
				</ul>
			)}

			<pre><code set:text={`sudo ${installCmd} ${pkg}`} /></pre>

			<aside class="starlight-aside starlight-aside--note">
				<p class="starlight-aside__title" aria-hidden="true">Note</p>
				<div class="starlight-aside__content">
					<p>Package installer may ask you to merge your ThingsBoard configuration. It is preferred to use merge option to make sure that all your previous parameters will not be overwritten.</p>
				</div>
			</aside>

			{v.upgrade && (
				<>
					{newer && (
						<aside class="starlight-aside starlight-aside--caution">
							<p class="starlight-aside__title" aria-hidden="true">Caution</p>
							<div class="starlight-aside__content">
								{v.patch ? (
									<p>If you are upgrading from {v.upgradableFrom}, you <strong>must</strong> run the script below. However, if you are upgrading from version {`${v.baseVersion}.x`}, <strong>DO NOT</strong> run the upgrade script; proceed directly to starting the service.</p>
								) : (
									<p>If you are upgrading from version {v.upgradableFrom}, you must run the script below.</p>
								)}
							</div>
						</aside>
					)}
					<pre><code set:text={`sudo /usr/share/thingsboard/bin/install/upgrade.sh${upgradeFlag}`} /></pre>
				</>
			)}

			{!v.upgrade && (
				<p><em>No database schema upgrade is required for this version. Proceed to starting the service.</em></p>
			)}

			<h4>Start the service</h4>

			{v.version === '3.7.0' && (
				<aside class="starlight-aside starlight-aside--note">
					<p class="starlight-aside__title" aria-hidden="true">Note</p>
					<div class="starlight-aside__content">
						<p><strong>In case Cassandra is installed</strong>, ensure that a proper <strong>JAVA_HOME</strong> parameter is set for <em>cassandra.in.sh</em> include file. As of 3.7.0 release, latest stable Cassandra version does not support Java 17 yet.</p>
						<p>In case action is required, you can refer to the <em>"you will need to install Java..."</em> section of the <a href={cassandraGuideLink}>Cassandra installation guide</a>.</p>
					</div>
				</aside>
			)}

			<pre><code>sudo service thingsboard start</code></pre>

			{v.version === '3.4.2' && (
				<aside class="starlight-aside starlight-aside--note">
					<p class="starlight-aside__title" aria-hidden="true">Note</p>
					<div class="starlight-aside__content">
						<p>Update the JWT signing key if you use the default one "thingsboardDefaultSigningKey" on production environments. See <a href="/docs/user-guide/ui/security-settings/#jwt-security-settings">JWT security settings</a> for details.</p>
					</div>
				</aside>
			)}
		</section>
	);
})}

<style>
	pre {
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 4px;
		padding: 0.75rem 1rem;
		overflow-x: auto;
		margin: 0.5rem 0 1rem;
	}

	pre code {
		font-family: var(--sl-font-mono);
		font-size: 0.85rem;
		white-space: pre;
	}

	section {
		margin-bottom: 3rem;
	}

	.starlight-aside {
		border-inline-start: 0.25rem solid;
		padding: 0.75rem 1rem;
		margin: 1rem 0;
		border-radius: 0 4px 4px 0;
	}

	.starlight-aside--note {
		border-color: var(--sl-color-blue);
		background: var(--sl-color-blue-low);
	}

	.starlight-aside--caution {
		border-color: var(--sl-color-orange);
		background: var(--sl-color-orange-low);
	}

	.starlight-aside__title {
		font-weight: 700;
		margin: 0 0 0.25rem;
	}

	.starlight-aside__content {
		margin: 0;
	}

	.starlight-aside__content p {
		margin: 0.25rem 0;
	}
</style>
