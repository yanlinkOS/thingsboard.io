---
/**
 * Drop-in replacement for Starlight's <Tabs> with extra props:
 *   defaultTab  — label of the tab active by default (server-side, no flash)
 *   urlParam    — URL query param name for tab sync, e.g. "instalationType"
 *
 * Usage in MDX:
 *   import Tabs    from '~/components/Tabs.astro';
 *   import TabItem from '~/components/TabItem.astro';  // ← needed for `id` prop
 *   // or Starlight's TabItem if you don't need per-tab `id`
 *
 *   <Tabs defaultTab="On-premises" urlParam="instalationType">
 *     <TabItem label="SaaS"         id="saas"         icon="tabler:device-analytics">...</TabItem>
 *     <TabItem label="On-premises"  id="on-premises"  icon="tabler:server-2">...</TabItem>
 *     <TabItem label="Cloud"        id="cloud"        icon="tabler:cloud">...</TabItem>
 *   </Tabs>
 *
 *   URL ?instalationType=cloud  → activates "Cloud" tab on load.
 *   Clicking a tab              → updates URL to ?instalationType=<id>.
 */
import { processPanels } from '@starlight/rehype-tabs';
import Icon from '~/components/starlight/Icon.astro';

interface Props {
	/** Label of the tab to activate by default (instead of the first tab). */
	defaultTab?: string;
	/** URL query param name for tab synchronisation, e.g. "instalationType". */
	urlParam?: string;
	syncKey?: string;
}

const { defaultTab, urlParam, syncKey } = Astro.props;

const panelHtml = await Astro.slots.render('default');
const { html: rawHtml, panels } = processPanels(panelHtml);

// Extract data-tab-id values from top-level <starlight-tab-item> only (skip nested).
// Walk the HTML tracking nesting depth to avoid picking up IDs from inner tabs.
const tabIds: string[] = [];
{
	const tagRe = /<(\/?)starlight-tab-item\b([^>]*?)>/g;
	let depth = 0;
	let m: RegExpExecArray | null;
	while ((m = tagRe.exec(panelHtml)) !== null) {
		const isClose = m[1] === '/';
		if (isClose) {
			depth--;
		} else {
			if (depth === 0) {
				const idMatch = m[2]!.match(/data-tab-id="([^"]*)"/);
				tabIds.push(idMatch ? idMatch[1]! : '');
			}
			depth++;
		}
	}
}

// Find the server-side active index from defaultTab (falls back to 0).
const activeIdx =
	defaultTab && tabIds.length > 0
		? Math.max(tabIds.indexOf(defaultTab), 0)
		: 0;

// processPanels always hides panels[1..n] and shows panels[0].
// Swap visibility when activeIdx > 0.
let html = rawHtml;
if (activeIdx > 0 && panels) {
	const first = panels[0];
	const active = panels[activeIdx];
	// Use regex to match the opening tag regardless of attribute order/presence
	// (e.g. tabindex="0" may appear between role="tabpanel" and hidden).
	html = html.replace(
		new RegExp(`id="${first.panelId}"([^>]*)>`),
		`id="${first.panelId}"$1 hidden>`
	);
	html = html.replace(
		new RegExp(`id="${active.panelId}"([^>]*?) hidden`),
		`id="${active.panelId}"$1`
	);
}

const isSynced = syncKey !== undefined;
const didRenderSyncedTabsRestoreScriptSymbol = Symbol.for('starlight:did-render-synced-tabs-restore-script');
// @ts-expect-error -- Symbol key not in Astro.locals type
const shouldRenderSyncedTabsRestoreScript = isSynced && Astro.locals[didRenderSyncedTabsRestoreScriptSymbol] !== true;
if (isSynced) {
	// @ts-expect-error -- Symbol key not in Astro.locals type
	Astro.locals[didRenderSyncedTabsRestoreScriptSymbol] = true;
}
---

{shouldRenderSyncedTabsRestoreScript && <script is:inline>
(() => {
	class StarlightTabsRestore extends HTMLElement {
		connectedCallback() {
			const starlightTabs = this.closest('starlight-tabs');
			if (!(starlightTabs instanceof HTMLElement) || typeof localStorage === 'undefined') return;
			const syncKey = starlightTabs.dataset.syncKey;
			if (!syncKey) return;
			const label = localStorage.getItem(`starlight-synced-tabs__${syncKey}`);
			if (!label) return;
			const tablist = starlightTabs.querySelector(':scope > .tablist-wrapper [role="tablist"]');
			if (!tablist) return;
			const tabs = [...tablist.querySelectorAll('[role="tab"]')];
			const tabIndexToRestore = tabs.findIndex(
				(tab) => tab instanceof HTMLAnchorElement && tab.textContent?.trim() === label
			);
			const panels = starlightTabs.querySelectorAll(':scope > [role="tabpanel"]');
			const newTab = tabs[tabIndexToRestore];
			const newPanel = panels[tabIndexToRestore];
			if (tabIndexToRestore < 1 || !newTab || !newPanel) return;
			tabs[0]?.setAttribute('aria-selected', 'false');
			tabs[0]?.setAttribute('tabindex', '-1');
			panels?.[0]?.setAttribute('hidden', 'true');
			newTab.removeAttribute('tabindex');
			newTab.setAttribute('aria-selected', 'true');
			newPanel.removeAttribute('hidden');
		}
	}
	customElements.define('starlight-tabs-restore', StarlightTabsRestore);
})()
</script>}

<starlight-tabs
	data-sync-key={syncKey}
	data-url-param={urlParam}
	data-tab-ids={urlParam ? JSON.stringify(tabIds) : undefined}
>
	{
		panels && (
			<div class="tablist-wrapper not-content">
				<ul role="tablist">
					{panels.map(({ icon, label, panelId, tabId }: { icon?: string; label: string; panelId: string; tabId: string }, idx: number) => (
						<li role="presentation" class="tab">
							<a
								role="tab"
								href={'#' + panelId}
								id={tabId}
								aria-selected={idx === activeIdx ? 'true' : 'false'}
								tabindex={idx !== activeIdx ? -1 : 0}
							>
								{icon && <Icon name={icon} />}
								{label}
							</a>
						</li>
					))}
				</ul>
			</div>
		)
	}
	<Fragment set:html={html} />
	{isSynced && <starlight-tabs-restore />}
</starlight-tabs>
{urlParam && (
	<script is:inline define:vars={{ _urlParam: urlParam, _tabIds: tabIds }}>
	/* Runs synchronously during HTML parsing — before first paint.
	   Switches the active tab to match the URL param without any flash. */
	(() => {
		const el = document.currentScript.previousElementSibling;
		if (!el) return;
		const urlValue = new URLSearchParams(location.search).get(_urlParam);
		if (!urlValue) return;
		const idx = _tabIds.indexOf(urlValue);
		if (idx < 0) return;
		const tablist = el.querySelector(':scope > .tablist-wrapper [role="tablist"]');
		if (!tablist) return;
		const tabs = [...tablist.querySelectorAll('[role="tab"]')];
		const panels = [...el.querySelectorAll(':scope > [role="tabpanel"]')];
		tabs.forEach((tab, i) => {
			tab.setAttribute('aria-selected', i === idx ? 'true' : 'false');
			tab.setAttribute('tabindex', i === idx ? '0' : '-1');
		});
		panels.forEach((panel, i) => {
			if (i === idx) panel.removeAttribute('hidden');
			else panel.setAttribute('hidden', '');
		});
	})();
	</script>
)}

<style>
	@layer starlight.components {
		starlight-tabs {
			display: block;
		}

		.tablist-wrapper {
			overflow-x: auto;
		}

		[role='tablist'] {
			display: flex;
			list-style: none;
			border-bottom: 2px solid var(--sl-color-gray-5);
			padding: 0;
		}

		.tab {
			display: flex;
		}
		.tab > [role='tab'] {
			--sl-tab-color-border: var(--sl-color-gray-5);
			display: flex;
			align-items: center;
			gap: 0.5rem;
			line-height: var(--sl-line-height-headings);
			padding: 0.275rem 1.25rem;
			text-decoration: none;
			box-shadow: 0 2px 0 var(--sl-tab-color-border);
			color: var(--sl-color-gray-3);
			outline-offset: var(--sl-outline-offset-inside);
			overflow-wrap: initial;
		}
		.tab [role='tab'][aria-selected='true'] {
			--sl-tab-color-border: var(--sl-color-text-accent);
			color: var(--sl-color-white);
			font-weight: 600;
		}

		.tablist-wrapper ~ :global([role='tabpanel']) {
			margin-top: 1rem;
		}
	}
</style>

<script>
	class StarlightTabs extends HTMLElement {
		static #syncedTabs = new Map<string, StarlightTabs[]>();

		tabs: HTMLAnchorElement[];
		panels: HTMLElement[];
		#syncKey: string | undefined;
		#urlParam: string | undefined;
		#tabIds: string[];
		#storageKeyPrefix = 'starlight-synced-tabs__';

		constructor() {
			super();
			const tablist = this.querySelector<HTMLUListElement>('[role="tablist"]')!;
			this.tabs = [...tablist.querySelectorAll<HTMLAnchorElement>('[role="tab"]')];
			this.panels = [...this.querySelectorAll<HTMLElement>(':scope > [role="tabpanel"]')];
			this.#syncKey = this.dataset.syncKey;
			this.#urlParam = this.dataset.urlParam;
			this.#tabIds = this.dataset.tabIds ? JSON.parse(this.dataset.tabIds) : [];

			if (this.#syncKey) {
				const syncedTabs = StarlightTabs.#syncedTabs.get(this.#syncKey) ?? [];
				syncedTabs.push(this);
				StarlightTabs.#syncedTabs.set(this.#syncKey, syncedTabs);
			}

			this.tabs.forEach((tab, i) => {
				tab.addEventListener('click', (e) => {
					e.preventDefault();
					const currentTab = tablist.querySelector('[aria-selected="true"]');
					if (e.currentTarget !== currentTab) {
						this.switchTab(e.currentTarget as HTMLAnchorElement, i);
					}
				});

				tab.addEventListener('keydown', (e) => {
					const index = this.tabs.indexOf(e.currentTarget as any);
					const nextIndex =
						e.key === 'ArrowLeft'
							? index - 1
							: e.key === 'ArrowRight'
								? index + 1
								: e.key === 'Home'
									? 0
									: e.key === 'End'
										? this.tabs.length - 1
										: null;
					if (nextIndex === null) return;
					if (this.tabs[nextIndex]) {
						e.preventDefault();
						this.switchTab(this.tabs[nextIndex], nextIndex);
					}
				});
			});
		}

		switchTab(newTab: HTMLAnchorElement | null | undefined, index: number, shouldSync = true) {
			if (!newTab) return;

			const previousTabsOffset = shouldSync ? this.getBoundingClientRect().top : 0;

			this.tabs.forEach((tab) => {
				tab.setAttribute('aria-selected', 'false');
				tab.setAttribute('tabindex', '-1');
			});
			this.panels.forEach((oldPanel) => {
				oldPanel.hidden = true;
			});

			const newPanel = this.panels[index];
			if (newPanel) newPanel.hidden = false;
			newTab.removeAttribute('tabindex');
			newTab.setAttribute('aria-selected', 'true');

			// Update URL param when user switches tabs.
			if (shouldSync && this.#urlParam && this.#tabIds[index]) {
				const url = new URL(location.href);
				url.searchParams.set(this.#urlParam, this.#tabIds[index]);
				history.replaceState(null, '', url.toString());
			}

			if (shouldSync) {
				newTab.focus();
				StarlightTabs.#syncTabs(this, newTab);
				window.scrollTo({
					top: window.scrollY + (this.getBoundingClientRect().top - previousTabsOffset),
					behavior: 'instant',
				});
			}
		}

		#persistSyncedTabs(label: string) {
			if (!this.#syncKey || typeof localStorage === 'undefined') return;
			localStorage.setItem(this.#storageKeyPrefix + this.#syncKey, label);
		}

		static #syncTabs(emitter: StarlightTabs, newTab: HTMLAnchorElement) {
			const syncKey = emitter.#syncKey;
			const label = StarlightTabs.#getTabLabel(newTab);
			if (!syncKey || !label) return;
			const syncedTabs = StarlightTabs.#syncedTabs.get(syncKey);
			if (!syncedTabs) return;

			for (const receiver of syncedTabs) {
				if (receiver === emitter) continue;
				const labelIndex = receiver.tabs.findIndex((tab) => StarlightTabs.#getTabLabel(tab) === label);
				if (labelIndex === -1) continue;
				receiver.switchTab(receiver.tabs[labelIndex], labelIndex, false);
			}

			emitter.#persistSyncedTabs(label);
		}

		static #getTabLabel(tab: HTMLAnchorElement) {
			return tab.textContent?.trim();
		}
	}

	customElements.define('starlight-tabs', StarlightTabs);
</script>
