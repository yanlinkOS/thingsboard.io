---
import { Badge as StarlightBadge } from '@astrojs/starlight/components';
export type Props = Parameters<typeof StarlightBadge>[0];
---

<StarlightBadge {...Astro.props} />

<style is:global>
	.neutral-badge {
		border-color: var(--sl-color-gray-5);
		background-color: var(--sl-color-gray-6);
		color: var(--sl-color-text);
	}

	/*
	 * tb-badge — text-only inline badge with accent color.
	 * No border, no background. Aligned to the top of the surrounding text.
	 *
	 * Usage:
	 *   <Badge text="New" class="tb-badge" />              ← 12px (default size="small")
	 *   <Badge text="New" class="tb-badge" size="medium" /> ← 14px
	 */
	.tb-badge {
		border: none;
		background: transparent;
		color: var(--sl-color-text-accent);
		vertical-align: top;
		padding: 0;
		font-weight: 600;
	}

	/* 12px = 0.75rem */
	.tb-badge.small {
		font-size: 0.75rem;
	}

	/* 14px = 0.875rem */
	.tb-badge.medium {
		font-size: 0.875rem;
	}

	/* On active sidebar item the accent background makes the badge invisible — inherit text color instead */
	a[aria-current='page'] .tb-badge {
		color: inherit;
	}
</style>
