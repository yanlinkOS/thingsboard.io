---
interface Props {
	text: string;
	/** Text + left-border color. Defaults to the page accent. */
	color?: string;
	/** Optional override for the left-border color (defaults to `color`). */
	borderColor?: string;
}

const { text, color, borderColor } = Astro.props;
---

<div
	class="section-badge"
	style={color || borderColor
		? `--badge-color: ${color || 'var(--sl-color-accent, #3369ff)'}; --badge-border: ${borderColor || color || 'var(--sl-color-blue-low, #b3c7ff)'}`
		: undefined}
>
	<span class="section-badge__text">{text}</span>
</div>

<style lang="scss" is:global>
	@use '../styles/variables' as *;

	// Section badge — the design "topic" frame: a full-width row with a vertical
	// line that sits exactly on the article's left rail. The page container
	// (`.use-case-page` / `.case-study-page`) already has a faint
	// `border-left + padding-left: $spacing-5` — the badge breaks out of
	// that padding via negative margin so its colored border-left lines up
	// with the page's rail (replacing the faint stroke for the badge's
	// 28px row), and its text falls at the section's natural content
	// start, which is where the h2 and paragraphs also begin.
	.section-badge {
		display: flex;
		align-items: center;
		width: 100%;
		min-height: 28px; // matches the design topic frame height
		margin-left: calc(-1 * #{$spacing-5} - 1px); // page padding (20px) + 1px border
		padding: 0 0 0 calc(#{$spacing-5} + 1px); // restore text to section's content start
		border-left: 1px solid var(--badge-border, var(--sl-color-blue-low, #b3c7ff));
		background: transparent;

		&__text {
			@include section-badge;
			color: var(--badge-color, var(--sl-color-accent, #3369ff));
			background: transparent;
		}
	}
</style>
