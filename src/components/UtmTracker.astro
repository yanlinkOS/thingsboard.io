<script is:inline>
	(function () {
		try {
			var url = new URL(window.location.href);
			var params = {};
			url.searchParams.forEach(function (value, key) {
				if (key.startsWith('utm_')) {
					params[key] = value;
				}
			});
			if (Object.keys(params).length > 0) {
				localStorage.setItem('utm', JSON.stringify(params));
			}
			var fpr = url.searchParams.get('fpr');
			if (fpr) {
				localStorage.setItem('fpr', fpr);
			}
		} catch (e) {}

		function patchLinks() {
			var searchParams = [];

			var utms = localStorage.getItem('utm');
			if (utms) {
				var utm = {};
				try {
					utm = JSON.parse(utms);
				} catch (e) {}
				searchParams = Object.keys(utm).map(function (key) {
					return key + '=' + encodeURIComponent(utm[key]);
				});
			}

			var fpr = localStorage.getItem('fpr');
			if (fpr) {
				searchParams.push('fpr=' + encodeURIComponent(fpr));
			}

			var search = searchParams.join('&');
			if (!search) return;

			var allowedDomains = [
				'https://thingsboard.cloud',
				'https://eu.thingsboard.cloud',
				'https://license.thingsboard.io',
			];

			Array.from(document.links).forEach(function (link) {
				var href = link.getAttribute('href');
				if (href && allowedDomains.some(function (d) { return href.startsWith(d); })) {
					var separator = href.includes('?') ? '&' : '?';
					link.setAttribute('href', href + separator + search);
				}
			});
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', patchLinks);
		} else {
			patchLinks();
		}

		document.addEventListener('astro:page-load', patchLinks);
	})();
</script>
