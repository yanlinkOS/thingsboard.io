---
// A single prev/next chevron, rendered three ways so the four near-identical
// copies in Pagination.astro (prev/next × numbers/compact rows) stay in sync:
//   - link mode, enabled  → real <a> (crawlable, rel=prev/next)
//   - interactive mode    → event-emitting <button> (data-nav-role)
//   - otherwise           → inert <span> (link-mode boundary, or the compact
//     row's interactive placeholder that pagination-client.ts swaps live)
import Chevron from '@components/Chevron.astro';

interface Props {
	direction: 'left' | 'right';
	isLinkMode: boolean;
	/** Whether navigation in this direction is possible (hasPrev / hasNext). */
	enabled: boolean;
	/** Target href for link mode (unused in the other branches). */
	href: string;
	rel: 'prev' | 'next';
	label: string;
	navRole: 'prev' | 'next';
	/**
	 * Render an event-emitting <button> in interactive mode. The compact row
	 * passes false: it ships an inert placeholder <span> that
	 * pagination-client.ts replaces with a live button on first update.
	 */
	interactiveButton?: boolean;
}

const {
	direction,
	isLinkMode,
	enabled,
	href,
	rel,
	label,
	navRole,
	interactiveButton = true,
} = Astro.props;
---

{
	isLinkMode && enabled ? (
		<a class="tb-pagination__chevron" href={href} rel={rel} aria-label={label}>
			<Chevron direction={direction} size={24} />
		</a>
	) : !isLinkMode && interactiveButton ? (
		<button
			type="button"
			class:list={['tb-pagination__chevron', !enabled && 'is-disabled']}
			aria-label={label}
			aria-disabled={!enabled ? 'true' : undefined}
			data-nav-role={navRole}
		>
			<Chevron direction={direction} size={24} />
		</button>
	) : (
		<span class="tb-pagination__chevron is-disabled" aria-hidden="true">
			<Chevron direction={direction} size={24} />
		</span>
	)
}
