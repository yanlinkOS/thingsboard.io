---
// Pagination row for surfaces that pair the page-number nav with an
// items-per-page dropdown (IoT Hub). The selector is a SIBLING of the nav,
// not slotted inside it, so hiding the nav on a single page (or on a fetch
// error) leaves the per-page control reachable — without it, a user who
// raised the page size enough to collapse results to one page would lose the
// only control that could lower it again. This wrapper is the positioned
// ancestor for the selector's popup and owns the centered/right layout that
// used to live on the nav.
import Pagination from './Pagination.astro';
import PerPageSelector from './PerPageSelector.astro';

interface Props {
	currentPage: number;
	totalPages: number;
	basePath: string;
	perPage: number;
	/** Stable per-instance string (e.g. basePath) for unique selector ids. */
	idBase: string;
	/**
	 * Layout variant:
	 *   - 'centered' (default) — page numbers centred, items-per-page
	 *     absolutely pinned to the right edge.
	 *   - 'right' — everything right-aligned in a single flex row, items-per-
	 *     page sits inline after the page numbers.
	 */
	variant?: 'centered' | 'right';
	class?: string;
}

const {
	currentPage,
	totalPages,
	basePath,
	perPage,
	idBase,
	variant = 'centered',
	class: className = '',
} = Astro.props;
---

<div
	class:list={['tb-pagination-bar', `tb-pagination-bar--${variant}`, className]}
	data-tb-pagination-bar
>
	<Pagination mode="link" currentPage={currentPage} totalPages={totalPages} basePath={basePath} />
	<PerPageSelector perPage={perPage} idBase={idBase} />
</div>

<style is:global lang="scss">
	@use '../../styles/_variables.scss' as *;

	.tb-pagination-bar {
		position: relative;
		// Establishes a stacking context (z-index !== auto) so the per-page
		// popup floats above the page sections that follow in DOM order.
		z-index: 5;
		display: flex;
		align-items: center;
		min-height: 40px;

		&[hidden] {
			display: none;
		}
	}

	// `centered` — nav fills the row and centres its numbers; the per-page
	// selector is taken out of flow and pinned to the right edge (set in
	// PerPageSelector.astro), so it never shifts the centred numbers.
	.tb-pagination-bar--centered {
		justify-content: center;

		.tb-pagination {
			flex: 1 1 0;
		}
	}

	// `right` — single right-aligned row. Used where the centred layout would
	// leave a big empty column to the left. Nav shrinks to its numbers, the
	// per-page selector flows inline after it.
	.tb-pagination-bar--right {
		justify-content: flex-end;
		gap: 16px;

		.tb-pagination {
			flex: 0 0 auto;
			padding-right: 0;
		}

		.tb-pagination__per-page {
			position: relative;
			top: auto;
			right: auto;
			transform: none;
		}
	}
</style>
