---
import { Icon } from 'astro-icon/components';
import Chevron from '@components/Chevron.astro';
import { PAGINATION_STRINGS } from './pagination-shared';

interface Props {
	/** Current items-per-page value; options are [n, 2n, 3n]. */
	perPage: number;
	/** Stable per-instance string (e.g. the page's basePath) for unique ids. */
	idBase: string;
}

const { perPage, idBase } = Astro.props;

const perPageOptions = [perPage, perPage * 2, perPage * 3];
// Deterministic instance-unique label id (reproducible SSR output).
const slug = idBase
	.toLowerCase()
	.replace(/[^a-z0-9]+/g, '-')
	.replace(/^-+|-+$/g, '');
const labelId = `tb-pagination-pp-${slug || 'nav'}`;
---

<div class="tb-pagination__per-page" data-per-page-root data-per-page={perPage}>
	<span class="tb-pagination__per-page-label" id={labelId}>
		{PAGINATION_STRINGS.perPageLabel}
	</span>
	<button
		type="button"
		class="tb-pagination__per-page-value"
		data-per-page-button
		aria-expanded="false"
		aria-labelledby={labelId}
	>
		<span data-per-page-label>{perPage}</span>
		<Chevron direction="down" />
	</button>
	<div
		class="tb-pagination__per-page-popup"
		hidden
		data-per-page-popup
		role="group"
		aria-label="Items per page"
	>
		{
			perPageOptions.map((n) => (
				<button
					type="button"
					class:list={[
						'tb-pagination__per-page-option',
						n === perPage && 'tb-pagination__per-page-option--selected',
					]}
					data-per-page-option
					data-per-page-value={n}
					aria-pressed={n === perPage}
				>
					<span class="tb-pagination__per-page-option-text">{n}</span>
					<Icon name="tabler:check" class="tb-pagination__per-page-option-check" size={24} />
				</button>
			))
		}
	</div>
</div>

{/* Global for consistency with the parent's .tb-pagination__* contract. */}
<style is:global lang="scss">
	@use '../../styles/_variables.scss' as *;

	.tb-pagination__per-page {
		position: absolute;
		top: 50%;
		right: 16px;
		transform: translateY(-50%);
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 14px;
		line-height: 24px;
		color: var(--color-text-muted);

		@include media-down(lg) {
			display: none;
		}
	}

	.tb-pagination__per-page-label {
		white-space: nowrap;
	}

	.tb-pagination__per-page-value {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		min-height: 40px;
		min-width: 72px;
		padding: 8px 8px 8px 12px;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		color: var(--color-text);
		font-family: inherit;
		font-size: 14px;
		line-height: 24px;
		font-weight: $font-weight-normal;
		cursor: pointer;
		background: var(--color-bg-surface);
		transition: background-color $transition-fast, border-color $transition-fast;

		&:hover,
		&[aria-expanded='true'] {
			background: var(--sl-color-gray-6);
		}

		svg {
			color: var(--color-text-secondary);
		}
	}

	// Popup anchored below the button. `right: 0` keeps it aligned to the
	// trigger's right edge so longer option labels expand leftward into the
	// row's empty space rather than overflowing the viewport.
	.tb-pagination__per-page-popup {
		position: absolute;
		top: calc(100% + 4px);
		right: 0;
		min-width: 100%;
		display: flex;
		flex-direction: column;
		padding: 4px;
		background: var(--color-bg-surface);
		border: 1px solid var(--iot-hub-hairline, rgba(0, 0, 0, 0.12));
		border-radius: 8px;
		box-shadow:
			0 1px 0.5px rgba(0, 0, 0, 0.12),
			0 2px 0.5px rgba(0, 0, 0, 0.24);
		// Within the .tb-pagination-bar stacking context (z-index: 5 on the
		// wrapper), this is the local stacking level — high enough to clear any
		// other internal absolutely-positioned siblings.
		z-index: 100;

		[data-theme='dark'] & {
			border-color: var(--color-border);
		}

		// 120ms decel enter curve; pivot top-right so the popup expands
		// downward from the button corner.
		transform-origin: top right;
		animation: tb-pagination-per-page-enter 120ms cubic-bezier(0, 0, 0.2, 1);

		&[hidden] {
			display: none;
		}
	}

	@keyframes tb-pagination-per-page-enter {
		from {
			transform: scaleY(0);
			opacity: 0;
		}
		to {
			transform: scaleY(1);
			opacity: 1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.tb-pagination__per-page-popup {
			animation: none;
		}
	}

	.tb-pagination__per-page-option {
		display: flex;
		align-items: center;
		gap: 8px;
		width: 100%;
		padding: 8px 12px;
		font-family: inherit;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: var(--sl-color-gray-2);
		background: transparent;
		border: none;
		border-radius: 5px;
		cursor: pointer;
		text-align: left;
		transition: background-color $transition-fast;

		&:hover {
			background: var(--sl-color-gray-6);
		}

		&:focus-visible {
			outline: 2px solid var(--color-primary);
			outline-offset: -2px;
		}
	}

	.tb-pagination__per-page-option-text {
		flex: 1 1 0;
		min-width: 0;
	}

	.tb-pagination__per-page-option-check {
		flex-shrink: 0;
		visibility: hidden;
	}

	.tb-pagination__per-page-option--selected {
		background: var(--sl-color-gray-6);
		color: var(--color-brand);

		.tb-pagination__per-page-option-check {
			visibility: visible;
		}
	}
</style>

<script>
	import { initPerPageSelectors } from './per-page-client';

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initPerPageSelectors);
	} else {
		initPerPageSelectors();
	}
	document.addEventListener('astro:page-load', initPerPageSelectors);
</script>
