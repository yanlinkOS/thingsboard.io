---
interface Props {
	text: string;
	href: string;
}

const { text, href } = Astro.props;
---

<a
	href={href}
	target="_blank"
	rel="noopener noreferrer"
	style="display:inline-block;padding:12px 24px;font-weight:600;font-size:1rem;border-radius:6px;text-decoration:none;background:var(--color-primary);color:var(--sl-color-black);border:none;margin:16px 0;transition:opacity 0.2s;"
	onmouseover="this.style.opacity='0.85'"
	onmouseout="this.style.opacity='1'"
>
	{text}
</a>
