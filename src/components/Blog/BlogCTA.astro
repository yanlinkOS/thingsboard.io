---
interface CTAButton {
	text: string;
	href: string;
	variant?: 'filled' | 'outline';
}

interface Props {
	title?: string;
	description?: string;
	buttons: CTAButton[];
}

const { title, description, buttons } = Astro.props;
---

<div
	style="margin:32px 0;padding:32px 40px;border-radius:16px;background:var(--color-bg-light);border:1px solid var(--color-border);text-align:center;"
>
	{title && <p style="font-size:1.25rem;font-weight:700;color:var(--color-text);margin:0 0 12px;">{title}</p>}
	{description && <p style="font-size:1rem;line-height:1.65;color:var(--color-text-secondary);margin:0 0 20px;">{description}</p>}
	<div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;">
		{buttons.map((btn) => (
			<a
				href={btn.href}
				target="_blank"
				rel="noopener noreferrer"
				class="blog-cta-btn"
				style={btn.variant === 'outline'
					? 'display:inline-block;padding:10px 24px;font-weight:600;font-size:1rem;border-radius:6px;text-decoration:none;background:transparent;color:var(--color-text);border:1px solid var(--color-border);'
					: 'display:inline-block;padding:10px 24px;font-weight:600;font-size:1rem;border-radius:6px;text-decoration:none;background:var(--color-primary);color:var(--sl-color-black);border:1px solid var(--color-primary);'
				}
			>
				{btn.text}
			</a>
		))}
	</div>
</div>

<style is:global>
	.blog-cta-btn:hover {
		opacity: 0.85 !important;
	}
</style>
