---
---

<section class="trainings-hero">
	<div class="trainings-wrapper">
		<div class="hero-top">
			<h1 class="hero-title">ThingsBoard training sessions</h1>
			<div class="hero-images">
				<img
					src="/images/trainings/thingsboard-home-page.png"
					class="hero-img hero-img--main"
					alt="ThingsBoard dashboards and menus"
					width="1200"
					height="675"
				/>
				<img
					src="/images/trainings/thingsboard-tenant-list.png"
					class="hero-img hero-img--2"
					alt="ThingsBoard tenant list"
					width="280"
					height="200"
				/>
				<img
					src="/images/trainings/thingsboard-alarm-list.png"
					class="hero-img hero-img--3"
					alt="ThingsBoard alarm list"
					width="400"
					height="280"
				/>
				<img
					src="/images/trainings/thingsboard-scada-example.png"
					class="hero-img hero-img--4"
					alt="ThingsBoard SCADA"
					width="420"
					height="300"
				/>
				<img
					src="/images/trainings/thingsboard-rule-chains-list.png"
					class="hero-img hero-img--5"
					alt="ThingsBoard rule chains list"
					width="588"
					height="400"
				/>
			</div>
		</div>
		<div class="hero-contact">
			<div class="contact-left">
				<div class="contact-label">
					<span class="course-name">Training sessions</span>
					<p class="contact-subtitle">Fast, informative, and engaging</p>
				</div>
				<a class="contact-btn contact-btn--desktop" href="/docs/contact-us/?subject=Training"
					>Contact Us</a
				>
			</div>
			<div class="contact-text">
				<p class="contact-description">
					Our ThingsBoard training sessions are practical workshops led by experts from the
					ThingsBoard team, created especially for your company's engineers. We offer fifteen
					2-hour sessions that explain the basics of using ThingsBoard. Even though our
					documentation is detailed, these sessions focus on the most important points, helping
					you start IoT solution development quickly and easily.
				</p>
			</div>
			<a class="contact-btn contact-btn--mobile" href="/docs/contact-us/?subject=Training"
				>Contact Us</a
			>
		</div>
	</div>
</section>

<style>
	.trainings-hero {
		padding-top: 100px;
		padding-bottom: 100px;
	}

	.trainings-wrapper {
		padding: 0 32px;
		max-width: 1460px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 77px;
	}

	/* Hero top */
	.hero-top {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 145px;
		isolation: isolate;
	}

	.hero-top::before {
		content: '';
		z-index: -1;
		position: absolute;
		width: 58%;
		height: 100%;
		transform: translateX(-50%);
		left: 50%;
		top: 0;
		border-radius: 675.253px;
		background: conic-gradient(
			from 180deg at 50% 50%,
			rgba(21, 114, 255, 0.24) 0deg,
			rgba(64, 145, 255, 0.24) 360deg
		);
		filter: blur(155px);
	}

	.hero-title {
		text-align: center;
		font-size: 48px;
		font-weight: 600;
		line-height: 60px;
	}

	/* Images */
	.hero-images {
		position: relative;
		width: 100%;
		isolation: isolate;
	}

	.hero-img {
		width: 100%;
		height: auto;
	}

	.hero-img--main {
		transform: translateY(-2%);
		animation: fadeoutCenter 750ms cubic-bezier(0.07, 0.43, 0.17, 0.81) forwards;
	}

	.hero-img--2 {
		opacity: 0;
		animation: fadein 600ms cubic-bezier(0.25, 0.46, 0.45, 0.94) 600ms forwards;
		position: absolute;
		bottom: 2%;
		left: 8%;
		max-width: 23%;
		width: 23%;
	}

	.hero-img--3 {
		opacity: 0;
		animation: fadein 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94) 800ms forwards;
		position: absolute;
		right: -3%;
		top: -9%;
		max-width: 33.3%;
		width: 33.3%;
	}

	.hero-img--4 {
		opacity: 0;
		animation: fadein 1000ms cubic-bezier(0.25, 0.46, 0.45, 0.94) 1000ms forwards;
		position: absolute;
		left: -1%;
		top: -21%;
		max-width: 35%;
		width: 35%;
		z-index: -1;
	}

	.hero-img--5 {
		opacity: 0;
		animation: fadein 500ms cubic-bezier(0.25, 0.46, 0.45, 0.94) 500ms forwards;
		position: absolute;
		right: 9%;
		top: -19%;
		z-index: -1;
		max-width: 49%;
		width: 49%;
	}

	/* Contact block */
	.hero-contact {
		display: flex;
		justify-content: space-between;
		gap: 32px;
		margin-bottom: 32px;
	}

	.contact-left {
		display: flex;
		flex-direction: column;
		gap: 32px;
		max-width: 385px;
		width: 100%;
	}

	.contact-label {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.course-name {
		color: #212529;
		font-size: 32px;
		font-weight: 500;
		line-height: normal;
	}

	.contact-subtitle {
		font-size: 18px;
		color: rgba(9, 9, 9, 0.54);
		font-weight: 500;
		margin: 0;
	}

	.contact-text {
		max-width: 928px;
	}

	.contact-description {
		font-size: 16px;
		line-height: 32px;
		letter-spacing: 0.15px;
		margin: 0;
	}

	.contact-btn {
		display: inline-block;
		font-size: 18px;
		font-weight: 500;
		padding: 12px 49px;
		border-radius: 6px;
		background: #2a7dec;
		color: #fff;
		text-decoration: none;
		transition: opacity 0.2s ease-in-out;
		white-space: nowrap;
		width: fit-content;
	}

	.contact-btn:hover {
		opacity: 0.7;
		color: #fff !important;
		text-decoration: none;
	}

	.contact-btn--mobile {
		display: none;
	}

	/* Keyframes */
	@keyframes fadein {
		from {
			opacity: 0;
			transform: scale(80%);
		}
		to {
			opacity: 1;
			transform: scale(100%);
		}
	}

	@keyframes fadeoutCenter {
		from {
			opacity: 0;
			transform: translateY(0%) scale(1.2);
		}
		to {
			opacity: 1;
			transform: translateY(-2%) scale(1);
		}
	}

	/* Responsive */
	@media (max-width: 959px) {
		.trainings-hero {
			padding-top: 40px;
			padding-bottom: 48px;
		}

		.trainings-wrapper {
			gap: 50px;
		}

		.hero-contact {
			flex-direction: column;
			gap: 24px;
		}

		.contact-btn--desktop {
			display: none;
		}

		.contact-btn--mobile {
			display: inline-block;
		}
	}

	@media (max-width: 799px) {
		.hero-top {
			gap: 75px;
		}
	}

	@media (max-width: 599px) {
		.hero-title {
			font-size: 32px;
		}

		.course-name {
			white-space: normal;
		}
	}
</style>
