---
import type { Course } from '../../data/trainings';

interface Props {
	courses: Course[];
}

const { courses } = Astro.props;

function totalHours(course: Course): number {
	return course.courseSessions.reduce((sum, s) => sum + s.sessionLengthInHours, 0);
}

const carouselId = 'courses-carousel';
---

<section class="courses-section">
	<div class="trainings-wrapper">
		<h2 class="section-title">Training courses</h2>

		<!-- Embla carousel -->
		<div class="course-carousel" data-carousel-id={carouselId} data-count={courses.length}>
			<div class="carousel-viewport" id={carouselId}>
				<div class="carousel-container">
					{
						courses.map((course, i) => (
							<div class:list={['carousel-slide', { 'is-active': i === 0 }]} data-index={i}>
								<div class="course-card">
									<div class="card-header">
										<ul class="card-meta">
											<li>
												<svg
													xmlns="http://www.w3.org/2000/svg"
													viewBox="0 0 24 24"
													width="20"
													height="20"
													fill="none"
													stroke="#2A7DEC"
													stroke-width="2"
													aria-hidden="true"
												>
													<circle cx="12" cy="12" r="10" />
													<polyline points="12 6 12 12 16 14" />
												</svg>
												<span>{totalHours(course)} hours</span>
											</li>
											<li>
												<img
													src="/images/trainings/icon_hat-graduation.svg"
													alt=""
													width="25"
													height="24"
												/>
												<span>{course.courseSessions.length} sessions</span>
											</li>
										</ul>
										<h3 class="card-name">{course.courseName}</h3>
									</div>
									<p class="card-desc">{course.carouselCourseDescription}</p>
									<a class="card-link" href="#course-panels">
										<span>More about the course below</span>
										<svg
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											width="18"
											height="18"
											fill="#2a7dec"
											aria-hidden="true"
										>
											<path d="M7 10l5 5 5-5z" />
										</svg>
									</a>
								</div>
							</div>
						))
					}
				</div>
			</div>

			<button class="arrow arrow-prev" type="button" aria-label="Previous">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M15 18l-6-6 6-6" />
				</svg>
			</button>
			<button class="arrow arrow-next" type="button" aria-label="Next">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M9 18l6-6-6-6" />
				</svg>
			</button>

			<div class="carousel-dots">
				{
					courses.map((_, i) => (
						<button
							class:list={['dot', { active: i === 0 }]}
							data-index={i}
							aria-label={`Go to slide ${i + 1}`}
						/>
					))
				}
			</div>
		</div>

		<!-- Course accordion panels -->
		<div id="course-panels">
			{
				courses.map((course, i) => (
					<div
						class:list={['course-panel', { active: i === 0 }]}
						id={`panel-${course.id}`}
						aria-hidden={i === 0 ? 'false' : 'true'}
					>
						<div class="panel-header">
							<div class="panel-left">
								<span class="course-label">{course.courseName}</span>
								<a class="contact-btn contact-btn--desktop" href="/docs/contact-us/?subject=Training">
									Contact Us
								</a>
							</div>
							<div class="panel-right">
								<p class="course-description">{course.courseDescription}</p>
								{course.warningMessage && (
									<p class="warning-message">
										<svg
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											width="18"
											height="18"
											fill="#F36500"
											aria-hidden="true"
										>
											<path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" />
										</svg>
										{course.warningMessage}
									</p>
								)}
								<a class="contact-btn contact-btn--mobile" href="/docs/contact-us/?subject=Training">
									Contact Us
								</a>
							</div>
						</div>

						<div class="sessions-list">
							{course.courseSessions.map((session, si) => (
								<details class="session-item" open={si === 0 ? true : undefined}>
									<summary class="session-summary">
										<span class="session-name">{session.sessionName}</span>
										<div class="session-meta">
											<div class="session-duration">
												<svg
													xmlns="http://www.w3.org/2000/svg"
													viewBox="0 0 24 24"
													width="24"
													height="24"
													fill="none"
													stroke="#2A7DEC"
													stroke-width="2"
													aria-hidden="true"
												>
													<circle cx="12" cy="12" r="10" />
													<polyline points="12 6 12 12 16 14" />
												</svg>
												<span>{session.sessionLengthInHours} hours</span>
											</div>
											<svg
												class="chevron"
												xmlns="http://www.w3.org/2000/svg"
												viewBox="0 0 24 24"
												width="24"
												height="24"
												fill="#2A7DEC"
												aria-hidden="true"
											>
												<path d="M7 10l5 5 5-5z" />
											</svg>
										</div>
									</summary>
									<ul class="topics-list">
										{session.sessionTopics.map((topic) => (
											<li class="topic-item">
												{topic.warning ? (
													<svg
														xmlns="http://www.w3.org/2000/svg"
														viewBox="0 0 24 24"
														width="18"
														height="18"
														fill="#F36500"
														aria-hidden="true"
													>
														<path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" />
													</svg>
												) : (
													<svg
														xmlns="http://www.w3.org/2000/svg"
														viewBox="0 0 24 24"
														width="18"
														height="18"
														fill="#2A7DEC"
														aria-hidden="true"
													>
														<path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
													</svg>
												)}
												<p>{topic.textContent}</p>
											</li>
										))}
									</ul>
								</details>
							))}
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<script>
	import EmblaCarousel from 'embla-carousel';
	import type { EmblaCarouselType } from 'embla-carousel';

	function initCoursesCarousel() {
		const wrapper = document.querySelector<HTMLElement>('.course-carousel');
		if (!wrapper) return;

		const carouselId = wrapper.dataset.carouselId;
		if (!carouselId) return;

		const viewport = document.getElementById(carouselId);
		if (!viewport) return;

		const container = viewport.querySelector<HTMLElement>('.carousel-container');
		if (!container) return;

		const count = parseInt(wrapper.dataset.count ?? '4', 10);

		// Clone original slides in JS so total width > 200% — required for Embla loop
		const originalSlides = Array.from(container.querySelectorAll<HTMLElement>('.carousel-slide'));
		originalSlides.forEach((slide) => {
			const clone = slide.cloneNode(true) as HTMLElement;
			clone.setAttribute('aria-hidden', 'true');
			container.appendChild(clone);
		});

		const embla = EmblaCarousel(viewport, {
			loop: true,
			align: 'center',
			containScroll: false,
			slidesToScroll: 1,
		});

		const dots = wrapper.querySelectorAll<HTMLButtonElement>('.dot');
		const prevBtn = wrapper.querySelector<HTMLButtonElement>('.arrow-prev');
		const nextBtn = wrapper.querySelector<HTMLButtonElement>('.arrow-next');
		const panels = document.querySelectorAll<HTMLElement>('.course-panel');

		function updateActive(api: EmblaCarouselType) {
			const selected = api.selectedScrollSnap() % count;

			// All .carousel-slide nodes (originals + JS clones + Embla clones)
			viewport.querySelectorAll<HTMLElement>('.carousel-slide').forEach((slide) => {
				const idx = parseInt(slide.dataset.index ?? '0', 10);
				slide.classList.toggle('is-active', idx === selected);
			});

			dots.forEach((dot, i) => dot.classList.toggle('active', i === selected));
			panels.forEach((panel, i) => {
				panel.classList.toggle('active', i === selected);
				panel.setAttribute('aria-hidden', i === selected ? 'false' : 'true');
			});
		}

		embla.on('init', updateActive);
		embla.on('select', updateActive);

		// Click handlers only on original slides
		originalSlides.forEach((slide) => {
			slide.addEventListener('click', (e) => {
				const idx = parseInt(slide.dataset.index ?? '0', 10);
				if (embla.selectedScrollSnap() % count !== idx) {
					e.preventDefault();
					embla.scrollTo(idx);
				}
			});
		});

		prevBtn?.addEventListener('click', () => embla.scrollPrev());
		nextBtn?.addEventListener('click', () => embla.scrollNext());

		dots.forEach((dot) => {
			dot.addEventListener('click', () => {
				const index = parseInt(dot.dataset.index || '0', 10);
				embla.scrollTo(index);
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initCoursesCarousel);
	document.addEventListener('astro:page-load', initCoursesCarousel);
</script>

<style>
	.courses-section {
		padding: 100px 0;
	}

	.trainings-wrapper {
		padding: 0 32px;
		max-width: 1460px;
		margin: 0 auto;
	}

	.section-title {
		font-size: 48px;
		font-weight: 600;
		line-height: 60px;
		text-align: center;
		margin-bottom: 0;
	}

	/* ── Carousel ── */
	.course-carousel {
		position: relative;
		margin: 64px 0 45px;
		padding: 0 48px;
	}

	.carousel-viewport {
		overflow: hidden;
	}

	.carousel-container {
		display: flex;
		backface-visibility: hidden;
		user-select: none;
		-webkit-tap-highlight-color: transparent;
	}

	.carousel-slide {
		flex: 0 0 33.33%;
		min-width: 0;
		padding: 30px 12px;
		cursor: pointer;
	}

	.carousel-slide.is-active {
		cursor: default;
	}

	.carousel-slide .course-card {
		transform: scale(0.88);
		transform-origin: center center;
		transition: transform 0.3s ease;
	}

	.carousel-slide.is-active .course-card {
		transform: scale(1);
	}

	/* ── Course card ── */
	.course-card {
		background: #fff;
		border: 1px solid rgba(42, 125, 236, 0.25);
		border-radius: 24px;
		padding: 46px;
		min-height: 416px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		box-shadow: 0px 10px 25px -15px rgba(0, 0, 0, 0.08), 0px 0px 6px 0px rgba(0, 0, 0, 0.08);
		transition: box-shadow 0.3s ease;
	}

	.is-active .course-card {
		box-shadow: -4px 15px 50px -20px rgba(42, 125, 236, 0.15), 0px 0px 8px 0px rgba(42, 125, 236, 0.08);
	}

	.card-header {
		display: flex;
		flex-direction: column;
		gap: 32px;
		align-items: center;
		width: 100%;
	}

	.card-meta {
		display: flex;
		justify-content: space-between;
		gap: 12px;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.card-meta li {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 14px;
		padding: 8px;
		background: rgba(42, 125, 236, 0.08);
		border-radius: 8px;
	}

	.card-name {
		font-size: 28px;
		font-weight: 500;
		color: rgba(0, 0, 0, 0.87);
		line-height: 38px;
		margin: 0;
		text-align: center;
	}

	.card-desc {
		font-size: 18px;
		color: rgba(0, 0, 0, 0.54);
		line-height: 24px;
		font-weight: 400;
		margin: 0;
		text-align: center;
		flex: 1;
	}

	.card-link {
		display: flex;
		align-items: center;
		gap: 8px;
		color: #2a7dec;
		font-size: 14px;
		font-weight: 500;
		text-decoration: none;
		pointer-events: none;
		opacity: 0;
		animation: slideDown 0.3s forwards;
	}

	.is-active .card-link {
		pointer-events: initial;
		opacity: 1;
		animation: slideUp 0.3s forwards;
	}

	.is-active .card-link:hover {
		opacity: 0.7;
		text-decoration: none;
	}

	@keyframes slideUp {
		from {
			transform: translateY(50px);
			opacity: 0;
		}
		to {
			transform: translateY(0);
			opacity: 1;
		}
	}

	@keyframes slideDown {
		from {
			transform: translateY(0);
			opacity: 1;
		}
		to {
			transform: translateY(50px);
			opacity: 0;
		}
	}

	/* ── Arrows — absolute, left/right sides ── */
	.arrow {
		position: absolute;
		top: calc(50% - 25px);
		width: 50px;
		height: 50px;
		background: transparent;
		border: none;
		outline: none;
		cursor: pointer;
		padding: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #2a7dec;
		transition: opacity 0.2s ease;
		z-index: 2;
	}

	.arrow svg {
		width: 24px;
		height: 30px;
	}

	.arrow:hover {
		opacity: 0.7;
	}

	.arrow-prev {
		left: 0;
	}

	.arrow-next {
		right: 0;
	}

	/* ── Dots — below viewport, centered ── */
	.carousel-dots {
		display: none;
		gap: 8px;
		align-items: center;
		justify-content: center;
		margin-top: 32px;
	}

	.dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		border: 1.5px solid #e0e1e2;
		background: transparent;
		cursor: pointer;
		padding: 0;
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease;
	}

	.dot.active {
		background: #212529;
		border-color: #212529;
		transform: scale(1.25);
	}

	/* Desktop (≥1280): arrows visible, dots hidden */
	@media (min-width: 1280px) {
		.carousel-dots {
			display: none;
		}
	}

	/* Tablet with peek (1025–1279): arrows visible, dots hidden */
	@media (max-width: 1279px) and (min-width: 1025px) {
		.carousel-slide {
			flex: 0 0 calc(100% - 250px);
		}
	}

	/* Small tablet (960–1024): 1 card + peek, hide arrows, show dots */
	@media (max-width: 1024px) and (min-width: 960px) {
		.carousel-slide {
			flex: 0 0 calc(100% - 250px);
		}

		.arrow {
			display: none;
		}

		.carousel-dots {
			display: flex;
		}
	}

	/* Mobile (600–959): 1 card + small peek, hide arrows, show dots */
	@media (max-width: 959px) and (min-width: 600px) {
		.course-carousel {
			padding: 0 16px;
		}

		.carousel-slide {
			flex: 0 0 calc(100% - 60px);
		}

		.course-card {
			padding: 32px;
		}

		.arrow {
			display: none;
		}

		.carousel-dots {
			display: flex;
		}
	}

	/* Small mobile (<600): full width, hide arrows, show dots */
	@media (max-width: 599px) {
		.course-carousel {
			padding: 0;
		}

		.carousel-slide {
			flex: 0 0 100%;
			padding: 16px 4px;
		}

		.course-card {
			padding: 28px 24px;
			min-height: unset;
		}

		.card-name {
			font-size: 22px;
			line-height: 30px;
		}

		.arrow {
			display: none;
		}

		.carousel-dots {
			display: flex;
		}
	}

	/* ── Course panels ── */
	.course-panel {
		display: none;
	}

	.course-panel.active {
		display: block;
	}

	.panel-header {
		display: flex;
		gap: 32px;
		margin-bottom: 32px;
		align-items: flex-start;
	}

	.panel-left {
		display: flex;
		flex-direction: column;
		gap: 32px;
		min-width: 260px;
		max-width: 385px;
		flex-shrink: 0;
	}

	.course-label {
		color: #212529;
		font-size: 32px;
		font-weight: 500;
		line-height: normal;
	}

	.warning-message {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 16px;
		color: rgba(9, 9, 9, 0.54);
		font-weight: 400;
		line-height: 1.5;
		margin: 0;
	}

	.warning-message svg {
		flex-shrink: 0;
	}

	.panel-right {
		display: flex;
		flex-direction: column;
		gap: 24px;
		flex: 1;
	}

	.course-description {
		font-size: 16px;
		line-height: 32px;
		letter-spacing: 0.15px;
		margin: 0;
		color: rgb(33, 37, 41);
	}

	.contact-btn {
		display: inline-block;
		font-size: 18px;
		font-weight: 500;
		padding: 12px 49px;
		border-radius: 6px;
		background: #2a7dec;
		color: #fff;
		text-decoration: none;
		transition: opacity 0.2s ease-in-out;
		width: fit-content;
		white-space: nowrap;
	}

	.contact-btn:hover {
		opacity: 0.7;
		color: #fff;
		text-decoration: none;
	}

	.contact-btn--mobile {
		display: none;
	}

	/* ── Sessions accordion ── */
	.sessions-list {
		display: flex;
		flex-direction: column;
	}

	.session-item {
		border-bottom: 1.5px solid rgba(62, 154, 248, 0.12);
	}

	.session-summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 58px 32px;
		cursor: pointer;
		list-style: none;
		gap: 20px;
		user-select: none;
	}

	.session-summary::-webkit-details-marker {
		display: none;
	}

	.session-name {
		font-size: 28px;
		font-weight: 400;
		color: #212529;
		line-height: normal;
		margin: 0;
		max-width: 981px;
	}

	.session-meta {
		display: flex;
		align-items: center;
		gap: 24px;
		flex-shrink: 0;
	}

	.session-duration {
		display: flex;
		align-items: center;
		gap: 12px;
		font-size: 24px;
		color: rgba(0, 0, 0, 0.54);
	}

	.chevron {
		transition: transform 0.3s ease-in-out;
	}

	.session-item[open] .chevron {
		transform: rotate(180deg);
	}

	.topics-list {
		padding: 0 32px 30px;
		margin: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.topic-item {
		display: flex;
		align-items: center;
		gap: 16px;
		padding: 0 1px;
	}

	.topic-item svg {
		flex-shrink: 0;
	}

	.topic-item p {
		font-size: 16px;
		color: rgba(0, 0, 0, 0.54);
		line-height: 1.5;
		margin: 0;
	}

	/* Responsive — panels */
	@media (max-width: 1279px) {
		.session-name {
			max-width: 600px;
		}
	}

	@media (max-width: 959px) {
		.courses-section {
			padding: 48px 0;
		}

		.section-title {
			font-size: 32px;
		}

		.panel-header {
			flex-direction: column;
			gap: 20px;
		}

		.panel-left {
			max-width: 100%;
		}

		.contact-btn--desktop {
			display: none;
		}

		.contact-btn--mobile {
			display: inline-block;
		}

		.session-summary {
			padding: 58px 0;
		}

		.topics-list {
			padding: 0 0 30px;
		}

		.session-name {
			max-width: 280px;
		}
	}

	@media (max-width: 599px) {
		.section-title {
			font-size: 28px;
		}

		.course-label {
			font-size: 24px;
		}

		.session-summary {
			gap: 25px;
			align-items: flex-start;
			flex-direction: column;
		}

		.session-meta {
			width: 100%;
			justify-content: space-between;
		}
	}
</style>
