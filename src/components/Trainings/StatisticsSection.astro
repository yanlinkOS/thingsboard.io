---
---

<section class="stats-section">
	<div class="trainings-wrapper">
		<div class="stats-cards">
			<div class="stat-card">
				<div class="stat-icon">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						width="64"
						height="64"
						fill="#2A7DEC"
						aria-hidden="true"
					>
						<path
							d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
						></path>
					</svg>
				</div>
				<div class="stat-number-wrap">
					<span class="stat-number"
						><span class="animated-num" data-target="1200">0</span>+</span
					>
					<span class="stat-label">Participants</span>
				</div>
				<p class="stat-text">More than 1200 participants took part in ThingsBoard training sessions</p>
			</div>
			<div class="stat-card">
				<div class="stat-icon">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						width="64"
						height="64"
						fill="#2A7DEC"
						aria-hidden="true"
					>
						<path
							d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"
						></path>
					</svg>
				</div>
				<div class="stat-number-wrap">
					<span class="stat-number"
						><span class="animated-num" data-target="200">0</span>+</span
					>
					<span class="stat-label">Sessions</span>
				</div>
				<p class="stat-text">More than 200 sessions were organized for ThingsBoard clients</p>
			</div>
		</div>
		<div class="stats-cta">
			<p>Professional training tailored for your needs. Get in touch and start learning!</p>
			<a class="cta-btn" href="/docs/contact-us/?subject=Training">Contact Us</a>
		</div>
	</div>
</section>

<script>
	function animateNumber(el: HTMLElement) {
		const target = parseInt(el.dataset.target || '0', 10);
		const duration = 2000;
		const start = performance.now();

		function update(now: number) {
			const elapsed = now - start;
			const progress = Math.min(elapsed / duration, 1);
			const eased = 1 - Math.pow(1 - progress, 3);
			el.textContent = String(Math.round(eased * target));
			if (progress < 1) requestAnimationFrame(update);
		}

		requestAnimationFrame(update);
	}

	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.querySelectorAll<HTMLElement>('.animated-num').forEach(animateNumber);
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.3 }
	);

	document.querySelectorAll('.stats-cards').forEach((el) => observer.observe(el));
</script>

<style>
	.stats-section {
		padding: 100px 0;
		background: #f7f9fc;
	}

	.trainings-wrapper {
		padding: 0 32px;
		max-width: 1460px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 80px;
	}

	.stats-cards {
		display: flex;
		justify-content: space-between;
		gap: 32px;
	}

	.stat-card {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 32px;
		background: #fff;
		box-shadow: 0px 10px 25px -15px rgba(0, 0, 0, 0.08);
		border-radius: 24px;
		padding: 46px;
	}

	.stat-icon {
		width: fit-content;
		padding: 22px 16px;
		border-radius: 24px;
		border: 3px solid #3e9af8;
	}

	.stat-number-wrap {
		display: flex;
		align-items: baseline;
		flex-direction: row;
		gap: 16px;
	}

	.stat-number {
		font-size: 64px;
		font-weight: 500;
		line-height: normal;
		display: flex;
	}

	.stat-label {
		font-size: 32px;
		font-weight: 500;
		line-height: normal;
		color: rgba(0, 0, 0, 0.54);
	}

	.stat-text {
		color: rgba(68, 71, 74, 0.8);
		font-size: 18px;
		font-weight: 400;
		line-height: normal;
		letter-spacing: 0.15px;
		margin: 0;
	}

	.stats-cta {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 32px;
	}

	.stats-cta p {
		line-height: 32px;
		font-size: 24px;
		color: rgba(0, 0, 0, 0.76);
		margin: 0;
	}

	.cta-btn {
		display: inline-block;
		font-size: 18px;
		font-weight: 500;
		padding: 12px 49px;
		border-radius: 6px;
		background: #2a7dec;
		color: #fff;
		text-decoration: none;
		transition: opacity 0.2s ease-in-out;
		width: fit-content;
	}

	.cta-btn:hover {
		opacity: 0.7;
		color: #fff;
		text-decoration: none;
	}

	@media (max-width: 1279px) {
		.stat-number-wrap {
			flex-direction: column;
			gap: 0;
		}
	}

	@media (max-width: 959px) {
		.stats-section {
			padding: 50px 0;
		}

		.stats-cards {
			flex-direction: column;
		}
	}
</style>
