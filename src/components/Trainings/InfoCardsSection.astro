---
---

<section class="info-cards-section">
	<div class="trainings-wrapper">
		<div class="cards-wrap">
			<div class="info-card">
				<h2 class="card-title">Who is this for</h2>
				<ul>
					<li>
						<img src="/images/trainings/icon_people.svg" alt="Users icon" width="32" height="32" />
						<span>Teams of <b>up to 8 people</b> who need to learn at the same pace.</span>
					</li>
					<li>
						<img src="/images/trainings/icon_trophy.svg" alt="Trophy icon" width="32" height="32" />
						<span>Individuals ready to get a <b>solid foundation and fully leverage</b> ThingsBoard.</span>
					</li>
					<li>
						<img src="/images/trainings/icon_target-line.svg" alt="Target icon" width="32" height="32" />
						<span>Those eager to quickly create <b>top-notch solutions</b>.</span>
					</li>
				</ul>
			</div>
			<div class="info-card">
				<h2 class="card-title">Primary goals of the training</h2>
				<ul>
					<li>
						<img src="/images/trainings/icon_arrow-growth.svg" alt="Graph icon" width="32" height="32" />
						<span>Enhance your <b>experience</b> with ThingsBoard.</span>
					</li>
					<li>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							width="32"
							height="32"
							fill="none"
							stroke="#2A7DEC"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
							class="question-icon"
						>
							<circle cx="12" cy="12" r="10"></circle>
							<path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
							<line x1="12" y1="17" x2="12.01" y2="17"></line>
						</svg>
						<span>Answer <b>practical questions</b> related to your specific use cases.</span>
					</li>
					<li>
						<img src="/images/trainings/akar-icons_reduce.svg" alt="Akar icons" width="32" height="32" />
						<span>Reduce your <b>time-to-market</b> for IoT products or solutions.</span>
					</li>
				</ul>
			</div>
		</div>
	</div>
</section>

<style>
	.info-cards-section {
		padding: 100px 0;
		background: #f7f9fc;
	}

	.trainings-wrapper {
		padding: 0 32px;
		max-width: 1460px;
		margin: 0 auto;
	}

	.cards-wrap {
		display: flex;
		justify-content: space-between;
		gap: 32px;
	}

	.info-card {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 32px;
		background: #fff;
		box-shadow: 0px 10px 25px -15px rgba(0, 0, 0, 0.08);
		border-radius: 24px;
		padding: 46px;
	}

	.card-title {
		color: #212529;
		font-size: 32px;
		font-weight: 500;
		line-height: normal;
	}

	ul {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		height: 100%;
		gap: 16px;
		max-width: 501px;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	li {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	li span {
		font-size: 16px;
		color: rgba(68, 71, 74, 0.8);
	}

	.question-icon {
		flex-shrink: 0;
	}

	@media (max-width: 959px) {
		.info-cards-section {
			padding: 50px 0;
		}

		.cards-wrap {
			flex-direction: column;
		}
	}
</style>
