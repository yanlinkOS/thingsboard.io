---
interface Props {
	title: string;
	description: string;
	features: string[];
	gtmFormId: string;
}

const { title, description, features, gtmFormId } = Astro.props;
---

<section class="demo-request">
	<div class="demo-request__inner">
		<h1 class="demo-request__heading">{title}</h1>
		<div class="demo-request__body">
			<div class="demo-request__info">
				<p>{description}</p>
				<ul>
					{features.map((f) => <li>{f}</li>)}
				</ul>
			</div>
			<div class="demo-request__form">
				<div
					class="ml-form-embed"
					data-account="1017142:w0j5m5g7f5"
					data-form="1575980:e2f1u0"
				>
				</div>
			</div>
		</div>
	</div>
</section>

<script is:inline define:vars={{ gtmFormId }}>
	(function (m, a, i, l, e, r) {
		m['MailerLiteObject'] = e;
		function f(...args) {
			const c = { a: args, q: [] };
			const r = this.push(c);
			return 'number' != typeof r ? r : f.bind(c.q);
		}
		f.q = f.q || [];
		m[e] = m[e] || f.bind(f.q);
		m[e].q = m[e].q || f.q;
		r = a.createElement(i);
		const _ = a.getElementsByTagName(i)[0];
		r.async = 1;
		r.src = l + '?v' + ~~(new Date().getTime() / 1000000);
		_.parentNode.insertBefore(r, _);
	})(window, document, 'script', 'https://static.mailerlite.com/js/universal.js', 'ml');

	ml('accounts', '1017142', 'w0j5m5g7f5', 'load');

	function waitForForm() {
		const $form = document.querySelector('form[action$="e2f1u0"]');
		if ($form) {
			$form.id = gtmFormId;
			$form.classList.add('gtm_form');
		} else {
			setTimeout(waitForForm, 150);
		}
	}

	document.addEventListener('DOMContentLoaded', waitForForm);
</script>

<style lang="scss">
	@use '../styles/variables' as *;

	.demo-request {
		padding: 40px 24px 0;

		&__inner {
			max-width: 900px;
			margin: 0 auto;
		}

		&__heading {
			text-align: center;
			font-size: 1.5rem;
			font-weight: 600;
			margin: 0 0 40px;
			color: var(--color-text);
		}

		&__body {
			display: flex;
			gap: 40px;
			align-items: flex-start;

			@media (max-width: 700px) {
				flex-direction: column;
				align-items: center;
			}
		}

		&__info {
			flex: 1;

			p {
				margin: 0 0 16px;
				color: var(--color-text-secondary);
				line-height: 1.6;
			}

			ul {
				list-style: disc !important;
				padding-left: 20px !important;
				margin: 0 !important;

				li {
					list-style: disc !important;
					margin-bottom: 8px;
					color: var(--color-text-secondary);
					line-height: 1.5;
				}
			}
		}

		&__form {
			flex: 1;
			min-height: 480px;
		}
	}
</style>
