---
import DeferredLoadTrigger from '@components/DeferredLoadTrigger.astro';
import GtmHead from '@components/GtmHead.astro';
import YourGptWidget from '@components/YourGptWidget.astro';
---

<!--
	Single entry point for all third-party browser scripts (GTM + YourGPT
	chatbot). Order matters: DeferredLoadTrigger MUST come first so the global
	window.__deferOnInteraction exists when the consumer scripts parse.
	Mounted in <head> by the Starlight Head override so every route (docs,
	marketing via BaseLayout, etc.) gets the same loaders.
-->
<DeferredLoadTrigger />
<GtmHead />
<YourGptWidget />
