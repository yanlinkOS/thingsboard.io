---
import DocLink from '@components/DocLink.astro';
import { Products } from '~/models/site.models';

type Variant = 'peFeature' | 'ce' | 'pe' | 'cloud' | 'trendz';

interface Props {
	/** Banner color variant:
	 *  'peFeature' — green (PE), renders only on CE pages, shows standard PE/Cloud links;
	 *  'ce' | 'pe' | 'cloud' | 'trendz' — matching product color, always renders. */
	variant: Variant;
	/** Current product context. Required for variant='peFeature'. */
	product?: Products;
	/** Path to the corresponding docs page (without leading/trailing slash).
	 *  Used to generate links to PE and Cloud versions. Defaults to 'installation'.
	 *  Ignored when a default slot is provided (the slot replaces the standard sentence). */
	path?: string;
}

const { variant, product, path } = Astro.props;

const show = variant === 'peFeature' ? product === Products.CE : true;
const linkPath = path || 'installation';
// A slot override replaces the default `peFeature` sentence (rather than appending to it),
// so callers can substitute custom wording while keeping the same color/visibility logic.
const hasSlotOverride = Astro.slots.has('default');
---

{show && (
	<aside class="tb-banner" data-variant={variant}>
		<div class="tb-banner-content">
			<p>
				{hasSlotOverride ? (
					<slot />
				) : variant === 'peFeature' ? (
					<>This feature is available in <DocLink product={Products.PE} path={linkPath} target="_blank">ThingsBoard Professional</DocLink> and <a href="/installations/?product=thingsboard-cloud" target="_blank" rel="noopener noreferrer" class="tb-banner-ext"><b>ThingsBoard Cloud</b></a> only. </>
				) : null}
			</p>
		</div>
	</aside>
)}

<style>
	.tb-banner {
		border: 1px solid var(--tb-banner-color);
		border-inline-start: 4px solid var(--tb-banner-color);
		border-radius: 0.5rem;
		padding: 0.75rem 1rem;
		margin-bottom: 1.5rem;
		background: color-mix(in srgb, var(--tb-banner-color) 6%, transparent);
	}

	.tb-banner[data-variant='peFeature'],
	.tb-banner[data-variant='pe'] {
		--tb-banner-color: var(--color-product-pe, #00695c);
	}

	.tb-banner[data-variant='ce'] {
		--tb-banner-color: var(--color-product-ce, #305680);
	}

	.tb-banner[data-variant='cloud'] {
		--tb-banner-color: var(--color-product-cloud, #3d50f5);
	}

	.tb-banner[data-variant='trendz'] {
		--tb-banner-color: var(--color-product-trendz, #2696f3);
	}

	/* Info-style banners (non-peFeature) shrink to fit content */
	.tb-banner:not([data-variant='peFeature']) {
		display: inline-block;
		width: fit-content;
	}

	.tb-banner-content p {
		margin: 0;
		line-height: 1.6;
	}

	.tb-banner a:not(.tb-banner-ext) {
		color: var(--tb-banner-color);
		text-decoration: underline;
		text-decoration-color: color-mix(in srgb, var(--tb-banner-color) 40%, transparent);
		text-underline-offset: 2px;
	}

	.tb-banner a:not(.tb-banner-ext):hover {
		text-decoration-color: var(--tb-banner-color);
	}
</style>
