---
import { IOT_HUB_API_URL } from '@models/iot-hub';

// Interactive image carousel for solution-template screenshots. Drop-in
// for the detail hero's preview slot when a listing has multiple
// screenshots — single-screenshot listings get a still image rendered by
// DetailHero directly. Scoped Astro markup + a small is:inline script for
// prev/next + dot navigation and gentle auto-advance; no carousel library.

interface Props {
	screenshots: Array<{ id: string }>;
	listingName: string;
}

const { screenshots, listingName } = Astro.props;
const resourceUrl = (id: string) => `${IOT_HUB_API_URL}/api/resources/${id}`;
---

{
	screenshots.length > 0 && (
		<div
			class="iot-hub-gallery"
			role="region"
			aria-roledescription="carousel"
			aria-label={`${listingName} screenshots`}
			data-iot-hub-gallery
		>
			<div class="iot-hub-gallery__viewport">
				<ul class="iot-hub-gallery__track" data-track>
					{screenshots.map((s, i) => (
						<li
							class="iot-hub-gallery__slide"
							role="group"
							aria-roledescription="slide"
							aria-label={`${i + 1} of ${screenshots.length}`}
						>
							<img
								src={resourceUrl(s.id)}
								alt={`${listingName} screenshot ${i + 1}`}
								loading={i === 0 ? 'eager' : 'lazy'}
								decoding="async"
							/>
						</li>
					))}
				</ul>
			</div>
			{screenshots.length > 1 && (
				<div class="iot-hub-gallery__controls">
					<button
						type="button"
						class="iot-hub-gallery__nav iot-hub-gallery__nav--prev"
						aria-label="Previous slide"
						data-prev
					>
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
							<path
								d="m15 6-6 6 6 6"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					</button>
					<div class="iot-hub-gallery__dots" role="tablist" aria-label="Select slide">
						{screenshots.map((_, i) => (
							<button
								type="button"
								class="iot-hub-gallery__dot"
								role="tab"
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-label={`Slide ${i + 1}`}
								data-dot
								data-index={i}
							/>
						))}
					</div>
					<button
						type="button"
						class="iot-hub-gallery__nav iot-hub-gallery__nav--next"
						aria-label="Next slide"
						data-next
					>
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
							<path
								d="m9 6 6 6-6 6"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					</button>
				</div>
			)}
		</div>
	)
}

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	// Single framed surface — background + border + rounded corners wrap the
	// slides AND the controls row, so the whole gallery reads as one panel
	// (the controls share the same backdrop as the slides above them).
	.iot-hub-gallery {
		position: relative;
		display: flex;
		flex-direction: column;
		width: 100%;
		background: var(--color-bg-light);
		border-radius: 12px;
		border: 1px solid var(--iot-hub-hairline, #edeef3);
		overflow: hidden;
	}

	.iot-hub-gallery__viewport {
		position: relative;
		overflow: hidden;
		// Pointer-drag swipe: let the browser keep vertical scrolling
		// (pan-y) but reserve horizontal gesture for our handler. Combined
		// with user-select:none / -webkit-user-drag:none on images so the
		// browser doesn't start its own text-select or image-drag mid-swipe.
		touch-action: pan-y;
		user-select: none;
		cursor: grab;

		&:active {
			cursor: grabbing;
		}

		img {
			user-select: none;
			-webkit-user-drag: none;
		}
	}

	// Sliding track — width is set to total*100% so slides line up side by side
	// and translateX moves between them. `--idx` is updated by the inline
	// script; defaults to 0 so the first slide is visible without JS.
	.iot-hub-gallery__track {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		transition: transform 0.4s ease;
		will-change: transform;
		transform: translateX(calc(var(--idx, 0) * -100%));
	}

	.iot-hub-gallery__slide {
		flex: 0 0 100%;
		min-width: 0;
		aspect-ratio: 16 / 9;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;

		img {
			width: 100%;
			height: 100%;
			object-fit: contain;
			display: block;
		}
	}

	// Bottom controls row: [prev] [dots, centred + flex:1] [next] — chevrons
	// sit at the row edges, dots float in the centre so the layout reads
	// symmetrically regardless of dot count.
	.iot-hub-gallery__controls {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding: 12px 16px;
	}

	.iot-hub-gallery__nav {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: #fff;
		border: 1px solid var(--iot-hub-hairline, #edeef3);
		color: rgba(0, 0, 0, 0.76);
		cursor: pointer;
		padding: 0;
		transition: background 0.15s ease, color 0.15s ease;

		&:hover {
			background: #f5f5f5;
			color: #000;
		}

		&:focus-visible {
			outline: 2px solid var(--color-primary);
			outline-offset: 2px;
		}

		:global([data-theme='dark']) & {
			background: rgba(255, 255, 255, 0.06);
			color: rgba(255, 255, 255, 0.85);
			border-color: rgba(255, 255, 255, 0.16);

			&:hover {
				background: rgba(255, 255, 255, 0.12);
				color: #fff;
			}
		}
	}

	// Pagination dots — 6px, transparent inactive, opaque active, with a
	// soft scale-up on the active dot so it reads clearly without changing
	// layout. `flex: 1` centres the strip within the controls row.
	.iot-hub-gallery__dots {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		flex: 1;
	}

	.iot-hub-gallery__dot {
		width: 6px;
		height: 6px;
		border-radius: 999px;
		border: 0;
		padding: 0;
		background: rgba(0, 0, 0, 0.38);
		cursor: pointer;
		transition: background 0.2s ease, transform 0.2s ease;

		&[aria-selected='true'] {
			background: rgba(0, 0, 0, 0.76);
			transform: scale(1.25);
		}

		&:focus-visible {
			outline: 2px solid var(--color-primary);
			outline-offset: 2px;
		}

		:global([data-theme='dark']) & {
			background: rgba(255, 255, 255, 0.38);

			&[aria-selected='true'] {
				background: rgba(255, 255, 255, 0.85);
			}
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.iot-hub-gallery__track {
			transition: none;
		}

		.iot-hub-gallery__dot {
			transition: none;
		}
	}
</style>

<script is:inline>
	// Wires up every `[data-iot-hub-gallery]` instance on the page. Drives the
	// active slide index by toggling a `--idx` custom property on the track
	// (CSS handles the translateX) and an `aria-selected` attribute on the
	// dots. Auto-advance runs every 5s, pauses on hover / keyboard focus
	// (so users reading a long screenshot aren't yanked away mid-glance) and
	// is suppressed entirely when prefers-reduced-motion is on.
	(function () {
		const AUTOPLAY_MS = 5000;
		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		document.querySelectorAll('[data-iot-hub-gallery]').forEach((gallery) => {
			const viewport = gallery.querySelector('.iot-hub-gallery__viewport');
			const track = gallery.querySelector('[data-track]');
			const slides = track ? track.querySelectorAll('.iot-hub-gallery__slide') : [];
			const total = slides.length;
			if (!track || total <= 1) return;

			const dots = gallery.querySelectorAll('[data-dot]');
			const prevBtn = gallery.querySelector('[data-prev]');
			const nextBtn = gallery.querySelector('[data-next]');

			let idx = 0;
			let paused = false;
			let timer = null;

			function render() {
				track.style.setProperty('--idx', String(idx));
				for (let i = 0; i < dots.length; i++) {
					dots[i].setAttribute('aria-selected', i === idx ? 'true' : 'false');
				}
			}

			function go(n) {
				idx = ((n % total) + total) % total;
				render();
			}

			function startAutoplay() {
				if (reduceMotion || timer) return;
				timer = window.setInterval(function () {
					if (!paused) go(idx + 1);
				}, AUTOPLAY_MS);
			}

			if (prevBtn) prevBtn.addEventListener('click', function () { go(idx - 1); });
			if (nextBtn) nextBtn.addEventListener('click', function () { go(idx + 1); });
			dots.forEach(function (d, i) {
				d.addEventListener('click', function () { go(i); });
			});

			gallery.addEventListener('mouseenter', function () { paused = true; });
			gallery.addEventListener('mouseleave', function () { paused = false; });
			gallery.addEventListener('focusin', function () { paused = true; });
			gallery.addEventListener('focusout', function () { paused = false; });

			// Keyboard navigation when the carousel (or any of its controls)
			// has focus — arrow keys advance, Home/End jump to the ends.
			gallery.addEventListener('keydown', function (e) {
				switch (e.key) {
					case 'ArrowLeft':
						e.preventDefault(); go(idx - 1); break;
					case 'ArrowRight':
						e.preventDefault(); go(idx + 1); break;
					case 'Home':
						e.preventDefault(); go(0); break;
					case 'End':
						e.preventDefault(); go(total - 1); break;
				}
			});

			// ----- Pointer drag / swipe ----------------------------------
			// One handler covers mouse, touch, and pen via the Pointer Events
			// API. During a drag we set `--idx` to a fractional value so the
			// translateX in CSS follows the finger directly. On release we
			// snap to the nearest integer slide (or advance one when the
			// horizontal delta passes a sensible threshold).
			if (viewport) {
				let dragging = false;
				let dragRecognized = false;
				let dragStartX = 0;
				let dragDelta = 0;
				let viewportWidth = 0;
				let dragPointerId = -1;
				const DRAG_THRESHOLD_PX = 10;

				viewport.addEventListener('pointerdown', function (e) {
					// Only react to the primary pointer (left mouse / first
					// finger). Skip when the click started on a child button
					// so its native click still fires.
					if (e.button !== 0 && e.pointerType === 'mouse') return;
					if (e.target && e.target.closest && e.target.closest('button')) return;

					dragging = true;
					dragRecognized = false;
					dragStartX = e.clientX;
					dragDelta = 0;
					viewportWidth = viewport.offsetWidth;
					dragPointerId = e.pointerId;
					// Snap to the integer slot before the drag begins —
					// otherwise a drag that starts mid-transition would jump.
					track.style.transition = 'none';
					track.style.setProperty('--idx', String(idx));
					try { viewport.setPointerCapture(e.pointerId); } catch { /* pointer capture unsupported */ }
				});

				viewport.addEventListener('pointermove', function (e) {
					if (!dragging || e.pointerId !== dragPointerId) return;
					dragDelta = e.clientX - dragStartX;
					if (!dragRecognized && Math.abs(dragDelta) > DRAG_THRESHOLD_PX) {
						dragRecognized = true;
					}
					if (!dragRecognized || viewportWidth === 0) return;
					// Fractional --idx: dragging right (positive delta) reveals
					// the previous slide, so we subtract delta/width from idx.
					const fractional = idx - dragDelta / viewportWidth;
					track.style.setProperty('--idx', String(fractional));
				});

				function endDrag(e) {
					if (!dragging || e.pointerId !== dragPointerId) return;
					dragging = false;
					try { viewport.releasePointerCapture(e.pointerId); } catch { /* capture may already be lost */ }
					// Restore the smooth transition so the snap animates.
					track.style.transition = '';
					if (dragRecognized) {
						const threshold = Math.max(50, viewportWidth * 0.15);
						if (dragDelta < -threshold) idx = (idx + 1) % total;
						else if (dragDelta > threshold) idx = ((idx - 1) % total + total) % total;
					}
					render();
				}
				viewport.addEventListener('pointerup', endDrag);
				viewport.addEventListener('pointercancel', endDrag);
			}

			render();
			startAutoplay();
		});
	})();
</script>
