---
import { IOT_HUB_API_URL } from '@models/iot-hub';

// Renders the listing's `screenshots` array as a preview gallery. Used in
// the detail hero's left column for SOLUTION_TEMPLATE items (which typically
// ship multiple screenshots) instead of the single image preview used for
// DEVICE / WIDGET listings.

interface Props {
	screenshots: Array<{ id: string }>;
	listingName: string;
}

const { screenshots, listingName } = Astro.props;

const featured = screenshots[0];
const thumbs = screenshots.slice(1, 5);
const resourceUrl = (id: string) => `${IOT_HUB_API_URL}/api/resources/${id}`;
---

{
	screenshots.length > 0 && (
		<div class="iot-hub-gallery" aria-label={`${listingName} screenshots`}>
			<div class="iot-hub-gallery__featured">
				<img
					src={resourceUrl(featured.id)}
					alt={`${listingName} screenshot 1`}
					loading="eager"
					decoding="async"
				/>
			</div>
			{thumbs.length > 0 && (
				<ul class="iot-hub-gallery__thumbs" role="list">
					{thumbs.map((s, i) => (
						<li class="iot-hub-gallery__thumb">
							<img
								src={resourceUrl(s.id)}
								alt={`${listingName} screenshot ${i + 2}`}
								loading="lazy"
								decoding="async"
							/>
						</li>
					))}
				</ul>
			)}
		</div>
	)
}

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-gallery {
		display: flex;
		flex-direction: column;
		gap: 8px;
		width: 100%;
	}

	.iot-hub-gallery__featured {
		display: flex;
		align-items: center;
		justify-content: center;
		aspect-ratio: 16 / 9;
		background: var(--color-bg-light);
		border-radius: 12px;
		overflow: hidden;
		border: 1px solid var(--iot-hub-hairline, #edeef3);

		img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
		}
	}

	.iot-hub-gallery__thumbs {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 8px;
	}

	.iot-hub-gallery__thumb {
		aspect-ratio: 16 / 9;
		border-radius: 6px;
		overflow: hidden;
		background: var(--color-bg-light);
		border: 1px solid var(--iot-hub-hairline, #edeef3);

		img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
		}
	}
</style>
