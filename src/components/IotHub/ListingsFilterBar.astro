---
import { IOT_HUB_STRINGS } from '@models/iot-hub';
import IotHubSort from './IotHubSort.astro';

interface Props {
	totalCount: number;
	searchText?: string;
	searchPlaceholder?: string;
}

const T = IOT_HUB_STRINGS.listingsBar;
const {
	totalCount,
	searchText = '',
	searchPlaceholder = T.defaultSearchPlaceholder,
} = Astro.props;
---

<div class="iot-hub-filter-bar" data-iot-hub-search-bar>
	<div class="iot-hub-filter-bar__row1">
		<button
			class="iot-hub-filter-bar__filter-btn"
			type="button"
			data-iot-hub-filter-toggle
			aria-expanded="false"
			aria-controls="iot-hub-filter-panel"
		>
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
				<path
					d="M3 4h18l-7 8v6l-4 2v-8L3 4Z"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"></path>
			</svg>
			<span>{T.filter}</span>
		</button>
		<div class="iot-hub-filter-bar__search">
			<input
				class="iot-hub-filter-bar__search-input"
				type="search"
				name="q"
				value={searchText}
				placeholder={searchPlaceholder}
				aria-label={T.searchAriaLabel}
				autocomplete="off"
				data-search-input
			/>
			<span class="iot-hub-filter-bar__search-glyph" aria-hidden="true"></span>
			<button
				class="iot-hub-filter-bar__search-clear"
				type="button"
				aria-label="Clear search"
				data-search-clear
			>
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path
						d="M5 5 19 19M19 5 5 19"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"></path>
				</svg>
			</button>
		</div>
	</div>
	<div class="iot-hub-filter-bar__row2">
		<p class="iot-hub-filter-bar__count" data-search-count>
			{totalCount} {totalCount === 1 ? T.resultSingular : T.resultPlural}
		</p>
		<div class="iot-hub-filter-bar__chips" data-filter-chips></div>
		<IotHubSort />
	</div>
</div>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-filter-bar {
		display: flex;
		flex-direction: column;
		gap: 16px;
		padding: 40px 16px 0;

		@include media-down(sm) {
			padding: 40px 12px 0;
		}
	}

	.iot-hub-filter-bar__row1 {
		display: flex;
		gap: 16px;
		align-items: center;

		@include media-down(sm) {
			gap: 8px;
		}
	}

	.iot-hub-filter-bar__filter-btn {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		padding: 14px 16px;
		font-family: inherit;
		font-size: 16px;
		font-weight: $font-weight-semibold;
		line-height: 28px;
		color: var(--color-primary);
		background: transparent;
		border: 1px solid var(--color-primary);
		border-radius: 8px;
		min-height: 56px;
		cursor: pointer;
		flex-shrink: 0;
		transition: background $transition-fast, color $transition-fast;

		svg {
			display: block;
		}

		// `var(--color-primary)` already theme-shifts via Starlight's
		// accent token; only the inverted text on the active state needs
		// a per-theme override.
		&[aria-expanded='true'] {
			background: var(--color-primary);
			color: #ffffff;

			:global([data-theme='dark']) & {
				color: var(--neutral---sl-color-black, #17181c);
			}
		}

		@include media-down(sm) {
			padding: 16px;

			span {
				display: none;
			}
		}
	}

	.iot-hub-filter-bar__search {
		flex: 1 1 0;
		min-width: 0;
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 8px 16px;
		min-height: 56px;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		transition: border-color $transition-fast;

		&:focus-within {
			border-color: var(--color-primary);
		}

		:global([data-theme='dark']) & {
			border-color: #353841;
		}
	}

	.iot-hub-filter-bar__search-input {
		flex: 1 1 0;
		min-width: 0;
		border: none;
		outline: none;
		background: transparent;
		font-family: inherit;
		font-size: 16px;
		line-height: 28px;
		color: var(--color-text);

		&::placeholder {
			color: var(--color-text-muted);
		}

		// Hide the UA `×` so only the custom clear button below shows.
		&::-webkit-search-cancel-button,
		&::-webkit-search-decoration {
			-webkit-appearance: none;
			appearance: none;
		}
	}

	.iot-hub-filter-bar__search-glyph {
		flex-shrink: 0;
		width: 24px;
		height: 24px;
		background-color: var(--color-text-secondary);
		-webkit-mask: url('/icons/iot-hub-search.svg') center / contain no-repeat;
		mask: url('/icons/iot-hub-search.svg') center / contain no-repeat;
	}

	.iot-hub-filter-bar__search-clear {
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		padding: 0;
		border: none;
		background: transparent;
		color: var(--color-text-secondary);
		cursor: pointer;
		transition: color $transition-fast;

		&:hover,
		&:focus-visible {
			color: var(--color-text);
		}

		svg { display: block; }
	}

	// Toggle glyph vs clear button by input state (same trick as
	// SearchFilterBar): glyph when empty, clear button when there's text.
	.iot-hub-filter-bar__search-input:placeholder-shown ~ .iot-hub-filter-bar__search-clear {
		display: none;
	}

	.iot-hub-filter-bar__search-input:not(:placeholder-shown) ~ .iot-hub-filter-bar__search-glyph {
		display: none;
	}

	.iot-hub-filter-bar__row2 {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		min-height: 40px;
	}

	.iot-hub-filter-bar__count {
		flex-shrink: 0;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		margin: 0;
		color: var(--color-text);
	}

	// Active-filter chips + the trailing "Clear all" button. Stretches to
	// fill the row's middle so IotHubSort stays right-aligned; wraps to
	// multiple lines when the user picks many filters at once.
	.iot-hub-filter-bar__chips {
		flex: 1 1 0;
		min-width: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 8px;

		&:empty {
			// Collapse the gap when there are no chips so the row keeps the
			// pre-chips spacing between count and sort.
			display: none;
		}
	}

	// Chip styles target the JS-built nodes — selectors are :global because
	// the children are created by `document.createElement` in the script
	// below and don't carry Astro's scope hash.
	:global(.iot-hub-filter-bar__chip) {
		display: inline-flex;
		align-items: center;
		padding: 4px 4px 4px 8px;
		border-radius: 16px;
		background: var(--sl-color-gray-6);
		font-size: 14px;
		line-height: 24px;
		color: var(--color-text);
	}

	:global(.iot-hub-filter-bar__chip-label) {
		padding: 0 4px;
	}

	:global(.iot-hub-filter-bar__chip-remove) {
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		padding: 4px;
		margin: 0;
		border: none;
		background: transparent;
		color: var(--color-text-secondary);
		cursor: pointer;
		border-radius: 50%;
		font-family: inherit;
		transition: color $transition-fast, background-color $transition-fast;

		&:hover,
		&:focus-visible {
			color: var(--color-text);
		}

		svg {
			display: block;
		}
	}

	:global(.iot-hub-filter-bar__clear-all) {
		display: inline-flex;
		align-items: center;
		padding: 4px 12px;
		font-family: inherit;
		font-size: 14px;
		font-weight: $font-weight-normal;
		line-height: 24px;
		color: var(--sl-color-gray-3);
		background: transparent;
		border: none;
		border-radius: 16px;
		cursor: pointer;
		transition: color $transition-fast;

		&:hover,
		&:focus-visible {
			color: var(--color-text);
			text-decoration: underline;
		}
	}
</style>

<script>
	import { initSearchBars } from './iot-hub-search-bar-init';
	initSearchBars();

	// Active-filter chips. The FilterPanel emits
	// `iot-hub-filter:change` { filters: Record<key, { value, label }[]> }
	// whenever a checkbox toggles; we re-render the chips strip in row 2.
	// Removing a chip flips the matching checkbox off, which bubbles back
	// out as another `iot-hub-filter:change` for the next render.

	type FilterEntry = { value: string; label: string };
	type FiltersByKey = Record<string, FilterEntry[]>;

	const REMOVE_X_SVG =
		'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">' +
		'<path d="M5 5 19 19M19 5 5 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>' +
		'</svg>';

	function findCheckbox(key: string, value: string): HTMLInputElement | null {
		return document.querySelector<HTMLInputElement>(
			`.iot-hub-filter-option__input[name="${CSS.escape(key)}"][value="${CSS.escape(value)}"]`
		);
	}

	function uncheckFilter(key: string, value: string): void {
		const cb = findCheckbox(key, value);
		if (!cb) return;
		cb.checked = false;
		cb.dispatchEvent(new Event('change', { bubbles: true }));
	}

	function clearAllFilters(): void {
		const panel = document.querySelector<HTMLElement>('[data-iot-hub-filter-panel]');
		if (!panel) return;
		const checked = Array.from(
			panel.querySelectorAll<HTMLInputElement>('.iot-hub-filter-option__input:checked')
		);
		if (checked.length === 0) return;
		for (const input of checked) input.checked = false;
		// Single dispatch — the FilterPanel listener re-collects the whole
		// snapshot, so one bubble is enough to update everything.
		checked[0].dispatchEvent(new Event('change', { bubbles: true }));
	}

	function makeChip(key: string, entry: FilterEntry): HTMLElement {
		const chip = document.createElement('span');
		chip.className = 'iot-hub-filter-bar__chip';
		const label = document.createElement('span');
		label.className = 'iot-hub-filter-bar__chip-label';
		label.textContent = entry.label;
		chip.appendChild(label);
		const remove = document.createElement('button');
		remove.type = 'button';
		remove.className = 'iot-hub-filter-bar__chip-remove';
		remove.setAttribute('aria-label', `Remove ${entry.label}`);
		remove.innerHTML = REMOVE_X_SVG;
		remove.addEventListener('click', () => uncheckFilter(key, entry.value));
		chip.appendChild(remove);
		return chip;
	}

	function makeClearAll(): HTMLElement {
		const btn = document.createElement('button');
		btn.type = 'button';
		btn.className = 'iot-hub-filter-bar__clear-all';
		btn.textContent = 'Clear all';
		btn.addEventListener('click', clearAllFilters);
		return btn;
	}

	function renderChips(chipsEl: HTMLElement, filters: FiltersByKey): void {
		chipsEl.replaceChildren();
		let hasAny = false;
		for (const [key, entries] of Object.entries(filters)) {
			for (const entry of entries) {
				chipsEl.appendChild(makeChip(key, entry));
				hasAny = true;
			}
		}
		if (hasAny) chipsEl.appendChild(makeClearAll());
	}

	function initListingsBars() {
		document.querySelectorAll<HTMLElement>('[data-iot-hub-search-bar]').forEach((bar) => {
			const chipsEl = bar.querySelector<HTMLElement>('[data-filter-chips]');
			if (!chipsEl || bar.dataset.chipsInited) return;
			bar.dataset.chipsInited = 'true';
			document.addEventListener('iot-hub-filter:change', ((e: CustomEvent) => {
				renderChips(chipsEl, e.detail?.filters ?? {});
			}) as EventListener);
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initListingsBars);
	} else {
		initListingsBars();
	}
	document.addEventListener('astro:page-load', initListingsBars);
</script>
