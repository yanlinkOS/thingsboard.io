---
import '@fontsource/material-icons';
import { getMdiSvg, svgIcons } from '@util/icons';

// Renders an IoT Hub icon — same convention as the Angular `<hub-icon>`
// (/data/git/iot-hub/ui/src/app/shared/components/icon.component.ts):
//   * bare names registered in `svgIcons` (e.g. `thingsboard`) → SVG inlined
//     from the in-memory registry
//   * names prefixed `mdi:` → SVG fetched from
//     `${IOT_HUB_API_URL}/assets/mdi/{name}.svg` and inlined
//   * everything else (bare Material Icons name) → Material Icons font glyph
//     rendered via ligature substitution
//
// MDI SVGs are fetched server-side at component render and cached per build
// worker, so each unique icon is fetched once regardless of how many
// listings use it.

interface Props {
	/**
	 * Icon name. Bare names registered in `svgIcons` render from the
	 * in-memory registry; `mdi:`-prefixed names are fetched from the IoT Hub
	 * asset endpoint and inlined; any other bare name renders as a Material
	 * Icons font glyph.
	 */
	icon: string;
	/**
	 * Rendered icon size as a CSS dimension. Numbers are treated as px.
	 * @default '1em'
	 */
	size?: string | number;
	class?: string;
}

const { icon, size = '1em', class: className } = Astro.props;
const sizeCss = typeof size === 'number' ? `${size}px` : size;

const inlineSvg = icon in svgIcons ? svgIcons[icon] : null;
const isMdi = icon.startsWith('mdi:');
const mdiName = isMdi ? icon.slice(4) : null;
const svgMarkup = inlineSvg ?? (mdiName ? await getMdiSvg(mdiName) : null);
const isSvg = svgMarkup !== null;
---

{
	isSvg ? (
		<span
			class:list={['iot-hub-icon', 'iot-hub-icon--svg', className]}
			style={`width:${sizeCss};height:${sizeCss};`}
			aria-hidden="true"
			set:html={svgMarkup}
		/>
	) : (
		<span
			class:list={['iot-hub-icon', 'iot-hub-icon--font', 'material-icons', className]}
			style={`font-size:${sizeCss};`}
			aria-hidden="true"
		>
			{icon}
		</span>
	)
}

<style lang="scss">
	@use '~/styles/_iot-hub.scss' as *;

	.iot-hub-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		line-height: 1;
		color: inherit;
		flex-shrink: 0;
	}

	// Inlined MDI SVG — fill the wrapper span and inherit colour via
	// currentColor (added on the root <svg> by getMdiSvg's normaliser).
	.iot-hub-icon--svg {
		:global(svg) {
			width: 100%;
			height: 100%;
			display: block;
			fill: currentColor;
		}
	}

	// Material Icons font ships glyphs via `liga` substitution — the element
	// text content (e.g. "memory") is rendered as the icon.
	.iot-hub-icon--font {
		@include iot-hub-material-icon;
	}
</style>
