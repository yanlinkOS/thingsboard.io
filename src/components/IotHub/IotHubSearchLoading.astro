---
// Absolute-positioned loading overlay used by any IoT Hub page that
// drives results via `setupDynamicSearch()`. Toggled by the `is-loading`
// modifier on the nearest `[data-search-items]` ancestor.
//
// Sits above the results container so the page height stays stable
// across fetches — a semi-opaque scrim dims previous content while the
// spinner is visible.
---

<div class="iot-hub-search-loading" aria-hidden="true">
	<span
		class="iot-hub-search-loading__spinner"
		role="progressbar"
		aria-label="Loading results"
	></span>
</div>

<style is:global lang="scss">
	.iot-hub-search-loading {
		display: none;
		position: absolute;
		inset: 0;
		z-index: 5;
		justify-content: center;
		padding-top: 64px;
		background: rgba(255, 255, 255, 0.72);
	}

	[data-theme='dark'] .iot-hub-search-loading {
		background: rgba(23, 24, 28, 0.72);
	}

	[data-search-items].is-loading .iot-hub-search-loading {
		display: flex;
	}

	.iot-hub-search-loading__spinner {
		width: 64px;
		height: 64px;
		border: 6px solid var(--color-bg-light, rgba(0, 0, 0, 0.08));
		border-top-color: var(--color-primary);
		border-radius: 50%;
		animation: iot-hub-search-loading-spin 0.8s linear infinite;
	}

	[data-theme='dark'] .iot-hub-search-loading__spinner {
		border-color: rgba(255, 255, 255, 0.12);
		border-top-color: #b3c7ff;
	}

	@keyframes iot-hub-search-loading-spin {
		to {
			transform: rotate(360deg);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.iot-hub-search-loading__spinner {
			animation-duration: 2.4s;
		}
	}
</style>
