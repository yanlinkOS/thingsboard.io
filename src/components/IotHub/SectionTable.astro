---
interface Props {
	heading: string;
	intro?: string;
	columns: string[];
	rows: string[][];
}

const { heading, intro, columns, rows } = Astro.props;
---

<section class="ih-table">
	<h2 class="ih-table__title">{heading}</h2>
	{intro && <p class="ih-table__intro">{intro}</p>}
	<div class="ih-table__scroll">
		<table class="ih-table__table">
			<thead>
				<tr>
					{columns.map((col) => <th scope="col">{col}</th>)}
				</tr>
			</thead>
			<tbody>
				{
					rows.map((row) => (
						<tr>
							{row.map((cell, i) =>
								i === 0 ? <th scope="row">{cell}</th> : <td>{cell}</td>
							)}
						</tr>
					))
				}
			</tbody>
		</table>
	</div>
</section>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;
	@use '../../styles/_iot-hub.scss' as *;

	.ih-table {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.ih-table__title {
		@include iot-hub-section-title;
	}

	.ih-table__intro {
		@include iot-hub-section-intro;
	}

	.ih-table__scroll {
		overflow-x: auto;
		// Rounded outer frame (matches buttons/cards); cells draw only inner
		// gridlines so the corners can round cleanly with no double border.
		border: 1px solid var(--iot-hub-hairline, var(--color-border));
		border-radius: 8px;
	}

	.ih-table__table {
		width: 100%;
		border-collapse: collapse;
		font-size: 15px;
		line-height: 24px;

		th,
		td {
			text-align: left;
			vertical-align: top;
			padding: 12px 16px;
			border-right: 1px solid var(--iot-hub-hairline, var(--color-border));
			border-bottom: 1px solid var(--iot-hub-hairline, var(--color-border));
		}

		th:last-child,
		td:last-child {
			border-right: none;
		}

		tbody tr:last-child th,
		tbody tr:last-child td {
			border-bottom: none;
		}

		thead th {
			font-weight: $font-weight-semibold;
			color: var(--color-text);
			background: var(--color-bg-surface);
			white-space: nowrap;
		}

		tbody th {
			font-weight: $font-weight-semibold;
			color: var(--color-text);
			width: 1%;
			white-space: nowrap;
		}

		tbody td {
			font-weight: $font-weight-normal;
			color: var(--sl-color-gray-2);
		}

		@include media-down(sm) {
			tbody th {
				white-space: normal;
			}
		}
	}
</style>
