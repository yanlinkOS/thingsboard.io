---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

import deviceImg from '~/assets/iot-hub/category-device-library-img.png';
import solutionImg from '~/assets/iot-hub/category-solution-templates-img.png';
import widgetImg from '~/assets/iot-hub/category-widgets-img.png';
import calcFieldImg from '~/assets/iot-hub/category-calculated-fields-img.png';
import alarmImg from '~/assets/iot-hub/category-alarm-rules-img.png';
import ruleChainImg from '~/assets/iot-hub/category-rule-chains-img.png';

interface Props {
	slug: string;
	label: string;
	color: string;
	colorDark: string;
	itemType: string;
}

const { slug, label, color, colorDark, itemType } = Astro.props;

const imageByType: Record<string, ImageMetadata> = {
	DEVICE: deviceImg,
	SOLUTION_TEMPLATE: solutionImg,
	WIDGET: widgetImg,
	CALCULATED_FIELD: calcFieldImg,
	ALARM_RULE: alarmImg,
	RULE_CHAIN: ruleChainImg,
};

const image = imageByType[itemType] ?? deviceImg;
const href = `/iot-hub/${slug}/`;
---

<a
	class="iot-hub-tile"
	href={href}
	style={`--tile-bg:${color};--tile-bg-dark:${colorDark};`}
	data-category={slug}
>
	<span class="iot-hub-tile__title">
		<span class="iot-hub-tile__title-text">{label}</span>
		<svg
			class="iot-hub-tile__chevron"
			width="24"
			height="24"
			viewBox="0 0 24 24"
			fill="none"
			aria-hidden="true"
		>
			<path
				d="m9 6 6 6-6 6"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"></path>
		</svg>
	</span>
	<div class="iot-hub-tile__img">
		<Image src={image} alt="" widths={[400, 600, 800]} sizes="(max-width: 750px) 100vw, 400px" />
	</div>
</a>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-tile {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 24px;
		padding-top: 24px;
		height: 200px;
		border-radius: 8px;
		border: 1px solid rgba(0, 0, 0, 0.12);
		background: var(--tile-bg);
		overflow: hidden;
		text-decoration: none;
		color: #17181c;
		cursor: pointer;

		&:hover,
		&:focus-visible {
			text-decoration: none;

			.iot-hub-tile__img img {
				transform: scale(1.054);
			}

			.iot-hub-tile__chevron {
				opacity: 1;
				width: 24px;
				margin-left: 4px;
				transform: translateX(0);
			}
		}

		// `:global()` is required because `data-theme` lives on <html>, which
		// is outside this component's Astro scope. In dark mode the tile uses
		// the saturated brand hue with white text and
		// no visible border.
		:global([data-theme='dark']) & {
			background: var(--tile-bg-dark);
			color: white;
			border-color: transparent;
		}
	}

	.iot-hub-tile__title {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		font-size: 18px;
		font-weight: $font-weight-medium;
		line-height: 24px;
		letter-spacing: 0.15px;
		color: inherit;
	}

	.iot-hub-tile__title-text {
		white-space: nowrap;
	}

	.iot-hub-tile__chevron {
		width: 0;
		height: 24px;
		margin-left: 0;
		opacity: 0;
		overflow: hidden;
		transform: translateX(-4px);
		color: inherit;
		flex-shrink: 0;
		transition:
			opacity 0.2s ease-out,
			transform 0.2s ease-out,
			width 0.2s ease-out,
			margin-left 0.2s ease-out;
	}

	.iot-hub-tile__img {
		width: 100%;
		flex: 1;
		min-height: 0;
		overflow: visible;
		display: flex;
		justify-content: center;
		align-items: flex-start;

		img {
			width: auto;
			max-width: 100%;
			height: 100%;
			object-fit: contain;
			object-position: center top;
			transition: transform 0.2s ease-out;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.iot-hub-tile {
			&:hover .iot-hub-tile__img img,
			&:focus-visible .iot-hub-tile__img img {
				transform: none;
			}
		}

		.iot-hub-tile__chevron,
		.iot-hub-tile__img img {
			transition: none;
		}
	}
</style>
