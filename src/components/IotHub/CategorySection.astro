---
import { getCardVariant, type ListingView } from '@models/iot-hub';
import ListingCard from './ListingCard.astro';
import ListingGrid from './ListingGrid.astro';

interface Props {
	categorySlug: string;
	categoryLabel: string;
	items: ListingView[];
	home?: boolean;
}

const { categorySlug, categoryLabel, items, home = false } = Astro.props;
const indexHref = `/iot-hub/${categorySlug}/`;
const variant = getCardVariant(items[0]?.itemType ?? '');
---

<section class="iot-hub-section">
	<a class="iot-hub-section__header" href={indexHref}>
		<span class="iot-hub-section__indicator" aria-hidden="true"></span>
		<h2 class="iot-hub-section__title">
			<span class="iot-hub-section__label">{categoryLabel}</span>
			<svg
				class="iot-hub-section__chevron"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				aria-hidden="true"
			>
				<path
					d="m9 6 6 6-6 6"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"></path>
			</svg>
		</h2>
	</a>
	{
		items.length > 0 ? (
			<ListingGrid variant={variant} home={home}>
				{items.map((item) => (
					<ListingCard item={item} categorySlug={categorySlug} />
				))}
			</ListingGrid>
		) : (
			<p class="iot-hub-section__empty">No items available yet.</p>
		)
	}
</section>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-section {
		// 64px top + 64px bottom — collapses with adjacent section margins so
		// section-to-section gap is 64px, and provides the 64px gap from the
		// "Most popular" heading to the first section (Figma).
		// No horizontal padding: per Figma, the section header's indicator
		// sits flush with the container's left edge while only the grid's
		// cards are inset (16px padding on .iot-hub-grid).
		margin: 4rem 0;

		@include media-down(xl) {
			margin: 3rem 0;
		}
	}

	.iot-hub-section__header {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		margin-bottom: 1rem;
		text-decoration: none;
		color: inherit;

		@include media-down(sm) {
			gap: 10px;
		}

		&:hover {
			text-decoration: none;

			.iot-hub-section__chevron {
				transform: translateX(2px);
			}
		}
	}

	.iot-hub-section__indicator {
		display: inline-block;
		width: 2px;
		height: 32px;
		border-radius: 1px;
		// Per Figma token neutral/--sl-color-gray-4 (#888c96).
		background: var(--neutral---sl-color-gray-4, #888c96);
	}

	.iot-hub-section__title {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		margin: 0;
		font-size: 20px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: var(--color-text);
	}

	.iot-hub-section__chevron {
		transition: transform $transition-fast;
		color: var(--color-text);
	}

	.iot-hub-section__empty {
		color: var(--color-text-muted);
		font-size: 0.95rem;
	}
</style>
