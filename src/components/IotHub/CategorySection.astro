---
import type { CollectionEntry } from 'astro:content';
import { getCardVariant } from '~/models/iot-hub';
import ListingCard from './ListingCard.astro';
import ListingCardSmall from './ListingCardSmall.astro';
import ListingGrid from './ListingGrid.astro';

interface Props {
	categorySlug: string;
	categoryLabel: string;
	entries: Array<CollectionEntry<'iotHubListings'>>;
}

const { categorySlug, categoryLabel, entries } = Astro.props;
const indexHref = `/iot-hub/${categorySlug}/`;
const variant = getCardVariant(entries[0]?.data.itemType ?? '');
---

<section class="iot-hub-section">
	<a class="iot-hub-section__header" href={indexHref}>
		<span class="iot-hub-section__indicator" aria-hidden="true"></span>
		<h2 class="iot-hub-section__title">
			<span class="iot-hub-section__label">{categoryLabel}</span>
			<svg
				class="iot-hub-section__chevron"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				aria-hidden="true"
			>
				<path
					d="m9 6 6 6-6 6"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"></path>
			</svg>
		</h2>
	</a>
	{
		entries.length > 0 ? (
			<ListingGrid variant={variant}>
				{entries.map((entry) =>
					variant === 'small' ? (
						<ListingCardSmall entry={entry} categorySlug={categorySlug} />
					) : (
						<ListingCard entry={entry} categorySlug={categorySlug} />
					)
				)}
			</ListingGrid>
		) : (
			<p class="iot-hub-section__empty">No items available yet.</p>
		)
	}
</section>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-section {
		margin: 2.5rem 0;
		padding: 0 1rem;
	}

	.iot-hub-section__header {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		margin-bottom: 1rem;
		text-decoration: none;
		color: inherit;

		&:hover {
			text-decoration: none;

			.iot-hub-section__chevron {
				transform: translateX(2px);
			}
		}
	}

	.iot-hub-section__indicator {
		display: inline-block;
		width: 2px;
		height: 32px;
		border-radius: 1px;
		background: var(--color-border);
	}

	.iot-hub-section__title {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		margin: 0;
		font-size: 20px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: var(--color-text);
	}

	.iot-hub-section__chevron {
		transition: transform $transition-fast;
		color: var(--color-text);
	}

	.iot-hub-section__empty {
		color: var(--color-text-muted);
		font-size: 0.95rem;
	}
</style>
