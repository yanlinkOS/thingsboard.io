---
import { getCardVariant, type ListingView } from '@models/iot-hub';
import ListingCard from './ListingCard.astro';
import ListingGrid from './ListingGrid.astro';

interface Props {
	categorySlug: string;
	categoryLabel: string;
	items: ListingView[];
	home?: boolean;
	/** Forwarded to ListingCard — false hides the creator row. */
	showCreator?: boolean;
}

const { categorySlug, categoryLabel, items, home = false, showCreator = true } = Astro.props;
const indexHref = `/iot-hub/${categorySlug}/`;
const variant = getCardVariant(items[0]?.itemType ?? '');
---

<section class="iot-hub-section">
	<div class="iot-hub-section__header">
		<a class="iot-hub-section__heading" href={indexHref}>
			<span class="iot-hub-section__indicator" aria-hidden="true"></span>
			<h2 class="iot-hub-section__title">
				<span class="iot-hub-section__label">{categoryLabel}</span>
			</h2>
		</a>
		<a class="iot-hub-section__explore" href={indexHref}>
			Explore all {categoryLabel.toLowerCase()}
			<svg
				class="iot-hub-section__explore-chevron"
				width="20"
				height="20"
				viewBox="0 0 24 24"
				fill="none"
				aria-hidden="true"
			>
				<path
					d="m9 6 6 6-6 6"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"></path>
			</svg>
		</a>
	</div>
	{
		items.length > 0 ? (
			<ListingGrid variant={variant} home={home}>
				{items.map((item) => (
					<ListingCard item={item} categorySlug={categorySlug} showCreator={showCreator} />
				))}
			</ListingGrid>
		) : (
			<p class="iot-hub-section__empty">No items available yet.</p>
		)
	}
</section>

<style is:global lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-section {
		// 64px top + 64px bottom — collapses with adjacent section margins so
		// section-to-section gap is 64px, and provides the 64px gap from the
		// "Most popular" heading to the first section (the design).
		// No horizontal padding: the header indicator sits flush with the
		// container's left edge, while the cards (16px .iot-hub-grid padding) and
		// the header's right edge (matching padding-right) are inset to align.
		margin: 4rem 0;

		@include media-down(xl) {
			margin: 3rem 0;
		}
	}

	.iot-hub-section__header {
		display: flex;
		align-items: center;
		// Title group left, "Explore all" link right; the link wraps to its own
		// left-aligned line when the row is too narrow to hold both.
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 8px 14px;
		margin-bottom: 1rem;
		// Right edge matches the card grid's gutter so the "Explore all" link
		// lines up with the cards' right edge (the indicator stays flush left).
		padding-right: 1rem;

		@include media-down(sm) {
			padding-right: 0.75rem;
		}
	}

	.iot-hub-section__heading {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		// Title links to the category index page; keep the title's own color and
		// no underline (matches the old header-link behavior, minus the chevron).
		text-decoration: none;
		color: inherit;

		@include media-down(sm) {
			gap: 10px;
		}
	}

	.iot-hub-section__indicator {
		display: inline-block;
		width: 2px;
		height: 32px;
		border-radius: 1px;
		// Per the design token neutral/--sl-color-gray-4 (#888c96).
		background: var(--neutral---sl-color-gray-4, #888c96);
	}

	.iot-hub-section__title {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		margin: 0;
		font-size: 20px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: var(--color-text);
		// One line, so the indicator bar stays aligned and the link wraps instead.
		white-space: nowrap;
	}

	// Link to the category index page, at the right edge of the header row.
	.iot-hub-section__explore {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		flex-shrink: 0;
		white-space: nowrap;
		font-size: 16px;
		font-weight: $font-weight-medium;
		line-height: 24px;
		color: var(--color-primary);
		text-decoration: none;

		@include media-down(sm) {
			// When the link wraps below the title, indent it to line up with the
			// title text and cards (indicator width 2px + heading gap 10px)
			// instead of sitting flush under the indicator bar.
			margin-left: 12px;
		}

		&:hover,
		&:focus-visible {
			text-decoration: none;

			.iot-hub-section__explore-chevron {
				transform: translateX(2px);
			}
		}
	}

	.iot-hub-section__explore-chevron {
		transition: transform $transition-fast;
	}

	.iot-hub-section__empty {
		color: var(--color-text-muted);
		font-size: 0.95rem;
	}
</style>
