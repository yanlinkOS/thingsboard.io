---
import type { LabeledItem } from '@models/iot-hub-sections';

interface Props {
	heading: string;
	intro?: string;
	items: LabeledItem[];
}

const { heading, intro, items } = Astro.props;
---

<section class="ih-features">
	<h2 class="ih-features__title">{heading}</h2>
	{intro && <p class="ih-features__intro">{intro}</p>}
	<ul class="ih-features__list">
		{
			items.map((item) => (
				<li class="ih-features__item">
					<span class="ih-features__label">{item.label}</span>
					{item.description && <span class="ih-features__desc">{item.description}</span>}
				</li>
			))
		}
	</ul>
</section>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;
	@use '../../styles/_iot-hub.scss' as *;

	.ih-features {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.ih-features__title {
		@include iot-hub-section-title;
	}

	.ih-features__intro {
		@include iot-hub-section-intro;
	}

	.ih-features__list {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 24px 40px;
		margin: 8px 0 0;
		padding: 0;
		list-style: none;

		@include media-down(md) {
			grid-template-columns: 1fr;
		}
	}

	.ih-features__item {
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding-left: 16px;
		border-left: 2px solid var(--color-primary);
	}

	.ih-features__label {
		@include iot-hub-item-label;
	}

	.ih-features__desc {
		@include iot-hub-item-desc;
	}
</style>
