---
import { IOT_HUB_API_URL } from '@models/iot-hub';

// Matches the platform's openSignup() in tb-iot-hub-home.
const submitUrl = `${IOT_HUB_API_URL}/signup`;
---

<section class="iot-hub-cta-wrap">
	<div class="iot-hub-cta">
		<div class="iot-hub-cta__content">
			<div class="iot-hub-cta__text">
				<h2 class="iot-hub-cta__title">Become a Creator</h2>
				<p class="iot-hub-cta__desc">
					Submit your templates to the ThingsBoard IoT Hub to get featured and showcase your
					solutions to our global community.
				</p>
			</div>
			<a class="iot-hub-cta__button" href={submitUrl} target="_blank" rel="noopener">
				<span>Contribute</span>
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path
						d="m9 6 6 6-6 6"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
			</a>
		</div>
	</div>
</section>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-cta-wrap {
		padding: 80px 1rem;

		@include media-down(lg) {
			padding-top: 40px;
		}
	}

	.iot-hub-cta {
		max-width: 1080px;
		margin: 0 auto;
		padding: 2.5rem;
		border: 1px solid rgba(61, 80, 245, 0.5);
		border-radius: 8px;
		background-image: linear-gradient(
			181deg,
			rgba(61, 80, 245, 0.08) 4%,
			rgba(61, 80, 245, 0) 97%
		);

		[data-theme='dark'] & {
			border-color: rgba(120, 140, 220, 0.4);
			background-image: linear-gradient(
				181deg,
				rgba(120, 140, 220, 0.1) 4%,
				rgba(120, 140, 220, 0) 97%
			);
		}

		@include media-down(md) {
			padding: 2rem 1.25rem;
		}
	}

	.iot-hub-cta__content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2.5rem;
	}

	.iot-hub-cta__text {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
		text-align: center;
	}

	.iot-hub-cta__title {
		font-size: 32px;
		font-weight: $font-weight-semibold;
		line-height: 40px;
		margin: 0;
		color: var(--color-text);

		@include media-down(md) {
			font-size: 24px;
			line-height: 32px;
		}
	}

	.iot-hub-cta__desc {
		font-size: 18px;
		font-weight: $font-weight-normal;
		line-height: 32px;
		margin: 0;
		color: var(--color-text);

		@include media-down(md) {
			font-size: 16px;
			line-height: 28px;
		}
	}

	.iot-hub-cta__button {
		@include button-primary;
		display: inline-flex;
		align-items: center;
		gap: 4px;
		padding: 14px 16px;
		font-size: 16px;
		font-weight: $font-weight-semibold;
		line-height: 28px;
		border-radius: 8px;

		svg {
			display: block;
		}

		// Dark theme inverts the CTA: lighter blue surface with dark text per
		// Figma node 1240:40372. `:global()` is required because `data-theme`
		// lives on <html>, outside this component's Astro scope.
		:global([data-theme='dark']) & {
			background: #b3c7ff;
			color: #17181c;
		}
	}
</style>
