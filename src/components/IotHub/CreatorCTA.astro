---
import { IOT_HUB_API_URL, IOT_HUB_CATEGORIES } from '@models/iot-hub';
import Chevron from '@components/Chevron.astro';

interface Props {
	category?: string;
	// Explicit overrides — used where there's no matching category (e.g. the IoT Hub home page).
	title?: string;
	description?: string;
	primaryLabel?: string;
	secondaryLabel?: string;
	guideHref?: string;
}

const props = Astro.props;
const { category } = props;

const config = IOT_HUB_CATEGORIES.find((c) => c.slug === category);
// Every IOT_HUB_CATEGORIES entry carries the cta* fields, so `config?.x` covers
// the matched-category case; the literal fallbacks only fire when there's no
// matching category (e.g. the IoT Hub home page passes explicit overrides).
const title = props.title ?? config?.ctaTitle ?? 'Become a Creator';
const description =
	props.description ??
	config?.ctaDescription ??
	'Submit your templates to the ThingsBoard IoT Hub to get featured and showcase your solutions to our global community.';
const howToHref = props.guideHref ?? config?.guideHref ?? '/docs/iot-hub/contribution-guides/';
const primaryLabel = props.primaryLabel ?? config?.ctaPrimaryLabel ?? 'Contribute';
const secondaryLabel = props.secondaryLabel ?? config?.ctaSecondaryLabel ?? 'How to contribute';

const submitUrl = `${IOT_HUB_API_URL}/signup`;
---

<section class="iot-hub-cta-wrap">
	<div class="iot-hub-cta">
		<div class="iot-hub-cta__content">
			<div class="iot-hub-cta__text">
				<h2 class="iot-hub-cta__title">{title}</h2>
				<p class="iot-hub-cta__desc">{description}</p>
			</div>
			<div class="iot-hub-cta__actions">
				<a class="iot-hub-cta__button" href={submitUrl} target="_blank" rel="noopener">
					<span>{primaryLabel}</span>
					<Chevron direction="right" size={24} />
				</a>
				<a class="iot-hub-cta__button-secondary" href={howToHref}>
					<span>{secondaryLabel}</span>
				</a>
			</div>
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-cta-wrap {
		padding: 2.5rem 1rem 5rem;

		@include media-down(sm) {
			padding: 2.5rem 0.75rem 5rem;
		}
	}

	.iot-hub-cta {
		max-width: 1080px;
		margin: 0 auto;
		padding: 2.5rem;
		border: 1px solid rgba(61, 80, 245, 0.5);
		border-radius: 8px;
		background-image: linear-gradient(
			181deg,
			rgba(61, 80, 245, 0.08) 4%,
			rgba(61, 80, 245, 0) 97%
		);

		[data-theme='dark'] & {
			border-color: rgba(120, 140, 220, 0.4);
			background-image: linear-gradient(
				181deg,
				rgba(120, 140, 220, 0.1) 4%,
				rgba(120, 140, 220, 0) 97%
			);
		}

		@include media-down(sm) {
			padding: 1.5rem;
		}
	}

	.iot-hub-cta__content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2.5rem;
	}

	.iot-hub-cta__text {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
		text-align: center;
	}

	.iot-hub-cta__title {
		font-size: 32px;
		font-weight: $font-weight-semibold;
		line-height: 40px;
		margin: 0;
		color: var(--color-text);

		@include media-down(sm) {
			font-size: 24px;
			line-height: 28px;
		}
	}

	.iot-hub-cta__desc {
		font-size: 18px;
		font-weight: $font-weight-normal;
		line-height: 32px;
		margin: 0;
		color: var(--color-text);

		@include media-down(sm) {
			font-size: 16px;
			line-height: 28px;
		}
	}

	.iot-hub-cta__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 16px;

		@include media-down(sm) {
			flex-direction: column;
			align-self: stretch;

			> * {
				width: 100%;
			}
		}
	}

	.iot-hub-cta__button {
		@include button-primary;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 4px;
		padding: 14px 16px;
		font-size: 16px;
		font-weight: $font-weight-semibold;
		line-height: 28px;
		border-radius: 8px;
		border: 1px solid transparent;

		svg {
			display: block;
		}

		:global([data-theme='dark']) & {
			background-color: #b3c7ff;
			color: #17181c;
		}
	}

	.iot-hub-cta__button-secondary {
		@include button-base;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 14px 16px;
		font-size: 16px;
		font-weight: $font-weight-semibold;
		line-height: 28px;
		border-radius: 8px;
		background-color: transparent;
		color: var(--color-primary);
		border: 1px solid var(--color-primary);
		transition: background-color 0.15s ease;

		&:hover {
			background-color: rgba(61, 80, 245, 0.08);
		}

		:global([data-theme='dark']) & {
			&:hover {
				background-color: rgba(120, 140, 220, 0.12);
			}
		}
	}
</style>
