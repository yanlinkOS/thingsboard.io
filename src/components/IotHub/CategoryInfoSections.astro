---
import { getCategorySections } from '@data/iot-hub/sections';
import SectionAbout from '@components/IotHub/SectionAbout.astro';
import SectionFeatureList from '@components/IotHub/SectionFeatureList.astro';
import SectionHowItWorks from '@components/IotHub/SectionHowItWorks.astro';
import SectionTable from '@components/IotHub/SectionTable.astro';

interface Props {
	categorySlug: string;
}

const { categorySlug } = Astro.props;
const info = getCategorySections(categorySlug)?.info;

// Compile-time exhaustiveness: adding a new InfoBlock kind without a renderer
// below makes this fail to typecheck instead of silently rendering nothing.
function assertNever(block: never): never {
	throw new Error(`Unhandled info block kind: ${JSON.stringify(block)}`);
}
---

{
	info && info.length > 0 && (
		<div class="ih-info">
			{info.map((block) =>
				block.kind === 'prose' ? (
					<SectionAbout heading={block.heading} body={block.body} />
				) : block.kind === 'bullets' ? (
					<SectionFeatureList heading={block.heading} intro={block.intro} items={block.items} />
				) : block.kind === 'table' ? (
					<SectionTable
						heading={block.heading}
						intro={block.intro}
						columns={block.columns}
						rows={block.rows}
					/>
				) : block.kind === 'steps' ? (
					<SectionHowItWorks
						heading={block.heading}
						intro={block.intro}
						steps={block.steps}
						cta={block.cta}
					/>
				) : (
						assertNever(block)
					)
			)}
		</div>
	)
}

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.ih-info {
		display: flex;
		flex-direction: column;
		gap: 64px;
		padding: 80px 16px;

		@include media-down(sm) {
			gap: 48px;
			padding: 56px 12px;
		}
	}
</style>
