---
import { IOT_HUB_API_URL } from '@models/iot-hub';

// Inline script that publishes the server-side IOT_HUB_API_URL value to
// the client via `window.__IOT_HUB_API_URL`. The model's runtime check
// (see @models/iot-hub.ts) then exposes the same `IOT_HUB_API_URL` value
// to bundled client scripts as it does to server-side code.
//
// Drop this once on any page (or layout) that runs client-side fetches
// against the IoT Hub API. It needs to be in <head> BEFORE any bundled
// module scripts so the global is set when modules first evaluate.
//
// Why this exists: Vite only inlines env vars prefixed `PUBLIC_*` into the
// client bundle. Keeping the var name as `IOT_HUB_API_URL` (no prefix) plus
// this inline script avoids a duplicate `PUBLIC_*` env var and keeps the
// value in one place in deployment config.
---

<script is:inline define:vars={{ apiUrl: IOT_HUB_API_URL }}>
	window.__IOT_HUB_API_URL = apiUrl;
</script>
