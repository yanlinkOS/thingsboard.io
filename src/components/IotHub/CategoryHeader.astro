---
interface Props {
	categoryLabel: string;
	totalCount: number;
}

const { categoryLabel, totalCount } = Astro.props;
---

<header class="iot-hub-category-header">
	<nav class="iot-hub-category-header__breadcrumb" aria-label="Breadcrumb">
		<a href="/iot-hub/">IoT Hub</a>
		<span aria-hidden="true">/</span>
		<span class="iot-hub-category-header__current">{categoryLabel}</span>
	</nav>
	<h1 class="iot-hub-category-header__title">{categoryLabel}</h1>
	<p class="iot-hub-category-header__count">
		{totalCount} {totalCount === 1 ? 'item' : 'items'}
	</p>
</header>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-category-header {
		padding: 2rem 0 1.5rem;
	}

	.iot-hub-category-header__breadcrumb {
		font-size: 0.875rem;
		display: flex;
		gap: 0.5rem;
		align-items: center;
		margin-bottom: 0.75rem;
		color: var(--color-text-muted, #6b7280);

		a {
			color: var(--color-accent, #305680);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}

	.iot-hub-category-header__title {
		font-size: 2rem;
		font-weight: 700;
		margin: 0 0 0.5rem;
	}

	.iot-hub-category-header__count {
		color: var(--color-text-muted, #6b7280);
		margin: 0;
	}
</style>
