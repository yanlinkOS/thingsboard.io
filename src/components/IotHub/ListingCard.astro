---
import {
	getCardVariant,
	getPlaceholderIcon,
	resolveImage,
	type ListingView,
} from '@models/iot-hub';
import IotHubIcon from './IotHubIcon.astro';
// Self-hosted Material Icons font — used for `verified`, `person`, `download`
// on every card. Compact-card placeholder glyphs are rendered via IotHubIcon.
import '@fontsource/material-icons';

interface Props {
	item: ListingView;
	categorySlug: string;
}

const { item, categorySlug } = Astro.props;
const { name, image, color, creatorDisplayName, creatorVerified, installCount, itemType, slug } =
	item;
const href = `/iot-hub/${categorySlug}/${slug}/`;
const author = creatorDisplayName ?? 'ThingsBoard';
const cta = itemType === 'DEVICE' ? 'Connect' : 'Install';
const isCompact = getCardVariant(itemType) === 'small';

const imageUrl = isCompact ? null : resolveImage(image);

const tileColor = color ?? '#4caf50';
// `mdi:foo` icons are fetched + inlined as SVG by IotHubIcon; bare names
// (e.g. `widgets`) render as Material Icons font glyphs.
const placeholderIcon = getPlaceholderIcon(item);
---

<a
	class:list={[
		'iot-hub-card',
		isCompact ? 'iot-hub-card--compact' : 'iot-hub-card--big',
		itemType === 'DEVICE' && 'iot-hub-card--device',
	]}
	href={href}
>
	{
		isCompact ? (
			<div
				class="iot-hub-card__icon"
				style={`background:${tileColor};`}
				aria-hidden="true"
			>
				<IotHubIcon icon={placeholderIcon} size={32} class="iot-hub-card__icon-glyph" />
			</div>
		) : (
			<div class="iot-hub-card__preview">
				{imageUrl ? (
					<img
						src={imageUrl}
						alt={name}
						width="305"
						height="172"
						loading="lazy"
						decoding="async"
					/>
				) : (
					<div class="iot-hub-card__preview-fallback" aria-hidden="true" />
				)}
			</div>
		)
	}
	<div class="iot-hub-card__body">
		<h3 class="iot-hub-card__title">{name}</h3>
		<div class="iot-hub-card__footer">
			<div class="iot-hub-card__author">
				<span
					class:list={[
						'material-icons',
						'iot-hub-card__author-icon',
						creatorVerified && 'iot-hub-card__author-icon--verified',
					]}
					aria-hidden="true"
				>
					{creatorVerified ? 'verified' : 'person'}
				</span>
				<span class="iot-hub-card__author-name">{author}</span>
			</div>
			<span class="iot-hub-card__dot" aria-hidden="true"></span>
			<div class="iot-hub-card__installs" title={`${installCount} installs`}>
				<span class="material-icons iot-hub-card__install-icon" aria-hidden="true">download</span>
				<span>{installCount}</span>
			</div>
			{!isCompact && <button type="button" class="iot-hub-card__cta">{cta}</button>}
		</div>
	</div>
	{isCompact && <button type="button" class="iot-hub-card__cta">{cta}</button>}
</a>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-card {
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		transition: transform $transition-fast, box-shadow $transition-fast, border-color $transition-fast;

		&:hover {
			transform: translateY(-2px);
			box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
			border-color: var(--color-border-light);
		}

		[data-theme='dark'] &:hover {
			box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
		}
	}

	// --- Big layout (preview image on top) ---------------------------------

	.iot-hub-card--big {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		overflow: hidden;
	}

	.iot-hub-card__preview {
		position: relative;
		aspect-ratio: 305 / 172;
		width: 100%;
		min-height: 141px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 10px;
		background: var(--color-bg-light);
		border-bottom: 1px solid var(--color-border);
		overflow: hidden;

		.iot-hub-card--device & {
			background: #fff;
		}

		img {
			max-width: 100%;
			max-height: 100%;
			width: auto;
			height: auto;
			object-fit: contain;
			display: block;
		}
	}

	.iot-hub-card__preview-fallback {
		width: 100%;
		height: 100%;
		background: linear-gradient(
			135deg,
			var(--color-bg-light) 0%,
			var(--color-bg-muted) 100%
		);
	}

	.iot-hub-card--big .iot-hub-card__body {
		padding: 0 1rem 1rem;
	}

	// --- Compact layout (colored tile on the left) -------------------------

	.iot-hub-card--compact {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1rem;
		min-height: 106px;
		min-width: 0;

		&:hover {
			transform: translateY(-1px);
			box-shadow: 0 6px 16px rgba(0, 0, 0, 0.06);
		}

		[data-theme='dark'] &:hover {
			box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
		}
	}

	.iot-hub-card__icon {
		flex-shrink: 0;
		width: 72px;
		height: 72px;
		border-radius: 6px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #fff;
	}

	// IotHubIcon controls its own width/height/font-size via the `size` prop;
	// this class is just a hook for any future per-card overrides.
	.iot-hub-card__icon-glyph {
		line-height: 1;
	}

	// Material Icons font ships glyphs via `liga` substitution — the element's
	// text content (e.g. "widgets") is rendered as the icon. `@font-face` is
	// registered by the `@fontsource/material-icons` import at the top.
	.material-icons {
		font-family: 'Material Icons';
		font-weight: normal;
		font-style: normal;
		letter-spacing: normal;
		text-transform: none;
		display: inline-block;
		white-space: nowrap;
		word-wrap: normal;
		direction: ltr;
		font-feature-settings: 'liga';
		-webkit-font-smoothing: antialiased;
	}

	.iot-hub-card--compact .iot-hub-card__body {
		flex: 1;
		min-width: 0;
	}

	// --- Body / shared -----------------------------------------------------

	.iot-hub-card__body {
		display: flex;
		flex-direction: column;
		gap: 4px;
		min-width: 0;
	}

	.iot-hub-card__title {
		font-size: 16px;
		font-weight: $font-weight-semibold;
		line-height: 28px;
		margin: 0;
		color: var(--color-text);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.iot-hub-card__footer {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		line-height: 16px;
		color: var(--color-text-muted);
		min-width: 0;
	}

	.iot-hub-card__author {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		min-width: 0;
	}

	.iot-hub-card__author-icon,
	.iot-hub-card__install-icon {
		font-size: 16px;
	}

	.iot-hub-card__author-icon {
		flex-shrink: 0;
		color: var(--color-text-muted);
	}

	.iot-hub-card__author-icon--verified {
		color: var(--color-primary);
	}

	.iot-hub-card__author-name {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		color: var(--sl-color-gray-3);
	}

	.iot-hub-card__dot {
		flex-shrink: 0;
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--sl-color-gray-5);
	}

	.iot-hub-card__installs {
		display: inline-flex;
		align-items: center;
		gap: 2px;
		flex-shrink: 0;
		color: var(--sl-color-gray-3);
	}

	.iot-hub-card__cta {
		margin-left: auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 4px 8px;
		font-family: inherit;
		font-size: 14px;
		font-weight: $font-weight-medium;
		line-height: 24px;
		border: 1px solid var(--color-border);
		border-radius: 4px;
		color: var(--color-primary);
		background: transparent;
		flex-shrink: 0;
		cursor: pointer;

		&:hover {
			border-color: var(--color-primary);
		}
	}
</style>
