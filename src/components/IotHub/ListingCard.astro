---
import {
	formatInstallCount,
	formatInstalls,
	getCardVariant,
	getCreatorHref,
	getPlaceholderIcon,
	resolveImage,
	type ListingView,
} from '@models/iot-hub';
import IotHubIcon from './IotHubIcon.astro';
import '@fontsource/material-icons'; // `verified`, `person`, `download` glyphs
import InstallButton from '@components/IotHub/InstallButton.astro';

interface Props {
	item: ListingView;
	categorySlug: string;
	/** When false, hide the creator row entirely (used on the creator's own page). */
	showCreator?: boolean;
}

const { item, categorySlug, showCreator = true } = Astro.props;
const { name, image, color, creatorId, creatorDisplayName, creatorVerified, installCount, itemType, slug } =
	item;
const href = `/iot-hub/${categorySlug}/${slug}/`;
const author = creatorDisplayName ?? 'ThingsBoard';
const creatorHref = creatorId ? getCreatorHref(creatorId) : null;
const isCompact = getCardVariant(itemType) === 'small';

const imageUrl = isCompact ? null : resolveImage(image);

const tileColor = color ?? '#4caf50';
const placeholderIcon = getPlaceholderIcon(item);
---

<a
	class:list={[
		'iot-hub-card',
		isCompact ? 'iot-hub-card--compact' : 'iot-hub-card--big',
	]}
	href={href}
	data-card-root
>
	{
		isCompact ? (
			<div
				class="iot-hub-card__icon"
				style={`background:${tileColor};`}
				aria-hidden="true"
				data-card-icon-tile
			>
				<IotHubIcon icon={placeholderIcon} size={32} class="iot-hub-card__icon-glyph" />
			</div>
		) : (
			<div class="iot-hub-card__preview">
				<img
					src={imageUrl ?? undefined}
					alt={name}
					width="305"
					height="172"
					loading="lazy"
					decoding="async"
					data-card-img
					hidden={!imageUrl}
				/>
				<div
					class="iot-hub-card__preview-fallback"
					aria-hidden="true"
					data-card-img-fallback
					hidden={!!imageUrl}
				/>
			</div>
		)
	}
	<div class="iot-hub-card__body">
		<h3 class="iot-hub-card__title" data-card-title>{name}</h3>
		<div class="iot-hub-card__footer">
			{/* Wrapped so the binder can hide author + dot together. */}
			<span
				class="iot-hub-card__author-wrap"
				data-card-author-wrap
				hidden={!(showCreator && creatorDisplayName)}
			>
				<span
					class:list={['iot-hub-card__author', creatorHref && 'iot-hub-card__author--link']}
					role={creatorHref ? 'link' : undefined}
					tabindex={creatorHref ? 0 : undefined}
					data-creator-href={creatorHref ?? undefined}
					title={creatorHref ? author : undefined}
					data-card-author
				>
					<span
						class:list={[
							'material-icons',
							'iot-hub-card__author-icon',
							creatorVerified && 'iot-hub-card__author-icon--verified',
						]}
						aria-hidden="true"
						data-card-author-icon
					>
						{creatorVerified ? 'verified' : 'person'}
					</span>
					<span class="iot-hub-card__author-name" data-card-author-name>{author}</span>
				</span>
				<span class="iot-hub-card__dot" aria-hidden="true" />
			</span>
			<div
				class="iot-hub-card__installs"
				title={formatInstalls(installCount)}
				data-card-installs-wrap
			>
				<span class="material-icons iot-hub-card__install-icon" aria-hidden="true">download</span>
				<span data-card-installs>{formatInstallCount(installCount)}</span>
			</div>
			{!isCompact && (
				<InstallButton
					slug={slug}
					itemType={itemType}
					name={name}
					affiliateId={item.creatorAffiliateId}
					variant="card"
				/>
			)}
		</div>
	</div>
	{isCompact && (
		<InstallButton
			slug={slug}
			itemType={itemType}
			name={name}
			affiliateId={item.creatorAffiliateId}
			variant="card"
		/>
	)}
</a>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;
	@use '../../styles/_iot-hub.scss' as *;

	.iot-hub-card {
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		transition: transform $transition-fast, box-shadow $transition-fast, border-color $transition-fast;

		&:hover {
			transform: translateY(-2px);
			box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
			border-color: var(--color-border-light);
		}

		[data-theme='dark'] &:hover {
			box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
		}
	}

	// --- Big variant ---------------------------------------------------------
	.iot-hub-card--big {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		overflow: hidden;
	}

	.iot-hub-card__preview {
		position: relative;
		aspect-ratio: 305 / 172;
		width: 100%;
		min-height: 141px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 10px;
		background: var(--color-bg-light);
		border-bottom: 1px solid var(--color-border);
		overflow: hidden;

		img {
			max-width: 100%;
			max-height: 100%;
			width: auto;
			height: auto;
			object-fit: contain;
			display: block;

			// Specificity guard so the `hidden` attribute beats `display: block`.
			&[hidden] {
				display: none;
			}
		}
	}

	.iot-hub-card__preview-fallback {
		width: 100%;
		height: 100%;
		background: linear-gradient(
			135deg,
			var(--color-bg-light) 0%,
			var(--color-bg-muted) 100%
		);

		&[hidden] {
			display: none;
		}
	}

	.iot-hub-card--big .iot-hub-card__body {
		padding: 0 1rem 1rem;
	}

	// --- Compact variant -----------------------------------------------------
	.iot-hub-card--compact {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1rem;
		min-height: 106px;
		min-width: 0;

		&:hover {
			transform: translateY(-1px);
			box-shadow: 0 6px 16px rgba(0, 0, 0, 0.06);
		}

		[data-theme='dark'] &:hover {
			box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
		}
	}

	.iot-hub-card__icon {
		flex-shrink: 0;
		width: 72px;
		height: 72px;
		border-radius: 6px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #fff;
	}

	// Hook for any future per-card icon-glyph overrides.
	.iot-hub-card__icon-glyph {
		line-height: 1;
	}

	.material-icons {
		@include iot-hub-material-icon;
		display: inline-block;
	}

	.iot-hub-card--compact .iot-hub-card__body {
		flex: 1;
		min-width: 0;
	}

	// --- Shared body ---------------------------------------------------------
	.iot-hub-card__body {
		display: flex;
		flex-direction: column;
		gap: 4px;
		min-width: 0;
	}

	.iot-hub-card__title {
		font-size: 16px;
		font-weight: $font-weight-semibold;
		line-height: 28px;
		margin: 0;
		color: var(--color-text);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.iot-hub-card__footer {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		line-height: 16px;
		color: var(--color-text-muted);
		min-width: 0;
	}

	// Author block + dot grouped so the binder hides both at once.
	// `&[hidden]` (0,2,0) beats the `display: inline-flex` (0,1,0) below.
	.iot-hub-card__author-wrap {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		min-width: 0;

		&[hidden] {
			display: none;
		}
	}

	.iot-hub-card__author {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		min-width: 0;
	}

	.iot-hub-card__author--link {
		cursor: pointer;
		border-radius: 4px;

		&:hover .iot-hub-card__author-name,
		&:focus-visible .iot-hub-card__author-name {
			color: var(--color-text);
			text-decoration: underline;
		}

		&:focus-visible {
			outline: 2px solid var(--color-primary);
			outline-offset: 2px;
		}
	}

	.iot-hub-card__author-icon,
	.iot-hub-card__install-icon {
		font-size: 16px;
	}

	.iot-hub-card__author-icon {
		flex-shrink: 0;
		color: var(--color-text-muted);
	}

	.iot-hub-card__author-icon--verified {
		color: var(--color-primary);
	}

	.iot-hub-card__author-name {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		color: var(--sl-color-gray-3);
	}

	.iot-hub-card__dot {
		flex-shrink: 0;
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--sl-color-gray-5);
	}

	.iot-hub-card__installs {
		display: inline-flex;
		align-items: center;
		gap: 2px;
		flex-shrink: 0;
		color: var(--sl-color-gray-3);
	}

</style>

<script>
	// Creator span (role="link") navigates to the creator page; the card
	// root <a> handles its own navigation. Delegated on `document` so the
	// handler also covers JS-cloned cards from the dynamic-search pipeline.
	function navigateToCreator(e: Event): void {
		const target = e.target as Element | null;
		const el = target?.closest<HTMLElement>('[data-creator-href]');
		if (!el) return;
		const href = el.dataset.creatorHref;
		if (!href) return;
		e.preventDefault();
		e.stopPropagation();
		window.location.href = href;
	}

	document.addEventListener('click', navigateToCreator);
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Enter' || e.key === ' ') navigateToCreator(e);
	});
</script>
