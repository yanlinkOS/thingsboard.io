---
import type { CollectionEntry } from 'astro:content';
import { resolveImage } from '~/models/iot-hub';

interface Props {
	entry: CollectionEntry<'iotHubListings'>;
	categorySlug: string;
}

const { entry, categorySlug } = Astro.props;
const { name, image, creatorDisplayName, creatorVerified, installCount, itemType } = entry.data;
const imageUrl = resolveImage(image);
const href = `/iot-hub/${categorySlug}/${entry.data.slug}/`;
const cta = itemType === 'DEVICE' ? 'Connect' : 'Install';
const author = creatorDisplayName ?? 'ThingsBoard';
---

<a class="iot-hub-card" href={href}>
	<div class="iot-hub-card__image">
		{
			imageUrl ? (
				<img src={imageUrl} alt={name} loading="lazy" decoding="async" />
			) : (
				<div class="iot-hub-card__image-fallback" aria-hidden="true" />
			)
		}
	</div>
	<div class="iot-hub-card__body">
		<h3 class="iot-hub-card__title">{name}</h3>
		<div class="iot-hub-card__meta">
			<div class="iot-hub-card__author">
				{
					creatorVerified ? (
						<svg
							class="iot-hub-card__author-icon iot-hub-card__author-icon--verified"
							width="16"
							height="16"
							viewBox="0 0 16 16"
							fill="none"
							aria-hidden="true"
						>
							<path
								d="m8 1.333 2.04 1.5 2.527-.234.234 2.527 1.5 2.04-1.5 2.041-.234 2.527-2.527.234L8 13.467l-2.04-1.5-2.527-.234-.234-2.527-1.5-2.041 1.5-2.04.234-2.527 2.527.234L8 1.333Z"
								fill="var(--color-primary)"
							/>
							<path
								d="m5.667 8 1.666 1.667L10.667 6.333"
								stroke="#fff"
								stroke-width="1.4"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					) : (
						<svg
							class="iot-hub-card__author-icon"
							width="16"
							height="16"
							viewBox="0 0 16 16"
							fill="none"
							aria-hidden="true"
						>
							<path
								d="M8 8.667a2.667 2.667 0 1 0 0-5.334 2.667 2.667 0 0 0 0 5.334ZM3.333 13.333a4.667 4.667 0 0 1 9.334 0"
								stroke="currentColor"
								stroke-width="1.3"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					)
				}
				<span class="iot-hub-card__author-name">{author}</span>
			</div>
			<span class="iot-hub-card__dot" aria-hidden="true"></span>
			<div class="iot-hub-card__installs" title={`${installCount} installs`}>
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
					<path
						d="M8 2v8.667M4.667 7.333 8 10.667l3.333-3.334M2.667 13.333h10.666"
						stroke="currentColor"
						stroke-width="1.3"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
				<span>{installCount}</span>
			</div>
		</div>
		<span class="iot-hub-card__cta">{cta}</span>
	</div>
</a>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-card {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding-bottom: 1rem;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition: transform $transition-fast, box-shadow $transition-fast, border-color $transition-fast;

		&:hover {
			transform: translateY(-2px);
			box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
			border-color: var(--color-border-light);
			text-decoration: none;
		}

		[data-theme='dark'] &:hover {
			box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
		}
	}

	.iot-hub-card__image {
		position: relative;
		aspect-ratio: 305 / 172;
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 10px;
		background: var(--color-bg-light);
		border-bottom: 1px solid var(--color-border);
		overflow: hidden;

		img {
			max-width: 100%;
			max-height: 100%;
			width: 100%;
			height: 100%;
			object-fit: contain;
			display: block;
		}
	}

	.iot-hub-card__image-fallback {
		width: 100%;
		height: 100%;
		background: linear-gradient(
			135deg,
			var(--color-bg-light) 0%,
			var(--color-bg-muted) 100%
		);
	}

	.iot-hub-card__body {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 0 1rem;
		position: relative;
	}

	.iot-hub-card__title {
		font-size: 16px;
		font-weight: $font-weight-semibold;
		line-height: 28px;
		margin: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		color: var(--color-text);
	}

	.iot-hub-card__meta {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		line-height: 16px;
		color: var(--color-text-muted);
	}

	.iot-hub-card__author {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		min-width: 0;
	}

	.iot-hub-card__author-icon {
		flex-shrink: 0;
		color: var(--color-text-muted);
	}

	.iot-hub-card__author-name {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.iot-hub-card__dot {
		flex-shrink: 0;
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--color-border);
	}

	.iot-hub-card__installs {
		display: inline-flex;
		align-items: center;
		gap: 2px;
		flex-shrink: 0;
	}

	.iot-hub-card__cta {
		position: absolute;
		right: 1rem;
		bottom: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 4px 8px;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		border: 1px solid var(--color-border);
		border-radius: 4px;
		color: var(--color-primary);
		background: transparent;

		.iot-hub-card:hover & {
			border-color: var(--color-primary);
		}
	}
</style>
