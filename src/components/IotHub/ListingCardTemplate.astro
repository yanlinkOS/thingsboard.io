---
import { type IotHubItemType, type ListingView } from '@models/iot-hub';
import ListingCard from './ListingCard.astro';

// Pattern C clone source for runtime listing-card rendering.
//
// Drop one per variant ('big' for DEVICE / WIDGET / SOLUTION_TEMPLATE,
// 'compact' for CALCULATED_FIELD / ALARM_RULE / RULE_CHAIN) on any page
// that renders cards dynamically. The search page emits both variants so
// the JS pipeline can clone the right one per item via
// `getCardVariant(item.itemType)`.
//
// Usage:
//     <ListingCardTemplate variant="big" />
//     <ListingCardTemplate variant="compact" />
//
//     const tmpl = document.querySelector<HTMLTemplateElement>(
//         '[data-listing-card-tmpl][data-variant="big"]'
//     );
//     const clone = tmpl.content.firstElementChild!.cloneNode(true) as HTMLElement;
//     bindListingCard(clone, item, categorySlug, /* showCreator */ true);
//
// The template renders a ListingCard with a placeholder item that has the
// same field types the binder will overwrite — that way the cloned DOM
// shape (number of children, class list, attribute presence) is identical
// to a build-time card, and Astro's scoped style hashes apply uniformly.

interface Props {
	variant: 'big' | 'compact';
	titleAs?: 'h2' | 'h3';
}

const { variant, titleAs = 'h3' } = Astro.props;

// Per-variant placeholder item. Item-type drives the variant inside
// ListingCard (via getCardVariant), so pick a representative item-type
// for each. Other fields are filled by the binder.
const placeholderItemType: IotHubItemType = variant === 'big' ? 'WIDGET' : 'CALCULATED_FIELD';
const placeholderItem = {
	slug: '',
	itemType: placeholderItemType,
	name: '',
	creatorId: null,
	description: null,
	image: null,
	icon: null,
	color: null,
	seoTitle: null,
	seoMetaDescription: null,
	ogImage: null,
	categories: [],
	useCases: [],
	cfType: null,
	widgetType: null,
	ruleChainType: null,
	hardwareType: null,
	vendor: null,
	connectivity: [],
	tags: [],
	installCount: 0,
	createdTime: null,
	updatedTime: null,
	publishedTime: null,
	creatorDisplayName: null,
	creatorAvatarUrl: null,
	creatorVerified: false,
	creatorAffiliateId: null,
	screenshots: [],
} satisfies ListingView;
---

<template data-listing-card-tmpl data-variant={variant}>
	<ListingCard
		item={placeholderItem}
		categorySlug=""
		showCreator={true}
		titleAs={titleAs}
	/>
</template>
