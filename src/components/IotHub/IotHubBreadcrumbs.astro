---
import IotHubChevron from './IotHubChevron.astro';

// Shared breadcrumb row for IoT Hub pages. The component owns only the
// inline row (chrome + separators); parents own the surrounding layout
// (header-clearance padding, gaps to sibling sections) so each page can
// keep its own vertical rhythm.

interface Crumb {
	label: string;
	/** Render as `<a href>` when set; otherwise as the current-page span. */
	href?: string;
}

interface Props {
	items: Crumb[];
	/** Allow the row to wrap on narrow viewports (DetailHero needs this
	 *  with three crumbs on small screens). */
	wrap?: boolean;
}

const { items, wrap = false } = Astro.props;
---

<nav
	class:list={['iot-hub-breadcrumbs', wrap && 'iot-hub-breadcrumbs--wrap']}
	aria-label="Breadcrumb"
>
	{items.map((crumb, i) => (
		<Fragment>
			{i > 0 && <IotHubChevron direction="right" class="iot-hub-breadcrumbs__sep" />}
			{crumb.href ? (
				<a class="iot-hub-breadcrumbs__link" href={crumb.href}>{crumb.label}</a>
			) : (
				<span class="iot-hub-breadcrumbs__current" aria-current="page">{crumb.label}</span>
			)}
		</Fragment>
	))}
</nav>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-breadcrumbs {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 16px;
		line-height: 28px;
		color: var(--color-text-secondary);
	}

	.iot-hub-breadcrumbs--wrap {
		flex-wrap: wrap;
	}

	.iot-hub-breadcrumbs__link {
		color: var(--color-primary);
		text-decoration: none;
		transition: color $transition-fast;

		&:hover,
		&:focus-visible {
			text-decoration: underline;
		}

		:global([data-theme='dark']) & {
			color: #b3c7ff;
		}
	}

	.iot-hub-breadcrumbs__sep {
		color: var(--color-text-muted);
		flex-shrink: 0;
	}

	.iot-hub-breadcrumbs__current {
		color: var(--color-text-secondary);
		font-weight: $font-weight-normal;
	}
</style>
