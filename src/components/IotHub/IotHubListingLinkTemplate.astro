---
import IotHubListingLink from './IotHubListingLink.astro';

// Pattern C clone source for runtime listing-card rendering.
//
// Drop one of these on any page that needs to instantiate listing cards
// dynamically (the search popup in IotHubHero, the upcoming dynamic
// category filter, …). Then in client script:
//
//     const tmpl = document.querySelector(
//         '[data-iot-hub-listing-link-tmpl]'
//     ) as HTMLTemplateElement;
//     const clone = tmpl.content.firstElementChild!.cloneNode(true) as HTMLElement;
//     bindListingLink(clone, item);
//     container.appendChild(clone);
//
// The cloned card carries IotHubListingLink's scoped style hashes on every
// element, so the styles defined in IotHubListingLink.astro apply to the
// runtime instance the same way they do to the build-time one.
//
// `variant` controls the chrome of the rendered template — pass 'row' for
// flush list contexts (popup, full-width grid) or omit for the default
// 360px bordered card.

interface Props {
	variant?: 'card' | 'row';
}

const { variant = 'card' } = Astro.props;
---

<template data-iot-hub-listing-link-tmpl>
	<IotHubListingLink variant={variant} />
</template>
