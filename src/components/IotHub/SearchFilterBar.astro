---
import { IOT_HUB_STRINGS, SEARCH_PAGE_SIZE } from '@models/iot-hub';
import IotHubSort from './IotHubSort.astro';
import PaginationBar from '@components/Pagination/PaginationBar.astro';

const T = IOT_HUB_STRINGS.searchPage;

interface Props {
	/** Static heading text. */
	heading: string;
	/** When set, the heading swaps to `${headingPrefix} "{q}"` on non-empty
	 *  input (and back to `heading` when emptied). Omit for a static heading. */
	headingPrefix?: string;
	/** Initial query text — always empty at build time; the hydrate script
	 *  picks `?q=` from the URL on the client. */
	searchText?: string;
	searchPlaceholder?: string;
	perPage?: number;
	paginationVariant?: 'centered' | 'right';
	totalResults: number;
	currentPage: number;
	totalPages: number;
	basePath: string;
}

const {
	heading,
	headingPrefix,
	searchText = '',
	searchPlaceholder = T.searchPlaceholder,
	perPage = SEARCH_PAGE_SIZE,
	paginationVariant = 'right',
	totalResults,
	currentPage,
	totalPages,
	basePath,
} = Astro.props;
const resultsWord = totalResults === 1 ? T.resultSingular : T.resultPlural;
const dynamicHeading = !!headingPrefix && searchText.length > 0;
---

<div
	class="search-bar"
	data-iot-hub-search-bar
	data-heading={heading}
	data-heading-prefix={headingPrefix ?? ''}
>
	<h2 class="search-bar__heading" data-search-heading>
		{dynamicHeading ? (
			<Fragment>
				{headingPrefix} &ldquo;<span data-search-query>{searchText}</span>&rdquo;
			</Fragment>
		) : (
			heading
		)}
	</h2>
	<div class="search-bar__filters">
		<div class="search-bar__row1">
			<div class="search-bar__search">
				<input
					class="search-bar__search-input"
					type="search"
					name="q"
					value={searchText}
					placeholder={searchPlaceholder}
					aria-label={searchPlaceholder}
					autocomplete="off"
					data-search-input
				/>
				<span class="search-bar__search-glyph" aria-hidden="true"></span>
				<button
					class="search-bar__search-clear"
					type="button"
					aria-label="Clear search"
					data-search-clear
				>
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path
							d="M5 5 19 19M19 5 5 19"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"></path>
					</svg>
				</button>
			</div>
			<IotHubSort />
		</div>
		<div class="search-bar__row2">
			<p class="search-bar__count" data-search-count>{totalResults} {resultsWord}</p>
			{totalPages > 1 && (
				<PaginationBar
					currentPage={currentPage}
					totalPages={totalPages}
					basePath={basePath}
					perPage={perPage}
					idBase={basePath}
					variant={paginationVariant}
				/>
			)}
		</div>
	</div>
</div>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.search-bar {
		display: flex;
		flex-direction: column;
		gap: 24px;
		padding: 40px 16px 0;

		@include media-down(sm) {
			padding: 40px 12px 0;
		}
	}

	.search-bar__heading {
		margin: 0;
		font-size: 24px;
		font-weight: $font-weight-semibold;
		line-height: 28px;
		color: var(--color-text);
	}

	.search-bar__filters {
		display: flex;
		flex-direction: column;
		gap: 16px;
		width: 100%;
	}

	.search-bar__row1 {
		display: flex;
		gap: 16px;
		align-items: center;

		@include media-down(sm) {
			gap: 8px;
		}
	}

	.search-bar__search {
		flex: 1 1 0;
		min-width: 0;
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 8px 16px;
		min-height: 56px;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;

		:global([data-theme='dark']) & {
			border-color: #353841;
		}
	}

	.search-bar__search-input {
		flex: 1 1 0;
		min-width: 0;
		border: none;
		outline: none;
		background: transparent;
		font-family: inherit;
		font-size: 16px;
		line-height: 28px;
		color: var(--color-text);

		&::placeholder { color: var(--color-text-muted); }

		// Hide the UA `×` so only the custom clear button below shows.
		&::-webkit-search-cancel-button,
		&::-webkit-search-decoration {
			-webkit-appearance: none;
			appearance: none;
		}
	}

	.search-bar__search-glyph {
		flex-shrink: 0;
		width: 24px;
		height: 24px;
		background-color: var(--color-text-secondary);
		-webkit-mask: url('/icons/iot-hub-search.svg') center / contain no-repeat;
		mask: url('/icons/iot-hub-search.svg') center / contain no-repeat;
	}

	.search-bar__search-clear {
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		padding: 0;
		border: none;
		background: transparent;
		color: var(--color-text-secondary);
		cursor: pointer;
		transition: color $transition-fast;

		&:hover,
		&:focus-visible {
			color: var(--color-text);
		}

		svg { display: block; }
	}

	// Toggle glyph vs clear button by input state.
	.search-bar__search-input:placeholder-shown ~ .search-bar__search-clear {
		display: none;
	}

	.search-bar__search-input:not(:placeholder-shown) ~ .search-bar__search-glyph {
		display: none;
	}

	.search-bar__row2 {
		display: flex;
		align-items: center;
		gap: 16px;
		min-height: 40px;
	}

	.search-bar__count {
		flex-shrink: 0;
		margin: 0;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: var(--color-text);
	}

	.search-bar__row2 :global(.tb-pagination-bar) {
		flex: 1 1 0;
	}
</style>

<script>
	import { initSearchBars } from './iot-hub-search-bar-init';
	initSearchBars();
</script>
