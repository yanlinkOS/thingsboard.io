---
import type { ListingDetail } from '~/models/iot-hub';
import { resolveImage } from '~/models/iot-hub';

interface Props {
	detail: ListingDetail;
}

const { detail } = Astro.props;
const heroImg = resolveImage(detail.image);
const placeholderBg = detail.color ?? '#e5e7eb';
---

<header class="iot-hub-detail-hero">
	<div class="iot-hub-detail-hero__image" style={`background-color: ${placeholderBg};`}>
		{heroImg ? <img src={heroImg} alt={detail.name} decoding="async" /> : null}
	</div>
	<div class="iot-hub-detail-hero__meta">
		<p class="iot-hub-detail-hero__title">{detail.name}</p>
		{detail.description ? <p class="iot-hub-detail-hero__desc">{detail.description}</p> : null}
		<dl class="iot-hub-detail-hero__stats">
			{
				detail.creatorDisplayName ? (
					<>
						<dt>By</dt>
						<dd>
							{detail.creatorDisplayName}
							{detail.creatorVerified ? <span aria-label="Verified creator">✓</span> : null}
						</dd>
					</>
				) : null
			}
			<dt>Installs</dt>
			<dd>{detail.installCount.toLocaleString('en-US')}</dd>
		</dl>
	</div>
</header>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-detail-hero {
		display: grid;
		grid-template-columns: minmax(0, 360px) 1fr;
		gap: 2rem;
		margin: 2rem 0;

		@media (max-width: 640px) {
			grid-template-columns: 1fr;
		}
	}

	.iot-hub-detail-hero__image {
		aspect-ratio: 4 / 3;
		border-radius: 12px;
		overflow: hidden;
		display: grid;
		place-items: center;

		img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
		}
	}

	.iot-hub-detail-hero__meta {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.iot-hub-detail-hero__title {
		font-size: 2rem;
		font-weight: $font-weight-bold;
		margin: 0;
	}

	.iot-hub-detail-hero__desc {
		font-size: 1rem;
		line-height: 1.6;
		color: var(--color-text-muted, #6b7280);
		margin: 0;
	}

	.iot-hub-detail-hero__stats {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.25rem 0.75rem;
		font-size: 0.875rem;
		margin: 0.5rem 0 0;

		dt {
			color: var(--color-text-muted, #6b7280);
		}

		dd {
			margin: 0;
		}
	}
</style>
