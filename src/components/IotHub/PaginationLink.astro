---
import { PAGE_SIZE, IOT_HUB_STRINGS, formatPageSummary } from '@models/iot-hub';
import Chevron from '@components/Chevron.astro';
import IotHubIcon from './IotHubIcon.astro';
import PaginationChevron from './PaginationChevron.astro';

interface Props {
	currentPage: number;
	totalPages: number;
	basePath: string;
	/** Items-per-page value shown in the (decorative) selector. */
	perPage?: number;
	/**
	 * Layout variant:
	 *   - 'centered' (default) — page-numbers centred, items-per-page
	 *     absolutely pinned to the right edge.
	 *   - 'right' — everything right-aligned in a single flex row, items-
	 *     per-page sits inline after the page numbers.
	 */
	variant?: 'centered' | 'right';
}

const {
	currentPage,
	totalPages,
	basePath,
	perPage = PAGE_SIZE,
	variant = 'centered',
} = Astro.props;

const pageUrl = (n: number): string => (n === 1 ? basePath : `${basePath}${n}/`);

function buildPages(current: number, total: number): Array<number | 'ellipsis'> {
	if (total <= 7) {
		return Array.from({ length: total }, (_, i) => i + 1);
	}
	const result: Array<number | 'ellipsis'> = [1];
	if (current > 3) result.push('ellipsis');
	for (let p = Math.max(2, current - 1); p <= Math.min(total - 1, current + 1); p++) {
		result.push(p);
	}
	if (current < total - 2) result.push('ellipsis');
	result.push(total);
	return result;
}

const items = buildPages(currentPage, totalPages);
const prevHref = currentPage > 1 ? pageUrl(currentPage - 1) : undefined;
const nextHref = currentPage < totalPages ? pageUrl(currentPage + 1) : undefined;

// Items-per-page selector: three multiples of `perPage`. The dropdown
// dispatches `iot-hub-page-size:change` { perPage } on selection so the
// host (the future dynamic-search pipeline) can refetch.
const perPageOptions = [perPage, perPage * 2, perPage * 3];
---

<nav
	class:list={['iot-hub-pagination', `iot-hub-pagination--${variant}`]}
	aria-label="Pagination"
	data-iot-hub-pagination
>
	<div class="iot-hub-pagination__pages-wrap">
		<ul class="iot-hub-pagination__pages iot-hub-pagination__pages--numbers">
			<li>
				<PaginationChevron
					direction="left"
					href={prevHref}
					label={IOT_HUB_STRINGS.pagination.prevPageAriaLabel}
				/>
			</li>
			{
				items.map((item) =>
					item === 'ellipsis' ? (
						<li class="iot-hub-pagination__ellipsis" aria-hidden="true">
							…
						</li>
					) : (
						<li>
							<a
								class={`iot-hub-pagination__page${item === currentPage ? ' is-current' : ''}`}
								href={pageUrl(item)}
								aria-current={item === currentPage ? 'page' : undefined}
							>
								{item}
							</a>
						</li>
					)
				)
			}
			<li>
				<PaginationChevron
					direction="right"
					href={nextHref}
					label={IOT_HUB_STRINGS.pagination.nextPageAriaLabel}
				/>
			</li>
		</ul>
		<div class="iot-hub-pagination__pages iot-hub-pagination__pages--compact">
			<PaginationChevron
				direction="left"
				href={prevHref}
				label={IOT_HUB_STRINGS.pagination.prevPageAriaLabel}
			/>
			<span class="iot-hub-pagination__summary">
				{formatPageSummary(currentPage, totalPages)}
			</span>
			<PaginationChevron
				direction="right"
				href={nextHref}
				label={IOT_HUB_STRINGS.pagination.nextPageAriaLabel}
			/>
		</div>
	</div>
	<div
		class="iot-hub-pagination__per-page"
		data-per-page-root
		data-per-page={perPage}
	>
		<span class="iot-hub-pagination__per-page-label" id="iot-hub-per-page-label">
			Items per page:
		</span>
		<button
			type="button"
			class="iot-hub-pagination__per-page-value"
			data-per-page-button
			aria-expanded="false"
			aria-labelledby="iot-hub-per-page-label"
		>
			<span data-per-page-label>{perPage}</span>
			<Chevron direction="down" />
		</button>
		<div
			class="iot-hub-pagination__per-page-popup"
			hidden
			data-per-page-popup
			role="group"
			aria-label="Items per page"
		>
			{perPageOptions.map((n) => (
				<button
					type="button"
					class:list={[
						'iot-hub-pagination__per-page-option',
						n === perPage && 'iot-hub-pagination__per-page-option--selected',
					]}
					data-per-page-option
					data-per-page-value={n}
					aria-pressed={n === perPage}
				>
					<span class="iot-hub-pagination__per-page-option-text">{n}</span>
					<IotHubIcon
						icon="check"
						size={24}
						class="iot-hub-pagination__per-page-option-check"
					/>
				</button>
			))}
		</div>
	</div>
</nav>

<style is:global lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-pagination {
		position: relative;
		// Establishes a stacking context (z-index !== auto) so the
		// per-page popup floats above the page sections that follow the
		// pagination in DOM order. Without this, the popup ends up below
		// later sections — they aren't z-indexed either, but DOM order
		// wins for elements at the same stacking level.
		z-index: 5;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 16px;
		min-height: 40px;

		@include media-down(sm) {
			padding: 0 12px;
		}
	}

	// `right` variant — single right-aligned row. Used by surfaces where
	// the centred layout would leave a big empty column to the left
	// (e.g. the search-page filter bar).
	.iot-hub-pagination--right {
		justify-content: flex-end;
		gap: 16px;
		padding-right: 0;

		.iot-hub-pagination__pages-wrap {
			flex: 0;
		}

		.iot-hub-pagination__per-page {
			position: relative;
			top: auto;
			right: auto;
			transform: none;
		}
	}

	.iot-hub-pagination__pages-wrap {
		display: flex;
		justify-content: center;
		flex: 1 1 0;
	}

	.iot-hub-pagination__pages {
		display: flex;
		align-items: center;
		gap: 1px;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.iot-hub-pagination__pages--compact {
		display: none;
		gap: 8px;
	}

	@include media-down(lg) {
		.iot-hub-pagination__pages--numbers {
			display: none;
		}

		.iot-hub-pagination__pages--compact {
			display: flex;
		}
	}

	// Mixin (not %placeholder + @extend) because @extend doesn't reliably
	// reach across `:global()` selectors after Astro's SCSS pipeline rewrites
	// them. Also: `font-family: inherit` / `appearance: none` / `cursor: pointer`
	// are explicit so dynamic-mode <button> elements render visually identical
	// to their static-mode <a> counterparts without UA defaults leaking in.
	@mixin pagination-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 40px;
		height: 40px;
		padding: 8px;
		border: none;
		border-radius: 8px;
		font-family: inherit;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		text-decoration: none;
		color: var(--color-text-secondary);
		background: transparent;
		appearance: none;
		cursor: pointer;
		transition: background $transition-fast, color $transition-fast;

		svg {
			display: block;
		}
	}

	.iot-hub-pagination__chevron {
		@include pagination-btn;

		&:hover,
		&:focus-visible {
			background: var(--color-bg-light);
			color: var(--color-text);
		}

		&.is-disabled {
			opacity: 0.4;
			pointer-events: none;
		}
	}

	.iot-hub-pagination__page {
		@include pagination-btn;
		padding: 8px 16px;
		color: var(--color-text);

		&:hover,
		&:focus-visible {
			background: var(--color-bg-light);
		}

		&.is-current {
			background: var(--color-primary);
			color: #fff;
			pointer-events: none;
		}

		[data-theme='dark'] &.is-current {
			background: #b3c7ff;
			color: #17181c;
		}
	}

	.iot-hub-pagination__ellipsis {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 40px;
		height: 40px;
		padding: 8px 16px;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: var(--sl-color-gray-5);
	}

	.iot-hub-pagination__summary {
		display: inline-flex;
		align-items: center;
		height: 40px;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: var(--color-text);
		white-space: nowrap;
	}

	.iot-hub-pagination__per-page {
		position: absolute;
		top: 50%;
		right: 16px;
		transform: translateY(-50%);
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 14px;
		line-height: 24px;
		color: var(--color-text-muted);

		@include media-down(lg) {
			display: none;
		}
	}

	.iot-hub-pagination__per-page-label {
		white-space: nowrap;
	}

	.iot-hub-pagination__per-page-value {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		min-height: 40px;
		min-width: 72px;
		padding: 8px 8px 8px 12px;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		color: var(--color-text);
		font-family: inherit;
		font-size: 14px;
		line-height: 24px;
		font-weight: $font-weight-normal;
		cursor: pointer;
		background: var(--color-bg-surface);
		transition: background-color $transition-fast, border-color $transition-fast;

		&:hover,
		&[aria-expanded='true'] {
			background: var(--sl-color-gray-6);
		}

		svg {
			color: var(--color-text-secondary);
		}

		[data-theme='dark'] & {
			border-color: #23262f;
		}
	}

	// Popup anchored below the button. `right: 0` keeps it aligned to the
	// trigger's right edge so longer option labels expand leftward into the
	// row's empty space rather than overflowing the viewport.
	.iot-hub-pagination__per-page-popup {
		position: absolute;
		top: calc(100% + 4px);
		right: 0;
		min-width: 100%;
		display: flex;
		flex-direction: column;
		padding: 4px;
		background: var(--color-bg-surface);
		border: 1px solid var(--iot-hub-hairline, rgba(0, 0, 0, 0.12));
		border-radius: 8px;
		box-shadow:
			0 1px 0.5px rgba(0, 0, 0, 0.12),
			0 2px 0.5px rgba(0, 0, 0, 0.24);
		// Within the .iot-hub-pagination stacking context (z-index: 5 on
		// the nav), this is the local stacking level — high enough to
		// clear any other internal absolutely-positioned siblings.
		z-index: 100;

		[data-theme='dark'] & {
			border-color: #23262f;
			background: #17181c;
		}

		// Enter animation parity with IotHubSort / hero autocomplete —
		// 120ms decel curve. Pivot is top-right so the popup expands
		// downward from the button corner.
		transform-origin: top right;
		animation: iot-hub-pagination-per-page-enter 120ms cubic-bezier(0, 0, 0.2, 1);

		&[hidden] {
			display: none;
		}
	}

	@keyframes iot-hub-pagination-per-page-enter {
		from {
			transform: scaleY(0);
			opacity: 0;
		}
		to {
			transform: scaleY(1);
			opacity: 1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.iot-hub-pagination__per-page-popup {
			animation: none;
		}
	}

	.iot-hub-pagination__per-page-option {
		display: flex;
		align-items: center;
		gap: 8px;
		width: 100%;
		padding: 8px 12px;
		font-family: inherit;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: var(--sl-color-gray-2);
		background: transparent;
		border: none;
		border-radius: 5px;
		cursor: pointer;
		text-align: left;
		transition: background-color $transition-fast;

		&:hover {
			background: var(--sl-color-gray-6);
		}

		&:focus-visible {
			outline: 2px solid var(--color-primary);
			outline-offset: -2px;
		}
	}

	.iot-hub-pagination__per-page-option-text {
		flex: 1 1 0;
		min-width: 0;
	}

	.iot-hub-pagination__per-page-option-check {
		flex-shrink: 0;
		visibility: hidden;
	}

	.iot-hub-pagination__per-page-option--selected {
		background: var(--sl-color-gray-6);
		color: var(--color-primary);

		[data-theme='dark'] & {
			color: #b3c7ff;
		}

		.iot-hub-pagination__per-page-option-check {
			visibility: visible;
		}
	}
</style>

<script>
	// Items-per-page dropdown. Click toggles, option click commits +
	// closes + dispatches `iot-hub-page-size:change` { perPage } on the
	// root for the future dynamic-search pipeline to listen to.

	function setupPerPage(root: HTMLElement) {
		if (root.dataset.perPageInited) return;
		root.dataset.perPageInited = 'true';

		const button = root.querySelector<HTMLButtonElement>('[data-per-page-button]');
		const popup = root.querySelector<HTMLElement>('[data-per-page-popup]');
		const label = root.querySelector<HTMLElement>('[data-per-page-label]');
		if (!button || !popup || !label) return;

		const options = Array.from(
			root.querySelectorAll<HTMLButtonElement>('[data-per-page-option]')
		);

		function openPopup() {
			popup!.hidden = false;
			button!.setAttribute('aria-expanded', 'true');
		}

		function closePopup() {
			popup!.hidden = true;
			button!.setAttribute('aria-expanded', 'false');
		}

		button.addEventListener('click', (e) => {
			e.stopPropagation();
			if (popup.hidden) openPopup();
			else closePopup();
		});

		for (const opt of options) {
			opt.addEventListener('click', (e) => {
				e.stopPropagation();
				const value = Number.parseInt(opt.dataset.perPageValue ?? '0', 10);
				if (!Number.isFinite(value) || value <= 0) return;
				for (const o of options) {
					const isSelected = o === opt;
					o.classList.toggle(
						'iot-hub-pagination__per-page-option--selected',
						isSelected
					);
					o.setAttribute('aria-pressed', String(isSelected));
				}
				label!.textContent = String(value);
				root.dataset.perPage = String(value);
				closePopup();
				root.dispatchEvent(
					new CustomEvent('iot-hub-page-size:change', {
						detail: { perPage: value },
						bubbles: true,
					})
				);
			});
		}

		document.addEventListener('click', (e) => {
			if (!popup.hidden && !root.contains(e.target as Node)) closePopup();
		});
		root.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && !popup.hidden) {
				closePopup();
				button!.focus();
			}
		});
	}

	function initAll() {
		document
			.querySelectorAll<HTMLElement>('[data-per-page-root]')
			.forEach(setupPerPage);
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initAll);
	} else {
		initAll();
	}
	document.addEventListener('astro:page-load', initAll);
</script>
