---
import {
	getSubtypeLabel,
	getCreatorHref,
	getInitials,
	resolveAvatar,
	type IotHubItemType,
	type ListingDetail,
} from '@models/iot-hub';
import '@fontsource/material-icons';

// Renders the 4-column "tags" row beneath the detail hero, per the design.
// Two variants — A: DEVICE / WIDGET / SOLUTION_TEMPLATE and B:
// CALCULATED_FIELD / RULE_CHAIN / ALARM_RULE — share the same layout and
// only differ in which subtype field drives the second/third columns.
// Chip color tint follows the design: type/secondary→blue, third→purple,
// use cases→green (via Starlight's `--sl-color-{blue,purple,green}-{low,high}`
// tokens, which auto-invert between light/dark themes).

interface Props {
	detail: ListingDetail;
}

const { detail } = Astro.props;

type Column = { label: string; values: string[]; tint: 'blue' | 'purple' | 'green' };

// Column 2 — secondary type (Hardware Type / Widget Type / Type). Raw API
// keys for widgetType / cfType / ruleChainType (`timeseries`, `SIMPLE`,
// `CORE`, …) go through `getSubtypeLabel` to become human-readable.
const itemType = detail.itemType as IotHubItemType;
const secondColumn: Column | null = (() => {
	switch (detail.itemType) {
		case 'DEVICE':
			return detail.hardwareType
				? { label: 'Hardware Type', values: [detail.hardwareType], tint: 'blue' }
				: null;
		case 'WIDGET':
			return detail.widgetType
				? {
						label: 'Widget Type',
						values: [getSubtypeLabel(itemType, detail.widgetType)],
						tint: 'blue',
					}
				: null;
		case 'CALCULATED_FIELD':
		case 'ALARM_RULE':
			// ALARM_RULE shares cfType (and cfTypeTranslations) with
			// CALCULATED_FIELD — force the lookup itemType to CALCULATED_FIELD
			// so the translation hits.
			return detail.cfType
				? {
						label: 'Type',
						values: [getSubtypeLabel('CALCULATED_FIELD', detail.cfType)],
						tint: 'blue',
					}
				: null;
		case 'RULE_CHAIN':
			return detail.ruleChainType
				? {
						label: 'Type',
						values: [getSubtypeLabel(itemType, detail.ruleChainType)],
						tint: 'blue',
					}
				: null;
		case 'SOLUTION_TEMPLATE':
		default:
			return detail.vendor
				? { label: 'Vendor', values: [detail.vendor], tint: 'blue' }
				: null;
	}
})();

// Column 3 — Connectivity (variant A: DEVICE/WIDGET/etc.) or Category (variant B).
const thirdColumn: Column | null = (() => {
	if (detail.connectivity.length > 0)
		return { label: 'Connectivity', values: detail.connectivity, tint: 'purple' };
	if (detail.categories.length > 0)
		return { label: 'Category', values: detail.categories, tint: 'purple' };
	return null;
})();

// Column 4 — Use Cases. All entries render; the runtime chip-overflow
// script at the bottom of this file hides those that don't fit the
// available row width and appends a "+N" counter chip.
const useCasesColumn: Column | null =
	detail.useCases.length > 0
		? { label: 'Use Cases', values: detail.useCases, tint: 'green' }
		: null;

const creator = detail.creatorDisplayName || null;
const verified = detail.creatorVerified;
const creatorHref = detail.creatorId ? getCreatorHref(detail.creatorId) : null;
// Avatar resolves a relative `/api/resources/...` path or absolute URL; falls
// back to initials when unset. The creator block is a link to the creator page
// when we have an id, otherwise a plain container — same markup either way.
const avatarUrl = resolveAvatar(detail.creatorAvatarUrl);
const initials = creator ? getInitials(creator) : '';
const CreatorTag = creatorHref ? 'a' : 'div';

const hasAnyColumn = creator || secondColumn || thirdColumn || useCasesColumn;
---

{
	hasAnyColumn && (
		<section class="iot-hub-detail-meta" aria-label="Listing details">
			{creator && (
				<div class="iot-hub-detail-meta__group">
					<span class="iot-hub-detail-meta__label">Creator</span>
					<CreatorTag
						class:list={[
							'iot-hub-detail-meta__author',
							creatorHref && 'iot-hub-detail-meta__author--link',
						]}
						href={creatorHref}
					>
						<span class="iot-hub-detail-meta__avatar" aria-hidden="true">
							{avatarUrl ? (
								<img
									class="iot-hub-detail-meta__avatar-img"
									src={avatarUrl}
									alt={`Photo of ${creator}`}
									loading="lazy"
									decoding="async"
									width="32"
									height="32"
								/>
							) : (
								<span class="iot-hub-detail-meta__avatar-initials">{initials || '?'}</span>
							)}
							{verified && (
								<span class="material-icons iot-hub-detail-meta__avatar-verified" aria-hidden="true">
									verified
								</span>
							)}
						</span>
						<span class="iot-hub-detail-meta__author-name">{creator}</span>
					</CreatorTag>
				</div>
			)}
			{secondColumn && (
				<div class="iot-hub-detail-meta__group">
					<span class="iot-hub-detail-meta__label">{secondColumn.label}</span>
					<ul class="iot-hub-detail-meta__chips" role="list">
						{secondColumn.values.map((v) => (
							<li class:list={['iot-hub-detail-meta__chip', `iot-hub-detail-meta__chip--${secondColumn.tint}`]}>
								{v}
							</li>
						))}
					</ul>
				</div>
			)}
			{thirdColumn && (
				<div class="iot-hub-detail-meta__group">
					<span class="iot-hub-detail-meta__label">{thirdColumn.label}</span>
					<ul class="iot-hub-detail-meta__chips" role="list">
						{thirdColumn.values.map((v) => (
							<li class:list={['iot-hub-detail-meta__chip', `iot-hub-detail-meta__chip--${thirdColumn.tint}`]}>
								{v}
							</li>
						))}
					</ul>
				</div>
			)}
			{useCasesColumn && (
				<div class="iot-hub-detail-meta__group iot-hub-detail-meta__group--wide">
					<span class="iot-hub-detail-meta__label">{useCasesColumn.label}</span>
					<ul
						class="iot-hub-detail-meta__chips iot-hub-detail-meta__chips--overflow"
						role="list"
						data-chip-overflow
						data-chip-overflow-gap="4"
					>
						{useCasesColumn.values.map((v) => (
							<li
								class:list={['iot-hub-detail-meta__chip', `iot-hub-detail-meta__chip--${useCasesColumn.tint}`]}
								data-chip-overflow-item
							>
								{v}
							</li>
						))}
						{/* Hidden until the runtime script measures and decides
						    how many chips overflow. Inline `display:none` so
						    the chip doesn't flash before the script runs. */}
						<li
							class:list={[
								'iot-hub-detail-meta__chip',
								`iot-hub-detail-meta__chip--${useCasesColumn.tint}`,
								'iot-hub-detail-meta__chip--counter',
							]}
							data-chip-overflow-counter
							style="display:none"
						>
							+0
						</li>
					</ul>
				</div>
			)}
		</section>
	)
}

<style lang="scss">
	@use '../../styles/_variables.scss' as *;
	@use '../../styles/_iot-hub.scss' as *;

	// Horizontal row of columns: all columns
	// inline, vertically centred, fixed-content sized except for Use Cases
	// which absorbs the remaining width. On narrow screens we fall back to a
	// wrapped/stacked layout to keep the chips legible.
	.iot-hub-detail-meta {
		display: flex;
		flex-direction: row;
		align-items: center;
		// Wrap is always on so the Use Cases column drops to its own row
		// when its flex-basis (see `--wide` below) can't fit alongside the
		// fixed-content columns. Without this, between the natural break and
		// the `md` viewport breakpoint the wide column would just shrink
		// and overflow:hidden would clip both its label and its first chip.
		flex-wrap: wrap;
		gap: 20px;
		padding: 20px 16px 16px 16px;
		border-bottom: 1px solid var(--iot-hub-hairline);

		@include media-down(sm) {
			padding: 20px 12px 16px 12px;
		}

		@include media-down(md) {
			align-items: flex-start;
		}
	}

	.iot-hub-detail-meta__group {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 4px;
		// Non-wide columns hold their content width (the design's `shrink-0`) and
		// don't compete with Use Cases for the remaining row space.
		flex-shrink: 0;

		// Use Cases stretches to fill the remainder of the row (matches the
		// design's use-cases column flex: 1 0 0). The 14em flex-basis is the
		// wrap trigger: when there's less than ~14em of space remaining
		// alongside the fixed-content columns, the parent's `flex-wrap: wrap`
		// drops this column onto its own row where it gets the full width.
		// `min-width: 0` still lets the chips row's `overflow: hidden` clip
		// in the case where 14em is available but the chips themselves don't
		// all fit (the runtime overflow script handles that with `+N`).
		&--wide {
			flex: 1 1 14em;
			min-width: 0;
		}
	}

	.iot-hub-detail-meta__label {
		font-size: 12px;
		font-weight: $font-weight-normal;
		line-height: 16px;
		color: var(--sl-color-gray-3);
		white-space: nowrap;
	}

	// --- Creator -----------------------------------------------------------

	.iot-hub-detail-meta__author {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 4px 0;
		height: 40px;
	}

	.iot-hub-detail-meta__author--link {
		text-decoration: none;
		color: inherit;
		border-radius: 8px;

		&:hover .iot-hub-detail-meta__author-name,
		&:focus-visible .iot-hub-detail-meta__author-name {
			color: var(--color-text);
			text-decoration: underline;
		}

		&:focus-visible {
			outline: 2px solid var(--color-primary);
			outline-offset: 2px;
		}
	}

	.iot-hub-detail-meta__avatar {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border-radius: 9999px;
		background: var(--sl-color-gray-6);
		color: var(--sl-color-gray-2);
		flex-shrink: 0;
	}

	.iot-hub-detail-meta__avatar-initials {
		font-size: 12px;
		font-weight: $font-weight-semibold;
		line-height: 1;
		text-transform: uppercase;
	}

	.iot-hub-detail-meta__avatar-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		border-radius: inherit;
		display: block;
	}

	// Small verified badge overlapping the top-right of the avatar circle
	//.
	.iot-hub-detail-meta__avatar-verified {
		position: absolute;
		line-height: 20px;
		font-size: 20px;
		top: -6px;
		left: 18px;
		width: 20px;
		height: 20px;
		color: var(--color-primary);
		border-radius: 50%;
	}

	.iot-hub-detail-meta__author-name {
		font-size: 13px;
		font-weight: $font-weight-semibold;
		line-height: 16px;
		color: var(--sl-color-gray-2);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	// --- Filter chips ------------------------------------------------------

	.iot-hub-detail-meta__chips {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 4px;
		// 8px vertical padding around the chip row so it shares the same
		// 40px column height as the Creator avatar block — matches the design.
		padding-block: 8px;
	}

	// Use Cases column — chips occupy a single row and the runtime
	// chip-overflow script (bottom of this file) hides items that don't fit
	// the available width, surfacing them through a "+N" counter chip.
	// `width: 100%` forces the ul to the wide column's full width — the
	// parent `.iot-hub-detail-meta__group` uses `align-items: flex-start`,
	// so without this the ul would size to its intrinsic content width
	// (sum of all chip widths) and `overflow: hidden` would have nothing
	// narrower than itself to clip against.
	.iot-hub-detail-meta__chips--overflow {
		width: 100%;
		flex-wrap: nowrap;
		overflow: hidden;
		min-width: 0;
		white-space: nowrap;
	}

	.iot-hub-detail-meta__chip {
		display: inline-flex;
		align-items: center;
		padding: 4px 8px;
		border-radius: 4px;
		font-size: 13px;
		font-weight: $font-weight-medium;
		line-height: 16px;
		white-space: nowrap;

		// Tints follow Starlight's complementary scale (light theme: low =
		// pale tint, high = saturated text; dark theme inverts).
		&--blue {
			background: var(--sl-color-blue-low);
			color: var(--sl-color-blue-high);
		}

		&--purple {
			background: var(--sl-color-purple-low);
			color: var(--sl-color-purple-high);
		}

		&--green {
			background: var(--sl-color-green-low);
			color: var(--sl-color-green-high);
		}

		&--counter {
			user-select: none;
		}
	}

	.material-icons {
		@include iot-hub-material-icon;
		display: inline-block;
	}
</style>

<script>
	// Runtime chip-overflow. For each `[data-chip-overflow]` container,
	// measure every `[data-chip-overflow-item]` chip, hide the ones that
	// don't fit, and update the `[data-chip-overflow-counter]` chip with
	// `+N`. Re-runs on container resize, on `astro:page-load`, and once
	// after web fonts settle so widths re-measure with final glyph metrics.

	type ChipDataset = { chipOverflowGap?: string; chipOverflowTemplate?: string; chipOverflowMin?: string; chipOverflowInited?: string };

	function setupChipOverflow(container: HTMLElement) {
		const ds = container.dataset as ChipDataset;
		if (ds.chipOverflowInited) return;
		ds.chipOverflowInited = 'true';

		const gap = Number.parseInt(ds.chipOverflowGap ?? '4', 10);
		const template = ds.chipOverflowTemplate ?? '+{n}';
		const minChips = Math.max(1, Number.parseInt(ds.chipOverflowMin ?? '1', 10));
		const counter = container.querySelector<HTMLElement>('[data-chip-overflow-counter]');
		if (!counter) return;

		const reflow = () => {
			const chips = Array.from(
				container.querySelectorAll<HTMLElement>('[data-chip-overflow-item]')
			);
			if (chips.length === 0) {
				counter.style.display = 'none';
				return;
			}

			// 1. Reveal everything to measure each chip's natural width.
			for (const chip of chips) chip.style.display = '';
			counter.style.display = 'none';
			const widths = chips.map((c) => Math.ceil(c.offsetWidth));

			// 2. Hide everything to read the container's true available width
			//    without the chips' intrinsic content inflating any flex/grid
			//    parent.
			for (const chip of chips) chip.style.display = 'none';
			const availableWidth = container.clientWidth;
			if (!availableWidth) {
				for (const chip of chips) chip.style.display = '';
				return;
			}

			// 3. Measure the counter chip with a "+9" placeholder so we know
			//    how much space to reserve for it before deciding which chips
			//    fit.
			counter.textContent = template.replace('{n}', '9');
			counter.style.display = 'inline-flex';
			const minOverflowWidth = counter.offsetWidth;
			counter.style.display = 'none';

			// 4. Pack chips left-to-right. Always keep the first `minChips`,
			//    even if they overflow on very narrow screens.
			let used = 0;
			let hidden = 0;
			const hiddenTitles: string[] = [];
			for (let i = 0; i < chips.length; i++) {
				const w = widths[i];
				const next = used ? used + gap + w : w;
				const withOverflow = next + (next ? gap : 0) + minOverflowWidth;
				if (i < minChips || withOverflow <= availableWidth) {
					chips[i].style.display = 'inline-flex';
					used = next;
				} else {
					hidden++;
					hiddenTitles.push(chips[i].textContent?.trim() ?? '');
				}
			}

			if (hidden > 0) {
				counter.textContent = template.replace('{n}', String(hidden));
				counter.style.display = 'inline-flex';
				counter.title = hiddenTitles.join(', ');
			} else {
				counter.style.display = 'none';
				counter.removeAttribute('title');
			}
		};

		const ro = new ResizeObserver(() => {
			requestAnimationFrame(reflow);
		});
		ro.observe(container);

		requestAnimationFrame(reflow);
		// Web fonts may finish loading after first paint — re-measure once
		// glyph metrics are final, otherwise chips packed with the fallback
		// font can mis-fit by a few pixels.
		if (document.fonts) {
			document.fonts.ready.then(() => requestAnimationFrame(reflow));
		}
	}

	function initAll() {
		document
			.querySelectorAll<HTMLElement>('[data-chip-overflow]')
			.forEach(setupChipOverflow);
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initAll);
	} else {
		initAll();
	}
	// Re-init after Starlight / Astro view transitions swap the DOM.
	document.addEventListener('astro:page-load', initAll);
</script>
