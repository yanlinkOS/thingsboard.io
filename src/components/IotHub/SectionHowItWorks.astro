---
import type { LabeledItem } from '@models/iot-hub-sections';
import Chevron from '@components/Chevron.astro';

interface Props {
	heading: string;
	intro?: string;
	steps: LabeledItem[];
	cta?: { label: string; href?: string };
}

const { heading, intro, steps, cta } = Astro.props;
---

<section class="ih-how">
	<h2 class="ih-how__title">{heading}</h2>
	{intro && <p class="ih-how__intro">{intro}</p>}
	<ul class="ih-how__steps">
		{
			steps.map((step) => (
				<li class="ih-how__step">
					<div class="ih-how__body">
						<span class="ih-how__label">{step.label}</span>
						{step.description && <span class="ih-how__desc">{step.description}</span>}
					</div>
				</li>
			))
		}
	</ul>
	{
		cta?.href && (
			<a class="ih-how__cta" href={cta.href}>
				<span>{cta.label}</span>
				<Chevron direction="right" />
			</a>
		)
	}
</section>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;
	@use '../../styles/_iot-hub.scss' as *;

	.ih-how {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.ih-how__title {
		@include iot-hub-section-title;
	}

	.ih-how__intro {
		@include iot-hub-section-intro;
	}

	.ih-how__steps {
		display: flex;
		flex-direction: column;
		gap: 20px;
		margin: 8px 0 0;
		padding: 0;
		list-style: none;
	}

	.ih-how__step {
		position: relative;
		padding-left: 24px;

		&::before {
			content: '';
			position: absolute;
			left: 2px;
			top: 9px;
			width: 8px;
			height: 8px;
			border-radius: 50%;
			background: var(--color-primary);
		}

		:global([data-theme='dark']) &::before {
			background: #b3c7ff;
		}
	}

	.ih-how__body {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.ih-how__label {
		@include iot-hub-item-label;
	}

	.ih-how__desc {
		@include iot-hub-item-desc;
	}

	.ih-how__cta {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		margin-top: 8px;
		font-size: 16px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		text-decoration: none;
		color: var(--color-primary);

		&:hover {
			text-decoration: underline;
		}

		svg {
			display: block;
		}

		:global([data-theme='dark']) & {
			color: #b3c7ff;
		}
	}
</style>
