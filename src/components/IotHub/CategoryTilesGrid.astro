---
import { IOT_HUB_CATEGORIES } from '@models/iot-hub';
import CategoryTile from './CategoryTile.astro';
---

<section class="iot-hub-tiles" aria-label="IoT Hub categories">
	<div class="iot-hub-tiles__grid">
		{
			IOT_HUB_CATEGORIES.map((cat) => (
				<CategoryTile
					slug={cat.slug}
					label={cat.tileLabel}
					color={cat.tileColor}
					colorDark={cat.tileColorDark}
					itemType={cat.itemType}
				/>
			))
		}
	</div>
</section>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-tiles {
		// Override the global `:where(section)` white fill so the top-section
		// pattern / blobs show through behind the category tiles.
		background-color: transparent;
		margin: 0 auto;
		padding: 0 1rem;
		// Page-load entrance: tiles fade in and settle up
		// (port of tb-iot-hub-home's categories animation).
		animation: iot-hub-fade-slide-up 1s cubic-bezier(0.19, 1, 0.22, 1) 0.2s both;

		@include media-down(sm) {
			padding: 0 0.75rem;
		}
	}

	.iot-hub-tiles__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;

		@include media-down(lg) {
			grid-template-columns: repeat(2, 1fr);
		}

		@include media-down(sm) {
			grid-template-columns: 1fr;
		}
	}

	@keyframes iot-hub-fade-slide-up {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.iot-hub-tiles {
			animation: none;
		}
	}
</style>
