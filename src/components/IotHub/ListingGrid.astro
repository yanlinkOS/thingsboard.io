---
import type { IotHubCardVariant } from '~/models/iot-hub';

interface Props {
	variant?: IotHubCardVariant;
	home?: boolean;
}

const { variant = 'big', home = false } = Astro.props;
---

<div class:list={['iot-hub-grid', `iot-hub-grid--${variant}`, {'iot-hub-grid--home': home}]}>
	<slot />
</div>

<style is:global lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-grid--big {
		&.iot-hub-grid--home {
			@include media-down(lg) {
				.iot-hub-card:nth-child(n+4) {
					display: none;
				}
			}
			@include media-down(md) {
				.iot-hub-card:nth-child(n+4) {
					display: flex;
				}
			}
			@include media-down(sm) {
				.iot-hub-card:nth-child(n+3) {
					display: none;
				}
			}
		}
	}
</style>

<style is:global lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-grid {
		display: grid;
		gap: 16px;
		// 16px gutter so cards align with the design's x=16 first-card inset while
		// the parent section's header indicator stays flush with the container.
		padding: 0 1rem;

		@include media-down(sm) {
			padding: 0 0.75rem;
		}
	}

	.iot-hub-grid--big {
		grid-template-columns: repeat(4, minmax(0, 1fr));

		[data-iot-hub-listings-wrap][data-filter-open='true'] & {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			@include media-down(md) {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
			@include media-down(sm) {
				grid-template-columns: 1fr;
			}
		}

		@include media-down(lg) {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		@include media-down(md) {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		@include media-down(sm) {
			grid-template-columns: 1fr;
		}
	}

	.iot-hub-grid--small {
		grid-template-columns: repeat(2, minmax(0, 1fr));

		@include media-down(md) {
			grid-template-columns: 1fr;
		}
	}
</style>
