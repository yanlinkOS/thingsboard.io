---
import { Icon } from 'astro-icon/components';
import { getInitials, getWebsiteLabel, IOT_HUB_STRINGS } from '@models/iot-hub';
import { normalizeSiteUrl } from '@util/site-links';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import '@fontsource/material-icons';

const T = IOT_HUB_STRINGS.creatorPage;

interface Props {
	name: string;
	avatarUrl: string | null;
	verified: boolean;
	bio?: string | null;
	website?: string | null;
	email?: string | null;
	github?: string | null;
	linkedin?: string | null;
	twitter?: string | null;
}

const { name, avatarUrl, verified, bio, website, email, github, linkedin, twitter } =
	Astro.props;

const initials = getInitials(name) || '?';
---

<section class="creator-hero">
	<Breadcrumbs items={[{ label: T.breadcrumbRoot, href: '/iot-hub/' }, { label: name }]} />
	<div class="creator-hero__main">
		<div class="creator-hero__photo" aria-hidden="true">
			{avatarUrl ? (
				<img src={avatarUrl} alt="" width="140" height="140" loading="eager" decoding="async" />
			) : (
				<span class="creator-hero__initials">{initials}</span>
			)}
		</div>
		<div class="creator-hero__text">
			<div class="creator-hero__name-row">
				<h1 class="creator-hero__name">{name}</h1>
				{verified && (
					<span class="creator-hero__verified" title={T.verifiedLabel} aria-label={T.verifiedLabel} role="img">
						verified
					</span>
				)}
			</div>
			{bio && <p class="creator-hero__bio">{bio}</p>}
			<div class="creator-hero__actions">
				{website && (
					<a class="creator-hero__website" href={normalizeSiteUrl(website)} target="_blank" rel="noopener">
						<Icon name="tabler:world" size={24} />
						<span>{getWebsiteLabel(website)}</span>
					</a>
				)}
				{email && (
					<a class="creator-hero__icon-btn" href={`mailto:${email}`} aria-label={T.emailLabel} title={T.emailLabel}>
						<Icon name="tabler:mail" size={24} />
					</a>
				)}
				{github && (
					<a class="creator-hero__icon-btn" href={github} target="_blank" rel="noopener" aria-label={T.githubLabel} title={T.githubLabel}>
						<Icon name="simple-icons:github" size={22} />
					</a>
				)}
				{linkedin && (
					<a class="creator-hero__icon-btn" href={linkedin} target="_blank" rel="noopener" aria-label={T.linkedinLabel} title={T.linkedinLabel}>
						<Icon name="simple-icons:linkedin" size={22} />
					</a>
				)}
				{twitter && (
					<a class="creator-hero__icon-btn" href={twitter} target="_blank" rel="noopener" aria-label={T.twitterLabel} title={T.twitterLabel}>
						<Icon name="simple-icons:x" size={20} />
					</a>
				)}
			</div>
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;
	@use '../../styles/_iot-hub.scss' as *;

	.creator-hero {
		display: flex;
		flex-direction: column;
		gap: 40px;
		padding: 40px 16px 40px;

		@include media-down(sm) {
			padding: 40px 12px 40px;
		}
	}

	.creator-hero__main {
		display: flex;
		gap: 40px;
		align-items: flex-start;

		@include media-down(sm) {
			flex-direction: column;
			gap: 24px;
		}
	}

	.creator-hero__photo {
		flex-shrink: 0;
		width: 140px;
		height: 140px;
		border-radius: 50%;
		overflow: hidden;
		border: 1.75px solid var(--iot-hub-hairline);
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--sl-color-gray-6);

		img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
		}
	}

	.creator-hero__initials {
		font-size: 48px;
		font-weight: $font-weight-semibold;
		color: var(--sl-color-gray-2);
		text-transform: uppercase;
	}

	.creator-hero__text {
		flex: 1 1 0;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.creator-hero__name-row {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.creator-hero__name {
		margin: 0;
		font-size: 32px;
		font-weight: $font-weight-semibold;
		line-height: 40px;
		color: var(--color-text);

		@include media-down(sm) {
			font-size: 24px;
			line-height: 32px;
		}
	}

	// Material Icons reset so the text "verified" renders as the glyph.
	.creator-hero__verified {
		@include iot-hub-material-icon;
		font-size: 32px;
		line-height: 32px;
		display: inline-block;
		color: var(--color-primary);
		flex-shrink: 0;

		:global([data-theme='dark']) & {
			color: #b3c7ff;
		}
	}

	.creator-hero__bio {
		margin: 0;
		max-width: 800px;
		font-size: 16px;
		line-height: 28px;
		color: var(--sl-color-gray-2);
	}

	.creator-hero__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 8px;
	}

	.creator-hero__website {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		padding: 14px 16px;
		border: 1px solid var(--color-primary);
		border-radius: 8px;
		font-size: 16px;
		font-weight: $font-weight-semibold;
		line-height: 28px;
		color: var(--color-primary);
		text-decoration: none;
		transition: background $transition-fast, color $transition-fast;

		svg { display: block; }

		&:hover {
			background: var(--color-bg-light);
		}

		:global([data-theme='dark']) & {
			border-color: #b3c7ff;
			color: #b3c7ff;
		}
	}

	.creator-hero__icon-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 8px;
		color: var(--color-text);
		text-decoration: none;
		transition: background $transition-fast;

		svg { display: block; }

		&:hover {
			background: var(--color-bg-light);
		}
	}
</style>
