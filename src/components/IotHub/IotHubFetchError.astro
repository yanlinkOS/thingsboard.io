---
import fetchErrorIllustration from '@root/assets/iot-hub/search-fetch-error.svg';
import { IOT_HUB_STRINGS } from '@models/iot-hub';

// Shown when the listings API call fails (network down, server
// unreachable, 5xx). Hidden by default; the dynamic-search script
// toggles `hidden` based on the most recent fetch outcome.
//
// The "Try again" button is a real <button> so the script can attach a
// click handler that replays the last refetch with the same state
// (search text, sort, page, page size, filters).

const { heading, subtitle, ctaLabel } = IOT_HUB_STRINGS.fetchError;
---

<div
	class="iot-hub-fetch-error"
	hidden
	data-iot-hub-fetch-error
	role="alert"
	aria-live="assertive"
>
	<img
		class="iot-hub-fetch-error__illustration"
		src={fetchErrorIllustration.src}
		alt=""
		width="140"
		height="140"
		aria-hidden="true"
	/>
	<div class="iot-hub-fetch-error__text">
		<p class="iot-hub-fetch-error__heading">{heading}</p>
		<p class="iot-hub-fetch-error__subtitle">{subtitle}</p>
	</div>
	<button
		type="button"
		class="iot-hub-fetch-error__cta"
		data-iot-hub-fetch-error-retry
	>
		{ctaLabel}
	</button>
</div>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-fetch-error {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 20px;
		padding: 64px 16px 40px;

		&[hidden] {
			display: none;
		}
	}

	.iot-hub-fetch-error__illustration {
		display: block;
		width: 140px;
		height: 140px;
	}

	.iot-hub-fetch-error__text {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		text-align: center;
	}

	.iot-hub-fetch-error__heading {
		margin: 0;
		font-size: 20px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: var(--sl-color-gray-2);
	}

	.iot-hub-fetch-error__subtitle {
		margin: 0;
		font-size: 14px;
		font-weight: $font-weight-normal;
		line-height: 24px;
		color: var(--sl-color-gray-3);
	}

	// Retry button. Same shape as the "Clear all filters" CTA on the
	// no-results panel so both empty states feel like one family. Light
	// theme: white text on saturated --color-primary. Dark theme: dark
	// text on the lighter `#b3c7ff` accent.
	.iot-hub-fetch-error__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 8px 16px;
		min-height: 40px;
		font-family: inherit;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: #fff;
		background: var(--color-primary);
		border: none;
		border-radius: 8px;
		text-decoration: none;
		cursor: pointer;
		appearance: none;
		transition: filter $transition-fast;

		&:hover,
		&:focus-visible {
			filter: brightness(0.95);
			color: #fff;
			text-decoration: none;
		}

		:global([data-theme='dark']) & {
			background: #b3c7ff;
			color: #17181c;
		}
	}
</style>
