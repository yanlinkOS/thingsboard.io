---
// Composite cluster SVGs ported from the platform's tb-iot-hub-home component
// (assets/iot-hub/hero-*-cluster.svg). One per category, layered absolutely
// over the hero; the active one fades + scales in while the rest collapse out.
import devicesCluster from '@root/assets/iot-hub/hero-device-cluster.svg';
import solutionsCluster from '@root/assets/iot-hub/hero-solution-template-cluster.svg';
import widgetsCluster from '@root/assets/iot-hub/hero-widget-cluster.svg';
import calcFieldsCluster from '@root/assets/iot-hub/hero-calculated-field-cluster.svg';
import alarmRulesCluster from '@root/assets/iot-hub/hero-alarm-rule-cluster.svg';
import ruleChainsCluster from '@root/assets/iot-hub/hero-rule-chain-cluster.svg';

// Each highlight is an anchor to its category index (same routing as the
// tiles below), and hovering one immediately makes it the active accent.
// Colors per Figma node 1158:14803; slugs mirror IOT_HUB_CATEGORIES.
// `clusterTop` is the cluster's `y` inside the Figma hero frame (1158:14803);
// since the hero frame starts at y=80 (header height), this is also the gap
// from the header bottom — added to `$header-height` in the CSS.
const highlights = [
	{ slug: 'devices', label: 'Devices,', color: '#4c63cc', cluster: devicesCluster, clusterTop: 57 },
	{ slug: 'solution-templates', label: 'Solution Templates,', color: '#2c6cb4', cluster: solutionsCluster, clusterTop: 40 },
	{ slug: 'widgets', label: 'Widgets,', color: '#2c9755', cluster: widgetsCluster, clusterTop: 60 },
	{ slug: 'calculated-fields', label: 'Calculated Fields,', color: '#3db5e0', cluster: calcFieldsCluster, clusterTop: 80 },
	{ slug: 'alarm-rules', label: 'Alarm Rules', color: '#d7702f', cluster: alarmRulesCluster, clusterTop: 64 },
	{ slug: 'rule-chains', label: '& Rule Chains', color: '#bb7ce9', cluster: ruleChainsCluster, clusterTop: 40 },
];
---

<section class="iot-hub-hero">
	{
		highlights.map(({ slug, cluster, clusterTop }) => (
			<div class="iot-hub-hero__cluster" data-hl-cluster={slug} aria-hidden="true">
				<img
					class="iot-hub-hero__cluster-img"
					src={cluster.src}
					alt=""
					style={`--cluster-top: ${clusterTop}px;`}
				/>
			</div>
		))
	}
	<div class="iot-hub-hero__inner">
		<h1 class="iot-hub-hero__title">ThingsBoard IoT Hub</h1>
		<p class="iot-hub-hero__subtitle">
			<span class="iot-hub-hero__subtitle-lead">Discover ready-to-use</span>
			{
				highlights.map(({ slug, label, color }) => (
					<a
						class="iot-hub-hero__hl"
						href={`/iot-hub/${slug}/`}
						data-hl-color={color}
					>
						{label}
					</a>
				))
			}
		</p>
		<form
			class="iot-hub-hero__search"
			role="search"
			action="/iot-hub/"
			method="get"
			onsubmit="event.preventDefault();"
		>
			<label class="iot-hub-hero__search-label" for="iot-hub-search">Search IoT Hub</label>
			<input
				id="iot-hub-search"
				class="iot-hub-hero__search-input"
				type="search"
				name="q"
				placeholder="Search in IoT Hub..."
				autocomplete="off"
			/>
			<button class="iot-hub-hero__search-button" type="submit" aria-label="Search">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path
						d="m21 21-4.3-4.3M11 19a8 8 0 1 1 0-16 8 8 0 0 1 0 16Z"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
			</button>
		</form>
	</div>
</section>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-hero {
		position: relative;
		// Override the global `:where(section)` white fill so the dotted pattern
		// and blobs behind the top section show through (Figma: transparent hero).
		background-color: transparent;
		// The fixed header ($header-height) overlays page content with no global
		// offset, so add it to the 180px Figma gap between header and title top.
		// Bottom padding is 80px per Figma (search input -> hero bottom gap).
		padding: calc(#{$header-height} + 180px) 1rem 80px;
		text-align: center;

		@include media-down(sm) {
			padding: calc(#{$header-height} + 140px) 0.75rem 40px;
		}
	}

	.iot-hub-hero__inner {
		max-width: 640px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		// Sit above the cluster overlays.
		position: relative;
		z-index: 1;
		// Page-load entrance: title/subtitle/search fade in and settle down
		// (port of tb-iot-hub-home's hero animation).
		animation: iot-hub-fade-slide-down 1s cubic-bezier(0.19, 1, 0.22, 1) 0.2s both;

		@include media-down(sm) {
			gap: 0.75rem;
		}
	}

	@keyframes iot-hub-fade-slide-down {
		from {
			opacity: 0;
			transform: translateY(-20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.iot-hub-hero__inner {
			animation: none;
		}
	}

	// Per-category cluster overlay (ported from tb-iot-hub-home). All six are
	// rendered absolutely on top of each other; the active one fades + scales
	// in while the rest collapse back toward the centre. The outer wrapper
	// handles the entry/exit animation around the hero centre; the inner img
	// positions and sizes the cluster art itself.
	.iot-hub-hero__cluster {
		position: absolute;
		inset: 0;
		pointer-events: none;
		opacity: 0;
		transform: scale(0.8);
		transform-origin: 50% 50%;
		transition: opacity 0.4s ease-out, transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
		z-index: 0;

		&.is-active {
			opacity: 1;
			transform: scale(1);
		}
	}

	.iot-hub-hero__cluster-img {
		position: absolute;
		// Per-cluster `--cluster-top` is set inline per highlight (its `y`
		// inside the Figma hero frame, which itself starts at $header-height).
		// Fallback matches the Devices state, which is the initial active.
		top: calc(#{$header-height} + var(--cluster-top, 57px));
		left: 50%;
		transform: translateX(-50%);
		width: min(890px, calc(100% - 80px));
		height: auto;
		display: block;
		pointer-events: none;

		@include media-down(lg) {
			top: calc(#{$header-height} + 80px);
		}
		
		@include media-down(md) {
			// Mobile uses a single top for all clusters (Figma node is
			// desktop-only); the per-cluster var is intentionally overridden.
			top: calc(#{$header-height} + 90px);
			width: calc(100% - 32px);
		}

		@include media-down(sm) {
			top: calc(#{$header-height} + 50px);
		}

	}

	.iot-hub-hero__title {
		@include page-title;
		font-size: 60px;
		line-height: 1.2;
		margin: 0;
		color: var(--color-text);

		@include media-down(md) {
			font-size: 48px;
		}

		@include media-down(sm) {
			font-size: 40px;
		}

	}

	.iot-hub-hero__subtitle {
		font-size: 18px;
		line-height: 32px;
		margin: 0;
		max-width: 520px;
		color: var(--color-text-secondary);
		text-align: center;
		word-spacing: 0.1rem;

		@include media-down(sm) {
			font-size: 16px;
		}
	}

	.iot-hub-hero__subtitle-lead {
		// Lead text per Figma (token: neutral/--sl-color-gray-2 = #353841).
		color: var(--sl-color-gray-2);
		margin-right: 0.2rem;
	}

	.iot-hub-hero__hl {
		display: inline;
		font-weight: $font-weight-semibold;
		// Muted gray for the off-state per Figma (token: neutral/--sl-color-gray-5 = #c1c3c8).
		color: var(--sl-color-gray-5);
		text-decoration: none;
		cursor: pointer;
		transition: color $transition-fast;

		&.is-active {
			// Active accent is set by the cycle script (or hover/focus) on a
			// shared ancestor, so the blob background and this color always
			// match. See script at the bottom of this component.
			color: var(--iot-hub-active-accent, var(--color-primary));
		}
	}

	.iot-hub-hero__search {
		width: 100%;
		max-width: 528px;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0.5rem 0.5rem 1rem;
		margin-top: 1rem;
		min-height: 56px;
		background: var(--color-bg-surface);
		// Border + shadow per Figma node 1169:2786. Border uses the gray-4
		// token (#888c96 light / #555962 dark — see dark override below).
		border: 1px solid var(--neutral---sl-color-gray-4, #888c96);
		border-radius: 8px;
		box-shadow:
			0 178px 25px rgba(0, 0, 0, 0),
			0 114px 23px rgba(0, 0, 0, 0.01),
			0 64px 19px rgba(0, 0, 0, 0.02),
			0 29px 14.5px rgba(0, 0, 0, 0.03),
			0 7px 8px rgba(0, 0, 0, 0.04);
		transition: border-color $transition-fast;

		&:focus-within {
			border-color: var(--color-primary);
		}

		// `:global()` so the data-theme attribute on <html> (outside this
		// component's scope) is matched. Border swaps to the dark gray-4
		// token in dark theme.
		:global([data-theme='dark']) & {
			border-color: var(--neutral---sl-color-gray-4, #555962);
		}

		@include media-down(sm) {
			margin-top: 0.75rem;
		}
	}

	.iot-hub-hero__search-label {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.iot-hub-hero__search-input {
		flex: 1;
		min-width: 0;
		border: none;
		outline: none;
		background: transparent;
		font-size: 16px;
		line-height: 28px;
		color: var(--color-text);
		font-family: inherit;

		&::placeholder {
			color: var(--color-text-muted);
		}
	}

	.iot-hub-hero__search-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border: none;
		background: transparent;
		border-radius: 8px;
		color: var(--color-text-secondary);
		cursor: pointer;
		transition: background $transition-fast, color $transition-fast;

		&:hover,
		&:focus-visible {
			background: var(--color-bg-light);
			color: var(--color-text);
		}
	}
</style>

<script is:inline>
	// Drives the active highlight in the IoT Hub hero. Mirrors the platform
	// behaviour in `tb-iot-hub-home` (Angular): auto-cycle every 3s, hover or
	// focus a highlight to immediately become active and pause the cycle, leave
	// to resume from the current one. The active accent is published as
	// `--iot-hub-active-accent` on the nearest `.iot-hub-home__top` so the
	// background blobs follow the same color via CSS custom-property inheritance.
	(function () {
		const hero = document.querySelector('.iot-hub-hero');
		if (!hero) return;
		const hls = Array.from(hero.querySelectorAll('.iot-hub-hero__hl'));
		const clusters = Array.from(hero.querySelectorAll('.iot-hub-hero__cluster'));
		if (!hls.length) return;
		const accentHost = hero.closest('.iot-hub-home__top') ?? document.documentElement;
		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const CYCLE_MS = 3000;
		let activeIdx = 0;
		let hoverPaused = false;
		let timer = null;

		function setActive(idx) {
			activeIdx = idx;
			const el = hls[idx];
			for (let i = 0; i < hls.length; i++) {
				hls[i].classList.toggle('is-active', i === idx);
			}
			for (let i = 0; i < clusters.length; i++) {
				clusters[i].classList.toggle('is-active', i === idx);
			}
			if (el && el.dataset.hlColor) {
				accentHost.style.setProperty('--iot-hub-active-accent', el.dataset.hlColor);
			}
		}

		function stopCycle() {
			if (timer) {
				clearInterval(timer);
				timer = null;
			}
		}

		function startCycle() {
			if (reduceMotion) return;
			stopCycle();
			timer = setInterval(() => {
				if (!hoverPaused) setActive((activeIdx + 1) % hls.length);
			}, CYCLE_MS);
		}

		hls.forEach((el, i) => {
			el.addEventListener('mouseenter', () => {
				hoverPaused = true;
				stopCycle();
				setActive(i);
			});
			el.addEventListener('mouseleave', () => {
				hoverPaused = false;
				startCycle();
			});
			el.addEventListener('focus', () => {
				hoverPaused = true;
				stopCycle();
				setActive(i);
			});
			el.addEventListener('blur', () => {
				hoverPaused = false;
				startCycle();
			});
		});

		// Double rAF so the browser actually paints the initial hidden state
		// (opacity 0, scale 0.8) BEFORE .is-active is added — without this,
		// a single rAF still runs before the first paint, so the transition
		// has nothing to interpolate from and the Devices cluster appears at
		// scale 1 instantly. Mirrors `heroIconsReady` in the platform.
		requestAnimationFrame(() => {
			requestAnimationFrame(() => {
				setActive(0);
				startCycle();
			});
		});
	})();
</script>
