---
// Material Icons font for the popup result cards (person glyph, type
// fallbacks). Each per-component import is deduped by Vite.
import '@fontsource/material-icons';

// Composite cluster SVGs — one per category, layered absolutely over the
// hero; the active one fades + scales in while the rest collapse out.
import devicesCluster from '@root/assets/iot-hub/hero-device-cluster.svg';
import solutionsCluster from '@root/assets/iot-hub/hero-solution-template-cluster.svg';
import widgetsCluster from '@root/assets/iot-hub/hero-widget-cluster.svg';
import calcFieldsCluster from '@root/assets/iot-hub/hero-calculated-field-cluster.svg';
import alarmRulesCluster from '@root/assets/iot-hub/hero-alarm-rule-cluster.svg';
import ruleChainsCluster from '@root/assets/iot-hub/hero-rule-chain-cluster.svg';

// Each highlight is an anchor to its category index (same routing as the
// tiles below), and hovering one immediately makes it the active accent.
// Colors per the design; slugs mirror IOT_HUB_CATEGORIES.
// `clusterTop` is the cluster's `y` inside the design hero frame;
// since the hero frame starts at y=80 (header height), this is also the gap
// from the header bottom — added to `$header-height` in the CSS.
const highlights = [
	{ slug: 'devices', label: 'Devices,', color: '#4c63cc', cluster: devicesCluster, clusterTop: 57 },
	{ slug: 'solution-templates', label: 'Solution Templates,', color: '#2c6cb4', cluster: solutionsCluster, clusterTop: 40 },
	{ slug: 'widgets', label: 'Widgets,', color: '#2c9755', cluster: widgetsCluster, clusterTop: 60 },
	{ slug: 'calculated-fields', label: 'Calculated Fields,', color: '#3db5e0', cluster: calcFieldsCluster, clusterTop: 80 },
	{ slug: 'alarm-rules', label: 'Alarm Rules', color: '#d7702f', cluster: alarmRulesCluster, clusterTop: 64 },
	{ slug: 'rule-chains', label: '& Rule Chains', color: '#bb7ce9', cluster: ruleChainsCluster, clusterTop: 40 },
];
---

<section class="iot-hub-hero">
	{
		highlights.map(({ slug, cluster, clusterTop }) => (
			<div class="iot-hub-hero__cluster" data-hl-cluster={slug} aria-hidden="true">
				<img
					class="iot-hub-hero__cluster-img"
					src={cluster.src}
					alt=""
					style={`--cluster-top: ${clusterTop}px;`}
				/>
			</div>
		))
	}
	<div class="iot-hub-hero__inner">
		<h1 class="iot-hub-hero__title">ThingsBoard IoT Hub</h1>
		<p class="iot-hub-hero__subtitle">
			<span class="iot-hub-hero__subtitle-lead">Discover ready-to-use</span>
			{
				highlights.map(({ slug, label, color }) => (
					<a
						class="iot-hub-hero__hl"
						href={`/iot-hub/${slug}/`}
						data-hl-color={color}
					>
						{label}
					</a>
				))
			}
		</p>
		<form
			class="iot-hub-hero__search"
			role="search"
			action="/iot-hub/search/"
			method="get"
			data-iot-hub-hero-search
		>
			<label class="iot-hub-hero__search-label" for="iot-hub-search">Search IoT Hub</label>
			<input
				id="iot-hub-search"
				class="iot-hub-hero__search-input"
				type="search"
				name="q"
				placeholder="Search in IoT Hub..."
				autocomplete="off"
			/>
			<button
				class="iot-hub-hero__search-clear"
				type="button"
				aria-label="Clear search"
				data-iot-hub-hero-clear
			>
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path
						d="M5 5 19 19M19 5 5 19"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"></path>
				</svg>
			</button>
			<button class="iot-hub-hero__search-button" type="submit" aria-label="Search">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path
						d="m21 21-4.3-4.3M11 19a8 8 0 1 1 0-16 8 8 0 0 1 0 16Z"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
			</button>
			<div
				class="iot-hub-hero__search-popup"
				hidden
				data-iot-hub-hero-popup
				role="listbox"
				aria-label="Search results"
			>
				<div class="iot-hub-hero__search-popup-body" data-popup-body></div>
				<a
					class="iot-hub-hero__search-popup-footer"
					href="/iot-hub/search/"
					data-popup-footer
				>
					See all results
				</a>
			</div>
		</form>
	</div>
</section>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;
	@use '~/styles/_iot-hub.scss' as *;

	.iot-hub-hero {
		position: relative;
		// Override the global `:where(section)` white fill so the dotted pattern
		// and blobs behind the top section show through (the design: transparent hero).
		background-color: transparent;
		// The fixed header ($header-height) overlays page content with no global
		// offset, so add it to the 180px the design gap between header and title top.
		// Bottom padding is 80px per the design (search input -> hero bottom gap).
		padding: calc(#{$header-height} + 180px) 1rem 80px;
		text-align: center;

		@include media-down(sm) {
			padding: calc(#{$header-height} + 140px) 0.75rem 40px;
		}
	}

	.iot-hub-hero__inner {
		max-width: 640px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		// Sit above the cluster overlays.
		position: relative;
		z-index: 1;
		// Page-load entrance: title/subtitle/search fade in and settle down
		// (port of tb-iot-hub-home's hero animation).
		animation: iot-hub-fade-slide-down 1s cubic-bezier(0.19, 1, 0.22, 1) 0.2s both;

		@include media-down(sm) {
			gap: 0.75rem;
		}
	}

	@keyframes iot-hub-fade-slide-down {
		from {
			opacity: 0;
			transform: translateY(-20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.iot-hub-hero__inner {
			animation: none;
		}
	}

	// Per-category cluster overlay (ported from tb-iot-hub-home). All six are
	// rendered absolutely on top of each other; the active one fades + scales
	// in while the rest collapse back toward the centre. The outer wrapper
	// handles the entry/exit animation around the hero centre; the inner img
	// positions and sizes the cluster art itself.
	.iot-hub-hero__cluster {
		position: absolute;
		inset: 0;
		pointer-events: none;
		opacity: 0;
		transform: scale(0.8);
		transform-origin: 50% 50%;
		transition: opacity 0.4s ease-out, transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
		z-index: 0;

		&.is-active {
			opacity: 1;
			transform: scale(1);
		}
	}

	.iot-hub-hero__cluster-img {
		position: absolute;
		// Per-cluster `--cluster-top` is set inline per highlight (its `y`
		// inside the design hero frame, which itself starts at $header-height).
		// Fallback matches the Devices state, which is the initial active.
		top: calc(#{$header-height} + var(--cluster-top, 57px));
		left: 50%;
		transform: translateX(-50%);
		width: min(890px, calc(100% - 80px));
		height: auto;
		display: block;
		pointer-events: none;

		@include media-down(lg) {
			top: calc(#{$header-height} + 80px);
		}

		@include media-down(md) {
			// Mobile uses a single top for all clusters (the design node is
			// desktop-only); the per-cluster var is intentionally overridden.
			top: calc(#{$header-height} + 90px);
			width: calc(100% - 32px);
		}

		@include media-down(sm) {
			top: calc(#{$header-height} + 50px);
		}

	}

	.iot-hub-hero__title {
		@include page-title;
		font-size: 60px;
		line-height: 1.2;
		margin: 0;
		color: var(--color-text);

		@include media-down(md) {
			font-size: 48px;
		}

		@include media-down(sm) {
			font-size: 40px;
		}

	}

	.iot-hub-hero__subtitle {
		font-size: 18px;
		line-height: 32px;
		margin: 0;
		max-width: 520px;
		color: var(--color-text-secondary);
		text-align: center;
		word-spacing: 0.1rem;

		@include media-down(sm) {
			font-size: 16px;
		}
	}

	.iot-hub-hero__subtitle-lead {
		// Lead text per the design (token: neutral/--sl-color-gray-2 = #353841).
		color: var(--sl-color-gray-2);
		margin-right: 0.2rem;
	}

	.iot-hub-hero__hl {
		display: inline;
		font-weight: $font-weight-semibold;
		// Muted gray for the off-state per the design (token: neutral/--sl-color-gray-5 = #c1c3c8).
		color: var(--sl-color-gray-5);
		text-decoration: none;
		cursor: pointer;
		transition: color $transition-fast;

		&.is-active {
			// Active accent is set by the cycle script (or hover/focus) on a
			// shared ancestor, so the blob background and this color always
			// match. See script at the bottom of this component.
			color: var(--iot-hub-active-accent, var(--color-primary));
		}
	}

	.iot-hub-hero__search {
		position: relative; // anchors the absolute-positioned search popup
		width: 100%;
		max-width: 528px;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0.5rem 0.5rem 1rem;
		margin-top: 1rem;
		min-height: 56px;
		background: var(--color-bg-surface);
		// Border + shadow per the design. Border uses the gray-4
		// token (#888c96 light / #555962 dark — see dark override below).
		border: 1px solid var(--neutral---sl-color-gray-4, #888c96);
		border-radius: 8px;
		box-shadow:
			0 178px 25px rgba(0, 0, 0, 0),
			0 114px 23px rgba(0, 0, 0, 0.01),
			0 64px 19px rgba(0, 0, 0, 0.02),
			0 29px 14.5px rgba(0, 0, 0, 0.03),
			0 7px 8px rgba(0, 0, 0, 0.04);
		transition: border-color $transition-fast;

		&:focus-within {
			border-color: var(--color-primary);
		}

		// `:global()` so the data-theme attribute on <html> (outside this
		// component's scope) is matched. Border swaps to the dark gray-4
		// token in dark theme.
		:global([data-theme='dark']) & {
			border-color: var(--neutral---sl-color-gray-4, #555962);
		}

		@include media-down(sm) {
			margin-top: 0.75rem;
		}
	}

	.iot-hub-hero__search-label {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.iot-hub-hero__search-input {
		flex: 1;
		min-width: 0;
		border: none;
		outline: none;
		background: transparent;
		font-size: 16px;
		line-height: 28px;
		color: var(--color-text);
		font-family: inherit;

		&::placeholder {
			color: var(--color-text-muted);
		}

		// Hide the browser's built-in `×` so our custom clear button (styled
		// to match the submit button) is the only one visible.
		&::-webkit-search-cancel-button,
		&::-webkit-search-decoration {
			-webkit-appearance: none;
			appearance: none;
		}
	}

	// Submit + clear share the same 40×40 icon-button chrome.
	.iot-hub-hero__search-button,
	.iot-hub-hero__search-clear {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border: none;
		background: transparent;
		border-radius: 8px;
		color: var(--color-text-secondary);
		cursor: pointer;
		transition: background $transition-fast, color $transition-fast;

		&:hover,
		&:focus-visible {
			background: var(--color-bg-light);
			color: var(--color-text);
		}
	}

	// Clear button only matters when the user has typed something. The
	// `:placeholder-shown` pseudo-class flips false as soon as the input
	// has a value, revealing the button — pure CSS, no JS needed for the
	// show/hide toggle (clicking the button still needs JS to wipe the
	// value; see the inline script below).
	.iot-hub-hero__search-input:placeholder-shown ~ .iot-hub-hero__search-clear {
		display: none;
	}

	// Tighten the clear→search gap to 4px (the form's flex gap is 8px).
	// Only applies when the clear button is visible (input has value);
	// when empty, the search button sits adjacent to the input at the
	// default 8px gap.
	.iot-hub-hero__search-input:not(:placeholder-shown) ~ .iot-hub-hero__search-button {
		margin-left: -4px;
	}

	// --- Search popup ---------------------------------------------------------
	// Dropped below the search input. Items are rendered client-side from the
	// IoT Hub API (see <script> below); the body classes use :global so the
	// JS-built DOM picks up these styles too.
	.iot-hub-hero__search-popup {
		position: absolute;
		top: 100%;
		left: 0;
		right: 0;
		display: flex;
		flex-direction: column;
		max-height: 424px;
		background: var(--color-bg-surface);
		border: 1px solid var(--neutral---sl-color-gray-4, #888c96);
		border-radius: 8px;
		box-shadow:
			0 7px 16px rgba(0, 0, 0, 0.04),
			0 29px 29px rgba(0, 0, 0, 0.03),
			0 64px 38px rgba(0, 0, 0, 0.02);
		z-index: 10;
		overflow: hidden;

		:global([data-theme='dark']) & {
			border-color: #353841;
		}

		&[hidden] {
			display: none;
		}
	}

	.iot-hub-hero__search-popup-body {
		flex: 1 1 auto;
		overflow-y: auto;
		padding: 8px 0;
	}

	.iot-hub-hero__search-popup-footer {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		min-height: 40px;
		padding: 8px 16px;
		border-top: 1px solid var(--color-border);
		background: var(--color-bg-surface);
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 20px;
		letter-spacing: 0.25px;
		color: var(--color-primary);
		text-decoration: none;
		cursor: pointer;

		&:hover,
		&:focus-visible {
			background: var(--color-bg-light);
			text-decoration: underline;
		}

		:global([data-theme='dark']) & {
			color: #b3c7ff;
			border-color: #353841;
		}
	}

	// --- Popup body content (client-rendered) ---------------------------------
	// All of these target classes that JS creates inside [data-popup-body].
	// They're :global so the unscoped JS-built DOM picks them up.

	:global(.iot-hub-hero__search-popup-group) {
		padding-bottom: 4px;
	}

	:global(.iot-hub-hero__search-popup-group + .iot-hub-hero__search-popup-group) {
		margin-top: 8px;
	}

	:global(.iot-hub-hero__search-popup-group-label) {
		padding: 4px 16px;
		min-height: 28px;
		display: flex;
		align-items: center;
		font-size: 14px;
		font-weight: $font-weight-medium;
		line-height: 20px;
		letter-spacing: 0.25px;
		color: var(--color-text-muted);
	}

	:global(.iot-hub-hero__search-popup-item) {
		display: flex;
		align-items: center;
		gap: 16px;
		padding: 8px 16px;
		text-decoration: none;
		color: inherit;

		&:hover,
		&:focus-visible {
			background: var(--color-bg-light);
			text-decoration: none;
		}
	}

	:global(.iot-hub-hero__search-popup-thumb) {
		flex-shrink: 0;
		width: 99px;
		height: 56px;
		border-radius: 4px;
		border: 1px solid var(--iot-hub-hairline, rgba(0, 0, 0, 0.12));
		background: rgba(0, 0, 0, 0.04);
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;

		img {
			width: 100%;
			height: 100%;
			object-fit: contain;
			display: block;
		}
	}

	:global([data-theme='dark']) :global(.iot-hub-hero__search-popup-thumb) {
		background: rgba(255, 255, 255, 0.04);
	}

	:global(.iot-hub-hero__search-popup-thumb--compact) {
		width: 56px;
		height: 56px;
		border: none;
		border-radius: 4.667px;
		color: #fff;
	}

	:global(.iot-hub-hero__search-popup-thumb-icon),
	:global(.iot-hub-hero__search-popup-thumb-fallback) {
		@include iot-hub-material-icon;
		font-size: 28px;
		line-height: 1;
	}

	:global(.iot-hub-hero__search-popup-thumb-fallback) {
		font-size: 24px;
		color: var(--color-text-muted);
	}

	:global(.iot-hub-hero__search-popup-text) {
		display: flex;
		flex-direction: column;
		gap: 4px;
		flex: 1 1 0;
		min-width: 0;
	}

	:global(.iot-hub-hero__search-popup-name) {
		font-size: 14px;
		font-weight: $font-weight-medium;
		line-height: 20px;
		letter-spacing: 0.25px;
		color: var(--color-text);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		text-align: start;
	}

	:global(.iot-hub-hero__search-popup-author) {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		font-size: 12px;
		line-height: 16px;
		letter-spacing: 0.25px;
		color: var(--color-text-muted);
		white-space: nowrap;
	}

	:global(.iot-hub-hero__search-popup-author-icon) {
		@include iot-hub-material-icon;
		font-size: 16px;
		line-height: 1;
	}

	:global(.iot-hub-hero__search-popup-status) {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 24px 16px;
		min-height: 80px;
		font-size: 14px;
		color: var(--color-text-muted);
	}

	:global(.iot-hub-hero__search-popup-empty) {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 16px;
		font-size: 14px;
		color: var(--color-text-muted);
	}

	:global(.iot-hub-hero__search-popup-empty-icon) {
		@include iot-hub-material-icon;
		font-size: 24px;
		line-height: 1;
	}
</style>

<script is:inline>
	// Drives the active highlight in the IoT Hub hero: auto-cycle every 3s;
	// hover or focus a highlight to become active and pause the cycle, leave
	// to resume. The active accent is published as `--iot-hub-active-accent`
	// on the nearest `.iot-hub-home__top` so the background blobs follow the
	// same color via CSS custom-property inheritance.
	// Clear-button click handler: wipe the search input, return focus to it
	// so the user can keep typing, and dispatch `input` so any listeners
	// (and the :placeholder-shown re-eval) pick up the change.
	document.querySelectorAll('[data-iot-hub-hero-clear]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const form = btn.closest('form');
			const input = form && form.querySelector('input[type="search"]');
			// instanceof check both narrows the type for the editor and
			// guards against the (impossible at runtime) null case.
			if (input instanceof HTMLInputElement) {
				input.value = '';
				input.dispatchEvent(new Event('input', { bubbles: true }));
				input.focus();
			}
		});
	});

	(function () {
		const hero = document.querySelector('.iot-hub-hero');
		if (!hero) return;
		const hls = Array.from(hero.querySelectorAll('.iot-hub-hero__hl'));
		const clusters = Array.from(hero.querySelectorAll('.iot-hub-hero__cluster'));
		if (!hls.length) return;
		const accentHost = hero.closest('.iot-hub-home__top') ?? document.documentElement;
		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const CYCLE_MS = 3000;
		let activeIdx = 0;
		let hoverPaused = false;
		let timer = null;

		function setActive(idx) {
			activeIdx = idx;
			const el = hls[idx];
			for (let i = 0; i < hls.length; i++) {
				hls[i].classList.toggle('is-active', i === idx);
			}
			for (let i = 0; i < clusters.length; i++) {
				clusters[i].classList.toggle('is-active', i === idx);
			}
			if (el && el.dataset.hlColor) {
				accentHost.style.setProperty('--iot-hub-active-accent', el.dataset.hlColor);
			}
		}

		function stopCycle() {
			if (timer) {
				clearInterval(timer);
				timer = null;
			}
		}

		function startCycle() {
			if (reduceMotion) return;
			stopCycle();
			timer = setInterval(() => {
				if (!hoverPaused) setActive((activeIdx + 1) % hls.length);
			}, CYCLE_MS);
		}

		hls.forEach((el, i) => {
			el.addEventListener('mouseenter', () => {
				hoverPaused = true;
				stopCycle();
				setActive(i);
			});
			el.addEventListener('mouseleave', () => {
				hoverPaused = false;
				startCycle();
			});
			el.addEventListener('focus', () => {
				hoverPaused = true;
				stopCycle();
				setActive(i);
			});
			el.addEventListener('blur', () => {
				hoverPaused = false;
				startCycle();
			});
		});

		// Double rAF so the browser actually paints the initial hidden state
		// (opacity 0, scale 0.8) BEFORE .is-active is added — a single rAF
		// runs before the first paint, leaving the transition nothing to
		// interpolate from and the first cluster appears at scale 1 instantly.
		requestAnimationFrame(() => {
			requestAnimationFrame(() => {
				setActive(0);
				startCycle();
			});
		});
	})();
</script>

<script>
	// Hero search popup. Opens on focus, fetches /api/listings/published with
	// installCount DESC + a 10-item page, groups results by category in
	// IOT_HUB_CATEGORIES priority order, and renders each as a small card
	// linking to the listing detail. "See all results" footer keeps its
	// href in sync with the input so it always jumps to the same query as
	// the submit button would.
	import {
		IOT_HUB_API_URL,
		IOT_HUB_CATEGORIES,
		getCardVariant,
		getPlaceholderIcon,
		resolveImage,
		type IotHubItemType,
		type ListingView,
	} from '@models/iot-hub';

	const DEBOUNCE_MS = 300;
	const PAGE_SIZE = 10;
	const SEARCH_PATH = '/iot-hub/search/';

	// Fallback type icons mirror IotHubListingLink's getTypeIcon switch.
	const TYPE_FALLBACK_ICON: Record<string, string> = {
		WIDGET: 'widgets',
		SOLUTION_TEMPLATE: 'integration_instructions',
		CALCULATED_FIELD: 'functions',
		ALARM_RULE: 'notification_important',
		RULE_CHAIN: 'account_tree',
		DEVICE: 'memory',
	};

	const ITEM_TYPE_BY_CATEGORY = new Map(
		IOT_HUB_CATEGORIES.map((c) => [c.itemType, c])
	);

	function buildSearchUrl(text: string): string {
		const q = text.trim();
		return q ? `${SEARCH_PATH}?q=${encodeURIComponent(q)}` : SEARCH_PATH;
	}

	async function fetchListings(text: string, signal: AbortSignal): Promise<ListingView[]> {
		const params = new URLSearchParams({
			pageSize: String(PAGE_SIZE),
			page: '0',
			sortProperty: 'installCount',
			sortOrder: 'DESC',
		});
		const trimmed = text.trim();
		if (trimmed) params.set('textSearch', trimmed);
		const res = await fetch(
			`${IOT_HUB_API_URL}/api/listings/published?${params.toString()}`,
			{ signal }
		);
		if (!res.ok) throw new Error(`HTTP ${res.status}`);
		const body = (await res.json()) as { data: ListingView[] };
		return body.data ?? [];
	}

	// Group by itemType in IOT_HUB_CATEGORIES priority order. Items whose
	// itemType isn't in the registry (defensive) are dropped.
	type Group = { label: string; items: ListingView[] };
	function groupByCategory(items: ListingView[]): Group[] {
		const byType = new Map<IotHubItemType, ListingView[]>();
		for (const it of items) {
			const cat = ITEM_TYPE_BY_CATEGORY.get(it.itemType as IotHubItemType);
			if (!cat) continue;
			const list = byType.get(cat.itemType) ?? [];
			list.push(it);
			byType.set(cat.itemType, list);
		}
		return IOT_HUB_CATEGORIES
			.filter((c) => byType.has(c.itemType))
			.map((c) => ({ label: c.label, items: byType.get(c.itemType)! }));
	}

	// Build one result card. Mirrors IotHubListingLink visually; uses the
	// same class names (declared :global in the component's <style>).
	function renderCard(item: ListingView): HTMLAnchorElement {
		const cat = ITEM_TYPE_BY_CATEGORY.get(item.itemType as IotHubItemType);
		const href = cat ? `/iot-hub/${cat.slug}/${item.slug}/` : '#';
		const a = document.createElement('a');
		a.className = 'iot-hub-hero__search-popup-item';
		a.href = href;

		const isCompact = getCardVariant(item.itemType) === 'small';
		const thumb = document.createElement('span');
		thumb.className = 'iot-hub-hero__search-popup-thumb';
		thumb.setAttribute('aria-hidden', 'true');
		if (isCompact) {
			thumb.classList.add('iot-hub-hero__search-popup-thumb--compact');
			thumb.style.background = item.color ?? '#048ad3';
			const glyph = document.createElement('span');
			glyph.className = 'iot-hub-hero__search-popup-thumb-icon';
			glyph.textContent = textIcon(getPlaceholderIcon(item), item.itemType);
			thumb.appendChild(glyph);
		} else {
			const imageUrl = resolveImage(item.image);
			if (imageUrl) {
				const img = document.createElement('img');
				img.src = imageUrl;
				img.alt = '';
				img.loading = 'lazy';
				img.decoding = 'async';
				thumb.appendChild(img);
			} else {
				const fallback = document.createElement('span');
				fallback.className = 'iot-hub-hero__search-popup-thumb-fallback';
				fallback.textContent = TYPE_FALLBACK_ICON[item.itemType] ?? 'category';
				thumb.appendChild(fallback);
			}
		}
		a.appendChild(thumb);

		const text = document.createElement('span');
		text.className = 'iot-hub-hero__search-popup-text';
		const name = document.createElement('span');
		name.className = 'iot-hub-hero__search-popup-name';
		name.textContent = item.name;
		text.appendChild(name);
		if (item.creatorDisplayName) {
			const author = document.createElement('span');
			author.className = 'iot-hub-hero__search-popup-author';
			const icon = document.createElement('span');
			icon.className = 'iot-hub-hero__search-popup-author-icon';
			icon.textContent = 'person';
			author.appendChild(icon);
			author.append(' ', item.creatorDisplayName);
			text.appendChild(author);
		}
		a.appendChild(text);
		return a;
	}

	// MDI icons aren't in the Material Icons font; substitute a type fallback
	// rather than render a junk glyph.
	function textIcon(rawIcon: string, itemType: string): string {
		if (rawIcon.startsWith('mdi:')) {
			return TYPE_FALLBACK_ICON[itemType] ?? 'category';
		}
		return rawIcon;
	}

	function renderState(
		body: HTMLElement,
		state: 'loading' | 'empty' | 'error',
		query: string
	): void {
		body.replaceChildren();
		if (state === 'loading') {
			const div = document.createElement('div');
			div.className = 'iot-hub-hero__search-popup-status';
			div.textContent = 'Loading…';
			body.appendChild(div);
		} else if (state === 'empty') {
			const div = document.createElement('div');
			div.className = 'iot-hub-hero__search-popup-empty';
			const icon = document.createElement('span');
			icon.className = 'iot-hub-hero__search-popup-empty-icon';
			icon.textContent = 'search_off';
			div.appendChild(icon);
			const msg = document.createElement('span');
			msg.textContent = query.trim()
				? `No results for "${query.trim()}"`
				: 'No items available';
			div.appendChild(msg);
			body.appendChild(div);
		} else {
			const div = document.createElement('div');
			div.className = 'iot-hub-hero__search-popup-status';
			div.textContent = 'Couldn’t load results';
			body.appendChild(div);
		}
	}

	function renderGroups(body: HTMLElement, groups: Group[]): void {
		body.replaceChildren();
		for (const group of groups) {
			const section = document.createElement('div');
			section.className = 'iot-hub-hero__search-popup-group';
			const label = document.createElement('div');
			label.className = 'iot-hub-hero__search-popup-group-label';
			label.textContent = group.label;
			section.appendChild(label);
			for (const item of group.items) {
				section.appendChild(renderCard(item));
			}
			body.appendChild(section);
		}
	}

	function setupPopup(form: HTMLFormElement): void {
		const input = form.querySelector<HTMLInputElement>('input[type="search"]');
		const popup = form.querySelector<HTMLElement>('[data-iot-hub-hero-popup]');
		const body = form.querySelector<HTMLElement>('[data-popup-body]');
		const footer = form.querySelector<HTMLAnchorElement>('[data-popup-footer]');
		if (!input || !popup || !body || !footer) return;

		let abort: AbortController | null = null;
		let debounceTimer: number | undefined;
		let lastQuery = '␀'; // sentinel: never matches a real first value

		function updateFooter(q: string): void {
			footer!.href = buildSearchUrl(q);
		}

		function runSearch(text: string, force = false): void {
			if (!force && text === lastQuery) return;
			lastQuery = text;
			if (abort) abort.abort();
			abort = new AbortController();
			renderState(body!, 'loading', text);
			updateFooter(text);
			fetchListings(text, abort.signal)
				.then((items) => {
					if (items.length === 0) renderState(body!, 'empty', text);
					else renderGroups(body!, groupByCategory(items));
				})
				.catch((err: unknown) => {
					if (err instanceof DOMException && err.name === 'AbortError') return;
					renderState(body!, 'error', text);
				});
		}

		function openPopup(): void {
			popup!.hidden = false;
			runSearch(input!.value, true);
		}

		function closePopup(): void {
			popup!.hidden = true;
			if (abort) {
				abort.abort();
				abort = null;
			}
			if (debounceTimer !== undefined) {
				clearTimeout(debounceTimer);
				debounceTimer = undefined;
			}
		}

		input.addEventListener('focus', openPopup);
		input.addEventListener('input', () => {
			updateFooter(input.value);
			if (debounceTimer !== undefined) clearTimeout(debounceTimer);
			debounceTimer = window.setTimeout(() => runSearch(input.value), DEBOUNCE_MS);
		});
		input.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') {
				closePopup();
				input.blur();
			}
		});
		// Hide when the user clicks anywhere outside the form. Clicks on
		// popup result links navigate away (full reload), so we don't need
		// to intercept those.
		document.addEventListener('click', (e) => {
			if (!form.contains(e.target as Node)) closePopup();
		});
	}

	document
		.querySelectorAll<HTMLFormElement>('[data-iot-hub-hero-search]')
		.forEach(setupPopup);
</script>
