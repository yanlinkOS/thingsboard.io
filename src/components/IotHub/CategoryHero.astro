---
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';
import {
	IOT_HUB_API_URL,
	IOT_HUB_CATEGORIES,
	type IotHubCategorySlug,
} from '@models/iot-hub';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import Chevron from '@components/Chevron.astro';

import deviceHero from '@root/assets/iot-hub/items-page-devices-hero.svg';
import solutionHero from '@root/assets/iot-hub/items-page-solution-templates-hero.png';
import widgetHero from '@root/assets/iot-hub/items-page-widgets-hero.svg';
import calcFieldHero from '@root/assets/iot-hub/items-page-calculated-fields-hero.svg';
import alarmHero from '@root/assets/iot-hub/items-page-alarm-rules-hero.svg';
import ruleChainHero from '@root/assets/iot-hub/items-page-rule-chains-hero.svg';

interface Props {
	categorySlug: IotHubCategorySlug | string;
}

const { categorySlug } = Astro.props;

const heroBySlug: Record<string, ImageMetadata> = {
	devices: deviceHero,
	'solution-templates': solutionHero,
	widgets: widgetHero,
	'calculated-fields': calcFieldHero,
	'alarm-rules': alarmHero,
	'rule-chains': ruleChainHero,
};

const cat = IOT_HUB_CATEGORIES.find((c) => c.slug === categorySlug);
const heroImage = heroBySlug[categorySlug];
const heroOptimized = heroImage ? await getImage({ src: heroImage }) : null;
const HERO_HEIGHT = 276;
const heroWidth = heroImage
	? Math.round((heroImage.width / heroImage.height) * HERO_HEIGHT)
	: 0;
const title = cat?.tileLabel ?? '';
const description = cat?.heroDescription ?? '';
const contributeHref = `${IOT_HUB_API_URL}/signup`;
const HERO_PLACEHOLDER =
	'data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==';
---

<section class="iot-hub-cat-hero">
	<Breadcrumbs jsonLd items={[{ label: 'IoT Hub', href: '/iot-hub/' }, { label: title }]} />

	<div class="iot-hub-cat-hero__main">
		<div class="iot-hub-cat-hero__text">
			<h1 class="iot-hub-cat-hero__title">{title}</h1>
			{description && <p class="iot-hub-cat-hero__desc">{description}</p>}
			<a
				class="iot-hub-cat-hero__cta"
				href={contributeHref}
				target="_blank"
				rel="noopener"
			>
				<span>Contribute</span>
				<Chevron direction="right" />
			</a>
		</div>
		{
			heroOptimized && (
				<picture
					class="iot-hub-cat-hero__image"
					style={`width: ${heroWidth}px;`}
				>
					<source media="(min-width: 1024px)" srcset={heroOptimized.src} />
					<img
						src={HERO_PLACEHOLDER}
						alt=""
						width={heroWidth}
						height={HERO_HEIGHT}
					/>
				</picture>
			)
		}
	</div>
</section>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-cat-hero {
		padding: 40px 16px 40px;
		display: flex;
		flex-direction: column;
		gap: 16px;

		@include media-down(sm) {
			padding: 40px 12px 40px;
		}
	}

	.iot-hub-cat-hero__main {
		display: flex;
		align-items: center;
		gap: 40px;
		min-height: 276px;

		@include media-down(lg) {
			min-height: 0;
		}
	}

	.iot-hub-cat-hero__text {
		flex: 1 1 0;
		min-width: 0;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 20px;
	}

	.iot-hub-cat-hero__title {
		font-size: 32px;
		font-weight: $font-weight-semibold;
		line-height: 40px;
		margin: 0;
		color: var(--color-text);
	}

	.iot-hub-cat-hero__desc {
		font-size: 16px;
		font-weight: $font-weight-normal;
		line-height: 28px;
		margin: 0;
		max-width: 800px;
		color: var(--sl-color-gray-2);
	}

	.iot-hub-cat-hero__cta {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		padding: 8px 16px;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		text-decoration: none;
		color: var(--color-primary);
		border: 1px solid var(--color-primary);
		border-radius: 8px;
		background: transparent;
		transition: background $transition-fast, color $transition-fast;

		&:hover,
		&:focus-visible {
			background: var(--color-primary);
			color: #fff;
			text-decoration: none;
		}

		svg {
			display: block;
		}

		:global([data-theme='dark']) & {
			color: #b3c7ff;
			border-color: #b3c7ff;

			&:hover,
			&:focus-visible {
				background: #b3c7ff;
				color: #17181c;
			}
		}
	}

	.iot-hub-cat-hero__image {
		flex-shrink: 0;
		height: 276px;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;

		img {
			width: 100%;
			height: 100%;
			object-fit: contain;
			display: block;
		}

		@include media-down(lg) {
			display: none;
		}
	}
</style>
