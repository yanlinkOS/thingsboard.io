---
import {
	DEFAULT_IOT_HUB_SORT_ID,
	IOT_HUB_SORT_OPTIONS,
	getIotHubSortOption,
} from '@models/iot-hub';
import Chevron from '@components/Chevron.astro';
import IotHubIcon from './IotHubIcon.astro';

// Sort selector reused across the IoT Hub filter bars. Renders a button
// with the current option's label + chevron and a dropdown that lists all
// IOT_HUB_SORT_OPTIONS.
//
// Selection is mirrored back to the host via a bubbling CustomEvent on the
// root element:
//   <iot-hub-sort:change detail={ id: IotHubSortId }>
// Listen on the bar's `data-iot-hub-sort` root (or any ancestor) to react.
//
// Visual chrome matches the figma sort tokens:
//   * default button — transparent bg, primary-cta text, chevron-down
//   * hovered / open  — `--sl-color-gray-6` bg
//   * dropdown panel  — surface bg, hairline border, soft drop shadow
//   * selected row    — `--sl-color-gray-6` bg + primary-cta text + check
//   * unselected row  — gray-2 text, transparent bg, gray-6 on hover

interface Props {
	/** Initial selection id; defaults to `'most-installed'`. */
	initialSortId?: string;
}

const { initialSortId = DEFAULT_IOT_HUB_SORT_ID } = Astro.props;
const initial = getIotHubSortOption(initialSortId);
---

<div
	class="iot-hub-sort"
	data-iot-hub-sort
	data-sort-id={initial.id}
>
	<button
		class="iot-hub-sort__button"
		type="button"
		data-sort-button
		aria-expanded="false"
	>
		<span class="iot-hub-sort__label" data-sort-label>{initial.label}</span>
		<Chevron direction="down" />
	</button>
	<div
		class="iot-hub-sort__popup"
		hidden
		data-sort-popup
		role="group"
		aria-label="Sort order"
	>
		{IOT_HUB_SORT_OPTIONS.map((opt) => (
			<button
				class:list={[
					'iot-hub-sort__option',
					opt.id === initial.id && 'iot-hub-sort__option--selected',
				]}
				type="button"
				data-sort-option
				data-sort-option-id={opt.id}
				aria-pressed={opt.id === initial.id}
			>
				<span class="iot-hub-sort__option-text">{opt.label}</span>
				<IotHubIcon
					icon="check"
					size={24}
					class="iot-hub-sort__option-check"
				/>
			</button>
		))}
	</div>
</div>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-sort {
		position: relative;
		display: inline-flex;
		flex-shrink: 0;
	}

	// --- Trigger button ------------------------------------------------------

	.iot-hub-sort__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0;
		padding: 8px;
		font-family: inherit;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: var(--color-primary);
		background: transparent;
		border: none;
		border-radius: 8px;
		cursor: pointer;
		transition: background-color $transition-fast;

		:global([data-theme='dark']) & {
			color: #b3c7ff;
		}

		// Hover and open states share the same gray-6 tinted background.
		&:hover,
		&[aria-expanded='true'] {
			background: var(--sl-color-gray-6);
		}

		svg {
			display: block;
		}
	}

	.iot-hub-sort__label {
		padding: 0 4px;
		white-space: nowrap;
	}

	// --- Popup panel ---------------------------------------------------------

	.iot-hub-sort__popup {
		position: absolute;
		top: calc(100% + 4px);
		right: 0;
		min-width: 200px;
		display: flex;
		flex-direction: column;
		padding: 4px;
		background: var(--color-bg-surface);
		border: 1px solid var(--iot-hub-hairline, rgba(0, 0, 0, 0.12));
		border-radius: 8px;
		box-shadow:
			0 1px 0.5px rgba(0, 0, 0, 0.12),
			0 2px 0.5px rgba(0, 0, 0, 0.24);
		z-index: 20;

		:global([data-theme='dark']) & {
			border-color: #23262f;
			background: #17181c;
		}

		// Same enter animation as the hero autocomplete popup so the
		// transition timing across IoT Hub feels uniform.
		transform-origin: top right;
		animation: iot-hub-sort-popup-enter 120ms cubic-bezier(0, 0, 0.2, 1);

		&[hidden] {
			display: none;
		}
	}

	@keyframes iot-hub-sort-popup-enter {
		from {
			transform: scaleY(0);
			opacity: 0;
		}
		to {
			transform: scaleY(1);
			opacity: 1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.iot-hub-sort__popup {
			animation: none;
		}
	}

	// --- Option rows ---------------------------------------------------------

	.iot-hub-sort__option {
		display: flex;
		align-items: center;
		gap: 8px;
		width: 100%;
		padding: 8px 12px;
		font-family: inherit;
		font-size: 14px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: var(--sl-color-gray-2);
		background: transparent;
		border: none;
		border-radius: 5px;
		cursor: pointer;
		text-align: left;
		transition: background-color $transition-fast;

		&:hover {
			background: var(--sl-color-gray-6);
		}

		&:focus-visible {
			outline: 2px solid var(--color-primary);
			outline-offset: -2px;
		}
	}

	.iot-hub-sort__option-text {
		flex: 1 1 0;
		min-width: 0;
	}

	.iot-hub-sort__option-check {
		flex-shrink: 0;
		visibility: hidden;
	}

	.iot-hub-sort__option--selected {
		background: var(--sl-color-gray-6);
		color: var(--color-primary);

		:global([data-theme='dark']) & {
			color: #b3c7ff;
		}

		.iot-hub-sort__option-check {
			visibility: visible;
		}
	}
</style>

<script>
	// Behaviour:
	//   * Click button → toggle popup; `aria-expanded` mirrors the state
	//     (also drives the open-state background via the CSS attribute
	//     selector).
	//   * Click option → mark selected, update button label, update root
	//     `data-sort-id`, close popup, dispatch `iot-hub-sort:change`.
	//   * Click outside the root → close popup.
	//   * Escape → close popup and return focus to the trigger.

	function setupSort(root: HTMLElement) {
		if (root.dataset.sortInited) return;
		root.dataset.sortInited = 'true';

		const button = root.querySelector<HTMLButtonElement>('[data-sort-button]');
		const popup = root.querySelector<HTMLElement>('[data-sort-popup]');
		const label = root.querySelector<HTMLElement>('[data-sort-label]');
		if (!button || !popup || !label) return;

		const options = Array.from(
			root.querySelectorAll<HTMLButtonElement>('[data-sort-option]')
		);

		function openPopup() {
			popup!.hidden = false;
			button!.setAttribute('aria-expanded', 'true');
		}

		function closePopup() {
			popup!.hidden = true;
			button!.setAttribute('aria-expanded', 'false');
		}

		button.addEventListener('click', (e) => {
			e.stopPropagation();
			if (popup.hidden) openPopup();
			else closePopup();
		});

		for (const opt of options) {
			opt.addEventListener('click', (e) => {
				e.stopPropagation();
				const id = opt.dataset.sortOptionId ?? '';
				for (const o of options) {
					const isSelected = o === opt;
					o.classList.toggle('iot-hub-sort__option--selected', isSelected);
					o.setAttribute('aria-pressed', String(isSelected));
				}
				const optLabel = opt.querySelector<HTMLElement>(
					'.iot-hub-sort__option-text'
				)?.textContent ?? '';
				label!.textContent = optLabel;
				root.dataset.sortId = id;
				closePopup();
				root.dispatchEvent(
					new CustomEvent('iot-hub-sort:change', {
						detail: { id },
						bubbles: true,
					})
				);
			});
		}

		// Close on outside click / Escape.
		document.addEventListener('click', (e) => {
			if (!popup.hidden && !root.contains(e.target as Node)) closePopup();
		});
		root.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && !popup.hidden) {
				closePopup();
				button!.focus();
			}
		});
	}

	function initAll() {
		document.querySelectorAll<HTMLElement>('[data-iot-hub-sort]').forEach(setupSort);
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initAll);
	} else {
		initAll();
	}
	document.addEventListener('astro:page-load', initAll);
</script>
