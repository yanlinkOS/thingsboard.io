---
import { getInstallVerb, type IotHubItemType } from '@models/iot-hub';

interface Props {
	slug: string;
	itemType: IotHubItemType;
	name: string;
	affiliateId?: string | null;
	variant?: 'card' | 'hero';
}

const { slug, itemType, name, affiliateId = null, variant = 'card' } = Astro.props;
// "Connect" for devices, "Install" otherwise — same wording in both variants.
const label = getInstallVerb(itemType, variant);
---

<button
	type="button"
	class:list={['iot-hub-install-btn', `iot-hub-install-btn--${variant}`]}
	data-iot-hub-install-trigger
	data-slug={slug}
	data-item-type={itemType}
	data-affiliate-id={affiliateId ?? undefined}
	aria-label={`${label} ${name}`}
>
	<span>{label}</span>
</button>

<script>
	import '@components/IotHub/install-dialog';
</script>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.iot-hub-install-btn {
		font-family: inherit;
		cursor: pointer;
	}

	// --- card variant: mirrors the previous .iot-hub-card__cta outline -----
	.iot-hub-install-btn--card {
		margin-left: auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 4px 8px;
		font-size: 14px;
		font-weight: $font-weight-medium;
		line-height: 24px;
		border: 1px solid var(--color-border);
		border-radius: 4px;
		color: var(--color-primary);
		background: transparent;
		flex-shrink: 0;

		&:hover {
			border-color: var(--color-primary);
		}
	}

	// --- hero variant: filled primary CTA (detail page; not wired yet) -----
	.iot-hub-install-btn--hero {
		// `button-primary` already sets display/align/justify/border:none.
		@include button-primary;
		gap: 4px;
		align-self: flex-start;
		padding: 14px 16px;
		font-size: 16px;
		font-weight: $font-weight-semibold;
		line-height: 28px;
		border-radius: 8px;

		:global(svg) {
			display: block;
		}
		:global([data-theme='dark']) & {
			background-color: #b3c7ff;
			color: #17181c;
		}
	}
</style>
