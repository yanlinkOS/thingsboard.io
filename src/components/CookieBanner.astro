---
---

<div id="cookie-banner" aria-live="polite" aria-label="Cookie consent">
	<div class="cookie-text">
		<span class="cookie-title">Cookie policy</span>
		<p>
			Our website uses cookies to ensure site security and optimize your experience. By continuing
			to browse this site, you agree to the use of these cookies, in accordance with our <a
				href="/cookie-policy/">Cookie Policy</a
			>. For details on managing cookies, please adjust your browser settings.
		</p>
	</div>
	<div class="cookie-actions">
		<button id="cookie-accept" type="button">Accept</button>
		<button id="cookie-dismiss" type="button" aria-label="Dismiss">✕</button>
	</div>
</div>

<style is:global>
	#cookie-banner {
		display: none;
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		z-index: 9999;
		align-items: center;
		justify-content: center;
		gap: 24px;
		padding: 14px 24px;
		background: rgba(18, 24, 32, 0.88);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
		box-sizing: border-box;
	}

	#cookie-banner.is-visible {
		display: flex;
	}

	#cookie-banner .cookie-text {
		display: flex;
		flex-direction: column;
		gap: 4px;
		max-width: 1100px;
	}

	#cookie-banner .cookie-title {
		font-size: 16px;
		font-weight: 600;
		color: #fff;
		line-height: 1.3;
	}

	#cookie-banner p {
		margin: 0;
		font-size: 14px;
		line-height: 1.5;
		color: rgba(255, 255, 255, 0.85);
		text-align: left;
	}

	#cookie-banner a {
		color: #fff;
		text-decoration: underline;
		text-underline-offset: 2px;
		opacity: 0.75;
	}

	#cookie-banner a:hover {
		opacity: 1;
	}

	#cookie-banner .cookie-actions {
		display: flex;
		align-items: center;
		gap: 8px;
		flex-shrink: 0;
	}

	#cookie-banner button {
		cursor: pointer;
		border: none;
		font-family: inherit;
		font-size: 14px;
		font-weight: 500;
		line-height: 1;
		transition: opacity 0.15s;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		filter: none;
	}

	#cookie-banner button:hover {
		opacity: 0.8;
		filter: none;
	}

	#cookie-accept {
		background: #2a7dec !important;
		color: #fff !important;
		padding: 8px 20px;
		border-radius: 6px;
	}

	#cookie-dismiss {
		background: rgba(255, 255, 255, 0.1) !important;
		color: rgba(255, 255, 255, 0.7) !important;
		padding: 8px 10px;
		border-radius: 6px;
		font-size: 13px;
	}

	@media (max-width: 600px) {
		#cookie-banner {
			flex-direction: column;
			align-items: flex-start;
			gap: 14px;
			padding: 16px;
		}

		#cookie-banner p {
			font-size: 13px;
		}
	}
</style>

<script is:inline>
	(function () {
		function getCookie(name) {
			const match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
			return match ? decodeURIComponent(match[1]) : null;
		}

		function setCookie(name, value, days) {
			const expires = new Date(Date.now() + days * 864e5).toUTCString();
			document.cookie = name + '=' + encodeURIComponent(value) + '; expires=' + expires + '; path=/';
		}

		function dismiss() {
			setCookie('cookie-notice-dismissed', 'true', 365);
			var banner = document.getElementById('cookie-banner');
			if (banner) banner.classList.remove('is-visible');
		}

		if (getCookie('cookie-notice-dismissed') !== 'true') {
			var banner = document.getElementById('cookie-banner');
			if (banner) banner.classList.add('is-visible');
		}

		var acceptBtn = document.getElementById('cookie-accept');
		var dismissBtn = document.getElementById('cookie-dismiss');
		if (acceptBtn) acceptBtn.addEventListener('click', dismiss);
		if (dismissBtn) dismissBtn.addEventListener('click', dismiss);
	})();
</script>