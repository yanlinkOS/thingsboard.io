---
// RuleNodeCardGrid.astro
// Renders a responsive 3-column grid of rule node category cards.
// Each card has an image area (screenshot or SVG icon placeholder), title, description, and optional badge.
//
// Usage:
//   <RuleNodeCardGrid items={[
//     { href: '#filter-nodes', title: 'Filter', description: '...', icon: '/src/assets/images/...svg' },
//   ]} />

import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { Badge } from '@astrojs/starlight/components';

export interface CardItem {
	image?: string; // Raster screenshot path inside /src/assets/ (png/jpg/webp/gif) — optimized to WebP at build time
	icon?: string; // SVG icon path inside /src/assets/ — shown centered in placeholder when no image is provided
	alt?: string; // Alt text for the image; falls back to title
	title: string;
	href: string;
	description: string;
	badge?: string; // Badge label shown in the top-right corner of the image area
	badgeVariant?: 'default' | 'note' | 'tip' | 'caution' | 'danger' | 'success';
}

interface Props {
	items: CardItem[];
}

const { items } = Astro.props;

type OptimizedImage = Awaited<ReturnType<typeof getImage>>;

interface ProcessedItem extends CardItem {
	optimized: OptimizedImage | null; // Processed raster image; null when no image or path not found
	iconSrc: string | null; // Resolved SVG src URL; null when no icon or path not found
}

// Eager globs — all paths resolved at build time by Vite
const assetModules = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/**/*.{png,jpg,jpeg,webp,gif}',
	{ eager: true }
);

const svgModules = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.svg', {
	eager: true,
});

// Optimise raster images to WebP and resolve SVG src URLs for all items
const processedItems: ProcessedItem[] = await Promise.all(
	items.map(async (item) => {
		let optimized: OptimizedImage | null = null;
		if (item.image) {
			const mod = assetModules[item.image];
			if (mod)
				optimized = await getImage({ src: mod.default, format: 'webp', quality: 85, width: 480 });
		}
		const iconSrc = item.icon ? (svgModules[item.icon]?.default?.src ?? null) : null;
		return { ...item, optimized, iconSrc };
	})
);
---

<ul class="rn-grid">
	{
		processedItems.map((item) => (
			<li class="rn-card">
				<a href={item.href} class="rn-card__anchor">
					{/* Image area — shows optimised screenshot or SVG icon placeholder */}
					<div class="rn-card__img-wrap">
						{item.optimized ? (
							<img
								src={item.optimized.src}
								alt={item.alt ?? item.title}
								width={item.optimized.attributes.width}
								height={item.optimized.attributes.height}
								loading="lazy"
								decoding="async"
							/>
						) : (
							<div class="rn-card__placeholder" aria-hidden="true">
								{item.iconSrc && (
									<img src={item.iconSrc} alt="" class="rn-card__placeholder-icon" />
								)}
							</div>
						)}
						{/* Badge — absolute-positioned in the top-right corner of the image area */}
						{item.badge && (
							<span class="rn-card__badge">
								<Badge text={item.badge} variant={item.badgeVariant ?? 'default'} />
							</span>
						)}
					</div>
					{/* Card body — title and description */}
					<div class="rn-card__body">
						<h4 class="rn-card__title">{item.title}</h4>
						<p class="rn-card__desc">{item.description}</p>
					</div>
				</a>
			</li>
		))
	}
</ul>

<style>
	/* Grid layout — 3 columns desktop, 2 tablet, 1 mobile */
	.rn-grid {
		list-style: none;
		padding: 0;
		margin: 1.5rem 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		align-items: stretch;
		gap: 1rem;
	}

	@media (max-width: 900px) {
		.rn-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 480px) {
		.rn-grid {
			grid-template-columns: 1fr;
		}
	}

	/* Card */
	.rn-card {
		height: 100%;
		margin-top: 0;
		border: 1px solid var(--sl-color-gray-5);
		overflow: hidden;
		transition: border-color 0.15s;
	}

	.rn-card:hover {
		border-color: var(--sl-color-text-accent);
	}

	.rn-card__anchor {
		display: flex;
		flex-direction: column;
		height: 100%;
		text-decoration: none;
		color: inherit;
	}

	/* Image area */
	.rn-card__img-wrap {
		padding: 0.75rem 1rem 1rem;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		position: relative;
	}

	.rn-card__img-wrap img {
		object-fit: cover;
		display: block;
	}

	/* Placeholder — shown when no raster image is provided; grid background + centered SVG icon */
	.rn-card__placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: #eeeeee;
		background-image:
			linear-gradient(to right, var(--sl-color-gray-5) 1px, transparent 1px),
			linear-gradient(to bottom, var(--sl-color-gray-5) 1px, transparent 1px);
		background-size: 25px 25px;
	}

	/* SVG icon inside placeholder — scales up on card hover */
	.rn-card__placeholder-icon {
		height: 45px;
		object-fit: contain;
		transition: transform 0.2s ease;
	}

	.rn-card:hover .rn-card__placeholder-icon {
		transform: scale(1.2);
	}

	/* Card body */
	.rn-card__body {
		padding: 0.75rem 1rem 1rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		flex: 1;
		margin-top: 0;
	}

	.rn-card__title {
		margin: 0;
		font-size: 1.5rem;
		font-weight: 600;
		color: var(--sl-color-white);
		line-height: 1.4;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.375rem;
	}

	.rn-card__desc {
		margin: 0;
		font-size: 0.8125rem;
		color: var(--sl-color-gray-2);
		line-height: 1.55;
	}

	/* Badge — absolute-positioned in the top-right corner of the image area */
	.rn-card__badge {
		position: absolute;
		top: 0;
		right: 0.5rem;
	}
</style>
