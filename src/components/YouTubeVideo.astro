---
interface Props {
	videoId: string;
	title?: string;
}

const { videoId, title = 'YouTube video' } = Astro.props;
---

<div class="yt-video">
	<iframe
		src={`https://www.youtube.com/embed/${videoId}`}
		title={title}
		referrerpolicy="strict-origin-when-cross-origin"
		frameborder="0"
		allowfullscreen></iframe>
</div>

<style>
	.yt-video {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
		margin: 1.5rem 0;
		border-radius: 8px;
		overflow: hidden;
		background: #000;
	}

	.yt-video iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: none;
	}
</style>
