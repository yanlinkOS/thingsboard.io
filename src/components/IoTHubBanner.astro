---
// Inline marketing block for doc pages — placed after a feature description
// to surface the IoT Hub catalog of pre-built templates.
//
// Usage:
//   <IoTHubBanner />                        — generic text (all catalog types)
//   <IoTHubBanner item="Rule Chain" />      — item-specific text
//   <IoTHubBanner item="Alarm Rule" href="/iot-hub/alarm-rules/" />
//   <IoTHubBanner href="...">Custom text with <strong>markup</strong>.</IoTHubBanner>

interface Props {
	/** Specific catalog item type shown in the text, e.g. "Rule Chain". Omit for generic copy or when using a slot. */
	item?: string;
	/** Link target. Defaults to the IoT Hub catalog landing page. */
	href?: string;
}

const { item, href = '/iot-hub/' } = Astro.props;
const hasSlot = Astro.slots.has('default');
---

<div class="iot-hub-banner">
	<span class="iot-hub-banner__pill">IoT Hub</span>
	{hasSlot
		? <div class="iot-hub-banner__text"><slot /></div>
		: <p class="iot-hub-banner__text">
				ThingsBoard <strong>IoT Hub</strong> includes a growing catalog of
				{item
					? <> pre-built <strong>{item}</strong> templates</>
					: ' ready-to-use rule chains, alarm rules, calculated fields, and widgets'}
				— contributed by experts for installed with one click. Find one that fits your use case and
				skip the manual setup.
			</p>
	}
	<a href={href} class="iot-hub-banner__link" target="_blank" rel="noopener noreferrer">
		Browse the catalog <span class="iot-hub-banner__arrow" aria-hidden="true">→</span>
	</a>
</div>

<style lang="scss">
	@use '../styles/variables' as *;

	.iot-hub-banner {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.25rem 1.5rem;
		margin-block: 1.5rem;
		border: 1px solid rgba(61, 80, 245, 0.3);
		border-radius: 0.75rem;
		background-image: linear-gradient(
			180deg,
			rgba(61, 80, 245, 0.06) 0%,
			rgba(61, 80, 245, 0) 100%
		);

		[data-theme='dark'] & {
			border-color: rgba(120, 140, 220, 0.3);
			background-image: linear-gradient(
				180deg,
				rgba(120, 140, 220, 0.08) 0%,
				rgba(120, 140, 220, 0) 100%
			);
		}
	}

	.iot-hub-banner__pill {
		display: inline-flex;
		align-items: center;
		padding: 2px 10px;
		border-radius: $radius-full;
		border: 1px solid rgba(61, 80, 245, 0.4);
		background: rgba(61, 80, 245, 0.08);
		color: #3d50f5;
		font-size: 0.6875rem;
		font-weight: $font-weight-bold;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		width: fit-content;

		[data-theme='dark'] & {
			border-color: rgba(179, 199, 255, 0.3);
			background: rgba(120, 140, 220, 0.12);
			color: #b3c7ff;
		}
	}

	.iot-hub-banner__text {
		margin: 0;
		line-height: 1.65;
		color: var(--sl-color-text);

		// Reset margin on the <p> MDX injects when slot content is used
		:global(p) {
			margin: 0;
		}
	}

	.iot-hub-banner__link {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		font-weight: $font-weight-semibold;
		color: #3d50f5;
		text-decoration: none;
		width: fit-content;

		[data-theme='dark'] & {
			color: #b3c7ff;
		}

		&:hover {
			text-decoration: underline;
			text-underline-offset: 2px;
		}
	}

	.iot-hub-banner__arrow {
		display: inline-block;
		transition: transform 0.15s ease;

		.iot-hub-banner__link:hover & {
			transform: translateX(3px);
		}
	}
</style>
