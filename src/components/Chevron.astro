---
interface Props {
	direction: 'left' | 'right' | 'down';
	size?: number;
	class?: string;
}

const { direction, size = 20, class: className } = Astro.props;

const paths: Record<Props['direction'], string> = {
	left: 'm15 6-6 6 6 6',
	right: 'm9 6 6 6-6 6',
	down: 'm6 9 6 6 6-6',
};
---

<svg
	class={className}
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	aria-hidden="true"
>
	<path
		d={paths[direction]}
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"></path>
</svg>
