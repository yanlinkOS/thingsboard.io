---
import { CHEVRON_PATHS, type ChevronDirection } from '@components/chevron-paths';

interface Props {
	direction: ChevronDirection;
	size?: number;
	class?: string;
}

const { direction, size = 20, class: className } = Astro.props;
---

<svg
	class={className}
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	aria-hidden="true"
>
	<path
		d={CHEVRON_PATHS[direction]}
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"></path>
</svg>
