---
const ports = [
	{ label: 'MQTT (TCP)',           value: '1883' },
	{ label: 'MQTTS (TLS)',          value: '8883' },
	{ label: 'WS (WebSocket)',       value: '8084' },
	{ label: 'WSS (WebSocket TLS)',  value: '443'  },
];
---

<div class="ldc-card">
	<div class="ldc-header">
		<!-- Host: copy button is position:absolute so it never inflates row height -->
		<div class="ldc-host-row">
			<span class="ldc-host">demo.tbmq.io</span>
			<button class="ldc-copy ldc-host-copy" data-value="demo.tbmq.io" aria-label="Copy host">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
				</svg>
			</button>
		</div>
		<!-- Status pill -->
		<div class="ldc-status" aria-live="polite">
			<span class="ldc-dot" aria-hidden="true"></span>
			<span class="ldc-status-text">Checking</span>
		</div>
	</div>

	<div class="ldc-divider"></div>

	<div class="ldc-section">
		{ports.map(({ label, value }) => (
			<div class="ldc-row">
				<span class="ldc-label">{label}</span>
				<div class="ldc-value-group">
					<span class="ldc-value">{value}</span>
					<button class="ldc-copy" data-value={value} aria-label={`Copy port ${value}`}>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
						</svg>
					</button>
				</div>
			</div>
		))}

		<div class="ldc-row-sep"></div>

		<div class="ldc-row">
			<span class="ldc-label">CA Certificate</span>
			<a class="ldc-cert-link" href="/resources/tbmq-demo-root-ca.pem" download="tbmq-demo-root-ca.pem">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
				</svg>
				tbmq-demo-root-ca.pem
			</a>
		</div>
		<div class="ldc-row">
			<span class="ldc-label">Username</span>
			<span class="ldc-value">demo</span>
		</div>
		<div class="ldc-row">
			<span class="ldc-label">Password</span>
			<span class="ldc-value ldc-muted">None required</span>
		</div>
	</div>
</div>

<style>
	/* ── Card shell ── */
	.ldc-card {
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-hairline-light);
		border-radius: 0.875rem;
		padding: 1.25rem 1.5rem;
		max-width: 38rem;
		margin-block: 1.75rem;
	}

	/* ────────────────────────────────────────────
	   Header
	   Both children rely solely on their OWN text
	   height for vertical centering — the copy
	   button is position:absolute so it never
	   inflates .ldc-host-row's block size.
	──────────────────────────────────────────── */
	.ldc-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.ldc-host-row {
		/* position:relative is the anchor for the abs. copy button */
		position: relative;
		display: flex;
		align-items: center;
		/* padding-right reserves space so the copy btn never overlaps status */
		padding-right: 1.75rem;
		line-height: 1;
	}

	.ldc-host {
		font-family: var(--sl-font-mono);
		font-size: 1rem;
		font-weight: 600;
		color: var(--sl-color-white);
		letter-spacing: -0.015em;
		line-height: 1;
	}

	/* Copy button floats OUTSIDE normal flow → zero height contribution */
	.ldc-host-copy {
		position: absolute;
		left: 100%;
		/* horizontally just outside the text, vertically dead-center */
		margin-left: -1.5rem; /* sits at the reserved padding-right space */
		top: 50%;
		transform: translateY(-50%);
		opacity: 0;
		transition: opacity 0.15s, color 0.15s, background 0.15s;
	}

	.ldc-host-row:hover .ldc-host-copy,
	.ldc-host-copy:focus-visible {
		opacity: 1;
	}

	/* ── Status pill ── */
	.ldc-status {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.25rem 0.625rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--sl-color-gray-4) 15%, transparent);
		line-height: 1;
		transition: background 0.4s;
		flex-shrink: 0;
	}

	.ldc-status.online  { background: rgba(48, 209, 88,  0.14); }
	.ldc-status.offline { background: rgba(255, 69, 58, 0.14); }

	.ldc-dot {
		position: relative;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--sl-color-gray-4);
		flex-shrink: 0;
		transition: background 0.4s;
	}

	.ldc-dot.online  { background: #30d158; }
	.ldc-dot.offline { background: #ff453a; }

	/* Ripple ring — absolute, never affects layout */
	.ldc-dot::after {
		content: '';
		position: absolute;
		inset: -3px;
		border-radius: 50%;
		opacity: 0;
		pointer-events: none;
	}

	.ldc-dot.online::after {
		background: #30d158;
		animation: ldc-ripple 2s ease-out infinite;
	}

	.ldc-dot.offline::after {
		background: #ff453a;
		animation: ldc-ripple 3s ease-out infinite;
	}

	@keyframes ldc-ripple {
		0%   { transform: scale(1);   opacity: 0.5; }
		100% { transform: scale(3.5); opacity: 0;   }
	}

	.ldc-status-text {
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		color: var(--sl-color-gray-3);
		transition: color 0.4s;
		line-height: 1;
	}

	.ldc-status-text.online  { color: #30d158; }
	.ldc-status-text.offline { color: #ff453a; }

	/* ── Divider ── */
	.ldc-divider {
		height: 1px;
		background: var(--sl-color-hairline-light);
		margin-block: 1rem;
	}

	/* ── Section / rows ── */
	.ldc-section {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}

	.ldc-row {
		display: grid;
		grid-template-columns: minmax(8rem, 11.5rem) 1fr;
		align-items: center;
		gap: 0.5rem;
		padding: 0.35rem 0.5rem;
		border-radius: 0.375rem;
		transition: background 0.12s;
	}

	.ldc-row:hover { background: var(--sl-color-gray-6); }

	/* Copy buttons inside rows: hidden until row is hovered */
	.ldc-row .ldc-copy {
		opacity: 0;
		transition: opacity 0.12s, color 0.12s, background 0.12s;
	}

	.ldc-row:hover .ldc-copy,
	.ldc-row .ldc-copy:focus-visible {
		opacity: 1;
	}

	.ldc-row-sep {
		height: 1px;
		background: var(--sl-color-hairline-light);
		margin-block: 0.375rem;
	}

	/* ── Labels / values ── */
	.ldc-label {
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3);
		white-space: nowrap;
	}

	.ldc-value-group {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.ldc-value {
		font-family: var(--sl-font-mono);
		font-size: 0.8125rem;
		color: var(--sl-color-gray-1);
	}

	.ldc-muted {
		font-family: inherit;
		font-style: italic;
		color: var(--sl-color-gray-4);
	}

	/* ── Copy button base ── */
	.ldc-copy {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.375rem;
		height: 1.375rem;
		padding: 0;
		border: none;
		border-radius: 0.25rem;
		background: transparent;
		color: var(--sl-color-gray-3);
		cursor: pointer;
		flex-shrink: 0;
	}

	.ldc-copy:hover   { color: var(--sl-color-gray-1); background: var(--sl-color-gray-5); }
	.ldc-copy.copied  { color: #30d158; }

	/* ── Cert download link ── */
	.ldc-cert-link {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-family: var(--sl-font-mono);
		font-size: 0.8125rem;
		color: var(--sl-color-text-accent);
		text-decoration: none;
	}

	.ldc-cert-link:hover { text-decoration: underline; }
</style>

<script>
	const dot  = document.querySelector<HTMLElement>('.ldc-dot');
	const text = document.querySelector<HTMLElement>('.ldc-status-text');
	const pill = document.querySelector<HTMLElement>('.ldc-status');

	fetch('https://demo.tbmq.io', { mode: 'no-cors' })
		.then(() => {
			dot?.classList.add('online');
			pill?.classList.add('online');
			if (text) { text.textContent = 'Online'; text.classList.add('online'); }
		})
		.catch(() => {
			dot?.classList.add('offline');
			pill?.classList.add('offline');
			if (text) { text.textContent = 'Offline'; text.classList.add('offline'); }
		});

	document.querySelectorAll<HTMLButtonElement>('.ldc-copy').forEach((btn) => {
		btn.addEventListener('click', () => {
			navigator.clipboard.writeText(btn.dataset.value ?? '').then(() => {
				const svg = btn.querySelector('svg');
				if (svg) svg.style.display = 'none';
				const tick = document.createElement('span');
				tick.textContent = '✓';
				tick.style.cssText = 'font-size:.75rem;line-height:1';
				btn.appendChild(tick);
				btn.classList.add('copied');
				setTimeout(() => {
					if (svg) svg.style.display = '';
					tick.remove();
					btn.classList.remove('copied');
				}, 1500);
			});
		});
	});
</script>
