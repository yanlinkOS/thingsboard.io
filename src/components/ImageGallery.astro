---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface ImageItem {
	// Шлях відносно кореня проекту, напр.: /src/assets/images/screenshot.png
	src: string;
	alt: string;
	caption?: string;
}

interface Props {
	images: ImageItem[];
}

const { images } = Astro.props;
const galleryId = `ig-${Math.random().toString(36).slice(2, 9)}`;

// Завантажуємо всі зображення з assets за допомогою glob (eager = синхронно при білді)
// Ключ — абсолютний шлях від кореня проекту (/src/assets/...)
const assetModules = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/**/*.{png,jpg,jpeg,webp,gif,svg}',
	{ eager: true },
);

// thumb — стиснуте WebP 800px для сітки (швидке завантаження)
// full  — WebP оригінального розміру, якість 90 для лайтбоксу
const processed = await Promise.all(
	images.map(async ({ src, alt, caption }) => {
		const mod = assetModules[src];
		if (!mod) throw new Error(`ImageGallery: зображення не знайдено "${src}". Перевірте шлях.`);

		const thumb = await getImage({ src: mod.default, width: 800, format: 'webp', quality: 80 });
		const full = await getImage({ src: mod.default, format: 'webp', quality: 90 });
		return { alt, caption: caption ?? '', thumbSrc: thumb.src, fullSrc: full.src };
	}),
);
---

<div class="image-gallery" id={galleryId}>
	<!-- Сітка мініатюр -->
	<div class="gallery-grid">
		{
			processed.map((img, index) => (
				<button
					class="gallery-thumb"
					type="button"
					data-index={index}
					data-full-src={img.fullSrc}
					data-alt={img.alt}
					data-caption={img.caption}
					aria-label={`Переглянути: ${img.alt}`}
				>
					<span class="thumb-img">
						<img src={img.thumbSrc} alt={img.alt} loading="lazy" decoding="async" />
					</span>
					{img.caption && (
						<span class="thumb-tooltip" aria-hidden="true" set:html={img.caption} />
					)}
				</button>
			))
		}
	</div>

	<!-- Лайтбокс -->
	<div
		class="gallery-lightbox"
		role="dialog"
		aria-modal="true"
		aria-hidden="true"
		aria-label="Перегляд зображення"
	>
		<!-- Розмитий фон (не чорний!) -->
		<div class="lb-backdrop"></div>

		<!-- Обгортка зображення (абсолютна, на весь viewport — потрібна для transform-origin) -->
		<div class="lb-img-wrapper">
			<img class="lb-img" src="" alt="" />
		</div>

		<!-- Всі кнопки position:fixed → гарантовано не перекриваються і незалежні від layout -->
		<button class="lb-close" type="button" aria-label="Закрити (Esc)">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
				<path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/>
			</svg>
		</button>

		<button class="lb-prev" type="button" aria-label="Попереднє (←)">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
				<path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</button>

		<button class="lb-next" type="button" aria-label="Наступне (→)">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
				<path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</button>

		<!-- Підпис і лічильник знизу по центру -->
		<div class="lb-footer">
			<span class="lb-caption"></span>
			<span class="lb-counter"></span>
		</div>
	</div>
</div>

<style>
	/* ═══════════════════════════════════════════════
	   СІТКА МІНІАТЮР
	═══════════════════════════════════════════════ */

	.image-gallery {
		margin: 1.5rem 0;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.75rem;
	}

	@media (max-width: 640px) {
		.gallery-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* Кнопка-мініатюра */
	.gallery-thumb {
		position: relative;
		cursor: pointer;
		border: 2px solid var(--sl-color-gray-5);
		border-radius: 8px;
		overflow: hidden;
		margin: 0;
		padding: 0;
		background: var(--sl-color-bg-sidebar);
		transition:
			border-color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
		display: block;
	}

	.gallery-thumb:hover,
	.gallery-thumb:focus-visible {
		border-color: var(--sl-color-accent);
		transform: translateY(-2px);
		box-shadow: 0 6px 18px rgba(0, 0, 0, 0.18);
		outline: none;
	}

	/* Фіксована висота → абсолютно однаковий розмір для всіх мініатюр */
	.thumb-img {
		display: block;
		height: 115px;
		overflow: hidden;
		background: var(--sl-color-bg-sidebar);
	}

	.thumb-img img {
		width: 100%;
		height: 100%;
		/* contain — повне зображення без обрізання */
		object-fit: contain;
		/* top — зображення "пришпилено" до верху, порожнє місце знизу (не зверху) */
		object-position: top center;
		display: block;
		/* скидаємо будь-який глобальний margin від Starlight/global.scss */
		margin: 0;
		padding: 0;
	}

	/* Tooltip з caption — з'являється при наведенні знизу */
	.thumb-tooltip {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 0.4rem 0.6rem;
		background: rgba(0, 0, 0, 0.72);
		color: #fff;
		font-size: 0.75rem;
		line-height: 1.3;
		text-align: center;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		/* схована за замовчуванням */
		opacity: 0;
		transform: translateY(4px);
		transition:
			opacity 0.2s ease,
			transform 0.2s ease;
		pointer-events: none;
	}

	.gallery-thumb:hover .thumb-tooltip,
	.gallery-thumb:focus-visible .thumb-tooltip {
		opacity: 1;
		transform: translateY(0);
	}

	/* ═══════════════════════════════════════════════
	   ЛАЙТБОКС — основний контейнер
	═══════════════════════════════════════════════ */

	.gallery-lightbox {
		position: fixed;
		inset: 0;
		z-index: 9999;
		/* прихований за замовчуванням */
		display: none;
	}

	/* Відкритий стан через клас (js керує класом і aria-hidden) */
	.gallery-lightbox.is-open {
		display: block;
	}

	/* Закривається — лайтбокс ще видимий, але pointer-events вже вимкнені */
	.gallery-lightbox.is-closing {
		display: block;
		pointer-events: none;
		animation: lb-fade-out 0.22s ease forwards;
	}

	@keyframes lb-fade-out {
		from { opacity: 1; }
		to   { opacity: 0; }
	}

	/* ── Розмитий фон (не чорний!) ─────────────────── */

	.lb-backdrop {
		position: absolute;
		inset: 0;
		/* Blur + напівпрозорий темний — не суцільно чорний */
		background: rgba(10, 10, 20, 0.55);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		/* Плавна поява фону при відкритті */
		animation: lb-backdrop-in 0.25s ease forwards;
	}

	@keyframes lb-backdrop-in {
		from { opacity: 0; }
		to   { opacity: 1; }
	}

	/* ── Обгортка зображення ──────────────────────── */

	/* Займає весь viewport → transform-origin задається в px від лівого верхнього кута viewport,
	   що дорівнює центру мініатюри → зображення "виростає" з неї */
	.lb-img-wrapper {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		/* transform-origin встановлюється через JS перед анімацією */
		transform-origin: 50% 50%;
	}

	/* Анімація "збільшення з мініатюри" при відкритті */
	.gallery-lightbox.is-opening .lb-img-wrapper {
		animation: lb-expand 0.38s cubic-bezier(0.34, 1.25, 0.64, 1) forwards;
	}

	/* Анімація "зменшення до мініатюри" при закритті */
	.gallery-lightbox.is-closing .lb-img-wrapper {
		animation: lb-collapse 0.22s ease-in forwards;
	}

	@keyframes lb-expand {
		from { transform: scale(0.07); opacity: 0; }
		to   { transform: scale(1);    opacity: 1; }
	}

	@keyframes lb-collapse {
		from { transform: scale(1);    opacity: 1; }
		to   { transform: scale(0.07); opacity: 0; }
	}

	.lb-img {
		max-width: 90vw;
		max-height: 88vh;
		object-fit: contain;
		border-radius: 4px;
		display: block;
		/* Тінь надає відчуття "плаваючого" зображення */
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
	}

	/* ── Кнопки лайтбоксу (всі position:fixed) ────── */

	.lb-close,
	.lb-prev,
	.lb-next {
		position: fixed;
		z-index: 10001;
		border-radius: 50%;
		border: 1px solid rgba(255, 255, 255, 0.2);
		background: rgba(30, 30, 40, 0.6);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		color: #fff;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition:
			background 0.18s ease,
			transform 0.18s ease;
	}

	.lb-close:hover,
	.lb-prev:hover,
	.lb-next:hover,
	.lb-close:focus-visible,
	.lb-prev:focus-visible,
	.lb-next:focus-visible {
		background: rgba(60, 60, 80, 0.85);
		transform: scale(1.08);
		outline: none;
	}

	.lb-close {
		top: 1rem;
		right: 1rem;
		width: 2.5rem;
		height: 2.5rem;
	}

	.lb-close svg {
		width: 1.1rem;
		height: 1.1rem;
	}

	/* Prev / Next — вертикально по центру viewport */
	.lb-prev {
		left: 1rem;
		top: 50%;
		transform: translateY(-50%);
		width: 3rem;
		height: 3rem;
	}

	.lb-next {
		right: 1rem;
		top: 50%;
		transform: translateY(-50%);
		width: 3rem;
		height: 3rem;
	}

	.lb-prev:hover,
	.lb-next:hover,
	.lb-prev:focus-visible,
	.lb-next:focus-visible {
		transform: translateY(-50%) scale(1.08);
	}

	.lb-prev svg,
	.lb-next svg {
		width: 1.4rem;
		height: 1.4rem;
	}

	.lb-prev[hidden],
	.lb-next[hidden] {
		visibility: hidden;
		pointer-events: none;
	}

	/* ── Footer: caption + лічильник ─────────────── */

	.lb-footer {
		position: fixed;
		z-index: 10001;
		bottom: 1.5rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.2rem;
		max-width: 80vw;
		text-align: center;
		pointer-events: none;
	}

	.lb-caption {
		color: rgba(255, 255, 255, 0.9);
		font-size: 0.9rem;
		line-height: 1.4;
		text-shadow: 0 1px 4px rgba(0, 0, 0, 0.8);
	}

	.lb-counter {
		color: rgba(255, 255, 255, 0.5);
		font-size: 0.75rem;
	}

	/* ── Reduced motion ────────────────────────────── */

	@media (prefers-reduced-motion: reduce) {
		.gallery-lightbox.is-opening .lb-img-wrapper,
		.gallery-lightbox.is-closing .lb-img-wrapper,
		.gallery-lightbox.is-closing,
		.lb-backdrop {
			animation: none !important;
		}

		.gallery-thumb {
			transition: none;
		}
	}
</style>

<script define:vars={{ galleryId }}>
	const gallery = document.getElementById(galleryId);
	if (!gallery) throw new Error(`ImageGallery: #${galleryId} not found`);

	const lightbox = gallery.querySelector('.gallery-lightbox');
	const imgWrapper = gallery.querySelector('.lb-img-wrapper');
	const lbImg = gallery.querySelector('.lb-img');
	const caption = gallery.querySelector('.lb-caption');
	const counter = gallery.querySelector('.lb-counter');
	const closeBtn = gallery.querySelector('.lb-close');
	const prevBtn = gallery.querySelector('.lb-prev');
	const nextBtn = gallery.querySelector('.lb-next');
	const backdrop = gallery.querySelector('.lb-backdrop');
	const thumbs = Array.from(gallery.querySelectorAll('.gallery-thumb'));

	// Teleport лайтбоксу в document.body — виходимо з будь-якого stacking context
	// (article, main, content div можуть мати isolation/transform/overflow що обмежує z-index)
	// Після цього position:fixed буде відносно viewport, а не батьківського елементу
	document.body.appendChild(lightbox);

	let currentIndex = 0;
	let isClosing = false;

	function isOpen() {
		return lightbox.getAttribute('aria-hidden') === 'false';
	}

	// Оновлює зображення і counter/caption
	function updateContent() {
		const btn = thumbs[currentIndex];
		lbImg.src = btn.dataset.fullSrc;
		lbImg.alt = btn.dataset.alt;
		caption.innerHTML = btn.dataset.caption ?? '';
		counter.textContent = `${currentIndex + 1} / ${thumbs.length}`;

		const single = thumbs.length <= 1;
		prevBtn.toggleAttribute('hidden', single);
		nextBtn.toggleAttribute('hidden', single);
	}

	function openLightbox(index, triggerBtn) {
		if (isClosing) return;

		// Центр мініатюри у координатах viewport → transform-origin для zoom-анімації
		const rect = triggerBtn.getBoundingClientRect();
		const originX = rect.left + rect.width / 2;
		const originY = rect.top + rect.height / 2;
		imgWrapper.style.transformOrigin = `${originX}px ${originY}px`;

		currentIndex = index;
		updateContent();

		lightbox.setAttribute('aria-hidden', 'false');
		document.body.style.overflow = 'hidden';

		// Спочатку is-open (показує елемент), потім is-opening (запускає анімацію)
		lightbox.classList.add('is-open', 'is-opening');
		imgWrapper.addEventListener('animationend', () => lightbox.classList.remove('is-opening'), {
			once: true,
		});

		closeBtn.focus();
	}

	function closeLightbox() {
		if (isClosing || !isOpen()) return;
		isClosing = true;

		// Оновлюємо origin до поточної позиції мініатюри (для collapse-анімації)
		const btn = thumbs[currentIndex];
		if (btn) {
			const rect = btn.getBoundingClientRect();
			imgWrapper.style.transformOrigin = `${rect.left + rect.width / 2}px ${rect.top + rect.height / 2}px`;
		}

		lightbox.classList.remove('is-open');
		lightbox.classList.add('is-closing');

		function finish() {
			lightbox.classList.remove('is-closing');
			lightbox.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
			thumbs[currentIndex]?.focus();
			isClosing = false;
		}

		// Завершуємо або по animationend, або через таймаут (якщо анімація вимкнена)
		lightbox.addEventListener('animationend', finish, { once: true });
		setTimeout(finish, 280);
	}

	function showPrev() {
		currentIndex = (currentIndex - 1 + thumbs.length) % thumbs.length;
		updateContent();
	}

	function showNext() {
		currentIndex = (currentIndex + 1) % thumbs.length;
		updateContent();
	}

	// Клік по мініатюрі
	thumbs.forEach((btn, i) => btn.addEventListener('click', () => openLightbox(i, btn)));

	// Кнопки лайтбоксу
	closeBtn.addEventListener('click', closeLightbox);
	backdrop.addEventListener('click', closeLightbox);
	prevBtn.addEventListener('click', showPrev);
	nextBtn.addEventListener('click', showNext);

	// Клавіатура (лише якщо цей лайтбокс відкритий)
	document.addEventListener('keydown', (e) => {
		if (!isOpen()) return;
		if (e.key === 'Escape') closeLightbox();
		else if (e.key === 'ArrowLeft') showPrev();
		else if (e.key === 'ArrowRight') showNext();
	});
</script>
