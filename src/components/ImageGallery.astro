---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { Products } from '~/models/site.models';
import 'photoswipe/style.css';

interface ImageItem {
	/** Project-relative path, e.g. `/src/assets/images/screenshot.png`. */
	src: string;
	alt: string;
	caption?: string;
	/** Restrict to a subset of products. */
	products?: Products[];
}

interface Props {
	images: ImageItem[];
	/** Enables product suffix resolution on filenames (e.g. `-pe`, `-paas`). */
	product?: Products;
	/** When `true` and only one image is supplied, render as a thumb card instead of inline. */
	cardMode?: boolean;
}

const { images, product, cardMode = false } = Astro.props;

const productSuffix: Record<Products, string> = {
	[Products.CE]: 'ce',
	[Products.PE]: 'pe',
	[Products.PAAS]: 'paas',
	[Products.PAAS_EU]: 'paas-eu',
	[Products.EDGE]: 'edge',
	[Products.EDGE_PE]: 'edge-pe',
	[Products.GW]: 'gw',
	[Products.LICENSE]: 'license',
	[Products.TRENDZ]: 'trendz',
	[Products.MOBILE]: 'mobile',
	[Products.MOBILE_PE]: 'mobile-pe',
	[Products.TBMQ]: 'tbmq',
	[Products.TBMQ_PE]: 'tbmq-pe',
};

// Fallback chain when a product-specific image is missing.
// e.g. PAAS_EU → PAAS → PE → base.
const productFallback: Partial<Record<Products, Products[]>> = {
	[Products.PAAS]: [Products.PE],
	[Products.PAAS_EU]: [Products.PAAS, Products.PE],
	[Products.EDGE_PE]: [Products.EDGE],
	[Products.MOBILE_PE]: [Products.MOBILE],
	[Products.TBMQ_PE]: [Products.TBMQ],
};

const assetModules = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/**/*.{png,jpg,jpeg,webp,gif,svg}',
	{ eager: true }
);

// Lazy raw SVG sources — used to inline SVGs with `<a>` so the anchors stay
// clickable (browsers disable interactivity when SVG is loaded via `<img>`).
const svgRawModules = import.meta.glob<string>(
	'/src/assets/**/*.svg',
	{ query: '?raw', import: 'default' }
);

// Add aria-label + force `target="_blank"` on every `<a>` inside an interactive SVG.
function prepareInteractiveSvg(raw: string, alt: string): string {
	let out = raw;
	const escapedAlt = alt.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
	out = out.replace(/<svg\b/, `<svg aria-label="${escapedAlt}"`);
	out = out.replace(/<a\b([^>]*)>/g, (_m, attrs) => {
		const stripped = attrs
			.replace(/\s+target="[^"]*"/g, '')
			.replace(/\s+rel="[^"]*"/g, '');
		return `<a${stripped} target="_blank" rel="noopener noreferrer">`;
	});
	return out;
}

// CDN fallback for images hosted outside the local assets pipeline.
const CDN_BASE = 'https://img.thingsboard.io/';
const LOCAL_PREFIX = '/src/assets/images/';

function resolveToCdn(path: string): string {
	return path.startsWith(LOCAL_PREFIX) ? CDN_BASE + path.slice(LOCAL_PREFIX.length) : path;
}

function splitExt(src: string): [string, string] {
	const dot = src.lastIndexOf('.');
	if (dot === -1) throw new Error(`ImageGallery: src has no extension: "${src}"`);
	return [src.slice(0, dot), src.slice(dot)];
}

/**
 * Asset path resolution with theme + product fallback chain:
 *   {base}-{product}-dark → {base}-dark → {base}-{product} → {base}
 * CE has no suffix (the base file IS the CE file).
 */
function resolvePaths(src: string): { lightPath: string; darkPath: string } {
	const [base, ext] = splitExt(src);

	const suffixes: string[] = [];
	if (product) {
		suffixes.push(productSuffix[product]);
		const fallbacks = productFallback[product];
		if (fallbacks) {
			for (const fb of fallbacks) suffixes.push(productSuffix[fb]);
		}
	}

	let lightPath: string = src;
	for (const s of suffixes) {
		if (assetModules[`${base}-${s}${ext}`]) {
			lightPath = `${base}-${s}${ext}`;
			break;
		}
	}

	let darkPath: string = lightPath;
	for (const s of suffixes) {
		if (assetModules[`${base}-${s}-dark${ext}`]) {
			darkPath = `${base}-${s}-dark${ext}`;
			break;
		}
	}
	if (darkPath === lightPath && assetModules[`${base}-dark${ext}`]) {
		darkPath = `${base}-dark${ext}`;
	}

	return { lightPath, darkPath };
}

// Render the inline-emphasis subset of Markdown (``code``, `*em*`, `**strong**`) to HTML.
function captionToHtml(s: string): string {
	if (!s) return '';
	if (!/[`*]/.test(s)) return s;
	return s
		.replace(/`([^`]+)`/g, '<code>$1</code>')
		.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
		.replace(/(?<!\*)\*([^*\s][^*]*?)\*(?!\*)/g, '<em>$1</em>');
}

const filteredImages = product
	? images.filter(({ products: p }) => !p || p.includes(product))
	: images;

// thumb = 800px WebP @ q80 (grid + single-mode src). full = original WebP @ q90 (lightbox).
const processed = await Promise.all(
	filteredImages.map(async ({ src, alt, caption }) => {
		const { lightPath, darkPath } = resolvePaths(src);
		const hasDark = darkPath !== lightPath;

		const lightMod = assetModules[lightPath];

		if (!lightMod) {
			const cdnSrc = resolveToCdn(lightPath);
			const darkCdnSrc = hasDark ? resolveToCdn(darkPath) : cdnSrc;
			return {
				alt,
				caption: captionToHtml(caption ?? ''),
				thumbSrc: cdnSrc,
				fullSrc: cdnSrc,
				darkThumbSrc: darkCdnSrc,
				darkFullSrc: darkCdnSrc,
				fullWidth: undefined,
				fullHeight: undefined,
				hasDark,
				interactiveSvg: undefined as string | undefined,
				isCdn: true,
			};
		}

		const isSvg = lightPath.endsWith('.svg');
		const isGif = lightPath.endsWith('.gif');

		// SVGs skip raster processing. If they contain `<a>`, inline them so anchors stay clickable.
		if (isSvg) {
			const lightSrc = lightMod.default.src;
			const darkMod = hasDark ? assetModules[darkPath] : null;
			const darkSrc = darkMod ? darkMod.default.src : lightSrc;

			const rawSvg = await svgRawModules[lightPath]?.();
			const interactiveSvg = rawSvg && /<a[\s>]/i.test(rawSvg)
				? prepareInteractiveSvg(rawSvg, alt)
				: undefined;

			return {
				alt,
				caption: captionToHtml(caption ?? ''),
				thumbSrc: lightSrc,
				fullSrc: lightSrc,
				darkThumbSrc: darkSrc,
				darkFullSrc: darkSrc,
				fullWidth: lightMod.default.width,
				fullHeight: lightMod.default.height,
				hasDark,
				interactiveSvg,
				isCdn: false,
			};
		}

		// GIFs bypass Sharp: it reads all frames (`pages: -1`) and trips
		// `limitInputPixels` on large multi-frame GIFs.
		if (isGif) {
			const lightSrc = lightMod.default.src;
			const darkMod = hasDark ? assetModules[darkPath] : null;
			const darkSrc = darkMod ? darkMod.default.src : lightSrc;

			return {
				alt,
				caption: captionToHtml(caption ?? ''),
				thumbSrc: lightSrc,
				fullSrc: lightSrc,
				darkThumbSrc: darkSrc,
				darkFullSrc: darkSrc,
				fullWidth: lightMod.default.width,
				fullHeight: lightMod.default.height,
				hasDark,
				interactiveSvg: undefined,
				isCdn: false,
			};
		}

		const thumb = await getImage({
			src: lightMod.default,
			width: 800,
			format: 'webp',
			quality: 80,
		});
		const full = await getImage({ src: lightMod.default, format: 'webp', quality: 90 });

		let darkThumbSrc = thumb.src;
		let darkFullSrc = full.src;

		if (hasDark) {
			const darkMod = assetModules[darkPath]!;
			const darkThumb = await getImage({
				src: darkMod.default,
				width: 800,
				format: 'webp',
				quality: 80,
			});
			const darkFull = await getImage({ src: darkMod.default, format: 'webp', quality: 90 });
			darkThumbSrc = darkThumb.src;
			darkFullSrc = darkFull.src;
		}

		return {
			alt,
			caption: captionToHtml(caption ?? ''),
			thumbSrc: thumb.src,
			fullSrc: full.src,
			darkThumbSrc,
			darkFullSrc,
			fullWidth: full.attributes.width as number | undefined,
			fullHeight: full.attributes.height as number | undefined,
			hasDark,
			interactiveSvg: undefined as string | undefined,
			isCdn: false,
		};
	})
);

const isSingle = processed.length === 1;
const useCardMode = cardMode && isSingle;
---

<div class="image-gallery">
	{
		isSingle && !useCardMode ? (
			/* Single image — inline DocImage-style. Interactive SVGs use a
			   div+role=button wrapper (nested <a> in <a> is invalid HTML). */
			<figure class="single-image">
				{processed[0].interactiveSvg ? (
					<div
						class="gallery-thumb single-thumb gallery-thumb--interactive"
						role="button"
						tabindex={0}
						data-pswp-interactive-svg="true"
						data-pswp-width={processed[0].fullWidth ?? 1600}
						data-pswp-height={processed[0].fullHeight ?? 900}
						data-caption={processed[0].caption}
						aria-label={`View: ${processed[0].alt}`}
					>
						<Fragment set:html={processed[0].interactiveSvg} />
					</div>
				) : (
					/* `src` = 800px thumb (bandwidth); `href` + `data-pswp-*` point
					   at the full asset so the lightbox shows it at full quality. */
					<a
						class="gallery-thumb single-thumb"
						href={processed[0].fullSrc}
						data-pswp-width={processed[0].fullWidth ?? 1600}
						data-pswp-height={processed[0].fullHeight ?? 900}
						data-pswp-src-dark={processed[0].hasDark ? processed[0].darkFullSrc : undefined}
						data-pswp-cdn={processed[0].isCdn ? 'true' : undefined}
						data-caption={processed[0].caption}
						aria-label={`View: ${processed[0].alt}`}
					>
						<img
							class:list={[{ 'light-only': processed[0].hasDark }]}
							src={processed[0].thumbSrc}
							alt={processed[0].alt}
							width={processed[0].fullWidth}
							height={processed[0].fullHeight}
							loading="lazy"
							decoding="async"
						/>
						{processed[0].hasDark && (
							<img
								class="dark-only"
								src={processed[0].darkThumbSrc}
								alt={processed[0].alt}
								width={processed[0].fullWidth}
								height={processed[0].fullHeight}
								loading="lazy"
								decoding="async"
							/>
						)}
					</a>
				)}
			</figure>
		) : (
			<div class="gallery-grid">
				{processed.map((img) => (
					<a
						class="gallery-thumb"
						href={img.fullSrc}
						data-pswp-width={img.fullWidth ?? 1600}
						data-pswp-height={img.fullHeight ?? 900}
						data-pswp-src-dark={img.hasDark ? img.darkFullSrc : undefined}
						data-pswp-cdn={img.isCdn ? 'true' : undefined}
						data-caption={img.caption}
						aria-label={`View: ${img.alt}`}
					>
						<span class="thumb-img">
							<img
								class:list={[{ 'light-only': img.hasDark }]}
								src={img.thumbSrc}
								alt={img.alt}
								loading="lazy"
								decoding="async"
							/>
							{img.hasDark && (
								<img
									class="dark-only"
									src={img.darkThumbSrc}
									alt={img.alt}
									loading="lazy"
									decoding="async"
								/>
							)}
						</span>
						{img.caption && (
							<span class="thumb-tooltip" aria-hidden="true" set:html={img.caption} />
						)}
					</a>
				))}
			</div>
		)
	}
</div>

<style>
	.image-gallery {
		margin: 1.5rem 0;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.75rem;
	}

	@media (max-width: 640px) {
		.gallery-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.gallery-thumb {
		position: relative;
		display: block;
		cursor: pointer;
		border: 2px solid var(--sl-color-gray-5);
		border-radius: 8px;
		overflow: hidden;
		margin: 0;
		padding: 0;
		background: var(--sl-color-bg-sidebar);
		color: inherit;
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.gallery-thumb:hover,
	.gallery-thumb:focus-visible {
		border-color: var(--sl-color-accent);
		transform: translateY(-2px);
		box-shadow: 0 6px 18px rgba(0, 0, 0, 0.18);
		outline: none;
	}

	.single-image {
		/* Reset browser default `figure` margin — parent provides spacing. */
		margin: 0;
		text-align: center;
	}

	.single-thumb {
		display: inline-block;
		border: none;
		background: none;
		padding: 0;
		margin: 0;
		cursor: zoom-in;
		max-width: 100%;
	}

	.single-thumb img {
		max-width: 100%;
		height: auto;
		display: block;
		margin: 0;
		padding: 0;
		transition: filter 0.2s ease;
	}

	.single-thumb:hover,
	.single-thumb:focus-visible {
		transform: none;
		box-shadow: none;
	}

	.single-thumb:hover img,
	.single-thumb:focus-visible img {
		filter: brightness(0.9);
	}

	.single-thumb:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}

	/* Fixed height keeps grid rows uniform regardless of image aspect ratio. */
	.thumb-img {
		display: block;
		height: 115px;
		overflow: hidden;
		background: var(--sl-color-bg-sidebar);
	}

	.thumb-img img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: top center;
		display: block;
		/* Reset global Starlight img margin. */
		margin: 0;
		padding: 0;
	}

	.thumb-tooltip {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 0.4rem 0.6rem;
		background: rgba(0, 0, 0, 0.72);
		color: #fff;
		font-size: 0.75rem;
		line-height: 1.3;
		text-align: center;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		opacity: 0;
		transform: translateY(4px);
		transition:
			opacity 0.2s ease,
			transform 0.2s ease;
		pointer-events: none;
		--sl-color-bg-inline-code: transparent;
	}

	.gallery-thumb:hover .thumb-tooltip,
	.gallery-thumb:focus-visible .thumb-tooltip {
		opacity: 1;
		transform: translateY(0);
	}

	/* Inline interactive SVG thumb — anchors inside revert to pointer cursor. */
	.gallery-thumb--interactive {
		cursor: zoom-in;
	}
	.gallery-thumb--interactive :global(svg) {
		display: block;
		max-width: 100%;
		height: auto;
	}
	.gallery-thumb--interactive :global(a) {
		cursor: pointer;
	}

	/* `!important` overrides the `display: block` on `.single-thumb img` / `.thumb-img img`. */
	.dark-only {
		display: none !important;
	}
	:global([data-theme='dark']) .light-only {
		display: none !important;
	}
	:global([data-theme='dark']) .dark-only {
		display: block !important;
	}

	@media (prefers-reduced-motion: reduce) {
		.gallery-thumb {
			transition: none;
		}
	}
</style>

<script>
	// Astro deduplicates this `<script>` per page — pages without an
	// `<ImageGallery>` never load it.
	import PhotoSwipeLightbox from 'photoswipe/lightbox';
	import type PhotoSwipe from 'photoswipe';
	import type { SlideData } from 'photoswipe';
	import { lockScroll, unlockScroll } from '@util/scroll-lock';

	// Tear down on re-init so View Transitions (when enabled) don't accumulate
	// duplicate click handlers / observers across navigations.
	let currentLb: PhotoSwipeLightbox | undefined;

	// CDN images skip the asset pipeline → no build-time dims. Use the visible
	// <img>'s naturalWidth/Height (thumb === full-res for CDN sources).
	function getVisibleImg(anchor: HTMLElement): HTMLImageElement | null {
		const isDark = document.documentElement.dataset.theme === 'dark';
		const selector = isDark ? 'img:not(.light-only)' : 'img:not(.dark-only)';
		return anchor.querySelector<HTMLImageElement>(selector);
	}

	function syncCdnAnchorDims(anchor: HTMLElement) {
		const img = getVisibleImg(anchor);
		if (!img) return;
		const apply = () => {
			if (img.naturalWidth && img.naturalHeight) {
				anchor.dataset.pswpWidth = String(img.naturalWidth);
				anchor.dataset.pswpHeight = String(img.naturalHeight);
			}
		};
		if (img.complete) apply();
		else img.addEventListener('load', apply, { once: true });
	}

	function init() {
		currentLb?.destroy();
		currentLb = undefined;
		if (!document.querySelector('.image-gallery')) return;

		document
			.querySelectorAll<HTMLElement>('.gallery-thumb[data-pswp-cdn="true"]')
			.forEach(syncCdnAnchorDims);

		const lb = new PhotoSwipeLightbox({
			gallery: '.image-gallery',
			children: '.gallery-thumb',
			pswpModule: () => import('photoswipe'),
			showHideAnimationType: 'zoom',
			bgOpacity: 1,
			padding: { top: 24, bottom: 64, left: 24, right: 24 },
			wheelToZoom: true,
			loop: false,
			zoom: false,
		});

		// Anchors inside interactive SVG thumbs navigate natively; lightbox stays closed.
		lb.addFilter('clickedIndex', (clickedIndex, e) =>
			(e.target as HTMLElement).closest('.gallery-thumb--interactive a') ? -1 : clickedIndex
		);

		// Interactive SVG slides + dark-theme src swap for raster images.
		lb.addFilter('itemData', (itemData: SlideData) => {
			const el = itemData.element as HTMLElement | undefined;
			if (!el) return itemData;

			if (el.dataset.pswpInteractiveSvg === 'true') {
				// PhotoSwipe's `_domElementToItemData` runs `querySelector('a')`
				// to extract an image href. With an SVG `<a>` inside, it returns
				// an `SVGAnimatedString` that stringifies to "[object
				// SVGAnimatedString]" — a broken URL. Build a fresh item with
				// `type: 'html'` instead of spreading the polluted one.
				return {
					element: el,
					type: 'html',
					html: el.innerHTML,
					width: parseInt(el.dataset.pswpWidth ?? '', 10) || 1600,
					height: parseInt(el.dataset.pswpHeight ?? '', 10) || 900,
				};
			}

			const isDark = document.documentElement.dataset.theme === 'dark';
			if (isDark) {
				const darkSrc = el.dataset.pswpSrcDark;
				if (darkSrc) itemData.src = darkSrc;
				const darkThumb = el.querySelector<HTMLImageElement>('img.dark-only');
				if (darkThumb?.src) itemData.msrc = darkThumb.src;
			}

			// Backup if init's load listener hasn't fired yet (fast click).
			if (el.dataset.pswpCdn === 'true') {
				const img = getVisibleImg(el);
				if (img?.naturalWidth && img.naturalHeight) {
					itemData.width = img.naturalWidth;
					itemData.height = img.naturalHeight;
				}
			}

			return itemData;
		});

		// Use the visible img for zoom bounds — the hidden variant has rect (0,0,0,0).
		lb.addFilter('thumbEl', (thumbnail, itemData) => {
			const el = itemData.element as HTMLElement | undefined;
			const isDark = document.documentElement.dataset.theme === 'dark';
			const selector = isDark ? 'img:not(.light-only)' : 'img:not(.dark-only)';
			return (el?.querySelector<HTMLImageElement>(selector) ?? thumbnail ?? el) as HTMLElement;
		});

		let pswp: PhotoSwipe | undefined;
		let themeObserver: MutationObserver | null = null;

		lb.on('beforeOpen', lockScroll);

		lb.on('afterInit', () => {
			pswp = lb.pswp;
			if (!pswp) return;

			pswp.ui!.registerElement({
				name: 'caption',
				appendTo: 'root',
				onInit: (el) => {
					el.className = 'pswp-caption';
					const refresh = () => {
						const src = pswp?.currSlide?.data.element as HTMLElement | undefined;
						const html = src?.dataset.caption ?? '';
						el.innerHTML = html;
						el.style.display = html ? '' : 'none';
					};
					pswp!.on('change', refresh);
					refresh();
				},
			});

			// Preload neighbours so swipe is instant.
			pswp.on('change', () => {
				if (!pswp) return;
				const cur = pswp.currIndex;
				[cur - 1, cur + 1].forEach((i) => {
					const data = pswp!.getItemData(i);
					if (data?.src) {
						new Image().src = data.src;
					}
				});
			});

			// Re-render current slide on site theme toggle.
			themeObserver = new MutationObserver(() => {
				if (pswp && pswp.currSlide) {
					pswp.refreshSlideContent(pswp.currIndex);
				}
			});
			themeObserver.observe(document.documentElement, {
				attributes: true,
				attributeFilter: ['data-theme'],
			});
		});

		lb.on('destroy', () => {
			unlockScroll();
			themeObserver?.disconnect();
			themeObserver = null;
			pswp = undefined;
		});

		lb.init();
		currentLb = lb;
	}

	init();
	document.addEventListener('astro:page-load', init);
</script>

<style is:global>
	/* `.pswp` + `.pswp__bg` ship with `transform: translateZ(0)` + `will-change: opacity`.
	   Together they create a compositing layer that prevents `backdrop-filter` from
	   sampling the page behind PhotoSwipe (blur appears not to work). Drop both. */
	.pswp {
		--pswp-bg: rgba(10, 10, 20, 0.55);
		/* Suppress the `#222` placeholder bg painted during zoom-from-thumbnail. */
		--pswp-placeholder-bg: transparent;
		/* PhotoSwipe icons have a 2px grey stroke designed for light buttons —
		   make everything white for our dark blur-glass buttons. */
		--pswp-icon-color: #fff;
		--pswp-icon-color-secondary: #fff;
		--pswp-icon-stroke-color: #fff;
		--pswp-icon-stroke-width: 0;
		--color-bg: transparent;
		transform: none !important;
		will-change: auto !important;
	}
	.pswp__bg {
		backdrop-filter: blur(18px) !important;
		-webkit-backdrop-filter: blur(18px) !important;
		transform: none !important;
		/* Pre-allocate the blur compositing layer so it appears in sync with
		   the bg opacity fade-in. */
		will-change: backdrop-filter !important;
	}

	.pswp__img {
		border-radius: 4px;
	}
	/* Shadow on the always-present wrap → no flicker on placeholder→full swap.
	   Excludes HTML slides (own shadow on `.pswp__content`) and SVG slides. */
	.pswp__zoom-wrap:not(:has(.pswp__content)):not(:has(.pswp__img[src$='.svg'])) {
