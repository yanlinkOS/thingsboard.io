---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { Products } from '~/models/site.models';

interface ImageItem {
	// Base path from project root, e.g. /src/assets/images/screenshot.png
	// When product/theme resolution is active, this is the base name without suffixes.
	src: string;
	alt: string;
	caption?: string;
	/** If set, this image is only included when the current product is in the list. */
	products?: Products[];
}

interface Props {
	images: ImageItem[];
	/** If set, enables product suffix resolution (e.g. -pe, -paas). */
	product?: Products;
}

const { images, product } = Astro.props;
const galleryId = `ig-${Math.random().toString(36).slice(2, 9)}`;

// Maps each product to the filename suffix inserted before the extension.
const productSuffix: Record<Products, string> = {
	[Products.CE]: 'ce',
	[Products.PE]: 'pe',
	[Products.PAAS]: 'paas',
	[Products.PAAS_EU]: 'paas-eu',
	[Products.EDGE]: 'edge',
	[Products.EDGE_PE]: 'edge-pe',
	[Products.GW]: 'gw',
	[Products.LICENSE]: 'license',
	[Products.TRENDZ]: 'trendz',
	[Products.MOBILE]: 'mobile',
	[Products.MOBILE_PE]: 'mobile-pe',
	[Products.TBMQ]: 'tbmq',
	[Products.TBMQ_PE]: 'tbmq-pe',
};

// Load all images from assets using glob (eager = synchronous at build time)
// Key — absolute path from project root (/src/assets/...)
const assetModules = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/**/*.{png,jpg,jpeg,webp,gif,svg}',
	{ eager: true }
);

// CDN fallback for images not found locally (e.g. use-case screenshots hosted externally)
const CDN_BASE = 'https://img.thingsboard.io/';
const LOCAL_PREFIX = '/src/assets/images/';

function resolveToCdn(path: string): string {
	return path.startsWith(LOCAL_PREFIX) ? CDN_BASE + path.slice(LOCAL_PREFIX.length) : path;
}

/**
 * Splits a src path into base (before extension) and ext (including dot).
 * e.g. "/src/assets/schemas/foo.svg" → ["/src/assets/schemas/foo", ".svg"]
 */
function splitExt(src: string): [string, string] {
	const dot = src.lastIndexOf('.');
	if (dot === -1) throw new Error(`ImageGallery: src has no extension: "${src}"`);
	return [src.slice(0, dot), src.slice(dot)];
}

/**
 * Resolve the actual asset path for a given base src, considering product and theme.
 * Fallback chain (most specific → least specific):
 *   1. {base}-{product}-dark{ext}  (product + dark)
 *   2. {base}-dark{ext}            (generic dark)
 *   3. {base}-{product}{ext}       (product + light)
 *   4. {base}{ext}                 (base — always exists)
 * For light theme, skip steps 1-2.
 * CE is the default product — no suffix needed (the base file IS the CE file).
 */
function resolvePaths(src: string): { lightPath: string; darkPath: string } {
	const [base, ext] = splitExt(src);
	const suffix = product ? productSuffix[product] : null;

	// Resolve light path: try product-specific first, then base
	let lightPath: string;
	if (suffix && assetModules[`${base}-${suffix}${ext}`]) {
		lightPath = `${base}-${suffix}${ext}`;
	} else {
		lightPath = src; // base file
	}

	// Resolve dark path: try product+dark, then generic dark, then fall back to light
	let darkPath: string;
	if (suffix && assetModules[`${base}-${suffix}-dark${ext}`]) {
		darkPath = `${base}-${suffix}-dark${ext}`;
	} else if (assetModules[`${base}-dark${ext}`]) {
		darkPath = `${base}-dark${ext}`;
	} else {
		darkPath = lightPath; // no dark variant — reuse light
	}

	return { lightPath, darkPath };
}

// Filter by product if specified, then resolve paths and process images
const filteredImages = product
	? images.filter(({ products: p }) => !p || p.includes(product))
	: images;

// Whether any image actually has a distinct dark variant
let hasThemeVariants = false;

// thumb — compressed WebP 800px for the grid (fast loading)
// full  — WebP at original size, quality 90 for the lightbox
const processed = await Promise.all(
	filteredImages.map(async ({ src, alt, caption }) => {
		const { lightPath, darkPath } = resolvePaths(src);
		const hasDark = darkPath !== lightPath;
		if (hasDark) hasThemeVariants = true;

		const lightMod = assetModules[lightPath];

		// CDN fallback: image not found locally → resolve to CDN URL, skip processing
		if (!lightMod) {
			const cdnSrc = resolveToCdn(lightPath);
			const darkCdnSrc = hasDark ? resolveToCdn(darkPath) : cdnSrc;
			return {
				alt,
				caption: caption ?? '',
				thumbSrc: cdnSrc,
				fullSrc: cdnSrc,
				darkThumbSrc: darkCdnSrc,
				darkFullSrc: darkCdnSrc,
				fullWidth: undefined,
				fullHeight: undefined,
				hasDark,
			};
		}

		const isSvg = lightPath.endsWith('.svg');

		// SVGs don't need processing — use raw src directly
		if (isSvg) {
			const lightSrc = lightMod.default.src;
			const darkMod = hasDark ? assetModules[darkPath] : null;
			const darkSrc = darkMod ? darkMod.default.src : lightSrc;
			return {
				alt,
				caption: caption ?? '',
				thumbSrc: lightSrc,
				fullSrc: lightSrc,
				darkThumbSrc: darkSrc,
				darkFullSrc: darkSrc,
				fullWidth: lightMod.default.width,
				fullHeight: lightMod.default.height,
				hasDark,
			};
		}

		const thumb = await getImage({
			src: lightMod.default,
			width: 800,
			format: 'webp',
			quality: 80,
		});
		const full = await getImage({ src: lightMod.default, format: 'webp', quality: 90 });

		let darkThumbSrc = thumb.src;
		let darkFullSrc = full.src;

		if (hasDark) {
			const darkMod = assetModules[darkPath]!;
			const darkThumb = await getImage({
				src: darkMod.default,
				width: 800,
				format: 'webp',
				quality: 80,
			});
			const darkFull = await getImage({ src: darkMod.default, format: 'webp', quality: 90 });
			darkThumbSrc = darkThumb.src;
			darkFullSrc = darkFull.src;
		}

		return {
			alt,
			caption: caption ?? '',
			thumbSrc: thumb.src,
			fullSrc: full.src,
			darkThumbSrc,
			darkFullSrc,
			fullWidth: full.attributes.width as number | undefined,
			fullHeight: full.attributes.height as number | undefined,
			hasDark,
		};
	})
);

const isSingle = processed.length === 1;
---

<div class:list={['image-gallery', { 'has-theme-variants': hasThemeVariants }]} id={galleryId}>
	{
		isSingle ? (
			/* Single image — displayed like DocImage but clickable */
			<figure class="single-image">
				<button
					class="gallery-thumb single-thumb"
					type="button"
					data-index={0}
					data-full-src={processed[0].fullSrc}
					data-full-src-dark={processed[0].darkFullSrc}
					data-alt={processed[0].alt}
					data-caption={processed[0].caption}
					data-full-width={processed[0].fullWidth}
					data-full-height={processed[0].fullHeight}
					aria-label={`View: ${processed[0].alt}`}
				>
					<img
						class:list={[{ 'light-only': processed[0].hasDark }]}
						src={processed[0].fullSrc}
						alt={processed[0].alt}
						width={processed[0].fullWidth}
						height={processed[0].fullHeight}
						loading="lazy"
						decoding="async"
					/>
					{processed[0].hasDark && (
						<img
							class="dark-only"
							src={processed[0].darkFullSrc}
							alt={processed[0].alt}
							width={processed[0].fullWidth}
							height={processed[0].fullHeight}
							loading="lazy"
							decoding="async"
						/>
					)}
				</button>
			</figure>
		) : (
			/* Multiple images — regular thumbnail grid */
			<div class="gallery-grid">
				{processed.map((img, index) => (
					<button
						class="gallery-thumb"
						type="button"
						data-index={index}
						data-full-src={img.fullSrc}
						data-full-src-dark={img.darkFullSrc}
						data-alt={img.alt}
						data-caption={img.caption}
						data-full-width={img.fullWidth}
						data-full-height={img.fullHeight}
						aria-label={`View: ${img.alt}`}
					>
						<span class="thumb-img">
							<img
								class:list={[{ 'light-only': img.hasDark }]}
								src={img.thumbSrc}
								alt={img.alt}
								loading="lazy"
								decoding="async"
							/>
							{img.hasDark && (
								<img
									class="dark-only"
									src={img.darkThumbSrc}
									alt={img.alt}
									loading="lazy"
									decoding="async"
								/>
							)}
						</span>
						{img.caption && (
							<span class="thumb-tooltip" aria-hidden="true" set:html={img.caption} />
						)}
					</button>
				))}
			</div>
		)
	}

	<!-- Lightbox -->
	<div
		class="gallery-lightbox"
		role="dialog"
		aria-modal="true"
		aria-hidden="true"
		aria-label="Image viewer"
	>
		<!-- Blurred backdrop (not solid black) -->
		<div class="lb-backdrop"></div>

		<!-- Image wrapper (absolute, full viewport — needed for transform-origin) -->
		<div class="lb-img-wrapper">
			<img class="lb-img lb-img-light" src="" alt="" />
			<img class="lb-img lb-img-dark" src="" alt="" />
			<!-- Caption placed below the image in flow to avoid overlapping it -->
			<div class="lb-footer">
				<span class="lb-caption"></span>
				<span class="lb-counter"></span>
			</div>
		</div>

		<!-- All buttons are position:fixed — guaranteed no overlap and independent of layout -->
		<button class="lb-close" type="button" aria-label="Close (Esc)">
			<svg
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2.5"
				aria-hidden="true"
			>
				<path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"></path>
			</svg>
		</button>

		<button class="lb-prev" type="button" aria-label="Previous (←)">
			<svg
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2.5"
				aria-hidden="true"
			>
				<path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</button>

		<button class="lb-next" type="button" aria-label="Next (→)">
			<svg
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2.5"
				aria-hidden="true"
			>
				<path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</button>
	</div>
</div>

<style>
	/* ═══════════════════════════════════════════════
	   THUMBNAIL GRID
	═══════════════════════════════════════════════ */

	.image-gallery {
		margin: 1.5rem 0;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.75rem;
	}

	@media (max-width: 640px) {
		.gallery-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* Thumbnail button */
	.gallery-thumb {
		position: relative;
		cursor: pointer;
		border: 2px solid var(--sl-color-gray-5);
		border-radius: 8px;
		overflow: hidden;
		margin: 0;
		padding: 0;
		background: var(--sl-color-bg-sidebar);
		transition:
			border-color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
		display: block;
	}

	.gallery-thumb:hover,
	.gallery-thumb:focus-visible {
		border-color: var(--sl-color-accent);
		transform: translateY(-2px);
		box-shadow: 0 6px 18px rgba(0, 0, 0, 0.18);
		outline: none;
	}

	/* ── Single image mode (like DocImage) ──── */

	.single-image {
		margin: 1.5rem 0;
		text-align: center;
	}

	.single-thumb {
		display: inline-block;
		border: none;
		background: none;
		padding: 0;
		margin: 0;
		cursor: zoom-in;
		max-width: 100%;
	}

	.single-thumb img {
		max-width: 100%;
		height: auto;
		display: block;
		margin: 0;
		padding: 0;
		transition: filter 0.2s ease;
	}

	.single-thumb:hover,
	.single-thumb:focus-visible {
		transform: none;
		box-shadow: none;
	}

	.single-thumb:hover img,
	.single-thumb:focus-visible img {
		filter: brightness(0.9);
	}

	.single-thumb:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}

	/* Fixed height → uniform size for all thumbnails */
	.thumb-img {
		display: block;
		height: 115px;
		overflow: hidden;
		background: var(--sl-color-bg-sidebar);
	}

	.thumb-img img {
		width: 100%;
		height: 100%;
		/* contain — full image without cropping */
		object-fit: contain;
		/* top — image pinned to top, empty space at bottom (not top) */
		object-position: top center;
		display: block;
		/* reset any global margin from Starlight/global.scss */
		margin: 0;
		padding: 0;
	}

	/* Caption tooltip — slides up from bottom on hover */
	.thumb-tooltip {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 0.4rem 0.6rem;
		background: rgba(0, 0, 0, 0.72);
		color: #fff;
		font-size: 0.75rem;
		line-height: 1.3;
		text-align: center;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		/* hidden by default */
		opacity: 0;
		transform: translateY(4px);
		transition:
			opacity 0.2s ease,
			transform 0.2s ease;
		pointer-events: none;
	}

	.gallery-thumb:hover .thumb-tooltip,
	.gallery-thumb:focus-visible .thumb-tooltip {
		opacity: 1;
		transform: translateY(0);
	}

	/* ═══════════════════════════════════════════════
	   LIGHTBOX — main container
	═══════════════════════════════════════════════ */

	.gallery-lightbox {
		position: fixed;
		inset: 0;
		z-index: 9999;
		/* hidden by default */
		display: none;
	}

	/* Open state via class (JS manages class and aria-hidden) */
	.gallery-lightbox.is-open {
		display: block;
	}

	/* Closing — lightbox still visible but pointer-events already disabled */
	.gallery-lightbox.is-closing {
		display: block;
		pointer-events: none;
		animation: lb-fade-out 0.22s ease forwards;
	}

	@keyframes lb-fade-out {
		from {
			opacity: 1;
		}
		to {
			opacity: 0;
		}
	}

	/* ── Blurred backdrop (not solid black) ─────────────────── */

	.lb-backdrop {
		position: absolute;
		inset: 0;
		/* Blur + semi-transparent dark — not solid black */
		background: rgba(10, 10, 20, 0.55);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		/* Smooth backdrop fade-in on open */
		animation: lb-backdrop-in 0.25s ease forwards;
	}

	@keyframes lb-backdrop-in {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	/* ── Image wrapper ──────────────────────────── */

	/* Covers the full viewport — transform-origin is set in px from the viewport top-left,
	   matching the thumbnail center → image "grows" from it */
	.lb-img-wrapper {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 1rem;
		/* transform-origin is set via JS before the animation */
		transform-origin: 50% 50%;
	}

	/* Footer hidden during zoom animations so it doesn't scale with the image */
	.gallery-lightbox.is-opening .lb-footer,
	.gallery-lightbox.is-closing .lb-footer {
		opacity: 0;
	}

	/* "Zoom from thumbnail" animation on open */
	.gallery-lightbox.is-opening .lb-img-wrapper {
		animation: lb-expand 0.38s cubic-bezier(0.34, 1.25, 0.64, 1) forwards;
	}

	/* "Collapse to thumbnail" animation on close */
	.gallery-lightbox.is-closing .lb-img-wrapper {
		animation: lb-collapse 0.22s ease-in forwards;
	}

	@keyframes lb-expand {
		from {
			transform: scale(0.07);
			opacity: 0;
		}
		to {
			transform: scale(1);
			opacity: 1;
		}
	}

	@keyframes lb-collapse {
		from {
			transform: scale(1);
			opacity: 1;
		}
		to {
			transform: scale(0.07);
			opacity: 0;
		}
	}

	.lb-img {
		max-width: 90vw;
		max-height: 78vh;
		object-fit: contain;
		border-radius: 4px;
		display: block;
		/* Shadow gives the "floating" image effect */
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
	}

	/* SVGs are vector — scale up to fill the viewport */
	.lb-img.lb-img--svg {
		width: 90vw;
		height: 78vh;
		box-shadow: none;
	}

	/* ── Lightbox buttons (all position:fixed) ────── */

	.lb-close,
	.lb-prev,
	.lb-next {
		position: fixed;
		z-index: 10001;
		border-radius: 50%;
		border: 1px solid rgba(255, 255, 255, 0.2);
		background: rgba(30, 30, 40, 0.6);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		color: #fff;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition:
			background 0.18s ease,
			transform 0.18s ease;
	}

	.lb-close:hover,
	.lb-prev:hover,
	.lb-next:hover,
	.lb-close:focus-visible,
	.lb-prev:focus-visible,
	.lb-next:focus-visible {
		background: rgba(60, 60, 80, 0.85);
		transform: scale(1.08);
		outline: none;
	}

	.lb-close {
		top: 1rem;
		right: 1rem;
		width: 2.5rem;
		height: 2.5rem;
	}

	.lb-close svg {
		width: 1.1rem;
		height: 1.1rem;
	}

	/* Prev / Next — vertically centered in the viewport */
	.lb-prev {
		left: 1rem;
		top: 50%;
		transform: translateY(-50%);
		width: 3rem;
		height: 3rem;
	}

	.lb-next {
		right: 1rem;
		top: 50%;
		transform: translateY(-50%);
		width: 3rem;
		height: 3rem;
	}

	.lb-prev:hover,
	.lb-next:hover,
	.lb-prev:focus-visible,
	.lb-next:focus-visible {
		transform: translateY(-50%) scale(1.08);
	}

	.lb-prev svg,
	.lb-next svg {
		width: 1.4rem;
		height: 1.4rem;
	}

	.lb-prev[hidden],
	.lb-next[hidden] {
		visibility: hidden;
		pointer-events: none;
	}

	/* ── Footer: caption + counter (fixed to bottom) ─────────────── */

	.lb-footer {
		position: fixed;
		bottom: 1.5rem;
		left: 50%;
		transform: translateX(-50%);
		z-index: 10000;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
		max-width: 80vw;
		text-align: center;
		pointer-events: none;
	}

	.lb-caption {
		color: #fff;
		font-size: 1.125rem;
		line-height: 1.5;
		background: rgba(0, 0, 0, 0.65);
		padding: 0.5rem 1.25rem;
		border-radius: 8px;
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.lb-counter {
		color: rgba(255, 255, 255, 0.6);
		font-size: 0.8rem;
	}

	/* ── Theme switching (light/dark image variants) ──── */
	/* !important needed to override .single-thumb img / .thumb-img img display rules */

	.dark-only {
		display: none !important;
	}
	:global([data-theme='dark']) .light-only {
		display: none !important;
	}
	:global([data-theme='dark']) .dark-only {
		display: block !important;
	}

	/* Lightbox: show correct themed image */
	.lb-img-dark {
		display: none !important;
	}
	:global([data-theme='dark']) .lb-img-light {
		display: none !important;
	}
	:global([data-theme='dark']) .lb-img-dark {
		display: block !important;
	}

	/* ── Reduced motion ────────────────────────────── */

	@media (prefers-reduced-motion: reduce) {
		.gallery-lightbox.is-opening .lb-img-wrapper,
		.gallery-lightbox.is-closing .lb-img-wrapper,
		.gallery-lightbox.is-closing,
		.lb-backdrop {
			animation: none !important;
		}

		.gallery-thumb {
			transition: none;
		}
	}
</style>

<script define:vars={{ galleryId }}>
	const gallery = document.getElementById(galleryId);
	if (!gallery) throw new Error(`ImageGallery: #${galleryId} not found`);

	const lightbox = gallery.querySelector('.gallery-lightbox');
	const imgWrapper = gallery.querySelector('.lb-img-wrapper');
	const lbImgLight = gallery.querySelector('.lb-img-light');
	const lbImgDark = gallery.querySelector('.lb-img-dark');
	const caption = gallery.querySelector('.lb-caption');
	const counter = gallery.querySelector('.lb-counter');
	const closeBtn = gallery.querySelector('.lb-close');
	const prevBtn = gallery.querySelector('.lb-prev');
	const nextBtn = gallery.querySelector('.lb-next');
	const backdrop = gallery.querySelector('.lb-backdrop');
	const thumbs = Array.from(gallery.querySelectorAll('.gallery-thumb'));

	// Teleport lightbox to document.body — escape any stacking context
	// (article, main, content div may have isolation/transform/overflow that limits z-index)
	// After this, position:fixed will be relative to viewport, not the parent element
	document.body.appendChild(lightbox);

	let currentIndex = 0;
	let isClosing = false;

	function isOpen() {
		return lightbox.getAttribute('aria-hidden') === 'false';
	}

	// Updates image and counter/caption
	function updateContent() {
		const btn = thumbs[currentIndex];
		const lightSrc = btn.dataset.fullSrc;
		const darkSrc = btn.dataset.fullSrcDark || lightSrc;
		lbImgLight.src = lightSrc;
		lbImgLight.alt = btn.dataset.alt;
		lbImgDark.src = darkSrc;
		lbImgDark.alt = btn.dataset.alt;
		caption.innerHTML = btn.dataset.caption ?? '';

		// SVGs are vector — scale up to fill viewport via CSS class
		const isSvg = lightSrc.includes('.svg');
		lbImgLight.classList.toggle('lb-img--svg', isSvg);
		lbImgDark.classList.toggle('lb-img--svg', isSvg);

		const single = thumbs.length <= 1;
		counter.textContent = single ? '' : `${currentIndex + 1} / ${thumbs.length}`;
		prevBtn.toggleAttribute('hidden', single);
		nextBtn.toggleAttribute('hidden', single);
	}

	function openLightbox(index, triggerBtn) {
		if (isClosing) return;

		// Thumbnail center in viewport coordinates → transform-origin for zoom animation
		const rect = triggerBtn.getBoundingClientRect();
		const originX = rect.left + rect.width / 2;
		const originY = rect.top + rect.height / 2;
		imgWrapper.style.transformOrigin = `${originX}px ${originY}px`;

		currentIndex = index;
		updateContent();

		lightbox.setAttribute('aria-hidden', 'false');
		document.body.style.overflow = 'hidden';

		// First is-open (shows the element), then is-opening (triggers animation)
		lightbox.classList.add('is-open', 'is-opening');
		imgWrapper.addEventListener('animationend', () => lightbox.classList.remove('is-opening'), {
			once: true,
		});

		closeBtn.focus();
	}

	function closeLightbox() {
		if (isClosing || !isOpen()) return;
		isClosing = true;

		// Update origin to current thumbnail position (for collapse animation)
		const btn = thumbs[currentIndex];
		if (btn) {
			const rect = btn.getBoundingClientRect();
			imgWrapper.style.transformOrigin = `${rect.left + rect.width / 2}px ${rect.top + rect.height / 2}px`;
		}

		lightbox.classList.remove('is-open');
		lightbox.classList.add('is-closing');

		function finish() {
			lightbox.classList.remove('is-closing');
			lightbox.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
			thumbs[currentIndex]?.blur();
			isClosing = false;
		}

		// Finish on animationend or after timeout (if animation is disabled)
		lightbox.addEventListener('animationend', finish, { once: true });
		setTimeout(finish, 280);
	}

	function showPrev() {
		currentIndex = (currentIndex - 1 + thumbs.length) % thumbs.length;
		updateContent();
	}

	function showNext() {
		currentIndex = (currentIndex + 1) % thumbs.length;
		updateContent();
	}

	// Thumbnail click
	thumbs.forEach((btn, i) => btn.addEventListener('click', () => openLightbox(i, btn)));

	// Lightbox buttons
	closeBtn.addEventListener('click', closeLightbox);
	backdrop.addEventListener('click', closeLightbox);
	imgWrapper.addEventListener('click', closeLightbox);
	prevBtn.addEventListener('click', showPrev);
	nextBtn.addEventListener('click', showNext);

	// Keyboard (only if this lightbox is open)
	document.addEventListener('keydown', (e) => {
		if (!isOpen()) return;
		if (e.key === 'Escape') closeLightbox();
		else if (e.key === 'ArrowLeft') showPrev();
		else if (e.key === 'ArrowRight') showNext();
	});
</script>
