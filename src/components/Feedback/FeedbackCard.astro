---
import { Icon } from 'astro-icon/components';
import type { FeedbackEntry } from '../../data/clients-feedback/types';

interface Props {
	entry: FeedbackEntry;
	category: string;
	duplicate?: boolean;
}

const { entry, category, duplicate = false } = Astro.props;
const isLong = entry.tagline.length + entry.text.reduce((s, p) => s + p.length, 0) > 600;
---

<article class:list={['cf-card', { 'cf-dupe': duplicate }]} data-category={category}>
	<div class="cf-card-header">
		<div class="cf-card-author">
			{entry.authorImage ? (
				<img
					class="cf-card-avatar"
					src={entry.authorImage}
					alt={entry.author}
					width="64"
					height="64"
					loading="lazy"
				/>
			) : (
				<div class="cf-card-avatar cf-card-avatar--placeholder">
					{entry.author.charAt(0)}
				</div>
			)}
			<div class="cf-card-author-info">
				<p class="cf-card-name">{entry.author}</p>
				{entry.position && <p class="cf-card-position">{entry.position}</p>}
			</div>
		</div>
		<div class="cf-card-company">
			{entry.link ? (
				<a href={entry.link} target="_blank" rel="noopener noreferrer">
					<img
						src={entry.companyImage}
						alt={entry.companyName}
						width={entry.companyImageWidth}
						height={entry.companyImageHeight}
						loading="lazy"
					/>
				</a>
			) : (
				<img
					src={entry.companyImage}
					alt={entry.companyName}
					width={entry.companyImageWidth}
					height={entry.companyImageHeight}
					loading="lazy"
				/>
			)}
		</div>
	</div>
	<div class:list={['cf-card-body', { 'cf-card-body--clamped': isLong }]}>
		<p class="cf-card-tagline">{entry.tagline}</p>
		{entry.text.map((paragraph) => (
			<p class="cf-card-text">{paragraph}</p>
		))}
	</div>
	{(isLong || entry.caseStudySlug) && (
		<div class="cf-card-actions">
			{isLong && (
				<button type="button" class="cf-read-more">
					<span class="cf-read-more-text">Read more</span>
					<Icon name="tabler:chevron-down" class="cf-read-more-icon" />
				</button>
			)}
			{entry.caseStudySlug && (
				<a href={`/case-studies/${entry.caseStudySlug}/`} class="cf-case-study-link" target="_blank">
					<Icon name="tabler:book-2" class="cf-cs-icon" />
					Case study
					<Icon name="tabler:arrow-right" class="cf-cs-arrow" />
				</a>
			)}
		</div>
	)}
</article>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	// ─── Card ───
	.cf-card {
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: $radius-xl;
		padding: $spacing-6;
		transition: border-color $transition-fast;

		&:hover {
			border-color: var(--color-border-light);
		}

		&.cf-hidden {
			display: none;
		}
	}

	.cf-card-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: $spacing-4;
		margin-bottom: $spacing-5;

		@include media-down(sm) {
			flex-direction: column;
		}
	}

	.cf-card-author {
		display: flex;
		align-items: center;
		gap: $spacing-3;
	}

	.cf-card-avatar {
		width: 64px;
		height: 64px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;

		&--placeholder {
			display: flex;
			align-items: center;
			justify-content: center;
			background: rgba($color-primary, 0.1);
			color: $color-primary;
			font-size: $font-size-2xl;
			font-weight: $font-weight-semibold;
		}
	}

	.cf-card-author-info {
		min-width: 0;
	}

	.cf-card-name {
		@include text-m;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
		margin: 0;
		line-height: 1.3;
	}

	.cf-card-position {
		@include text-s;
		color: var(--color-text-secondary);
		margin: 2px 0 0;
	}

	.cf-card-company {
		flex-shrink: 0;

		a {
			display: block;
			text-decoration: none;
			opacity: 0.8;
			transition: opacity $transition-fast;

			&:hover {
				opacity: 1;
			}
		}

		img {
			display: block;
			max-width: 140px;
			max-height: 48px;
			width: auto;
			height: auto;
			object-fit: contain;

			[data-theme='dark'] & {
				background: rgba(255, 255, 255, 0.9);
				padding: 6px 10px;
				border-radius: $radius-md;
			}
		}
	}

	.cf-card-body {
		position: relative;

		&--clamped:not(&--expanded) {
			max-height: 220px;
			overflow: hidden;

			&::after {
				content: '';
				position: absolute;
				bottom: 0;
				left: 0;
				right: 0;
				height: 60px;
				background: linear-gradient(to bottom, transparent, var(--color-bg-surface));
				pointer-events: none;
			}
		}
	}

	.cf-card-tagline {
		@include text-m;
		font-weight: $font-weight-medium;
		color: var(--color-text);
		margin: 0 0 $spacing-3;
	}

	.cf-card-text {
		@include text-s;
		color: var(--color-text-secondary);
		margin: 0 0 $spacing-2;

		&:last-child {
			margin-bottom: 0;
		}
	}

	// ─── Card actions bar ───
	.cf-card-actions {
		display: flex;
		align-items: center;
		gap: $spacing-4;
		margin-top: $spacing-4;
		padding-top: $spacing-4;
		border-top: 1px solid var(--color-border);
	}

	// ─── Read more toggle ───
	.cf-read-more {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 0;
		border: none;
		background: none;
		color: var(--color-text-secondary);
		font-size: $font-size-sm;
		font-weight: $font-weight-medium;
		cursor: pointer;
		transition: color $transition-fast;

		&:hover {
			color: var(--color-text);
		}

		.cf-read-more-icon {
			width: 10px;
			height: 10px;
			transition: transform 0.25s ease;
		}

		&--expanded .cf-read-more-icon {
			transform: rotate(180deg);
		}
	}

	// ─── Read more — expanded state ───
	.cf-card-body--clamped.cf-card-body--expanded {
		max-height: none;
		overflow: visible;

		&::after {
			display: none;
		}
	}

	// ─── Case study pill ───
	.cf-case-study-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		margin-left: auto;
		padding: 5px $spacing-3;
		font-size: $font-size-xs;
		font-weight: $font-weight-medium;
		color: $color-primary;
		text-decoration: none;
		border: 1px solid rgba($color-primary, 0.25);
		border-radius: $radius-full;
		background: rgba($color-primary, 0.04);
		transition: background-color $transition-fast, border-color $transition-fast;

		&:hover {
			background: rgba($color-primary, 0.1);
			border-color: rgba($color-primary, 0.5);
		}

		.cf-cs-icon {
			width: 11px;
			height: 11px;
			opacity: 0.7;
		}

		.cf-cs-arrow {
			width: 10px;
			height: 10px;
			opacity: 0.5;
			transition: transform $transition-fast, opacity $transition-fast;
		}

		&:hover .cf-cs-arrow {
			transform: translateX(2px);
			opacity: 0.8;
		}
	}
</style>

<script>
	function initFeedbackCards() {
		document.querySelectorAll<HTMLButtonElement>('.cf-read-more').forEach((btn) => {
			if (btn.dataset.initialized) return;
			btn.dataset.initialized = 'true';

			btn.addEventListener('click', () => {
				const card = btn.closest('.cf-card');
				const body = card?.querySelector('.cf-card-body');
				const textEl = btn.querySelector('.cf-read-more-text');
				const expanded = body?.classList.toggle('cf-card-body--expanded');
				btn.classList.toggle('cf-read-more--expanded', expanded);
				if (textEl) textEl.textContent = expanded ? 'Read less' : 'Read more';
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initFeedbackCards);
	document.addEventListener('astro:page-load', initFeedbackCards);
</script>
