---
import { Icon } from 'astro-icon/components';

// Site-wide promo carousel. Two announcement slides that crossfade (one fades out as
// the next fades in over the same spot — all motion is CSS) with ‹ › manual controls
// and a 6s auto-rotate. Shared by marketing (BaseLayout) and docs (starlight/Header).
// A slide whose own target page is the current page is dropped, so the banner never
// self-promotes the page you're already reading. Relative URLs keep the current host.
const SLIDES = [
	{
		href: '/blog/thingsboard-cli-for-ai-driven-iot-development/?utm_source=tb&utm_medium=bnr&utm_campaign=cli',
		target: '/blog/thingsboard-cli-for-ai-driven-iot-development',
		badge: 'NEW',
		// Plain text for the link's accessible name.
		label: 'ThingsBoard CLI: build your IoT solution with AI Coding agents',
		// Display markup (keeps the bold lead-in); rendered with set:html.
		html: '<strong>ThingsBoard CLI</strong>: build your IoT solution with <strong>AI Coding agents</strong>',
	},
	{
		href: '/blog/ai-solution-creator/?utm_source=tb&utm_medium=bnr&utm_campaign=ASC',
		target: '/blog/ai-solution-creator',
		badge: 'AI FEATURE',
		label: 'AI Solution Creator — get a working IoT prototype in 10 minutes',
		html: '<strong>AI Solution Creator</strong> — get a working IoT prototype in 10 minutes',
	},
];

const current = Astro.url.pathname.replace(/\/+$/, '');
const slides = SLIDES.filter((s) => s.target !== current);
const showBanner = slides.length > 0;
const hasSwitcher = slides.length > 1;
---

{
	showBanner && (
		<div
			id="promo-banner"
			class:list={[{ 'has-switcher': hasSwitcher }]}
			role="region"
			aria-label="Site announcements"
		>
			<div class="promo-inner" id="promo-slides">
				{slides.map((s, i) => (
					<a
						class="promo-slide"
						class:list={[{ 'is-active': i === 0 }]}
						href={s.href}
						target="_blank"
						rel="noopener noreferrer"
						data-label={s.label}
						aria-label={`${s.label} (opens in a new tab)`}
						aria-hidden={i === 0 ? undefined : 'true'}
						tabindex={i === 0 ? undefined : -1}
					>
						<span class="promo-badge">
							<span class="promo-pill">
								<svg
									class="promo-star"
									width="9"
									height="12"
									viewBox="0 0 9 12"
									fill="none"
									aria-hidden="true"
									focusable="false"
								>
									<path
										d="M5.17938 4.94344C5.25803 4.70471 5.59123 4.70471 5.66988 4.94344L6.13105 6.34471C6.23256 6.65274 6.40359 6.93262 6.63058 7.16215C6.85757 7.39169 7.13429 7.56458 7.43879 7.66712L8.82304 8.13373C9.05899 8.2133 9.05899 8.55042 8.82304 8.62999L7.43808 9.0966C7.13363 9.1993 6.85701 9.37235 6.63014 9.60201C6.40327 9.83167 6.2324 10.1116 6.13105 10.4197L5.66988 11.8203C5.65292 11.8726 5.62008 11.9181 5.57604 11.9503C5.532 11.9826 5.47901 12 5.42463 12C5.37025 12 5.31726 11.9826 5.27322 11.9503C5.22918 11.9181 5.19634 11.8726 5.17938 11.8203L4.71821 10.419C4.61677 10.1111 4.44585 9.83123 4.21899 9.6017C3.99213 9.37216 3.71555 9.19923 3.41118 9.0966L2.02622 8.62999C1.97456 8.61284 1.92956 8.57961 1.89767 8.53505C1.86577 8.49049 1.84859 8.43688 1.84859 8.38186C1.84859 8.32684 1.86577 8.27323 1.89767 8.22867C1.92956 8.18411 1.97456 8.15088 2.02622 8.13373L3.41118 7.66712C3.71555 7.56449 3.99213 7.39155 4.21899 7.16202C4.44585 6.93249 4.61677 6.65266 4.71821 6.34471L5.17938 4.94344ZM1.99828 0.829404C2.00853 0.798076 2.02828 0.770814 2.05472 0.751491C2.08117 0.732169 2.11295 0.721769 2.14557 0.721769C2.17819 0.721769 2.20997 0.732169 2.23642 0.751491C2.26286 0.770814 2.28261 0.798076 2.29286 0.829404L2.56957 1.67002C2.69326 2.04475 2.98355 2.33846 3.35392 2.46361L4.18476 2.74358C4.21572 2.75395 4.24267 2.77393 4.26176 2.80069C4.28086 2.82744 4.29114 2.8596 4.29114 2.8926C4.29114 2.9256 4.28086 2.95777 4.26176 2.98452C4.24267 3.01127 4.21572 3.03125 4.18476 3.04163L3.35392 3.32159C3.17115 3.38296 3.00507 3.48667 2.8689 3.62444C2.73272 3.76222 2.63023 3.93026 2.56957 4.11518L2.29286 4.9558C2.28261 4.98713 2.26286 5.01439 2.23642 5.03371C2.20997 5.05304 2.17819 5.06344 2.14557 5.06344C2.11295 5.06344 2.08117 5.05304 2.05472 5.03371C2.02828 5.01439 2.00853 4.98713 1.99828 4.9558L1.72157 4.11518C1.66091 3.93026 1.55842 3.76222 1.42225 3.62444C1.28607 3.48667 1.11999 3.38296 0.937216 3.32159L0.106383 3.04163C0.0754195 3.03125 0.0484746 3.01127 0.0293769 2.98452C0.0102791 2.95777 0 2.9256 0 2.8926C0 2.8596 0.0102791 2.82744 0.0293769 2.80069C0.0484746 2.77393 0.0754195 2.75395 0.106383 2.74358L0.937216 2.46361C1.11999 2.40224 1.28607 2.29854 1.42225 2.16076C1.55842 2.02299 1.66091 1.85494 1.72157 1.67002L1.99828 0.829404ZM7.05263 0.0705355C7.05969 0.049937 7.07292 0.0320755 7.09047 0.0194342C7.10803 0.00679286 7.12904 0 7.15059 0C7.17214 0 7.19315 0.00679286 7.2107 0.0194342C7.22826 0.0320755 7.24149 0.049937 7.24854 0.0705355L7.43301 0.630464C7.51524 0.880767 7.70901 1.07681 7.9564 1.16001L8.50981 1.34665C8.53017 1.35379 8.54782 1.36717 8.56032 1.38494C8.57281 1.4027 8.57952 1.42396 8.57952 1.44576C8.57952 1.46756 8.57281 1.48882 8.56032 1.50658C8.54782 1.52434 8.53017 1.53773 8.50981 1.54487L7.9564 1.73151C7.83459 1.77275 7.72391 1.84204 7.63308 1.93394C7.54226 2.02583 7.47377 2.13781 7.43301 2.26106L7.24854 2.82098C7.24149 2.84158 7.22826 2.85944 7.2107 2.87208C7.19315 2.88473 7.17214 2.89152 7.15059 2.89152C7.12904 2.89152 7.10803 2.88473 7.09047 2.87208C7.07292 2.85944 7.05969 2.84158 7.05263 2.82098L6.86816 2.26106C6.82741 2.13781 6.75892 2.02583 6.66809 1.93394C6.57727 1.84204 6.46659 1.77275 6.34478 1.73151L5.79208 1.54487C5.77172 1.53773 5.75407 1.52434 5.74158 1.50658C5.72908 1.48882 5.72237 1.46756 5.72237 1.44576C5.72237 1.42396 5.72908 1.4027 5.74158 1.38494C5.75407 1.36717 5.77172 1.35379 5.79208 1.34665L6.34549 1.16001C6.59289 1.07681 6.78665 0.880767 6.86888 0.630464L7.05263 0.0705355Z"
										fill="currentColor"
									/>
								</svg>
								{s.badge}
							</span>
						</span>
						<span class="promo-msg" set:html={s.html} />
						<svg
							class="promo-arrow"
							viewBox="0 0 18 7"
							fill="none"
							aria-hidden="true"
							focusable="false"
						>
							<path
								d="M12.175 6.6C12.342 6.167 12.525 5.767 12.725 5.4C12.925 5.017 13.15 4.658 13.4 4.325H0V2.275H13.4C13.167 1.942 12.95 1.592 12.75 1.225C12.55 0.842 12.367 0.433 12.2 0H14.1C15.133 1.217 16.267 2.142 17.5 2.775V3.85C16.267 4.45 15.133 5.367 14.1 6.6H12.175Z"
								fill="currentColor"
							/>
						</svg>
					</a>
				))}

				{hasSwitcher && (
					<div class="promo-nav">
						<button
							type="button"
							class="promo-btn promo-prev"
							aria-label="Previous announcement"
							aria-controls="promo-slides"
						>
							<Icon name="tabler:chevron-left" aria-hidden="true" />
						</button>
						<button
							type="button"
							class="promo-btn promo-next"
							aria-label="Next announcement"
							aria-controls="promo-slides"
						>
							<Icon name="tabler:chevron-right" aria-hidden="true" />
						</button>
					</div>
				)}
			</div>
			{hasSwitcher && (
				/* Announces the active slide to screen readers (controls give no other feedback). */
				<span class="promo-status" role="status" aria-live="polite" aria-atomic="true" />
			)}
		</div>
	)
}
{
	/* No slide to show (e.g. all targets matched the current page): zero --promo-h. */
	!showBanner && <style is:inline set:html=":root{--promo-h:0px;--promo-anim:none}" />
}

<script>
	// State + timer only; the crossfade itself is a CSS opacity transition (see styles).
	const bar = document.getElementById('promo-banner');
	const slides = bar ? Array.from(bar.querySelectorAll<HTMLElement>('.promo-slide')) : [];

	if (bar && slides.length > 1) {
		const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const status = bar.querySelector<HTMLElement>('.promo-status');
		let cur = 0;
		let timer: ReturnType<typeof setInterval> | undefined;
		// Ground-truth pause state (not a counter): autoplay runs only when the user is
		// neither hovering nor keyboard-focused inside the bar. Booleans can't desync the
		// way a +/- counter can when one source (e.g. lingering focus after a click) never
		// fires its release event.
		let hovering = false;
		let focused = false;

		const go = (n: number) => {
			n = (n + slides.length) % slides.length;
			if (n === cur) return;
			slides[cur].classList.remove('is-active');
			slides[cur].setAttribute('aria-hidden', 'true');
			slides[cur].tabIndex = -1;
			slides[n].classList.add('is-active');
			slides[n].removeAttribute('aria-hidden');
			slides[n].tabIndex = 0;
			cur = n;
		};

		// Announce the active slide — only on manual nav, so the live region stays
		// quiet during autoplay (a 6s-chatty live region is an a11y anti-pattern).
		// Runs regardless of reduced motion so manual prev/next stays perceivable.
		const announce = () => {
			if (status) status.textContent = slides[cur].dataset.label ?? '';
		};

		const stop = () => clearInterval(timer);
		// Single source of truth: stop, then (re)start only if nothing should block it.
		const sync = () => {
			stop();
			if (reduce || hovering || focused) return; // reduced motion, or user interacting
			timer = setInterval(() => go(cur + 1), 6000);
		};

		bar.querySelector('.promo-prev')?.addEventListener('click', () => {
			go(cur - 1);
			announce();
		});
		bar.querySelector('.promo-next')?.addEventListener('click', () => {
			go(cur + 1);
			announce();
		});
		bar.addEventListener('mouseenter', () => {
			hovering = true;
			sync();
		});
		bar.addEventListener('mouseleave', () => {
			hovering = false;
			sync();
		});
		bar.addEventListener('focusin', () => {
			focused = true;
			sync();
		});
		bar.addEventListener('focusout', (e) => {
			// Ignore focus moves that stay inside the bar; only a real exit resumes autoplay.
			if (bar.contains(e.relatedTarget as Node | null)) return;
			focused = false;
			sync();
		});

		sync();
	}
</script>

<style lang="scss" is:global>
	@use '../styles/variables' as *;

	// Live banner offset. Header/sidebar/TOC read it. On docs it's scroll-driven
	// (see _starlight-overrides); on marketing it stays --promo-h (sticky unit hides).
	@property --promo-cur {
		syntax: '<length>';
		inherits: true;
		initial-value: 0px;
	}

	:root {
		--promo-h: 40px; // constant reserved height (content offset reads this)
		--promo-cur: var(--promo-h);
	}

	// Docs banner is fixed and print.css won't unfix it — hide it in print.
	@media print {
		#promo-banner {
			display: none;
		}
	}

	#promo-banner {
		// bg uses the cloud product token (auto light→dark). Dark value is light
		// lavender, so the foreground is flipped in the [data-theme='dark'] block below.
		--promo-bg: var(--color-product-cloud, #3d50f5);
		--promo-fg: #fff; // message text
		--promo-pill-bg: #fff;
		--promo-pill-fg: #305680; // pill text + star

		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		// Fixed height (not min-height): the hide offset assumes the banner is exactly
		// --promo-h tall, so a future longer message clips instead of growing past it
		// (which would poke above the docs header / leave a sliver on marketing).
		height: var(--promo-h);
		overflow: hidden;
		z-index: 8889; // above header (8888), below cookie banner (9999) / burger (10000)
		background-color: var(--promo-bg);
		font-family: var(--sl-font, var(--sl-font-system));
		// Slides off as --promo-cur → 0 (banner height == --promo-h → fully hidden).
		transform: translateY(calc(var(--promo-cur) - var(--promo-h)));
		will-change: transform;

		// Positioning context for the stacked slides + nav. Stays relative regardless
		// of whether the bar itself is fixed (docs) or static (marketing).
		// Both slides share ONE grid cell (grid-area 1/1) sized to the WIDER slide.
		// With the content left-aligned inside, the badge + message sit at the same
		// fixed x on every slide — so nothing reflows or jumps when one crossfades
		// into the other. The cell is centered in the bar. The track is capped with
		// minmax(0, max-content) so when the longest slide can't fit (narrow desktop)
		// the message ellipsizes instead of overflowing past overflow:hidden.
		.promo-inner {
			position: relative;
			width: 100%;
			height: 100%;
			display: grid;
			grid-template-columns: minmax(0, max-content);
			grid-template-rows: 1fr; // single full-height row; slides stretch into it
			justify-content: center;
			align-items: center;
		}

		// Slides stack in the same cell and crossfade between one another.
		.promo-slide {
			grid-area: 1 / 1;
			min-width: 0;
			display: flex;
			flex-wrap: nowrap; // keep pill + message + arrow on one row (no stray arrow)
			align-items: center;
			justify-content: flex-start; // left-align so the badge/message x is fixed
			gap: 16px;
			padding: 4px 16px;
			text-align: left;
			text-decoration: none;
			opacity: 0;
			pointer-events: none;
			transition: opacity 0.8s ease;

			&.is-active {
				opacity: 1;
				pointer-events: auto;
			}
		}

		// Safari-only fix.
		@supports (background: -webkit-named-image(i)) {
			.promo-slide {
				transition: opacity 0.4s ease; // outgoing: fade out first, no delay

				&.is-active {
					transition: opacity 0.4s ease 0.4s; // incoming: wait out the fade-out, then fade in
				}
			}
		}

		// Reserve room for the ‹ › controls on the right (so the arrow never tucks
		// under them); mirror it on the left so the content stays optically centered
		// in the bar rather than drifting left.
		&.has-switcher .promo-slide {
			padding-inline: 76px;
		}

		// Fixed-width slot with the pill right-aligned inside it, so both slides'
		// badges share the same right edge. The message then always starts at the
		// same x and doesn't jump when "NEW" crossfades to the wider "AI FEATURE".
		.promo-badge {
			display: flex;
			justify-content: flex-end;
			flex-shrink: 0;
			width: 120px;
		}

		.promo-pill {
			display: inline-flex;
			align-items: center;
			gap: 6px;
			flex-shrink: 0;
			padding: 5px 14px; // wider + taller, ~24px pill per the design
			border-radius: $radius-full;
			background-color: var(--promo-pill-bg);
			color: var(--promo-pill-fg);
			@include text-xs; // ~12px / 500
			letter-spacing: 0.02em;
		}

		.promo-star {
			width: auto;
			height: 15px; // larger sparkle per the design
			color: var(--promo-pill-fg); // drives the star's currentColor fill
		}

		.promo-msg {
			@include text-s; // body text: 400 (matches the design's base weight)
			font-size: 15px; // a touch larger than the 14px text-s default
			line-height: 1.3;
			color: var(--promo-fg);
			word-spacing: 0.12em; // a touch more space between words
			white-space: nowrap; // one line on desktop; mobile re-enables wrapping
			// Shrink + ellipsis when the longest slide won't fit (narrow desktop),
			// so it degrades cleanly instead of being clipped by overflow:hidden.
			min-width: 0;
			overflow: hidden;
			text-overflow: ellipsis;

			strong {
				font-weight: $font-weight-bold; // 700, per the design's bold segments
			}
		}

		// Long thin arrow (the design SVG — replaces the old → glyph).
		.promo-arrow {
			flex-shrink: 0;
			width: auto;
			height: 9px;
			color: var(--promo-fg);
		}

		// Visually-hidden live region: announces the active slide to screen readers.
		.promo-status {
			position: absolute;
			width: 1px;
			height: 1px;
			margin: -1px;
			padding: 0;
			border: 0;
			overflow: hidden;
			clip: rect(0 0 0 0);
			clip-path: inset(50%);
			white-space: nowrap;
		}

		// ‹ › manual switcher, pinned to the right edge (aligned with the header's
		// 20px gutter, so it sits above the nav's right edge / "Try it now" button).
		.promo-nav {
			position: absolute;
			top: 0;
			right: 20px;
			height: 100%;
			display: flex;
			align-items: center;
			gap: 2px;
			z-index: 1;
		}

		.promo-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 26px;
			height: 26px;
			padding: 0;
			border: 0;
			border-radius: $radius-full;
			background: none;
			color: var(--promo-fg);
			cursor: pointer;
			opacity: 0.85;
			transition: opacity 0.2s ease;

			&:hover {
				opacity: 1;
			}

			svg {
				width: 20px;
				height: 20px;
			}
		}
	}

	// Reduced motion: cut the crossfade — and Safari's fade-through override (autoplay is
	// also disabled in JS). Must also match `.is-active` to beat that override's
	// higher-specificity transition; this block comes later in source, so it wins.
	@media (prefers-reduced-motion: reduce) {
		#promo-banner .promo-slide,
		#promo-banner .promo-slide.is-active {
			transition: none;
		}
	}

	// Dark theme: flip foreground for the light lavender background.
	[data-theme='dark'] #promo-banner {
		--promo-fg: #0d2743; // deep navy on the light lavender strip
		--promo-pill-bg: #3d50f5; // saturated indigo pill stands out
		--promo-pill-fg: #fff;
	}

	// Pages whose "Try it now" CTA is the azure primary (not indigo): match the banner
	// to the button. Two ids → beats the dark-theme rule, so it holds in both themes.
	#home,
	#thingsboard-pe,
	#thingsboard-paas,
	#thingsboard-edge,
	#mobile-app,
	#mobile-pe,
	#mqtt-broker,
	#trendz,
	#development-services,
	#services,
	#trainings,
	#company,
	#mediakit,
	#careers {
		#promo-banner {
			--promo-bg: #{$color-primary}; // azure, same as the CTA button
			--promo-fg: #fff;
			--promo-pill-bg: #fff;
			--promo-pill-fg: #305680;
		}
	}

	// Marketing: scrolls away inside the .tb-topbar sticky unit (see HeaderContent).
	// Docs: fixed, hides via scroll-driven --promo-cur (see _starlight-overrides).
	.tb-topbar #promo-banner {
		position: static;
	}

	// Mobile: badge stays left, message wraps beside it; taller bar.
	@include media-down(md) {
		:root {
			--promo-h: 52px;
		}

		#promo-banner {
			// Revert to absolute stacking so each slide fills the full bar width and
			// the message can wrap (the desktop auto-sized centered cell would force
			// the long messages off-screen on a phone).
			.promo-inner {
				display: block;
			}

			.promo-slide {
				position: absolute;
				inset: 0;
				justify-content: flex-start; // badge hugs the left; message takes the rest
				gap: 8px;
				padding: 6px 14px;
			}

			// Controls are hidden on mobile, so reclaim their reserved room.
			&.has-switcher .promo-slide {
				padding-inline: 14px;
			}

			// Drop the fixed-width slot so the badge shrinks to its content and
			// hugs the left, letting the wrapping message claim the rest of the row.
			.promo-badge {
				width: auto;
			}

			// Smaller badge + tighter spacing free enough width for the longest
			// message ("AI FEATURE" slide) to wrap to two rows instead of three.
			.promo-pill {
				padding: 4px 10px;
				font-size: 11px;
			}

			.promo-star {
				height: 13px;
			}

			.promo-msg {
				font-size: 13px;
				text-align: left;
				min-width: 0; // allow the message to shrink and wrap beside the pill
				word-spacing: normal; // reclaim the extra inter-word space
				white-space: normal; // wrap to two rows on mobile
			}

			// Declutter the cramped mobile bar: drop the switcher and the trailing
			// arrow. Auto-rotation still runs and the whole slide stays tappable.
			.promo-nav,
			.promo-arrow {
				display: none;
			}
		}
	}
</style>
