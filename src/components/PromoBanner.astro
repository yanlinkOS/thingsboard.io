---
// Site-wide promo strip for the AI Solution Creator campaign. Shared by marketing
// pages (BaseLayout) and docs (starlight/Header). Hidden on the page it links to.
// Relative URL → stays on the current host; UTM params kept for tracking.
const HREF = '/blog/ai-solution-creator/?utm_source=tb&utm_medium=bnr&utm_campaign=ASC';

const TARGET_PATH = '/blog/ai-solution-creator';
const showBanner = Astro.url.pathname.replace(/\/+$/, '') !== TARGET_PATH;
---

{
	showBanner && (
		<a
			id="promo-banner"
			href={HREF}
			target="_blank"
			rel="noopener"
			aria-label="AI Solution Creator — get a working IoT prototype in 10 minutes (opens in a new tab)"
		>
			<span class="promo-pill">
				<svg class="promo-star" width="9" height="12" viewBox="0 0 9 12" fill="none" aria-hidden="true" focusable="false">
