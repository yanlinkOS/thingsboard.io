---
import '@astrojs/starlight/style/markdown.css';
import BackendGuidesNav from '../BackendGuidesNav.astro';
import CMSGuidesNav from '../CMSGuidesNav.astro';
import DeployGuidesNav from '../DeployGuidesNav.astro';
import MediaGuidesNav from '../MediaGuidesNav.astro';
import IntegrationsNav from '../IntegrationsNav.astro';
import MigrationGuidesNav from '../MigrationGuidesNav.astro';
import FeedbackPrompt from './FeedbackPrompt.astro';
import { shouldShowFeedback } from '~/util/shouldShowFeedback';

// Docs markdown chrome — wraps the content slot in `.sl-markdown-content`,
// tacks on the per-type "more guides" navigation, binds anchor-link copy,
// and emits the docs-specific table / config-list styles. Kept separate
// from `MarkdownContent.astro` so its scoped CSS + nav-component imports
// only land in route bundles that actually need them. `MarkdownContent.
// astro` proxies in front and short-circuits to a bare `<slot />` on
// `BaseLayout` pages.

const { entry } = Astro.locals.starlightRoute;
const hasToc = !!Astro.locals.starlightRoute.toc;
const showFeedback = shouldShowFeedback(Astro.locals.starlightRoute);
---

<div class="sl-markdown-content">
	<slot />

	{
		entry.data.type === 'backend' && (
			<>
				<h2>{Astro.locals.t('backend.navTitle')}</h2>
				<BackendGuidesNav minimal={true} />
			</>
		)
	}
	{
		entry.data.type === 'cms' && (
			<>
				<h2>{Astro.locals.t('cms.navTitle')}</h2>
				<CMSGuidesNav minimal={true} />
			</>
		)
	}
	{
		entry.data.type === 'deploy' && (
			<>
				<h2>{Astro.locals.t('deploy.altSectionTitle')}</h2>
				<DeployGuidesNav minimal={true} />
			</>
		)
	}
	{
		entry.data.type === 'media' && (
			<>
				<h2>{Astro.locals.t('media.navTitle')}</h2>
				<MediaGuidesNav minimal={true} />
			</>
		)
	}
	{
		entry.data.type === 'integration' && (
			<>
				<h2>{Astro.locals.t('integrations.more')}</h2>
				<IntegrationsNav />
			</>
		)
	}
	{
		entry.data.type === 'migration' && (
			<>
				<h2>{Astro.locals.t('migration.navTitle')}</h2>
				<MigrationGuidesNav minimal={true} />
			</>
		)
	}
</div>

{
	showFeedback && (
		<div class:list={['feedback-mount', { 'feedback-mount--mobile-only': hasToc }]}>
			<FeedbackPrompt />
		</div>
	)
}

<script>
	function initAnchorCopy() {
		document.querySelectorAll<HTMLElement>('.sl-heading-wrapper').forEach((wrapper) => {
			if (wrapper.dataset.anchorInit) return;
			wrapper.dataset.anchorInit = '1';

			const link = wrapper.querySelector('.sl-anchor-link');
			if (!link) return;

			link.addEventListener('click', () => {
				// URL is updated by the browser after click — wait one tick
				requestAnimationFrame(() => {
					navigator.clipboard?.writeText(window.location.href);
				});
			});
		});
	}

	initAnchorCopy();
	document.addEventListener('astro:page-load', initAnchorCopy);
</script>

<style is:global>
	html[data-has-sidebar]:not([data-has-toc]) {
		--sl-content-width: 72rem;
	}

	.feedback-mount {
		--feedback-max-width: none;
	}

	@media (min-width: 72rem) {
		.feedback-mount--mobile-only {
			display: none;
		}
	}

	.sl-markdown-content table:not(:where(.not-content *)) {
		display: block;
		overflow-x: auto;
		border-collapse: collapse;
	}

	/* Config reference compact definition list */
	.config-def-list {
		margin-block: 1rem;
	}
	.config-def-item {
		padding-block: 0.625rem;
		border-bottom: 1px solid var(--sl-color-hairline-light);
	}
	.config-def-item:last-child {
		border-bottom: none;
	}
	.config-def-meta {
		font-size: 0.8125rem;
		margin: 0 0 0.2rem;
		word-break: break-all;
	}
	.config-def-env {
		font-weight: 600;
		font-size: 0.875rem;
	}
	.config-def-label {
		font-size: 0.6875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-text-accent);
	}
	.config-def-meta code {
		font-size: 0.8125rem;
	}
	.config-def-desc {
		font-size: 0.875rem;
		color: var(--sl-color-gray-2, var(--sl-color-text));
		margin: 0;
		line-height: 1.5;
	}

	.sl-markdown-content :is(th, td):not(:where(.not-content *)) {
		border: 1px solid var(--sl-color-hairline-light);
		padding: 0.5rem 1rem;
	}

	/* Restore padding removed by Starlight for first/last cells */
	.sl-markdown-content :is(th:first-child, td:first-child):not(:where(.not-content *)) {
		padding-inline-start: 1rem;
	}
	.sl-markdown-content :is(th:last-child, td:last-child):not(:where(.not-content *)) {
		padding-inline-end: 1rem;
	}

	/* Zebra striping: header row + every even tbody row */
	.sl-markdown-content thead tr:not(:where(.not-content *)) {
		background-color: var(--sl-color-gray-7, var(--sl-color-gray-6));
	}
	.sl-markdown-content tbody tr:nth-child(even):not(:where(.not-content *)) {
		background-color: var(--sl-color-gray-7, var(--sl-color-gray-6));
	}

	/* Inside aside blocks: odd rows are transparent and show aside bg —
	   override them to use the page background so zebra striping stays readable */
	.sl-markdown-content .starlight-aside tbody tr:nth-child(odd):not(:where(.not-content *)) {
		background-color: var(--sl-color-bg);
	}
</style>
