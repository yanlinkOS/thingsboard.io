---
import GtmNoscript from '~/components/GtmNoscript.astro';
import { Icon } from '@astrojs/starlight/components';

// Theme-switcher icon palette (light/dark/auto) that `updatePickers()` clones
// into the `<starlight-theme-select>` label icon. Rendered here at the top of
// <body> instead of <head>: a warmed `astro dev` traps hoisted <style> blocks
// inside any <head> <template>, unstyling the page
// (https://github.com/withastro/astro/issues/16994). Only needed where the
// switcher exists (not forceLightTheme).
const locals = Astro.locals as unknown as Record<string, unknown>;
const forceLight = locals.bsl === true && locals.bslForceLight === true;
---

<GtmNoscript />
<a href="#_top">{Astro.locals.t('skipLink.label')}</a>
{
	!forceLight && (
		<template id="theme-icons">
			<Icon name="sun" class="light" />
			<Icon name="moon" class="dark" />
			<Icon name="laptop" class="auto" />
		</template>
	)
}

<style>
	@layer starlight.core {
		a {
			clip: rect(0, 0, 0, 0);
			position: fixed;
			top: 0.75rem;
			inset-inline-start: 0.75rem;
		}
		a:focus {
			clip: unset;
			z-index: var(--sl-z-index-skiplink);
			display: block;
			padding: 0.5rem 1rem;
			text-decoration: none;
			color: var(--sl-color-text-invert);
			background-color: var(--sl-color-text-accent);
			box-shadow: var(--sl-shadow-lg);
		}
	}
</style>
