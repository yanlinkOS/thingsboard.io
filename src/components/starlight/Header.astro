---
import HeaderContent from '../Landing/HeaderContent.astro';
import { Products } from '@models/site.models';
import { resolveHeaderConfig, type HeaderConfig } from '@util/header-config';

const pathname = Astro.url.pathname;

function getGitHubPlatform(path: string): Products {
	if (path.includes('/docs/iot-gateway/')) return Products.GW;
	if (path.includes('/docs/edge/pe/') || path.includes('/docs/edge/')) return Products.EDGE;
	if (path.includes('/docs/mqtt-broker/pe/') || path.includes('/docs/mqtt-broker/')) return Products.TBMQ;
	return Products.CE;
}

const locals = Astro.locals as unknown as Record<string, unknown>;

// `BaseLayout` passes the page's product via Astro.locals so the GitHub button
// targets the right repo; everywhere else the platform is inferred from the URL
// (docs routes carry the product as a path prefix).
const override = locals.bslGitHubPlatform as Products | undefined;
const gitHubPlatform = override ?? getGitHubPlatform(pathname);

// Docs / Starlight pages don't pass through BaseLayout, so no header config is
// present → fall back to the default `docs` look.
const headerConfig = (locals.bslHeaderConfig as HeaderConfig | undefined) ?? resolveHeaderConfig();
---

<HeaderContent gitHubPlatform={gitHubPlatform} headerConfig={headerConfig} />
