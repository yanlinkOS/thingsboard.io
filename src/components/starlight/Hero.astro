---
import DocHero from '~/components/starlight/DocHero.astro';

// Proxy in front of the docs hero chrome. Pages rendered through
// `BaseLayout` set `Astro.locals.bsl = true` and pass an
// empty `hero` object in frontmatter — that switches Starlight's
// `Page.astro` to its hero branch (so `<PageTitle />` is never
// rendered) while this proxy short-circuits to nothing, leaving just
// the page slot inside the ContentPanel. Every other route gets
// `DocHero`. Splitting the two keeps the docs-hero scoped styles out
// of BSL bundles entirely.
const isBaseStarlight = (Astro.locals as unknown as Record<string, unknown>).bsl === true;
---

{!isBaseStarlight && <DocHero />}
