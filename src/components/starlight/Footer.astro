---
import DocFooter from '~/components/starlight/DocFooter.astro';
import LandingFooter from '~/components/Landing/Footer.astro';

// Proxy in front of the actual Starlight footer chrome. Pages
// rendered through `BaseLayout` set `Astro.locals.bsl = true`
// to opt into the marketing footer (`Landing/Footer`); everything else
// gets the docs footer (`DocFooter`). Each branch is a separate
// component so only the styles of the chosen variant land in the
// route's CSS bundle — there's no per-page cost for the unused one.
const isBaseStarlight = (Astro.locals as unknown as Record<string, unknown>).bsl === true;
---

{isBaseStarlight ? <LandingFooter /> : <DocFooter />}
