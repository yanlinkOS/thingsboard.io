---
import DefaultFooter from '@astrojs/starlight/components/Footer.astro';
import Icon from '~/components/starlight/Icon.astro';
import { tutorialPages as allTutorialPages } from '~/content';
import { getTutorialPages, getTutorialUnits } from '~/util/getTutorialPages';
import { getVersionFromURL, getVersionFromSlug } from '~/util/path-utils';
import SocialNetworks from '~/components/Landing/SocialNetworks.astro';

const currentYear = new Date().getFullYear();
const currentUrl = Astro.url.pathname.replace(/\/$/, '');

// Check if current page is a tutorial page
const currentVersion = getVersionFromURL(Astro.url.pathname);
const versionPages = allTutorialPages.filter((p) => getVersionFromSlug(p.id) === currentVersion);

const seriesRoot = versionPages.find(
	(p) =>
		p.data.unitTitle &&
		(currentUrl.endsWith('/' + p.id) || currentUrl.endsWith(p.id) || currentUrl.includes('/' + p.id + '/'))
);

const isTutorialPage = !!seriesRoot;
let prevLink: { href: string; title: string } | null = null;
let nextLink: { href: string; title: string } | null = null;

if (isTutorialPage && seriesRoot) {
	const seriesPages = versionPages.filter((p) => p.id === seriesRoot.id || p.id.startsWith(seriesRoot.id + '/'));
	const tutorialPages = getTutorialPages(seriesPages);
	const units = getTutorialUnits(tutorialPages);

	// Flatten lessons from all units
	const allLessons = units.flatMap((unit) => unit.lessons);

	// Find current lesson index
	const currentLessonIndex = allLessons.findIndex((lesson) => currentUrl.endsWith(lesson.id));

	if (currentLessonIndex > -1) {
		// Get previous link
		if (currentLessonIndex > 0) {
			const prevLesson = allLessons[currentLessonIndex - 1];
			prevLink = {
				href: `/${prevLesson.id}/`,
				title: prevLesson.data.title,
			};
		}

		// Get next link
		if (currentLessonIndex < allLessons.length - 1) {
			const nextLesson = allLessons[currentLessonIndex + 1];
			nextLink = {
				href: `/${nextLesson.id}/`,
				title: nextLesson.data.title,
			};
		}
	}
}
---

{
	isTutorialPage && (prevLink || nextLink) ? (
		<div class="pagination-links">
			{prevLink && (
				<a href={prevLink.href} rel="prev">
					<Icon name="left-arrow" size="1.5rem" />
					<span>
						Previous
						<br />
						<span class="link-title">{prevLink.title}</span>
					</span>
				</a>
			)}
			{nextLink && (
				<a href={nextLink.href} rel="next">
					<Icon name="right-arrow" size="1.5rem" />
					<span>
						Next
						<br />
						<span class="link-title">{nextLink.title}</span>
					</span>
				</a>
			)}
		</div>
	) : (
		<DefaultFooter />
	)
}

<div class="doc-footer sl-markdown-content">
	<nav>
		<a href="/docs/getting-started/">Get Started</a>
		<a href="/docs/">Documentation</a>
		<a href="/use-cases/">Use cases</a>
		<a href="/blog/">Blog</a>
		<a href="/services/">Services</a>
		<a href="/contact-us/">Contact us</a>
	</nav>
	<div class="deepmost">
		<div class="copyright">&copy; {currentYear} The ThingsBoard Authors</div>
		<SocialNetworks />
	</div>
</div>

<style>
	@media (min-width: 72rem) {
		:global([data-has-toc]) .hide-when-toc-is-visible {
			display: none;
		}
	}

	.doc-footer {
		container-type: inline-size;
		border-top: 1px solid var(--sl-color-hairline);
		padding: var(--sl-content-pad-x) 0;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem 1.75rem;
		margin-bottom: 1.5rem;
	}

	@container (max-width: 36rem) {
		nav {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
	}

	nav a {
		font-size: 1rem;
		color: var(--sl-color-text);
		text-decoration: none;
		white-space: nowrap;
	}

	nav a:hover {
		color: var(--sl-color-white);
		text-decoration: underline;
	}

	.deepmost {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5rem;
		--sn-color: var(--sl-color-gray-3);
	}

	.deepmost :global(.social) {
		margin-top: 0;
	}

	@container (max-width: 36rem) {
		.deepmost {
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: 1.5rem;
		}
	}

	.copyright {
		font-size: 0.875rem;
		color: var(--sl-color-gray-3);
	}

	.pagination-links {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
		gap: 1rem;
	}

	.pagination-links a {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 0.5rem;
		width: 100%;
		flex-basis: calc(50% - 0.5rem);
		flex-grow: 1;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		padding: 1rem;
		text-decoration: none;
		color: var(--sl-color-gray-2);
		box-shadow: var(--sl-shadow-md);
		overflow-wrap: anywhere;
	}

	[rel='next'] {
		justify-content: end;
		text-align: end;
		flex-direction: row-reverse;
	}

	.pagination-links a:hover {
		border-color: var(--sl-color-gray-2);
	}

	.link-title {
		color: var(--sl-color-white);
		font-size: var(--sl-text-2xl);
		line-height: var(--sl-line-height-headings);
	}

	.pagination-links svg {
		flex-shrink: 0;
	}
</style>
