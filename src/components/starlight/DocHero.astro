---
import Button from '../Button.astro';
import FacePile from './Hero/FacePile.astro';
import HeroImage from './Hero/HeroImage.astro';
import type { Products } from '~/models/site.models';

// Docs hero chrome. Kept separate from `Hero.astro` so its scoped
// styles only land in route bundles that actually render a hero.
// `Hero.astro` proxies in front of this and skips it entirely on
// `BaseLayout` pages, where the hero slot exists only as a
// switch to suppress Starlight's auto-rendered <PageTitle>.

type HeroActivity =
	| { type: 'contributors'; tagline: string; linkText: string; link: string }
	| { type: 'dashboard'; product: Products };

const { hero } = Astro.locals.starlightRoute.entry.data;
const { title, tagline, actions, gridVariant = 'lines', variant = 'default' } = hero!;
const { activity } = hero as typeof hero & { activity?: HeroActivity };
---

<div
	class="hero"
	data-grid-variant={gridVariant}
	data-hero-variant={variant}
	data-has-activity={activity ? '' : undefined}
>
	<div class="grid-bg"></div>
	<div id="_top" class="hero-content stack" style="--stack-gap: 2rem;">
		<div class="stack" style="--stack-gap: 1rem;">
			<h1 set:html={title} />
			<p set:html={tagline} />
		</div>
		<div class="sl-flex actions">
			{
				actions.map(({ link, icon, text, variant, attrs }) => (
					<Button {link} {variant} {icon} target={attrs?.target?.toString()} set:html={text} />
				))
			}
		</div>
	</div>
	{
		activity?.type === 'contributors' && (
			<FacePile tagline={activity.tagline} linkText={activity.linkText} link={activity.link} />
		)
	}
	{activity?.type === 'dashboard' && <HeroImage product={activity.product} />}
</div>

<style>
	.hero {
		position: relative;
		margin: -1.5rem calc(-1 * var(--sl-content-pad-x));
	}

	/* ── Lines variant (default) ── */
	.grid-bg {
		z-index: -1;
		position: absolute;
		content: '';
		inset: 0;
		background-image:
			linear-gradient(to right, var(--sl-color-white) 1px, transparent 1px),
			linear-gradient(to bottom, var(--sl-color-white) 1px, transparent 1px);
		background-position: right -1px;
		background-size: 23px 23px;
		-webkit-mask-image: radial-gradient(circle at 100% 0%, white, transparent 65%);
		mask-image: radial-gradient(circle at 100% 0%, white, transparent 65%);
		opacity: 0.05;
	}

	/* ── Dots variant ── */
	/*
	 * Single dot-pattern mask on the element itself.
	 * Vertical fade is handled by ::after — a gradient overlay from transparent
	 * (top) to the page background colour (bottom) — no mask-composite needed.
	 */
	:global([data-grid-variant='dots']) .grid-bg {
		background: linear-gradient(
			90deg,
			#ff3845 0.12%,
			#fd8741 17.27%,
			#fc9440 31.35%,
			#91b9f7 43.04%,
			#9d9fe6 60%,
			#a391dd 75.16%,
			#b172c9 94.65%
		);
		-webkit-mask-image: radial-gradient(
			circle 1.5px at 11.5px 11.5px,
			white 100%,
			transparent 100%
		);
		mask-image: radial-gradient(circle 1.5px at 11.5px 11.5px, white 100%, transparent 100%);
		-webkit-mask-size: 23px 23px;
		mask-size: 23px 23px;
		opacity: 0.65;
	}

	/* Vertical fade: transparent at top → page bg at bottom */
	:global([data-grid-variant='dots']) .grid-bg::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(to bottom, transparent 5%, var(--sl-color-bg) 45%);
		pointer-events: none;
	}

	.stack {
		display: flex;
		flex-direction: column;
		gap: var(--stack-gap, 1.5rem);
	}

	.hero-content {
		padding: 3rem var(--sl-content-pad-x);
		text-align: center;
	}

	h1 {
		font-size: var(--sl-text-5xl);
		line-height: var(--sl-line-height-headings);
		font-weight: 600;
		color: var(--sl-color-white);
	}
	.actions {
		flex-wrap: wrap;
		gap: 1rem 2rem;
		justify-content: center;
	}

	:global([data-has-hero] .main-pane) {
		--sl-content-margin-inline: 0;
		width: 100%;
	}

	@media (min-width: 32rem) {
		.hero-content {
			max-width: 36rem;
			padding-block: 6rem;
		}

		h1 {
			font-size: var(--sl-text-6xl);
		}
	}

	:global([data-has-hero] .sl-container) {
		max-width: 100%;
	}

	.hero-content,
	:global([data-has-hero] .sl-markdown-content) {
		max-width: 72rem;
		margin-inline: auto;
	}

	@media (min-width: 78rem) {
		:global([data-has-hero] .main-pane) {
			/* Red gradient calculated on the basis of the face pile grid, but set here so it's under the grid background image. */
			--cell-size: 3.5rem;
			background:
				radial-gradient(var(--sl-color-red-low) 0%, transparent 40%) no-repeat -170vw -55vh / 250vw
					250vh,
				radial-gradient(closest-side, var(--sl-color-blue-low) 0%, transparent 100%) no-repeat
					calc(100% + var(--cell-size) * 6) calc(var(--cell-size) * -7) /
					calc(var(--cell-size) * 12) calc(var(--cell-size) * 19);
		}

		.hero {
			display: grid;
		}
		.hero > :global(*) {
			/* Position all elements in the hero on top of each other in the same grid area. */
			grid-area: 1 / 1 / -1 / -1;
		}

		.hero-content {
			width: 100%;
			text-align: start;
			align-self: center;
		}
		.hero[data-has-activity] .hero-content > * {
			/* Limit the content width so it doesn't overlap with facepile elements. */
			max-width: calc(100% - 26rem);
		}

		.actions {
			justify-content: start;
		}
	}

	@media (min-width: 77.9375rem) and (max-width: 100rem) {
		.hero-content {
			align-self: start;
			padding-block-start: 6rem;
		}

		.hero[data-has-activity] .hero-content > * {
			max-width: calc(100% - 22rem);
		}
	}

	/* ── Simple variant ── */
	/* Neutralise the horizontal negative margin from `.hero` (line 42) on the
	   simple variant so it sits inside ContentPanel's inline padding instead
	   of stretching to the main-pane edges. The default variant needs that
	   stretch for its gradient/grid background; the simple variant has no bg
	   and only contained the negative margin to extend a non-existent
	   background. With `.hero` inside ContentPanel, `.hero-content`'s
	   centered `max-width: 72rem` automatically aligns the page title with
	   the body content below at every viewport width. */
	.hero[data-hero-variant='simple'] {
		margin-inline: 0;
	}

	:global([data-hero-variant='simple']) .hero-content {
		padding-bottom: 0;
		padding-left: 0;
	}

	:global([data-hero-variant='simple']) .hero-content > .stack {
		max-width: 100%;
	}

	@media (min-width: 78rem) {
		:global([data-has-hero]:has([data-hero-variant='simple']) .main-pane) {
			background: none;
		}
	}
</style>
