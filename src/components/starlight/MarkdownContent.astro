---
import DocMarkdownContent from '~/components/starlight/DocMarkdownContent.astro';

// Proxy in front of the docs markdown chrome. Pages rendered through
// `BaseLayout` set `Astro.locals.bsl = true` to opt out of
// the `.sl-markdown-content` wrapper, the per-type "more guides"
// navigation, the anchor-copy script, and the table / config-list
// styles — marketing pages own their own layout inside the slot.
// Everything else gets `DocMarkdownContent`. Splitting the two keeps
// the docs-markdown CSS + nav-component imports out of BSL bundles.
const isBaseStarlight = (Astro.locals as unknown as Record<string, unknown>).bsl === true;
---

{
	isBaseStarlight ? (
		<slot />
	) : (
		<DocMarkdownContent>
			<slot />
		</DocMarkdownContent>
	)
}
