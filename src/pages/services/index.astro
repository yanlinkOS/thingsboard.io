	// ── Tinted callout (one per Maintain / Advise / Train / Deliver) ─────
	// The design info-block:
	//  - 1px border in card mid color, 8px radius
	//  - background: linear gradient from accent-low (top) to white at ~138%
	//  - 16px padding, column flex, gap 8px between title row and body
	//  - title row: 24px bulb icon + 8px gap + heading (18/1.2 SemiBold high)
	//  - body: 16/1.72 Regular in primary text
	//  - inline links: #3d50f5 (primary blue) underlined
	.we-callout {
		// Two-layer paint:
		//   1. inner fill (padding-box) — heavily diluted accent-soft fading
		//      to white at ~75%, giving a much softer tint than the raw
		//      accent-soft → white gradient we had before
		//   2. border layer  (border-box) — vertical gradient from accent
		//      (top) to accent-soft (bottom) shows through a 1px transparent
		//      border, producing a real gradient border
		// Soft accent fill that fades from a stronger tint at top to a
		// lighter tint at bottom. Solid 1px accent border all the way around
		// — uniform colour so there are no visual "pieces" at the corners
		// caused by gradient interpolation.
		background: linear-gradient(
			to bottom,
			color-mix(in srgb, var(--card-accent-soft) 70%, #ffffff) 0%,
			color-mix(in srgb, var(--card-accent-soft) 30%, #ffffff) 100%
		);
		border: 1px solid var(--card-accent);
		border-radius: 8px;
		padding: $spacing-4;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: $spacing-2;

		// The design --sl-text-h5: 18/1.2 SemiBold in accent-high.
