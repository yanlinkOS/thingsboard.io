---
import { Icon } from 'astro-icon/components';
import BaseLayout from '@layouts/BaseLayout.astro';

// ── Hero stats ──────────────────────────────────────────────────────────
const heroStats = [
	{ value: '30 min', label: 'avg. support response\nwithin business hours' },
	{ value: '99.95%', label: 'platform uptime\nPrivate Cloud' },
	{ value: '350+', label: 'delivered\nIoT projects' },
	{ value: '9 years', label: 'in the\nIoT domain' },
];

// ── Plans coverage matrix used on the "We Support" card ─────────────────
const supportPlans = [
	{ label: 'Self-Hosted License', note: 'Pilot and above' },
	{ label: 'Public Cloud', note: 'Pilot and above' },
	{ label: 'Private Cloud', note: 'All plans' },
	{ label: 'Managed Service', note: 'All plans' },
];

const supportSLA = [
	{ label: 'Response SLA', value: '24 hours' },
	{ label: 'Avg. response', value: '~30 min' },
	{ label: 'Avg. resolution', value: '~8 hours' },
	{ label: 'Hours', value: '8:00–20:00 EET Mon–Fri' },
];

const maintainHandled = [
	'Major and minor ThingsBoard version upgrades',
	'Daily backups, with restoration when needed',
	'Proactive 24/7 monitoring and incident response',
	'Auto-scaling — compute (Enterprise) and storage (all tiers)',
	'Security patching — OS, database, and ThingsBoard itself',
	'Access to Private Cloud logs and monitoring dashboards',
	'Migration of existing self-managed ThingsBoard to Private Cloud',
];

const maintainSLA = [
	{ label: 'Public Cloud', value: '99.5%' },
	{ label: 'Private Cloud', value: '99.95%' },
];

const adviseHow = [
	"20 hours per month of your Advisory Engineer's time",
	'Same engineer every month — they learn your setup end-to-end (with a named backup for vacation coverage)',
	'Weekly call + dedicated Slack channel + joint workshops',
	'6-month minimum engagement',
	'Available regardless of licensing model',
];

const adviseUses = [
	{ title: 'Integration design', desc: 'devices, cloud systems, external APIs' },
	{ title: 'Performance tuning', desc: 'slow rule chains, slow queries, widgets, scaling' },
	{ title: 'Feature strategy', desc: 'which ThingsBoard feature for which problem' },
	{ title: 'Architecture reviews', desc: 'data model, rule chains, tenant layout' },
	{ title: 'Upgrade planning', desc: 'what changes, what to test, how to roll it out' },
];

const trainTracks = [
	{ title: 'Data Visualization', desc: 'UI fundamentals, dashboards, widgets, custom widget development.' },
	{ title: 'Platform Administration', desc: 'Deployment, cluster setup, troubleshooting, AWS hands-on.' },
	{ title: 'SCADA', desc: 'Symbol library, dashboard creation, advanced properties and behaviors.' },
	{ title: 'Management & Security', desc: 'Rule engine, RBAC, alarms, API, custom rule nodes.' },
];

const deliverBuilds = [
	'Full IoT solution implementations — fleet tracking, energy monitoring, asset tracking, smart metering, SCADA, and more',
	'Custom integrations with your business systems',
	'Custom dashboards and widgets',
	'Custom rule nodes',
	'White-label mobile applications',
	'Custom protocol adapters',
];

const deliverSteps = [
	{ n: '1', title: 'Technical workshop', desc: 'Align on goals and constraints.' },
	{ n: '2', title: 'Scope & proposal', desc: 'Fixed scope, fixed cost, clear timeline.' },
	{ n: '3', title: 'Kick-off', desc: 'Iterative development begins.' },
	{ n: '4', title: 'Deployment', desc: 'Shipped into your environment.' },
	{ n: '5', title: 'Maintenance', desc: '12-month period, included.' },
];

const recommendations = [
	{
		title: 'Foundation',
		suffix: 'Support + Maintain',
		desc: 'Day-to-day platform coverage.',
	},
	{
		title: 'Augment',
		suffix: '+ Advise',
		desc: 'When your team wants a part-time ThingsBoard architect.',
	},
	{
		title: 'Build',
		suffix: '+ Deliver',
		desc: 'When you want us to build the solution for you.',
	},
];
---

<BaseLayout
	headerVariant="solid-border"
	showSearch={false}
	title="Support and Services | ThingsBoard"
	customTitle
	description="Professional support, managed platform operations, and on-demand experts — everything you need to run ThingsBoard with confidence."
>
	<main class="services-page">
		{/* ── Hero ────────────────────────────────────────────────────── */}
		<section class="sp-hero">
			<div class="sp-container sp-hero__inner">
				<h1 class="sp-hero__title">Support and Services</h1>
				<p class="sp-hero__lead">
					Professional support, managed platform operations, and on-demand experts — everything you need to run
					ThingsBoard with confidence.
				</p>
				<div class="sp-hero__ctas">
					<a class="sp-btn sp-btn--primary" href="/contact-us/">
						Talk to Our Team <Icon name="tabler:chevron-right" />
					</a>
					<a class="sp-btn sp-btn--secondary" href="#included">
						See What's Included <Icon name="tabler:chevron-right" />
					</a>
				</div>
			</div>
		</section>

		{/* ── Stats strip ─────────────────────────────────────────────── */}
		<section class="sp-stats">
			<div class="sp-container">
				<ul class="sp-stats__grid">
					{
						heroStats.map((s) => (
							<li class="sp-stat">
								<div class="sp-stat__value">{s.value}</div>
								<div class="sp-stat__label">{s.label}</div>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		{/* ── Section 1: Included with your plan ──────────────────────── */}
		<section id="included" class="sp-section sp-section--included">
			<div class="sp-container">
				<header class="sp-section__header">
					<span class="sp-eyebrow">Included with your plan</span>
					<div class="sp-section__title-block">
						<h2 class="sp-section__title">Support and platform operations, on us</h2>
						<p class="sp-section__lead">
							Professional support from the Pilot plan and above. Fully-managed operations on Public Cloud, Private
							Cloud, and Managed Services.
						</p>
					</div>
				</header>

				{/* ── We Support card ───────────────────────────────────── */}
				<article class="we-card" data-card="support">
					<button class="we-card__head" type="button" aria-expanded="false" aria-controls="we-card-support-body">
						<span class="we-card__icon" aria-hidden="true">
							<Icon name="tabler:headset" />
						</span>
						<h3 class="we-card__title">
							<strong>We Support</strong>
							<span class="we-card__sep">—</span>
							<span class="we-card__desc">Technical support for paid ThingsBoard plans</span>
						</h3>
						<span class="we-card__toggle">
							<span class="we-card__toggle-label">More Detail</span>
							<Icon name="tabler:chevron-down" class="we-card__chevron" />
						</span>
					</button>

					<div class="we-card__intro">
						<p>
							Open a ticket, get an expert response. Our support team is the same team that
							builds ThingsBoard — committed response SLA, unlimited tickets, and
							access for up to 6 team members.
						</p>
					</div>

					<div class="we-card__body" id="we-card-support-body" inert aria-hidden="true">
						<div class="we-card__body-inner">
							<p class="we-card__opener">
								<strong>A direct line to the engineers behind ThingsBoard.</strong> When something in the platform isn't working
								the way you expect, open a ticket — and get a real answer from someone who knows the code.
							</p>

							<div class="we-card__grid we-card__grid--2">
								<div>
									<h4 class="we-card__h4">What you can ask us about</h4>
									<ul class="we-list we-list--check">
										<li>
											<Icon name="tabler:check" aria-hidden="true" />Questions about standard ThingsBoard functionality
										</li>
										<li><Icon name="tabler:check" aria-hidden="true" />Installation and upgrade assistance</li>
										<li><Icon name="tabler:check" aria-hidden="true" />License management</li>
										<li><Icon name="tabler:check" aria-hidden="true" />Tenant administration and password resets</li>
										<li><Icon name="tabler:check" aria-hidden="true" />Bug reports</li>
									</ul>
								</div>
								<div>
									<h4 class="we-card__h4">How it works</h4>
									<dl class="we-sla">
										{
											supportSLA.map((row) => (
												<div class="we-sla__cell">
													<dt>{row.label}</dt>
													<dd>{row.value}</dd>
												</div>
											))
										}
									</dl>
								</div>
							</div>

							<div class="we-card__plans">
								<h4 class="we-card__h4">Included on</h4>
								<ul class="we-plans">
									{
										supportPlans.map((p) => (
											<li class="we-plan">
												<div class="we-plan__label">{p.label}</div>
												<div class="we-plan__note">{p.note}</div>
											</li>
										))
									}
								</ul>
							</div>
						</div>
					</div>

					<footer class="we-card__footer">
						<div class="we-card__footer-row">
							<p class="we-card__note">Average first response in ~30 minutes during business hours.</p>
							<a class="we-card__cta" href="/pricing/?section=thingsboard-pe-options&product=thingsboard-cloud">
								Explore Plans <Icon name="tabler:chevron-right" />
							</a>
						</div>
					</footer>
				</article>

				{/* ── We Maintain card ──────────────────────────────────── */}
				<article class="we-card" data-card="maintain">
					<button class="we-card__head" type="button" aria-expanded="false" aria-controls="we-card-maintain-body">
						<span class="we-card__icon" aria-hidden="true">
							<Icon name="tabler:server-cog" />
						</span>
						<h3 class="we-card__title">
							<strong>We Maintain</strong>
							<span class="we-card__sep">—</span>
							<span class="we-card__desc">Fully-managed platform operations</span>
						</h3>
						<span class="we-card__toggle">
							<span class="we-card__toggle-label">More Detail</span>
							<Icon name="tabler:chevron-down" class="we-card__chevron" />
						</span>
					</button>

					<div class="we-card__intro">
						<p>
							We run ThingsBoard for you — upgrades, backups, monitoring, scaling, and security patching, all handled by
							our platform team. Included with Public Cloud, Private Cloud, and Managed Services.
						</p>
					</div>

					<div class="we-card__body" id="we-card-maintain-body" inert aria-hidden="true">
						<div class="we-card__body-inner">
							<p class="we-card__opener">
								<strong>Your platform, operated by our team.</strong> On Public Cloud, Private Cloud, and Managed Services,
								our platform team keeps ThingsBoard running — proactively. You focus on what you're building; we make sure
								it stays up.
							</p>

							<div class="we-card__grid we-card__grid--2">
								<div>
									<h4 class="we-card__h4">What's handled for you</h4>
									<ul class="we-list we-list--check">
										{
											maintainHandled.map((item) => (
												<li>
													<Icon name="tabler:check" aria-hidden="true" />
													{item}
												</li>
											))
										}
									</ul>
								</div>
								<div>
									<h4 class="we-card__h4">Uptime SLA</h4>
									<dl class="we-sla we-sla--two">
										{
											maintainSLA.map((row) => (
												<div class="we-sla__cell">
													<dt>{row.label}</dt>
													<dd>{row.value}</dd>
												</div>
											))
										}
									</dl>
								</div>
							</div>

							<aside class="we-callout">
								<div class="we-callout__head">
									<Icon name="tabler:bulb" class="we-callout__icon" />
									<strong>Your application vision, delivered by our team</strong>
								</div>
								<p>
									Rule chains, dashboards, integrations, and custom data models are yours to design and evolve. If you
									want expert hands on them, that's what our
									<a href="#advise">Advisory Engineers</a> and
									<a href="/services/development-services/">Development Services</a> are for.
								</p>
							</aside>
						</div>
					</div>

					<footer class="we-card__footer">
						<div class="we-card__footer-row">
							<p class="we-card__note">99.95% uptime SLA on Private Cloud.</p>
							<a class="we-card__cta" href="/pricing/?section=thingsboard-pe-options&product=thingsboard-cloud">
								Explore Plans <Icon name="tabler:chevron-right" />
							</a>
						</div>
					</footer>
				</article>

				{/* ── Community note ─────────────────────────────────── */}
				<p class="sp-community">
					<em>Using Community Edition, Maker, or Prototype plans?</em>
					<a
						class="sp-community__cta"
						href="https://github.com/thingsboard/thingsboard/discussions"
						target="_blank"
						rel="noopener noreferrer"
					>
						<span>Community support</span>
						<Icon name="tabler:info-circle" />
					</a>
				</p>
			</div>
		</section>

		{/* ── Section 2: Expert hands on your solution ───────────────── */}
		<section id="expert" class="sp-section sp-section--expert">
			<div class="sp-container">
				<header class="sp-section__header">
					<span class="sp-eyebrow">Expert services</span>
					<div class="sp-section__title-block">
						<h2 class="sp-section__title">Expert hands on your solution</h2>
						<p class="sp-section__lead">
							On-demand help when you want expert hands on your solution. Available on top of any Support or Maintenance
							plan.
						</p>
					</div>
				</header>

				{/* ── We Advise card ─────────────────────────────────── */}
				<article id="advise" class="we-card" data-card="advise">
					<button class="we-card__head" type="button" aria-expanded="false" aria-controls="we-card-advise-body">
						<span class="we-card__icon" aria-hidden="true">
							<Icon name="tabler:user-star" />
						</span>
						<h3 class="we-card__title">
							<strong>We Advise</strong>
							<span class="we-card__sep">—</span>
							<span class="we-card__desc">A fractional ThingsBoard architect embedded with your team</span>
						</h3>
						<span class="we-card__toggle">
							<span class="we-card__toggle-label">More Detail</span>
							<Icon name="tabler:chevron-down" class="we-card__chevron" />
						</span>
					</button>

					<div class="we-card__intro">
						<p>
							A dedicated ThingsBoard engineer working 20 hours a month alongside your team — architecture reviews,
							performance tuning, integration design, weekly calls, direct Slack access.
						</p>
					</div>

					<div class="we-card__body" id="we-card-advise-body" inert aria-hidden="true">
						<div class="we-card__body-inner">
							<p class="we-card__opener">
								<strong>The expert your engineers wish they worked with.</strong> We Advise pairs you with a dedicated ThingsBoard
								engineer who learns your deployment and works alongside your team — reviewing designs, tuning performance,
								answering hard questions in the weekly call, and responding on Slack in between. Your engineers stay in control
								of production; our engineer makes them faster and better at everything ThingsBoard-related.
							</p>

							<div class="we-card__grid we-card__grid--2">
								<div>
									<h4 class="we-card__h4">How it works</h4>
									<ul class="we-list we-list--check">
										{
											adviseHow.map((item) => (
												<li>
													<Icon name="tabler:check" aria-hidden="true" />
													{item}
												</li>
											))
										}
									</ul>
								</div>
								<div>
									<h4 class="we-card__h4">What customers use them for</h4>
									<ul class="we-uses">
										{
											adviseUses.map((row) => (
												<li>
													<strong>{row.title}</strong> — {row.desc}
												</li>
											))
										}
									</ul>
								</div>
							</div>

							<aside class="we-callout">
								<div class="we-callout__head">
									<Icon name="tabler:bulb" class="we-callout__icon" />
									<strong>Scope of Responsibility</strong>
								</div>
								<p>
									Your Advisory Engineer is a senior expert, not a contractor. They won't ship code into your production
									environment or deliver a full project single-handed — that's where <a href="#deliver">We Deliver</a> picks
									up.
								</p>
							</aside>
						</div>
					</div>

					<footer class="we-card__footer">
						<div class="we-card__footer-row">
							<p class="we-card__note">20 hours / month · 6-month minimum · same engineer every month.</p>
							<a class="we-card__cta" href="/contact-us/">
								Talk to Us About Advise <Icon name="tabler:chevron-right" />
							</a>
						</div>
					</footer>
				</article>

				{/* ── We Train card ──────────────────────────────────── */}
				<article id="train" class="we-card" data-card="train">
					<button class="we-card__head" type="button" aria-expanded="false" aria-controls="we-card-train-body">
						<span class="we-card__icon" aria-hidden="true">
							<Icon name="tabler:school" />
						</span>
						<h3 class="we-card__title">
							<strong>We Train</strong>
							<span class="we-card__sep">—</span>
							<span class="we-card__desc">Live instructor-led courses for developers, admins, and architects</span>
						</h3>
						<span class="we-card__toggle">
							<span class="we-card__toggle-label">More Detail</span>
							<Icon name="tabler:chevron-down" class="we-card__chevron" />
						</span>
					</button>

					<div class="we-card__intro">
						<p>
							Four structured course tracks, taught live by the engineers who build ThingsBoard. Written materials and a
							certificate of completion included.
						</p>
					</div>

					<div class="we-card__body" id="we-card-train-body" inert aria-hidden="true">
						<div class="we-card__body-inner">
							<p class="we-card__opener">
								<strong>Bring your team up to speed — fast.</strong> Live, instructor-led training delivered by the engineers
								who build ThingsBoard. Each track is structured as 2-hour sessions with Q&amp;A, written materials, and a
								certificate of completion.
							</p>

							<h4 class="we-card__h4">Four course tracks</h4>
							<ul class="we-tracks">
								{
									trainTracks.map((track) => (
										<li class="we-track">
											<div class="we-track__title">{track.title}</div>
											<div class="we-track__desc">{track.desc}</div>
										</li>
									))
								}
							</ul>

							<aside class="we-callout">
								<div class="we-callout__head">
									<Icon name="tabler:bulb" class="we-callout__icon" />
									<strong>Who it's for</strong>
								</div>
								<p>Developers, platform administrators, and solution architects.</p>
							</aside>
						</div>
					</div>

					<footer class="we-card__footer">
						<div class="we-card__footer-row">
							<p class="we-card__note">Live sessions · written materials · certificate of completion.</p>
							<a class="we-card__cta" href="/services/trainings/">
								Explore Training Courses <Icon name="tabler:chevron-right" />
							</a>
						</div>
					</footer>
				</article>

				{/* ── We Deliver card ────────────────────────────────── */}
				<article id="deliver" class="we-card" data-card="deliver">
					<button class="we-card__head" type="button" aria-expanded="false" aria-controls="we-card-deliver-body">
						<span class="we-card__icon" aria-hidden="true">
							<Icon name="tabler:code" />
						</span>
						<h3 class="we-card__title">
							<strong>We Deliver</strong>
							<span class="we-card__sep">—</span>
							<span class="we-card__desc">Full IoT solutions, built by ThingsBoard</span>
						</h3>
						<span class="we-card__toggle">
							<span class="we-card__toggle-label">More Detail</span>
							<Icon name="tabler:chevron-down" class="we-card__chevron" />
						</span>
					</button>

					<div class="we-card__intro">
						<p>
							Fixed-scope, fixed-cost development engagements. Full implementations, custom integrations, white-label
							mobile apps, custom widgets, and more — with a 12-month maintenance period included on every delivery.
						</p>
					</div>

					<div class="we-card__body" id="we-card-deliver-body" inert aria-hidden="true">
						<div class="we-card__body-inner">
							<p class="we-card__opener">
								<strong>Your project, built by the team who built ThingsBoard.</strong> If you want the platform and your
								solution in the same hands, <strong>We Deliver</strong>
								is our full development service. Fixed scope, fixed cost, a structured timeline — and a year of maintenance
								included on everything we ship.
							</p>

							<h4 class="we-card__h4">What we build</h4>
							<ul class="we-list we-list--check we-list--single">
								{
									deliverBuilds.map((item) => (
										<li>
											<Icon name="tabler:check" aria-hidden="true" />
											{item}
										</li>
									))
								}
							</ul>

							<h4 class="we-card__h4 we-card__h4--with-gap">How it works</h4>
							<ol class="we-steps">
								{
									deliverSteps.map((step) => (
										<li class="we-step">
											<div class="we-step__n">Step {step.n}</div>
											<div class="we-step__title">{step.title}</div>
											<div class="we-step__desc">{step.desc}</div>
										</li>
									))
								}
							</ol>

							<aside class="we-callout">
								<div class="we-callout__head">
									<Icon name="tabler:bulb" class="we-callout__icon" />
									<strong>Advise or Deliver — how to choose</strong>
								</div>
								<p>
									<strong>Advise</strong> if you have an engineering team and want a part-time ThingsBoard expert alongside
									them. <strong>Deliver</strong> if you want our team to build it for you, fast.
								</p>
							</aside>
						</div>
					</div>

					<footer class="we-card__footer">
						<div class="we-card__footer-row">
							<p class="we-card__note">Fixed scope · fixed cost · 12 months of maintenance included.</p>
							<a class="we-card__cta" href="/services/development-services/">
								Explore Development Services <Icon name="tabler:chevron-right" />
							</a>
						</div>
					</footer>
				</article>
			</div>
		</section>

		{/* ── Bottom CTA: Need help choosing the right mix? ──────────── */}
		<section class="sp-mix">
			<div class="sp-container">
				<div class="sp-mix__card">
					<div class="sp-mix__heading">
						<h2 class="sp-mix__title">Need help choosing the right mix?</h2>
						<p class="sp-mix__lead">
							Most ThingsBoard engagements combine a couple of these services. Tell us what you're building — we'll
							recommend the right combination in a short call.
						</p>
					</div>
					<ul class="sp-mix__grid">
						{
							recommendations.map((r) => (
								<li class="sp-mix__item">
									<h3 class="sp-mix__item-title">
										{r.title} <span class="sp-mix__item-suffix">({r.suffix})</span>
									</h3>
									<p class="sp-mix__item-desc">{r.desc}</p>
								</li>
							))
						}
					</ul>
					<div class="sp-mix__cta">
						<a class="sp-btn sp-btn--primary" href="/contact-us/">
							Talk to Our Team <Icon name="tabler:chevron-right" />
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>

<script>
	// Expand / collapse the More Detail body on each "We …" card.
	// Toggles aria-expanded on the trigger + is-expanded on the card; the
	// CSS handles the smooth height transition. The body also gets `inert` +
	// `aria-hidden` when collapsed so screen readers and tab order skip it.
	const cards = document.querySelectorAll<HTMLElement>('.we-card');

	const setExpanded = (card: HTMLElement, expanded: boolean) => {
		const head = card.querySelector<HTMLButtonElement>('.we-card__head');
		const body = card.querySelector<HTMLElement>('.we-card__body');
		if (!head || !body) return;
		head.setAttribute('aria-expanded', String(expanded));
		card.classList.toggle('is-expanded', expanded);
		if (expanded) {
			body.removeAttribute('inert');
			body.removeAttribute('aria-hidden');
		} else {
			body.setAttribute('inert', '');
			body.setAttribute('aria-hidden', 'true');
		}
	};

	cards.forEach((card) => {
		const head = card.querySelector<HTMLButtonElement>('.we-card__head');
		if (!head) return;
		head.addEventListener('click', () => {
			const expanded = head.getAttribute('aria-expanded') === 'true';
			setExpanded(card, !expanded);
		});
	});

	// Auto-expand cards based on the URL hash:
	//   #advise / #train / #deliver → the targeted card
	//   #included (the section wrapping all cards) → every card in it
	// Handles initial page load + later hashchange events + same-hash
	// re-clicks on in-page anchor links.
	const expandFromHash = () => {
		const hash = window.location.hash;
		if (!hash || hash.length < 2) return;
		let target: Element | null = null;
		try {
			target = document.querySelector(hash);
		} catch {
			return;
		}
		if (!target) return;
		// Direct hit on (or inside) a card → expand just that one.
		const direct = target.closest<HTMLElement>('.we-card');
		if (direct) {
			if (!direct.classList.contains('is-expanded')) setExpanded(direct, true);
			return;
		}
		// Otherwise expand any cards living inside the target (e.g. the
		// `#included` section that holds all five "We …" cards).
		target.querySelectorAll<HTMLElement>('.we-card').forEach((card) => {
			if (!card.classList.contains('is-expanded')) setExpanded(card, true);
		});
	};

	window.addEventListener('hashchange', expandFromHash);
	document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
		a.addEventListener('click', () => {
			// Run after the browser updates location.hash (which happens
			// synchronously on the link's default action). hashchange may
			// not fire if the hash is unchanged, so call directly.
			requestAnimationFrame(expandFromHash);
		});
	});
	expandFromHash();
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	// ── Page-scoped tokens (theme-aware via CSS custom properties) ──────
	// Card accent palette mirrors the design "complimentary" color tokens.
	// Each card variant exposes 3 surfaces:
	//   --card-accent       — solid mid color (checks, footer chevron, vertical bars)
	//   --card-accent-soft  — light tint for callout fill + icon-box background
	//   --card-accent-text  — dark/high color for headings inside accent surfaces
	.services-page {
		// Page chrome — all values lifted from the design "neutral" token set:
		//   --sl-color-black / --sl-color-white  → primary text (#17181c)
		//   neutral/gray-2  → secondary body text (#353841)
		//   neutral/gray-3  → muted text + SLA labels (#555962)
		//   neutral/gray-5  → card + SLA cell outline (#c1c3c8)
		//   hairline-light  → internal dividers (#edeef3)
		--sp-page-bg: var(--color-bg);
		--sp-surface: var(--color-bg-surface);
		--sp-surface-2: var(--color-bg-light);
		--sp-card-border: #c1c3c8; // The design neutral/gray-5 (card outlines, SLA cells)
		--sp-border: #edeef3; // The design hairline-light (internal dividers)
		--sp-page-line: #e3e4e8; // page-frame hairlines — softer than card outline
		--sp-text: #17181c;
		--sp-text-secondary: #353841;
		--sp-text-muted: #555962;
		--sp-brand: #3d50f5;

		// Default card accent = primary blue (We Support)
		--card-accent: #3d50f5;
		--card-accent-soft: #cfd4fc;
		--card-accent-text: #0f1c8a;

		background: var(--sp-page-bg);
		color: var(--sp-text);
		position: relative;
		overflow: hidden;

		// Two page-wide vertical hairlines at the left and right edges of the
		// 1080-wide centered content column. From the design, the lines
		// are 1px wide, full-page height, in gray-5 (#c1c3c8) — same shade as
		// the card outline so they read as a unified design frame.
		&::before,
		&::after {
			content: '';
			position: absolute;
			top: 0;
			bottom: 0;
			width: 1px;
			background: var(--sp-page-line);
			pointer-events: none;
			z-index: 2;
		}

		&::before {
			left: calc(50% - 540px);
		}

		&::after {
			right: calc(50% - 540px);
		}

		// Below the column width, hide the side lines (no content to bracket).
		@media (max-width: 1080px) {
			&::before,
			&::after {
				display: none;
			}
		}

		// Per-card accents — light mode
		[data-card='support'] {
			--card-accent: #3d50f5; // blue
			--card-accent-soft: #cfd4fc;
			--card-accent-text: #0f1c8a;
		}
		[data-card='maintain'] {
			--card-accent: #bb3df5; // purple
			--card-accent-soft: #edd1fa;
			--card-accent-text: #660891;
		}
		[data-card='advise'] {
			--card-accent: #f53d7d; // red/pink
			--card-accent-soft: #f9c3d6;
			--card-accent-text: #8a0f3a;
		}
		[data-card='train'] {
			--card-accent: #f5bb3d; // amber
			--card-accent-soft: #fceac5;
			--card-accent-text: #73520d;
		}
		[data-card='deliver'] {
			--card-accent: #4fdf0c; // green
			--card-accent-soft: #defbd0;
			--card-accent-text: #28650b;
		}
	}

	// Dark theme: keep hue identity but raise luminance so accents read on dark
	// surfaces, and lighten the "soft" fills via low-alpha overlays.
	[data-theme='dark'] .services-page {
		--sp-border: #2e3035; // matches site --color-border (dark)
		--sp-card-border: #383a40; // softer outline on dark cards
		--sp-page-line: #2a2c31; // dark-mode page frame hairlines
		--sp-text: #e4e5e7;
		--sp-text-secondary: #c1c3c8;
		--sp-text-muted: #a1a2a8;
		// Pale sky-blue so eyebrow / CTA links / vertical bars / item titles
		// read cleanly on dark surfaces instead of looking like vivid purple.
		--sp-brand: #b3c7ff;

		--card-accent: #8b9bff;
		--card-accent-soft: rgba(61, 80, 245, 0.18);
		--card-accent-text: #cfd4fc;

		[data-card='support'] {
			--card-accent: #8b9bff;
			--card-accent-soft: rgba(61, 80, 245, 0.18);
			--card-accent-text: #cfd4fc;
		}
		[data-card='maintain'] {
			--card-accent: #d585fb;
			--card-accent-soft: rgba(187, 61, 245, 0.18);
			--card-accent-text: #edd1fa;
		}
		[data-card='advise'] {
			--card-accent: #f985aa;
			--card-accent-soft: rgba(245, 61, 125, 0.18);
			--card-accent-text: #f9c3d6;
		}
		[data-card='train'] {
			--card-accent: #fbd47b;
			--card-accent-soft: rgba(245, 187, 61, 0.18);
			--card-accent-text: #fceac5;
		}
		[data-card='deliver'] {
			--card-accent: #8aec5b;
			--card-accent-soft: rgba(79, 223, 12, 0.18);
			--card-accent-text: #defbd0;
		}
	}

	// ── Layout primitives ────────────────────────────────────────────────
	// The design column is 1080 wide with cards inset 16px on each side (cards are
	// 1048 wide). Container uses a uniform 16px horizontal padding on every
	// breakpoint so the cards reproduce that 16px gap from the page frame.
	.sp-container {
		width: 100%;
		max-width: 1080px;
		margin: 0 auto;
		padding: 0 $spacing-4;
	}

	// ── Buttons (hero + bottom CTA) ──────────────────────────────────────
	// The design: 56px tall (height 56 in hero CTA frame), 16px horizontal padding,
	// 8px radius, 16/24 regular text + 24×24 chevron.
	.sp-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: $spacing-2;
		min-width: 100px;
		height: 56px;
		padding: 0 $spacing-5;
		border-radius: 8px;
		font-size: $font-size-base;
		font-weight: $font-weight-normal;
		line-height: 24px;
		text-decoration: none;
		transition:
			background-color 0.15s,
			color 0.15s,
			border-color 0.15s,
			box-shadow 0.15s,
			transform 0.05s;
		cursor: pointer;
		border: 1px solid transparent;
		white-space: nowrap;

		[data-icon] {
			width: 20px;
			height: 20px;
			flex-shrink: 0;
		}

		&:active {
			transform: translateY(1px);
		}

		// Filled primary button uses Starlight's semantic tokens so the bg
		// flips between light + dark mode automatically — same colour scheme
		// as the pricing-page "Get started" buttons.
		&--primary {
			background-color: var(--sl-color-text-accent);
			color: var(--sl-color-black);
			border-color: var(--sl-color-text-accent);
			background-image: linear-gradient(rgba(0, 0, 0, 0), rgba(0, 0, 0, 0));

			&:hover {
				background-image: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.15));
				color: var(--sl-color-black);
				border-color: var(--sl-color-text-accent);
			}
		}

		// Outlined button: foreground-color border (the design renders the See What's
		// Included button with a near-black 1px border on light, white on dark).
		&--secondary {
			background: transparent;
			color: var(--sp-text);
			border-color: var(--sp-text);

			&:hover {
				background: var(--sp-text);
				color: var(--sp-page-bg);
			}
		}
	}

	// ── Hero ─────────────────────────────────────────────────────────────
	// Hero has a generous top gap from the header, and a balanced bottom
	// gap to the stats band (~100px). On mobile the fixed header is ~80px
	// tall, so the hero needs >=120px top padding to keep the title from
	// disappearing behind it. The matching top gap on .sp-section keeps the
	// rhythm symmetrical above and below the stats.
	.sp-hero {
		padding: 40px 0 $spacing-16;
		position: relative;
		isolation: isolate;
		z-index: 1;

		@include media-up(md) {
			padding: 120px 0 100px;
		}

		&__inner {
			position: relative;
			text-align: center;
		}

		// The design headings/h1: 60/72 SemiBold. Project mixin caps at 48px,
		// so we override directly to 60px on desktop with responsive shrinks.
		&__title {
			font-size: 60px;
			line-height: 72px;
			font-weight: $font-weight-semibold;
			margin: 0 0 $spacing-6;
			color: var(--sp-text);
			letter-spacing: -0.01em;

			@include media-down(lg) {
				font-size: 48px;
				line-height: 1.15;
			}

			@include media-down(md) {
				font-size: 36px;
				line-height: 1.2;
			}

			@include media-down(sm) {
				font-size: 30px;
			}
		}

		// The design content/body-l: 18/32 regular. Max-width 823px (matches the
		// inner description frame width inside the centered hero Text frame).
		&__lead {
			max-width: 823px;
			margin: 0 auto $spacing-6;
			color: var(--sp-text-secondary);
			font-size: 18px;
			line-height: 32px;
			font-weight: $font-weight-normal;

			@include media-down(md) {
				font-size: 16px;
				line-height: 28px;
			}
		}

		&__ctas {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: $spacing-3;

			@include media-down(sm) {
				flex-direction: column;
				align-items: stretch;

				.sp-btn {
					justify-content: center;
				}
			}
		}
	}

	// ── Stats strip ──────────────────────────────────────────────────────
	// The design: 1px hairline top + bottom borders, 32px vertical padding,
	// four 140px-wide stat blocks centered with 84px gaps.
	.sp-stats {
		position: relative;
		z-index: 1;
		padding: 0;
		border-top: 1px solid var(--sp-page-line);
		border-bottom: 1px solid var(--sp-page-line);

		&__grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: $spacing-6 $spacing-4;
			list-style: none;
			padding: $spacing-8 0;
			margin: 0;
			text-align: center;

			@include media-up(md) {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 84px;
			}
		}
	}

	.sp-stat {
		@include media-up(md) {
			width: 140px;
			flex-shrink: 0;
		}

		// The design headings/h4: 32/40 SemiBold.
		&__value {
			font-size: 32px;
			font-weight: $font-weight-semibold;
			line-height: 40px;
			color: var(--sp-text);
			margin: 0 0 $spacing-2;

			@include media-down(md) {
				font-size: 24px;
				line-height: 32px;
			}
		}

		// The design content/body-s: 14/24 regular gray.
		&__label {
			font-size: 14px;
			line-height: 24px;
			color: var(--sp-text-secondary);
			white-space: pre-line;
		}
	}

	// ── Section chrome ───────────────────────────────────────────────────
	.sp-section {
		position: relative;
		z-index: 1;
		padding: $spacing-12 0;
		// Keep section heading clear of the 80px fixed site header when the
		// section is reached via a #hash link (e.g. "See What's Included").
		scroll-margin-top: calc(#{$header-height} + 16px);

		@include media-up(md) {
			padding: 100px 0 0;
		}

		// The design: 16px gap between eyebrow row and title-block, then the
		// title-block itself has 16px left padding so the title aligns with
		// the eyebrow label (not the vertical bar).
		&__header {
			display: flex;
			flex-direction: column;
			gap: $spacing-4; // 16px between eyebrow and title block
			margin-bottom: $spacing-8;

			@include media-up(md) {
				margin-bottom: 56px;
			}
		}

		&__title-block {
			display: flex;
			flex-direction: column;
			gap: $spacing-4; // 16px between title and lead
			max-width: 800px;
		}

		// The design headings/h4: 32/40 SemiBold.
		&__title {
			font-size: 32px;
			font-weight: $font-weight-semibold;
			line-height: 40px;
			margin: 0;
			color: var(--sp-text);

			@include media-down(md) {
				font-size: 24px;
				line-height: 32px;
			}
		}

		// The design content/body-l: 18/32 regular in gray-2.
		&__lead {
			font-size: 18px;
			line-height: 32px;
			margin: 0;
			color: var(--sp-text-secondary);

			@include media-down(md) {
				font-size: 16px;
				line-height: 28px;
			}
		}
	}

	// ── Eyebrow (small label above the section title) ────────────────────
	// The design: 32px-tall row with a 2px-thick vertical line + 16px gap +
	// "Included with your plan" in headings/h6 (20/24 SemiBold) primary blue.
	// The vertical bar is pulled LEFT with a negative margin equal to the
	// container's responsive padding so it sits flush with the page-frame
	// hairline (the 1080-wide column edge), matching the design layout.
	.sp-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: $spacing-4;
		font-size: 20px;
		font-weight: $font-weight-semibold;
		line-height: 24px;
		color: var(--sp-brand);
		min-height: 32px;
		margin-left: -$spacing-4;

		&::before {
			content: '';
			display: block;
			width: 2px;
			height: 32px;
			background: var(--sp-brand);
			flex-shrink: 0;
		}
	}

	// ── "We …" card ──────────────────────────────────────────────────────
	// The design: 1px gray-5 outline, 8px radius, 40px inner padding, white surface.
	// We use explicit margin-top on intro / body / footer so the gap between
	// title row and intro stays consistent (24px) even when the title wraps
	// to 2 lines — flex+gap would also gap the collapsed-body element and
	// leave a double-space between intro and footer in collapsed state.
	.we-card {
		position: relative;
		background: var(--sp-surface);
		border: 1px solid var(--sp-card-border);
		border-radius: 8px;
		padding: $spacing-6;
		margin: 0 0 $spacing-6;
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease;

		// When jumped to via in-page hash (#advise, #train, #deliver),
		// keep the card title clear of the fixed site header (80px) instead
		// of letting it slide underneath.
		scroll-margin-top: calc(#{$header-height} + 16px);

		@include media-up(md) {
			padding: $spacing-10; // 40px
		}

		// Header row: icon | title | toggle button.
		&__head {
			display: grid;
			grid-template-columns: 32px 1fr;
			grid-template-areas:
				'icon title'
				'toggle toggle';
			align-items: start;
			column-gap: $spacing-4;
			row-gap: $spacing-3;
			width: 100%;
			padding: 0;
			background: none;
			border: 0;
			font: inherit;
			color: inherit;
			text-align: left;
			cursor: pointer;

			@include media-up(md) {
				grid-template-columns: 32px 1fr auto;
				grid-template-areas: 'icon title toggle';
				column-gap: $spacing-4;
			}

			&:focus-visible {
				outline: 2px solid var(--sp-brand);
				outline-offset: 4px;
				border-radius: 8px;
			}
		}

		// The design icon-box: 8px padding around a 16px glyph (total 32×32), 4px
		// radius, light accent-low fill, 1px accent-high border, accent-high
		// glyph colour.
		&__icon {
			grid-area: icon;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 8px;
			border-radius: 4px;
			background: var(--card-accent-soft);
			border: 1px solid var(--card-accent-text);
			color: var(--card-accent-text);
			flex-shrink: 0;
			align-self: start;

			[data-icon] {
				width: 16px;
				height: 16px;
			}
		}

		// The design --sl-text-h4: 24/1.2 SemiBold for the title row. Name is bold,
		// the em-dash separator + descriptor are the same size in Regular
		// weight (the design code splits them into two <span> with different
		// font-family styles, "SemiBold" vs "Regular").
		&__title {
			grid-area: title;
			margin: 0;
			color: var(--sp-text);
			font-size: 24px;
			line-height: 1.2;
			font-weight: $font-weight-normal;

			strong {
				font-weight: $font-weight-semibold;
				color: var(--sp-text);
			}

			.we-card__sep {
				margin: 0 4px;
			}

			.we-card__desc {
				color: var(--sp-text);
			}

			@include media-down(md) {
				font-size: 20px;
			}
		}

		// The design "More Detail" button: 1px gray-2 (#353841) outline, transparent
		// fill, 40px fixed height, 16px horizontal padding, 100px min-width,
		// 8px radius, 16/1.72 text + 24px chevron. The 14/16 padding from the
		// The design turns into 0 vertical + 16 horizontal once the button height
		// is fixed at 40px — otherwise the content would push it taller.
		&__toggle {
			grid-area: toggle;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: $spacing-2;
			height: 40px;
			padding: 0 16px;
			min-width: 100px;
			border: 1px solid var(--sp-text-secondary);
			border-radius: 8px;
			font-size: 14px;
			line-height: 1;
			font-weight: $font-weight-normal;
			color: var(--sp-text-secondary);
			background: transparent;
			justify-self: stretch;
			white-space: nowrap;
			transition:
				border-color 0.15s,
				background-color 0.15s,
				color 0.15s;

			@include media-up(md) {
				justify-self: end;
			}

			.we-card__head:hover & {
				background: var(--sp-text-secondary);
				color: #ffffff;
			}
		}

		// Chevron rotates 180° when the card is expanded so the indicator
		// flips visibly between states.
		&__chevron {
			width: 24px;
			height: 24px;
			color: currentColor;
			transition: transform 0.25s ease;
		}

		&__head[aria-expanded='true'] .we-card__chevron {
			transform: rotate(180deg);
		}

		// Intro text below the title row. 24px gap below the title row even
		// when the title wraps to 2 lines. Width is capped at 800px so the
		// paragraph doesn't wrap under the "More Detail" button.
		&__intro {
			margin: $spacing-6 0 0;

			p {
				margin: 0;
				color: var(--sp-text);
				font-size: 16px;
				line-height: 28px;
				max-width: 800px;
			}
		}

		// Smooth expand/collapse using the grid-template-rows: 0fr → 1fr
		// trick. The wrapper grid animates to natural content height, while
		// the inner div sets `min-height: 0; overflow: hidden` so children
