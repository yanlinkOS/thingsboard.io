			display: flex;
			align-items: center;
			gap: $spacing-2;
			color: var(--card-accent-text);
			font-size: 18px;
			line-height: 1.2;
			font-weight: $font-weight-semibold;
			margin: 0;

			strong {
				font-weight: $font-weight-semibold;
			}
		}

		// The design bulb icon: 24px.
		&__icon {
			width: 24px;
			height: 24px;
			flex-shrink: 0;
		}

		// The design --sl-text-body: 16/1.72 Regular in primary text.
		p {
			font-size: 16px;
			line-height: 1.72;
			margin: 0;
			color: var(--sp-text);
		}

		// Inline links always use brand blue, underlined.
		a {
			color: var(--sp-brand);
			text-decoration: underline;
			font-weight: $font-weight-normal;

			&:hover {
				text-decoration: none;
			}
		}

		strong {
			color: var(--sp-text);
			font-weight: $font-weight-semibold;
		}
