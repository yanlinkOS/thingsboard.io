	// ≤1279px — project-timeline → mobile layout
	@media (max-width: 1279px) {
		.project-timeline {
			.table-container {
				display: none;
			}

			.mobile-timeline {
				display: flex;
				flex-direction: row;

				.mt-left {
					flex: 1;
					display: flex;
					flex-direction: column;

					div {
						padding: 51px 0 51px 16px;
						font-size: 18px;
						font-weight: 400;
						line-height: 30px;
						letter-spacing: 0.15px;
						color: #3d3d3d;
						border-bottom: 1px dashed #757575;

						&:last-child {
							border-bottom: none;
						}
					}
				}

				.mt-right {
					flex: 3;
					display: flex;
					flex-direction: column;
					gap: 9px;

					& > div {
						border-radius: 8px;
						transition: padding 0.5s ease-in-out;
						overflow: hidden;

						h3 {
							color: #212121;
							font-size: 24px;
							font-weight: 500;
							line-height: 36px;
							letter-spacing: 0.15px;
						}

						p {
							font-size: 18px;
							font-weight: 400;
							line-height: 30px;
							letter-spacing: 0.15px;
							color: #3d3d3d;
						}

						p:last-child {
							max-height: 0;
							overflow: hidden;
							transition:
								max-height 0.5s ease-in-out,
								margin-top 0.5s ease-in-out,
								opacity 0.4s ease-in-out;
							margin-top: 0;
							opacity: 0;
						}

						// 500px is the practical worst-case for the longest
						// body paragraph here ("Project Kick-off" ~50 words)
						// at the smallest viewport — 200px was clipping it.
						&.expanded p:last-child {
							max-height: 500px;
							margin-top: 16px;
							opacity: 1;
						}

						// Each card has a `min-height` that holds the collapsed
						// visual rhythm of the timeline (so Week labels on the
						// left line up with their card on the right). When the
						// user expands a card, the body p reveals and the card
						// grows naturally to fit — no `max-height` cap to
						// clip the text. Earlier `max-height` + `height: 100%`
						// pinned the expanded card to its parent's flex height,
						// which clipped the tail of the longest paragraphs
						// even with a 1500px cap.
						&:nth-child(1) {
							padding: 51.5px 16px;
							background: linear-gradient(180deg, #fff 0%, #b5c0ce 100%);
							min-height: 167px;
						}

						&:nth-child(2) {
							padding: 34px 16px;
							background: #d4e5fb;
							min-height: 132px;
						}

						&:nth-child(3) {
							padding: 4px 16px;
							background: #bbd5f9;
							min-height: 72px;
						}

						&:nth-child(4) {
							padding: 34px 16px;
							background: #1e67d4;
							min-height: 132px;

							p,
							h3 {
								color: white;
							}
						}

						&:nth-child(5) {
							padding: 100px 16px;
							background: #bbd5f9;
							min-height: 264px;
						}

						&:nth-child(6) {
							padding: 4px 16px;
							background: #d4e5fb;
							min-height: 72px;
						}

						&:nth-child(7) {
							padding: 51.5px 16px;
							background: linear-gradient(180deg, #b5c0ce 0%, #fff 100%);
							min-height: 167px;
						}
					}
				}
			}
		}
	}

