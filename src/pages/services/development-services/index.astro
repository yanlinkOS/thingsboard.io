			cursor: pointer;

			.expansion-header {
				padding: 0 0 20px;
				display: flex;
				justify-content: space-between;
				align-items: center;
				position: relative;

				&::after {
					content: '';
					display: block;
					width: 8px;
					height: 8px;
					border-right: 2px solid #6b7178;
					border-bottom: 2px solid #6b7178;
					transform: rotate(45deg);
					transition: transform 0.6s;
					flex-shrink: 0;
					position: absolute;
					top: 16px;
					right: 10px;
