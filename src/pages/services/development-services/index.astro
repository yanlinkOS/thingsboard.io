	// ── Industries Section ───────────────────────────────────────────────────────
	.industries {
		padding: 100px 0;

		.industries-container {
			width: 100%;
			display: flex;
			flex-direction: column;
			align-items: center;
		}

		.industries-title {
			font-size: 36px;
			font-weight: 500;
			line-height: 48px;
			color: #212121;
			margin-bottom: 20px;
		}

		.industries-subtitle {
			margin-bottom: 64px;
			color: #424242;
			font-size: 18px;
			font-weight: 400;
			max-width: 900px;
			text-align: center;
			line-height: 30px;
		}

		.content-container {
			max-height: 700px;
			display: flex;
			gap: 32px;
			width: 100%;
		}

		.menu {
			overflow-y: scroll;
			max-width: 50%;
			width: 50%;
			scrollbar-width: thin;
			scrollbar-color: #adb5bd transparent;
			padding-right: 16px;

			.menu-item {
				display: flex;
				align-items: center;
				gap: 12px;
				padding: 20px 32px;
				cursor: pointer;

				&:hover .menu-item-header h3 {
					color: #000;
				}

				&.active {
					border-radius: 24px;
					background: #f4f8fe;

					.menu-item-header h3 {
						color: #000;
					}
				}

				.menu-item-header {
					display: flex;
					align-items: center;
					justify-content: start;
					width: 100%;
					gap: 10px;
					margin: 0 10px;

					h3 {
						font-size: 24px;
						font-weight: 400;
						line-height: 36px;
						color: #3d3d3d;
					}
				}
			}
		}

		:global(.industries-card) {
			max-width: 50%;
			display: flex;
			position: relative;
			overflow: hidden;
			flex-direction: column;
			gap: 32px;
		}

		:global(.industries-card.inline) {
			display: none;
		}
	}

	// Industries card inner content — fully global (injected via innerHTML)
	:global(.industries-card .card-img) {
		max-width: 407px;
		height: auto;
		position: absolute;
		bottom: 0;
		right: 0;
	}

	:global(.industries-card .card-text-container) {
		font-size: 16px;
		font-weight: 400;
		line-height: 28px;
		color: #212121;
	}

	:global(.industries-card .card-descr) {
		margin-bottom: 32px;
	}

	:global(.industries-card ul) {
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding-left: 20px;
	}

	:global(.industries-card ul li) {
		list-style-type: disc;
		color: #3d3d3d;
		font-size: 16px;
		font-weight: 400;
		line-height: 28px;
	}

	:global(.industries-card ul li::marker) {
		color: #2a7dec;
	}

	// ≤1280px — industries (mobile: inline card)
	@media (max-width: 1280px) {
		.industries {
			.industries-title {
				text-align: center;
			}

			.content-container {
				width: 100%;
				max-width: 100%;
				max-height: unset;
			}

			.menu {
				width: 100%;
				max-width: 100%;
				max-height: unset;
				padding: 0;
				overflow-y: hidden;

				.menu-item {
					flex-direction: column;
					padding: 16px 0;

					&.active .menu-item-header {
						padding-bottom: 0;
					}

					.menu-item-header {
						padding: 16px 32px;
					}
				}
			}

			:global(.industries-card.global) {
				display: none;
			}

			:global(.industries-card.inline) {
				display: flex;
				width: 100%;
				max-width: 95%;
			}

			:global(.industries-card.inline .card-descr) {
				width: 60%;
			}
			:global(.industries-card.inline .card-img) {
				max-width: 300px;
				bottom: 20px;
				right: 20px;
			}
		}
	}

	// ≤599px — industries
	@media (max-width: 599px) {
		.industries {
			padding: 40px 0;

			.industries-container {
				padding: 10px;
			}

			.menu .menu-item {
				padding: 12px 0;
			}
		}

		:global(.industries-card.inline) {
			padding: 15px;
			font-size: 14px;
			line-height: 21px;
		}

		:global(.industries-card.inline .card-img) {
			display: none;
		}
		:global(.industries-card.inline .card-descr) {
			width: 100%;
		}
	}

	// ── Trusted Partner Section ──────────────────────────────────────────────────
	.trusted-partner {
		padding: 100px 0 0;
		text-align: center;
		position: relative;

		&::before {
			content: '';
			position: absolute;
			width: 100vw;
			height: 100%;
			background-color: #f4f8fe;
			z-index: -1;
			left: 49.4%;
			transform: translateX(-50%);
			top: 0;
		}

		.trusted-partner-title {
			font-size: 36px;
			font-weight: 500;
			line-height: 48px;
			margin-bottom: 40px;
		}

		.trusted-partner-container {
			position: relative;
			display: flex;
			flex-direction: column;
			gap: 40px;
			color: #212529;
		}

		.trusted-partner-header {
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			gap: 32px;
		}

		.trusted-tips {
			display: flex;
			gap: 120px;
		}

		.trusted-tip {
			display: flex;
			flex-direction: column;
			gap: 12px;
			align-items: center;
			color: #202021;
			font-size: 24px;
			font-weight: 500;
			line-height: 36px;

			&::before {
				content: '✓';
				color: #fafbfc;
				background-color: #2a7dec;
				border-radius: 50%;
				font-size: 25px;
				font-weight: 600;
				display: flex;
				align-items: center;
				justify-content: center;
				width: 40px;
				height: 40px;
				flex-shrink: 0;
			}
		}

		.trusted-partner-header-descr p {
			color: #202021;
			font-size: 24px;
			font-weight: 500;
			line-height: 36px;
		}

		.trusted-partner-footer {
			display: flex;
			flex-direction: row-reverse;
			gap: 32px;
		}

		.wrap {
			display: flex;
			flex-direction: column;
		}

		.trusted-partner-descr {
			display: flex;
			flex-direction: column;
			gap: 12px;
			border-left: 3px solid #2a7dec;
			padding-left: 17px;
			margin-bottom: 32px;

			p {
				line-height: 28px;
				font-size: 16px;
				color: #202021;
				font-weight: 400;
				text-align: start;
			}
		}

		.trusted-partner-avatar {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 16px;

			.avatar {
				max-width: 220px;
				height: auto;
			}
			.avatar-mobile {
				display: none;
			}

			.trusted-partner-text {
				.name {
					font-size: 24px;
					font-weight: 500;
					line-height: 36px;
					color: #212529;
				}
				.tp-title {
					font-size: 18px;
					font-weight: 400;
					color: #212529;
				}
			}
		}
	}

	// ≤1279px — trusted partner
	@media (max-width: 1279px) {
		.trusted-partner .trusted-partner-container {
			padding: 40px;
		}
		.trusted-partner .trusted-partner-avatar .avatar {
			max-width: 245px;
		}
	}

	// ≤959px — trusted partner
	@media (max-width: 959px) {
		.trusted-partner .trusted-partner-container {
			padding: 20px;
		}
		.trusted-partner .trusted-partner-footer {
			flex-direction: column-reverse;
			gap: 20px;
			padding-top: 16px;

			.trusted-partner-avatar {
				width: 100%;

				.avatar {
					margin: 0 auto;
				}
				.trusted-partner-text {
					text-align: left;
				}
			}
		}
	}

	// ≤599px — trusted partner
	@media (max-width: 599px) {
		.trusted-partner {
			padding: 40px 0;

			.trusted-partner-title {
				font-size: 28px;
				line-height: 44px;
			}
			.trusted-partner-container {
				padding: 20px 0;
			}

			.trusted-tips {
				gap: 45px;

				.trusted-tip {
					font-size: 20px;
					font-weight: 400;
					line-height: 32px;

					&::before {
						width: 32px;
						height: 32px;
						font-size: 14px;
					}
				}
			}

			.trusted-partner-header-descr p {
				font-size: 16px;
				font-weight: 400;
				line-height: 30px;
			}

			.trusted-partner-descr p {
				font-size: 14px;
				font-weight: 400;
			}

			.trusted-partner-avatar {
				flex-direction: row;

				.avatar {
					width: 100%;
					display: none;
				}
				.avatar-mobile {
					display: block;
				}
			}
		}
	}

	// ── Fast Delivery Section ────────────────────────────────────────────────────
	.fast-delivery {
		text-align: center;
		padding: 100px 0;
		position: relative;
		background-color: transparent;

		&::before {
			content: '';
			position: absolute;
			width: 100vw;
			height: 100%;
			background-color: #f4f8fe;
			z-index: -1;
			left: 49.4%;
			transform: translateX(-50%);
			top: 0;
		}

		.fast-delivery-title {
			font-size: 28px;
			font-weight: 500;
			line-height: 44px;
			margin-bottom: 40px;
			padding: 0 80px;
			color: #212121;
		}

		.mobile-container {
			display: none;
		}

		table {
			width: 100%;
			border-collapse: collapse;

			th,
			td {
				padding: 10px 20px;
				text-align: center;
				font-size: 16px;
				font-weight: 400;
				line-height: 28px;
				border: 4px solid #f4f7fa;
				border-radius: 7px;
				background: #fff;
				color: #3d3d3d;
				height: 75px;
			}

			thead th {
				font-size: 28px;
				font-weight: 500;
				line-height: 44px;
				color: #212121;
				text-align: center;
				padding: 24px 20px;
				background: #fff;
			}

			thead th:first-child {
				width: 30%;
				background-color: #f4f8fe;
				border-radius: 0;
			}

			thead th:not(:first-child) {
				width: 35%;
			}

			tbody td:first-child {
				font-weight: 400;
				color: #212529;
				width: 30%;
				background-color: #f4f8fe;
				border-radius: 0;
				text-align: left;
			}

			tbody td:not(:first-child) {
				width: 35%;
			}

			tr:last-child td {
				border-bottom: none;
			}
		}
	}

	// ≤1279px — fast delivery
	@media (max-width: 1279px) {
		.fast-delivery table td {
			padding: 20px;
		}
	}

	// ≤959px — fast delivery
	@media (max-width: 959px) {
		.fast-delivery {
			padding: 100px 10px;

			.table-container {
				display: none;
			}

			.mobile-container {
				display: flex;
				flex-direction: column;
				padding: 0 16px;

				.row {
					display: flex;
					flex-wrap: nowrap;
					gap: 4px;
					margin-bottom: 12px;

					.content {
						flex: 1;
						display: block;
						padding: 16px;
						background: #fff;
						border-radius: 4px;
						font-size: 14px;
						line-height: 24px;
						font-weight: 400;
						color: #3d3d3d;
						text-align: left;
						box-shadow: 0 26px 40px 0 rgba(42, 125, 236, 0.08);
					}

					&:first-child .content {
						font-size: 24px;
						font-weight: 500;
						line-height: 36px;
						color: #212121;
						text-align: center;
					}
				}

				h3 {
					margin-bottom: 8px;
					font-size: 16px;
					font-weight: 500;
					line-height: 28px;
					color: #1f2021;
				}
			}
		}
	}

	// ≤599px — fast delivery
	@media (max-width: 599px) {
		.fast-delivery {
			padding: 40px 0;
			padding-top: 0;

			.fast-delivery-title {
				padding: 0;
				font-size: 24px;
				line-height: 36px;
			}
			.table-container {
				overflow-x: scroll;
			}
		}
	}

	// ── Quote with Mark Section ──────────────────────────────────────────────────
	.quote-with-mark {
		padding: 100px 0;
		display: flex;
		gap: 64px;
		align-items: flex-start;

		img {
			flex-shrink: 0;
		}

		.quote-text {
			p {
				color: #3a3b3d;
				font-style: italic;
				font-size: 18px;
				font-weight: 400;
				line-height: 30px;
				letter-spacing: 0.249px;
				margin-bottom: 32px;

				a.read-more-link {
					color: #3d3d3d;
					font-style: normal;
					text-decoration: underline;
				}
			}

			h2 {
				color: #202021;
				font-size: 28px;
				font-weight: 400;
				line-height: 44px;
				letter-spacing: 0.249px;
				margin-bottom: 0;
			}
		}
	}

	// ≤599px — quote
	@media (max-width: 599px) {
		.quote-with-mark {
			flex-direction: column;
			padding: 40px 0;

			img {
				display: none;
			}
		}
	}

	// ── More Feature Section ─────────────────────────────────────────────────────
	.more-feature {
		padding: 100px 0;
		position: relative;

		&::before {
			content: '';
			position: absolute;
			width: 100vw;
			height: 100%;
			background-color: #f4f8fe;
			z-index: -1;
			left: 49.4%;
			transform: translateX(-50%);
			top: 0;
		}

		.more-feature-title {
			text-align: center;
			font-size: 36px;
			font-weight: 500;
			line-height: 48px;
			color: #212121;
			margin-bottom: 40px;
		}

		.cards {
			display: flex;
			justify-content: center;
			gap: 32px;
			margin-bottom: 0;
		}

		.card {
			padding: 46px;
			border-radius: 24px;
			box-shadow: -2.933px 11px 36.667px -14.667px rgba(0, 0, 0, 0.15);
			background: #fff;
			flex: 1 1 0px;
			margin-bottom: 80px;

			.card-title {
				font-size: 28px;
				font-weight: 500;
				line-height: 44px;
				color: #212529;
				margin-bottom: 16px;
			}

			.card-descr {
				color: #424242;
				font-size: 16px;
				font-weight: 400;
				line-height: 28px;
			}
		}
	}

	// ≤1279px — more feature
	@media (max-width: 1279px) {
		.more-feature .cards .card {
			padding: 32px;
		}
		.more-feature :global(.banner-img) {
			display: none;
		}
	}

	// ≤959px — more feature
	@media (max-width: 959px) {
		.more-feature .cards {
			flex-wrap: wrap;
			margin-bottom: 80px;
			width: 100%;

			.card {
				margin-bottom: 0;
				width: 48%;
				flex: unset;
			}
		}
	}

	// ≤599px — more feature
	@media (max-width: 599px) {
		.more-feature {
			padding: 40px 0;

			.more-feature-title {
				font-size: 24px;
				line-height: 36px;
			}

			.cards {
				flex-direction: column;
				margin-bottom: 32px;

				.card {
					width: 100%;
					margin-bottom: 0;
					padding: 32px;
				}
				.card-title {
					font-size: 24px;
					line-height: 36px;
					margin-bottom: 0;
				}
			}
		}
	}

	// ─── PROJECT TIMELINE ───────────────────────────────────────────────────────

	.project-timeline {
		padding: 100px 0;

		h2 {
			color: #212121;
			text-align: center;
			font-size: 36px;
			line-height: 48px;
			font-weight: 500;
			margin-bottom: 20px;
		}

		.pt-subtitle {
			max-width: 900px;
			color: #212121;
			text-align: center;
			font-size: 16px;
			line-height: 28px;
			font-weight: 400;
			margin: 0 auto 42px;
		}

		.table-container {
			width: 100%;
			max-width: 1400px;

			.timeline-table {
				width: 100%;
				border-collapse: separate;
				table-layout: fixed;

				th {
					padding: 12px 0;
					font-size: 18px;
					font-weight: 500;
					line-height: 30px;
					text-align: center;
					border-bottom: 1px solid #9e9e9e;

					&:first-child {
						text-align: left;
						padding-left: 8px;
					}
				}

				th:not(:last-child),
				td:not(:last-child) {
					border-right: 1px dashed #9e9e9e;
				}

				th:first-child,
				td:first-child {
					width: 276px;

					@media (max-width: 1919px) {
						width: 175px;
					}
				}

				tbody {
					tr {
						&:nth-child(4).highlight-row {
							background-color: #f2f7fe;
						}
						&:hover {
							background-color: #f2f7fe;
						}
						&:hover td:first-child {
							font-weight: 500;
						}
					}

					td {
						padding: 12px 0;
					}

					td:first-child {
						padding: 16px 0 16px 8px;
						font-size: 16px;
						font-weight: 400;
						line-height: 28px;
						color: #212121;
						vertical-align: top;
						letter-spacing: 0.15px;
					}

					.expansion-cell {
						padding: 4px 8px;
						border-radius: 8px;
						text-align: center;
						height: 36px;
						overflow: hidden;
						position: relative;
						color: rgb(33, 37, 41);
						transition:
							height 0.3s ease-in-out,
							width 0.3s ease-in-out,
							transform 0.3s ease-in-out,
							text-align 0.3s;
						cursor: default;

						p {
							font-size: 14px;
							line-height: 24px;
							color: rgb(33, 37, 41);

							&:first-child {
								font-weight: 500;
								pointer-events: none;
								margin-bottom: 8px;
							}

							&:last-child {
								opacity: 0;
							}
						}

						&.first {
							border: 1px solid #b5c0ce;
							background: linear-gradient(90deg, #fff 0%, #b5c0ce 100%);
							width: 150%;

							&:hover {
								padding-left: 8px;
								padding-right: 8px;
								width: 359px;
								text-align: left;
								height: 136px;

								p:last-child {
									opacity: 1;
								}
							}
						}

						&.second {
							border: 1px solid rgba(42, 125, 236, 0.4);
							background: #d9ebff;
							width: 100%;
							margin-left: 50%;

							&:hover {
								padding-left: 8px;
								width: 424px;
								text-align: left;
								height: 136px;

								p:last-child {
									opacity: 1;
								}
							}
						}

						&.third {
							border: 1px solid rgba(42, 125, 236, 0.6);
							background: #bbd5f9;
							width: 50%;
							margin-left: 50%;
							padding: 6px 2px;

							&:hover {
								padding-left: 8px;
								width: 370px;
								text-align: left;
								height: 136px;

								p:last-child {
									opacity: 1;
								}
							}
						}

						&.fourth {
							border: 1px solid #2670d4;
							background: #1e67d4;
							width: 100%;
							color: white;
							height: 80px;
							padding: 4px 1px;
							text-align: center;

							p {
								color: white;
							}

							&:hover {
								padding-left: 8px;
								padding-right: 8px;
								width: 436px;
								text-align: left;
								height: 136px;

								p:last-child {
									opacity: 1;
								}
							}
						}

						&.fifth {
							border: 1px solid rgba(42, 125, 236, 0.6);
							background: #bbd5f9;
							width: 200%;
							height: 54px;

							&:hover {
								padding-left: 8px;
								width: 440px;
								text-align: left;
								height: 136px;

								p:last-child {
									opacity: 1;
								}
							}
						}

						&.sixth {
							border: 1px solid #2670d4;
							background: #d9ebff;
							width: 50%;
							padding: 6px 2px;

							&:hover {
								padding-left: 8px;
								width: 333px;
								text-align: left;
								height: 136px;
