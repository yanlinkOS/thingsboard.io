	const solutionDemoLink = document.getElementById('solutions-demo-link') as HTMLAnchorElement | null;
	const panels = document.querySelectorAll<HTMLElement>('.expansion-panel');

	// Initialize first panel on mobile
	if (isMobile) updateClientInfo(0, panels[0]);

	panels.forEach((panel, index) => {
		panel.querySelector<HTMLElement>('.expansion-header')?.addEventListener('click', () => {
			if (panel.classList.contains('expanded')) return;
			panels.forEach((p) => p.classList.remove('expanded'));
			panel.classList.add('expanded');
			if (solutionImage && panel.dataset.image) {
				solutionImage.style.opacity = '0';
				setTimeout(() => {
					solutionImage.src = panel.dataset.image!;
					solutionImage.style.opacity = '1';
				}, 150);
			}
			if (solutionDemoLink && panel.dataset.demoLink) {
				solutionDemoLink.href = panel.dataset.demoLink;
			}
			// Pass the panel so the mobile branch can inject the testimonial
			// inside this expanded panel's `.panel-images`. Without it, only
			// the first panel (initialized above) ever gets the testimonial.
			updateClientInfo(index, panel);
		});
	});

	document.addEventListener('DOMContentLoaded', function () {
		function animateNumber(el: HTMLElement, target: number, duration = 800) {
			const start = parseInt(el.dataset.start ?? '0', 10);
			const startTime = performance.now();

			function updateNumber(currentTime: number) {
				const elapsed = currentTime - startTime;
				const progress = Math.min(elapsed / duration, 1);
				el.textContent = String(Math.floor(progress * (target - start) + start));
				if (progress < 1) {
					requestAnimationFrame(updateNumber);
				} else {
					el.textContent = String(target);
				}
			}

			requestAnimationFrame(updateNumber);
		}

		const elements = document.querySelectorAll<HTMLElement>('.animated-num');
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const el = entry.target as HTMLElement;
						const target = parseInt(el.dataset.target ?? '0', 10);
						el.style.opacity = '1';
						animateNumber(el, target);
						observer.unobserve(el);
					}
				});
			},
			{ threshold: 0.5 }
		);

		elements.forEach((el) => {
			observer.observe(el);
		});

		// Mobile timeline — click to expand
		const timelineBlocks = Array.from(document.querySelectorAll<HTMLElement>('.mt-right > div'));
		timelineBlocks.forEach((block) => {
			block.addEventListener('click', () => {
				const isExpanded = block.classList.contains('expanded');
				timelineBlocks.forEach((b) => b.classList.remove('expanded'));
				if (!isExpanded) block.classList.add('expanded');
			});
		});
	});

