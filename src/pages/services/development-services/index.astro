	// ≤599px — mobile
	@media (max-width: 599px) {
		.hero-container {
			// Inherit `height: unset` from the ≤1279px tablet rule so the
			// container sizes to content; the previous `100vh` left a tall
			// empty gap between the laptop image and the statistics band
			// on short mobile viewports.
			padding: 0 16px;
			text-align: center;

			.text {
				padding-bottom: 50px;
				margin: 0;
			}
		}

		.cdu-title {
			font-size: 28px;
			line-height: 44px;
		}
		.cdu-sub-title {
			width: 100%;
		}

		// At this width the secondary screenshots break out of the laptop's
		// frame — `.right` sits at right:-114px off-screen and `.bottom`
		// drops below the main image instead of overlapping it. Hide them
		// so the hero shows just the laptop, cleanly centered.
		.hero-images {
			.top,
			.right,
			.bottom {
				display: none;
			}
		}

		#first-screen {
			margin-bottom: 0;
			min-height: 0;
			overflow: visible;
		}

		// At this width the stats wrap to two rows and grow taller than the
		// fixed `bottom: -300px` offset they used to ride in. Let them flow
		// naturally below the hero-container so the dark band sits flush
		// against the laptop image instead of leaving a page-bg gap.
		.statistics {
			position: static;
			gap: 16px;
			flex-wrap: wrap;
			padding: 32px 16px;

			.block {
				margin: 0 39px;
				text-align: center;
			}

			.stat-num {
				font-size: 36px;
				line-height: 48px;
				margin-bottom: 16px;
			}
			.stat-label {
				font-size: 14px;
				line-height: 24px;
				width: 80px;
			}
		}

		.development-services-container {
			padding: 0 16px;
		}

		.custom-solutions {
			padding: 40px 0;
			margin-bottom: 0;
		}

		.custom-solutions-wrapper h2 {
			font-size: 28px;
			line-height: 44px;
			margin-bottom: 24px;
		}

		.expansion-title {
			font-size: 22px;
		}

		.expansion-content {
			padding: 0;
		}

		:global(.buttons-block) {
			flex-direction: column;
			width: 100%;
		}
		:global(.buttons-block .button) {
			width: 100%;
		}

		.panel-images {
			:global(.project-screen-container) {
				display: block;
				width: 100%;
				padding: 56px 0 32px;
				margin-bottom: 0;
				min-height: unset;
			}

			:global(.feedback-heading) {
				display: block;
				font-size: 24px;
				line-height: 36px;
				margin-bottom: 12px;
			}

			:global(.buttons-block) {
				margin-bottom: 22px;
			}

			:global(.client-info) {
				padding: 0;
			}

			:global(.client-avatar-container) {
				flex-direction: column;
			}

			:global(.client-avatar-img) {
				width: 75px;
				height: 75px;
			}

			:global(.client-avatar-img img) {
				width: 75px;
				height: 75px;
			}

			:global(.client-info > div:last-child) {
				margin-left: 0;
			}
		}

		:global(.project-screen .bg-1) {
			right: -13px;
			top: 10px;
		}
		:global(.project-screen .bg-2) {
			left: -10px;
			top: -31px;
		}
		:global(.project-screen .bg-3) {
			right: -14px;
			top: -19px;
		}
	}

