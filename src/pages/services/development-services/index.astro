			.expansion-content {
				padding: 24px;
				max-height: 0;
				overflow: hidden;
				text-align: left;
				opacity: 0;
				transition:
					opacity 0.4s ease-in-out,
					max-height 0.4s ease-in-out,
					padding 0.4s ease-in-out;

				ul {
