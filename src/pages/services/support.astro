---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SupportPlanCard from '../../components/Services/SupportPlanCard.astro';
import InnerNavigation from '../../components/Services/InnerNavigation.astro';

const tabs = [
	{
		id: 'community-support',
		label: 'Community support',
		icon: '/images/pricing/thingsboard-icon.svg',
	},
	{
		id: 'professional-support',
		label: 'Professional support',
		icon: '/images/pricing/thingsboard-icon.svg',
		active: true,
	},
];

const plans = [
	{
		id: 'Serv_Support_PS_Essential',
		name: 'Essential',
		desc: 'for 1 server instance only',
		price: '$248',
		features: [
			'<strong>Email consulting</strong>: 2h per month',
			'<strong>Server issue response time</strong>: &lt; 24h',
			'<strong>On-demand trainings</strong>: not packed',
			'<strong>1 named contact</strong> within normal business hours',
		],
	},
	{
		id: 'Serv_Support_PS_Premium',
		name: 'Premium',
		desc: 'for up to 5 running servers',
		price: '$498',
		features: [
			'<strong>Email consulting</strong>: 4h per month',
			'<strong>Server issue response time</strong>: &lt; 24h',
			'<strong>On-demand trainings</strong>: 2h per month',
			'<strong>2 named contacts</strong> within extended business hours',
		],
	},
	{
		id: 'Serv_Support_PS_Ultimate',
		name: 'Ultimate',
		desc: 'privileged bundle for up to 10 running servers',
		price: '$1198',
		features: [
			'<strong>Email consulting</strong>: 8h per month',
			'<strong>Server issue response time</strong>: &lt; 12h',
			'<strong>On-demand trainings</strong>: 4h per month',
			'<strong>3 named contacts</strong> within 24/7',
		],
	},
];
---

<BaseLayout
	forceLightTheme
	title="Support plans"
	description="ThingsBoard professional support plans for IoT projects, cloud infrastructure support"
	pageId="services"
>
	<div class="support-header">
		<div class="support-hero">
			<h1>ThingsBoard support options</h1>
		</div>
		<InnerNavigation tabs={tabs} />
	</div>

	<div class="tab-content" id="tab-community-support" style="display:none">
		<div class="tab-inner">
			<div class="community-wrap">
				<div class="pricing-square">
					<h2>Community support</h2>
					<div class="community-support-card">
						<p>
							Community support is free-of-charge option. It is a volunteering initiative, provided
							by our team. Please, be aware that support is one of ThingsBoard Inc. business fields.
							Although our engineers (as many of our customers know) successfully handle user's
							requests in their free time. Community support doesn't mean any obligation for
							ThingsBoard Inc. We encourage you to:
						</p>
						<ul>
							<li>
								<img
									class="filter-icon"
									src="/images/feature-logo/guides.svg"
									alt="Documentation icon"
								/>
								<a href="/docs">Read documentation</a>
							</li>
							<li>
								<img src="/images/pricing/yootube-icon.svg" alt="YouTube icon" />
								<span
									>Subscribe to our <a href="https://www.youtube.com/c/thingsboard"
										>YouTube channel</a
									></span
								>
							</li>
							<li>
								<img src="/images/pricing/education-icon.svg" alt="Education icon" />
								<span
									>Keep an eye on our <a
										href="https://www.youtube.com/watch?v=M0CaascgDmg&list=PLYEKB_XwLCZJ6T8RPLTjRwMw0eoabpEKO"
										>free Education course updates</a
									></span
								>
							</li>
						</ul>
						<p>So, most demanded tutorials, samples and guides are available 24/7.</p>
						<p>
							Customer may also rely on answers from ThingsBoard <a
								href="https://github.com/thingsboard/thingsboard/issues">community on GitHub</a
							> (issues page), start <a
								href="https://stackoverflow.com/questions/tagged/thingsboard">Stack Overflow</a
							> themes.
						</p>
						<div class="community-cta">
							<a
								id="Serv_Support_CS_HelpMe"
								class="btn-blue btn-pricing gtm_button"
								href="/contact-us/?subject=Technical%20Support">Help me!</a
							>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="tab-content" id="tab-professional-support">
		<div class="tab-inner">
			<div class="professional-header">
				<h2>Support packages</h2>
				<p>Our support packs designed to cover diverse requirements</p>
			</div>
			<div class="plans-grid">
				{plans.map((plan) => <SupportPlanCard {...plan} />)}
			</div>
		</div>
	</div>
</BaseLayout>


<style lang="scss">
	@use 'sass:color';

	$blue: #2a7dec;

	// ── Header (hero + nav) ───────────────────────────────────────────────────
	.support-header {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.support-hero {
		padding: 120px 0 48px;

		h1 {
			font-size: 36px;
			font-weight: 700;
			color: #212529;
			margin: 0;
		}
	}

	// ── Tab content — full-width with background ──────────────────────────────
	.tab-content {
		background-color: #f4f8fe;
		width: 100%;
		padding: 40px 0 60px;
	}

	.tab-inner {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 20px;
	}

	// ── Community support ─────────────────────────────────────────────────────
	.community-wrap {
		display: flex;
		justify-content: center;

		.pricing-square {
			max-width: 640px;
			width: 100%;

			h2 {
				margin-bottom: 16px;
			}
		}
	}

	.community-support-card {
		display: flex;
		flex-direction: column;
		gap: 16px;
		color: #212529;

		p {
			font-size: 14px;
			line-height: 21px;
			letter-spacing: 0;
			color: #212529;
		}

		span,
		a:not(.btn-blue) {
			font-size: 14px;
			line-height: 21px;
			color: #212529;
		}

		a:not(.btn-blue) {
			color: $blue;
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}

		ul {
			list-style: none;
			padding: 0;
			margin: 0;
			display: flex;
			flex-direction: column;
			gap: 12px;

			li {
				display: flex;
				align-items: center;
				gap: 12px;
			}

			img {
				width: 18px;
				flex-shrink: 0;

				&.filter-icon {
					filter: invert(37%) sepia(84%) saturate(891%) hue-rotate(184deg) brightness(105%)
						contrast(88%);
				}
			}
		}
	}

	.community-cta {
		display: flex;
		justify-content: center;
		margin-top: 8px;
	}

	.btn-blue {
		display: inline-block;
		background-color: $blue;
		color: #fff;
		padding: 8px 24px;
		text-align: center;
		font-size: 18px;
		font-weight: 500;
		border-radius: 4px;
		border: solid 2px $blue;
		line-height: 28px;
		text-decoration: none;
		min-width: 200px;
		transition:
			background-color 0.15s,
			color 0.15s;

		&.btn-pricing {
			height: 48px;
			margin-bottom: 16px;
		}

		&:hover {
			background-color: #fff;
			color: $blue;
		}
	}

	.pricing-square {
		padding: 28px 24px;
		border: 1px solid rgba(42, 125, 236, 0.16);
		border-radius: 12px;
		box-shadow: 0 26px 40px 0 rgba(42, 125, 236, 0.08);
		background-color: #fff;

		h2 {
			font-size: 28px;
			font-weight: 500;
			line-height: 44px;
		}
	}

	// ── Professional support ──────────────────────────────────────────────────
	.professional-header {
		margin-bottom: 32px;

		h2 {
			font-size: 24px;
			font-weight: 700;
			color: #212529;
			margin-bottom: 8px;
		}

		p {
			font-size: 15px;
			color: #75767c;
			margin: 0;
		}
	}

	.plans-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	// ── Responsive ────────────────────────────────────────────────────────────
	@media screen and (max-width: 900px) {
		.plans-grid {
			grid-template-columns: 1fr;
			max-width: 480px;
			margin: 0 auto;
		}
	}

	@media screen and (max-width: 600px) {
		.support-hero h1 {
			font-size: 28px;
		}

		.tab-btn {
			font-size: 14px;
			padding: 10px 16px;
		}

		.community-card {
			padding: 24px;
		}
	}
</style>