---
import BaseLayout from '../../layouts/BaseLayout.astro';

const cards = [
	{
		title: 'Proof of Concept',
		description:
			'In short terms, our team will implement your most critical business processes on top of ThingsBoard platform. It allows to quickly evaluate ThingsBoard Platform and develop further Solution Architecture.',
	},
	{
		title: 'DevOps services',
		description:
			'Our experienced DevOps team take over the administration of your ThingsBoard cluster that is deployed in the cloud or on-premises. It includes installation and upgrades to latest versions, platform maintenance and optimization.',
	},
	{
		title: 'Consulting',
		description:
			'Our core team will review your business use cases, existing environment, SLA requirements and develop solution architecture based on a synergy of existing infrastructure and ThingsBoard platform.',
	},
	{
		title: 'Solution Development',
		description:
			'Our experienced engineering team enables rapid application development for your software solutions. Review and improve your current solution architecture or design it completely from scratch based on your business strategy. ThingsBoard platform customization to meet your business requirements.',
	},
	{
		title: 'Managed Services',
		description:
			'We are able to completely take over the administration of your ThingsBoard cluster that is deployed in the cloud or on-premises. Our engineers will be responsible for monitoring, elastic scalability and optimization of your ThingsBoard cluster.',
	},
];
---

<BaseLayout
	forceLightTheme
	title="Professional services"
	description="Professional services"
	pageId="services"
>
	<div class="consulting-page">
		<div class="consulting-inner">
			<h1>Professional services</h1>
			<div class="cards">
				{
					cards.map((card) => (
						<div class="card">
							<h3 class="card-title">{card.title}</h3>
							<p class="card-description">{card.description}</p>
						</div>
					))
				}
			</div>
		</div>
		<div class="bottom">
			<div class="bottom-inner">
				<a
					class="contact-button gtm_button"
					href="/contact-us/?subject=Professional%20Services"
				>Contact Us</a>
				<p>Contact us to get the ThingsBoard Professional services</p>
			</div>
		</div>
	</div>
</BaseLayout>

<style lang="scss">
	.consulting-page {
		padding-top: 120px;
	}

	.consulting-inner {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 20px 56px;

		h1 {
			font-size: 36px;
			font-weight: 700;
			color: #212529;
			margin: 0 0 24px;
		}
	}

	.cards {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.card {
		color: #212529;
		padding: 31px;
		border: 1px solid #ebebeb;

		& + .card {
			border-top: none;
		}

		.card-title {
			font-size: 18px;
			font-weight: 600;
			margin: 0;
			line-height: 1.4;
		}

		.card-description {
			margin-top: 24px;
			margin-bottom: 0;
			font-size: 14px;
			line-height: 1.6;
		}
	}

	.bottom {
		background-color: #f9fbfe;
		padding: 50px 20px;
	}

	.bottom-inner {
		max-width: 1400px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.contact-button {
		display: block;
		width: 350px;
		background-color: #2a7dec;
		font-size: 24px;
		font-weight: 400;
		text-align: center;
		color: #fff;
		border-radius: 4px;
		text-decoration: none;
		padding: 16px 20px;
		margin-bottom: 48px;
		box-shadow: 0 18px 16px -10px rgba(42, 125, 236, 0.25);
		transition: background-color 0.15s;

		&:hover {
			background-color: #4f97f8;
			color: #fff;
		}
	}

	.bottom p {
		color: #899aab;
		margin: 0;
		font-size: 14px;
	}

	@media screen and (max-width: 600px) {
		.consulting-page {
			padding-top: 80px;
		}

		.consulting-inner h1 {
			font-size: 28px;
		}

		.contact-button {
			width: 100%;
			max-width: 350px;
		}
	}
</style>