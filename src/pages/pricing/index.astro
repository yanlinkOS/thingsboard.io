---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PricingHero from '../../components/Pricing/PricingHero.astro';
import ProductTabs from '../../components/Pricing/ProductTabs.astro';
import ProductSubTabs from '../../components/Pricing/ProductSubTabs.astro';
import PlanCardGrid from '../../components/Pricing/PlanCardGrid.astro';
import CommunityEditionCard from '../../components/Pricing/CommunityEditionCard.astro';
import RegionToggle from '../../components/Pricing/RegionToggle.astro';
import BillingToggle from '../../components/Pricing/BillingToggle.astro';
import UpsellCard from '../../components/Pricing/UpsellCard.astro';
import AddOnsSection from '../../components/Pricing/AddOnsSection.astro';
import TopUpsSection from '../../components/Pricing/TopUpsSection.astro';
import PerpetualBenefits from '../../components/Pricing/PerpetualBenefits.astro';
import TbPaygCalculator from '../../components/Pricing/TbPaygCalculator.astro';
import TbPrivateCloudCalculator from '../../components/Pricing/TbPrivateCloudCalculator.astro';
import TbmqPaygCalculator from '../../components/Pricing/TbmqPaygCalculator.astro';
import TbmqPerpetualCalculator from '../../components/Pricing/TbmqPerpetualCalculator.astro';
import TbmqPrivateCloudCalculator from '../../components/Pricing/TbmqPrivateCloudCalculator.astro';
import PricingBackground from '../../components/Pricing/PricingBackground.astro';
import NButton from '../../components/Landing/NButton.astro';
import ComparisonTable from '../../components/Pricing/ComparisonTable.astro';

import { tbCeData } from '../../data/pricing/tb-ce';
import { tbCloudData, tbCloudTopUps } from '../../data/pricing/tb-cloud';
import { tbPrivateCloudData, tbPrivateCloudAddOns } from '../../data/pricing/tb-private-cloud';
import { tbSelfManagedData, tbSelfManagedAddOns, tbPerpetualHero } from '../../data/pricing/tb-self-managed';
import { tbmqCeData } from '../../data/pricing/tbmq-ce';
import { tbmqSelfManagedData } from '../../data/pricing/tbmq-self-managed';
import { tbmqPrivateCloudData } from '../../data/pricing/tbmq-private-cloud';
import { cloudAddOns } from '../../data/pricing/add-ons';
import { pcFeatureHeaders, pcFeatureRows } from '../../data/pricing/tb-private-cloud-features';
import type { PlanCard as PlanCardType } from '../../data/pricing/types';
import FaqSection from '../../components/Pricing/FaqSection.astro';
import { pricingFaqData } from '../../data/pricing/faq/index';

import ceIcon from '../../assets/pricing/community-edition-icon.svg?raw';
import cloudIcon from '../../assets/pricing/cloud-icon.svg?raw';
import pcIcon from '../../assets/pricing/private-cloud-icon.svg?raw';
import smIcon from '../../assets/pricing/self-icon.svg?raw';

// Build a faqId → answer lookup from all FAQ data (strip HTML, truncate for tooltip)
const faqAnswerMap = new Map<string, string>();
for (const section of pricingFaqData) {
	for (const cat of section.categories) {
		for (const item of cat.items) {
			const plain = item.answer.replace(/<[^>]+>/g, '').trim().replace(/\s+/g, ' ');
			const maxChars = 120;
			const truncated = plain.length > maxChars ? plain.slice(0, maxChars).replace(/\s+\S*$/, '') + '\u2026' : plain;
			faqAnswerMap.set(item.id, truncated);
		}
	}
}

// Auto-fill faqTooltip from FAQ answer when not explicitly provided
function enrichTabs(tabs: { id: string; label: string; icon?: string; faqId?: string; faqTooltip?: string; default?: boolean }[]) {
	return tabs.map((tab) => {
		const autoFill = !tab.faqTooltip && tab.faqId ? faqAnswerMap.get(tab.faqId) : undefined;
		return {
			...tab,
			faqTooltip: tab.faqTooltip || autoFill || undefined,
			autoTooltip: !!autoFill,
		};
	});
}

// Auto-fill faqTooltip on plan features that have faqId but no explicit tooltip
function enrichPlans(plans: PlanCardType[]): PlanCardType[] {
	return plans.map((plan) => ({
		...plan,
		features: plan.features.map((f) => ({
			...f,
			faqTooltip: f.faqTooltip || (f.faqId && faqAnswerMap.get(f.faqId)) || undefined,
		})),
	}));
}

// Auto-fill faqTooltip on comparison rows that have faqId but no explicit tooltip
function enrichRows(rows: import('../../data/pricing/types').ComparisonRow[]): import('../../data/pricing/types').ComparisonRow[] {
	return rows.map((row) => {
		const autoFill = !row.faqTooltip && row.faqId ? faqAnswerMap.get(row.faqId) : undefined;
		return {
			...row,
			faqTooltip: row.faqTooltip || autoFill || undefined,
			autoTooltip: !!autoFill,
		};
	});
}

const tbSubTabs = enrichTabs([
	{
		id: 'thingsboard-ce',
		label: 'Community Edition',
		icon: ceIcon,
		faqId: 'what-is-tb-ce',
		faqTooltip:
			'Community Edition is the free, open-source starting point\u2014perfect for fast pilots and proof-of-value. Start small, validate quickly, and scale up when you\u2019re ready.',
	},
	{
		id: 'thingsboard-cloud',
		label: 'Public Cloud',
		icon: cloudIcon,
		default: true,
		faqId: 'tb-cloud-definition',
		faqTooltip:
			'Public Cloud is fully managed ThingsBoard\u2014built for speed. We handle infrastructure, upgrades, and reliability so your team can focus on shipping IoT solutions faster.',
	},
	{
		id: 'thingsboard-private-cloud',
		label: 'Private Cloud',
		icon: pcIcon,
		faqId: 'tb-private-cloud-what-does-thingsboard-private-cloud-stand-for',
		faqTooltip:
			'Private Cloud is a dedicated, isolated ThingsBoard Professional Edition cluster run by us for you. You get enterprise-grade control and security\u2014without the ops overhead.',
	},
	{
		id: 'thingsboard-pe',
		label: 'Self-managed',
		icon: smIcon,
		faqId: 'pe-pay-as-you-go-self-managed-definition',
		faqTooltip:
			'Self-managed lets you run ThingsBoard on your own infrastructure (on-prem or cloud). Ideal when you need full environment control and prefer to manage operations in-house.',
	},
]);

const tbmqSubTabs = enrichTabs([
	{
		id: 'tbmq-ce',
		label: 'Community Edition',
		icon: ceIcon,
		faqId: 'what-is-tbmq-ce',
	},
	{
		id: 'tbmq-pe',
		label: 'Self-managed',
		icon: smIcon,
		default: true,
		faqId: 'tbmq-payg-sm-definition',
	},
	{
		id: 'tbmq-private-cloud',
		label: 'Private Cloud',
		icon: pcIcon,
		faqId: 'tbmq-stand-for',
	},
]);
---

<BaseLayout
	title="Pricing"
	description="ThingsBoard Products Pricing"
	pageId="pricing"
>
	<PricingBackground />
	<main class="pricing-page">
		<PricingHero />
		<ProductTabs />

		<!-- ═══ ThingsBoard product sections ═══ -->
		<div class="pricing-product-content" data-product-content="thingsboard">
			<ProductSubTabs product="thingsboard" tabs={tbSubTabs} />

			<!-- TB CE -->
			<section class="pricing-section" data-section="thingsboard-ce">
				<CommunityEditionCard data={tbCeData} />
			</section>

			<!-- TB Public Cloud -->
			<section class="pricing-section active" data-section="thingsboard-cloud">
				<div class="pricing-section-header-row">
					<div class="pricing-section-header">
						<h2>{tbCloudData.na.sectionTitle}</h2>
						<p>{tbCloudData.na.sectionSubtitle}</p>
					</div>
					<RegionToggle />
				</div>
				<div data-region-content="na">
					<PlanCardGrid plans={enrichPlans(tbCloudData.na.plans)}>
						<UpsellCard
							heading="Require dedicated infrastructure for unique enterprise needs?"
							ctaText="See Private Cloud Options"
							targetSection="thingsboard-private-cloud"
						/>
					</PlanCardGrid>
					<AddOnsSection addOns={cloudAddOns.na} />
					<TopUpsSection topUps={tbCloudTopUps.na} />
				</div>
				<div data-region-content="eu" style="display:none;">
					<PlanCardGrid plans={enrichPlans(tbCloudData.eu.plans)}>
						<UpsellCard
							heading="Require dedicated infrastructure for unique enterprise needs?"
							ctaText="See Private Cloud Options"
							targetSection="thingsboard-private-cloud"
						/>
					</PlanCardGrid>
					<AddOnsSection addOns={cloudAddOns.eu} />
					<TopUpsSection topUps={tbCloudTopUps.eu} />
				</div>
			</section>

			<!-- TB Private Cloud -->
			<section class="pricing-section" data-section="thingsboard-private-cloud">
				<div class="pricing-section-header">
					<h2>{tbPrivateCloudData.sectionTitle}</h2>
					<p>{tbPrivateCloudData.sectionSubtitle}</p>
				</div>
				<PlanCardGrid plans={enrichPlans(tbPrivateCloudData.plans)}>
					<UpsellCard
						heading="Not sure which plan fits?"
						subtitle="Use our calculator to estimate the best plan for your needs."
						ctaText="Calculate your pricing"
						onclick="window.openTbPcCalc?.()"
					/>
				</PlanCardGrid>
				<AddOnsSection addOns={tbPrivateCloudAddOns} />
				<ComparisonTable headers={pcFeatureHeaders} rows={enrichRows(pcFeatureRows)} />
			</section>

			<!-- TB Self-managed -->
			<section class="pricing-section" data-section="thingsboard-pe">
				<div class="pricing-section-header-row">
					<div class="pricing-section-header">
						<h2>Subscription plans</h2>
						<p data-billing-subtitle="tb-sm-billing" data-payg-text="All subscription plans include unlimited customers, dashboards, integrations, api calls, data points & messages." data-perpetual-text="One-time payment, run forever on your infrastructure.">All subscription plans include unlimited customers, dashboards, integrations, api calls, data points & messages.</p>
					</div>
					<BillingToggle
						leftLabel="Pay-as-you-go"
						rightLabel="Perpetual"
						leftValue="payg"
						rightValue="perpetual"
						id="tb-sm-billing"
					/>
				</div>
				<div data-billing-content="payg" data-billing-group="tb-sm-billing">
					<PlanCardGrid plans={enrichPlans(tbSelfManagedData.payg.plans)}>
						<UpsellCard
							heading="Not sure which plan fits?"
							subtitle="Use our calculator to estimate the best plan for your needs."
							ctaText="Calculate your pricing"
							onclick="window.openTbPaygCalc?.()"
						/>
					</PlanCardGrid>
					<AddOnsSection addOns={tbSelfManagedAddOns} />
				</div>
				<div data-billing-content="perpetual" data-billing-group="tb-sm-billing" style="display:none;">
					<CommunityEditionCard data={tbPerpetualHero} />
					{tbSelfManagedData.perpetual.benefits && (
						<PerpetualBenefits benefits={tbSelfManagedData.perpetual.benefits} />
					)}
					<div class="perpetual-bottom-cta">
						<h3>Let us help you identify the best option for your business</h3>
						<NButton
							href="/contact-us/?subject=ThingsBoard%20Products"
							variant="filled"
							size="md"
						>
							Contact us
						</NButton>
					</div>
				</div>
			</section>
		</div>

		<!-- ═══ TBMQ product sections ═══ -->
		<div class="pricing-product-content" data-product-content="tbmq" style="display:none;">
			<ProductSubTabs product="tbmq" tabs={tbmqSubTabs} />

			<!-- TBMQ CE -->
			<section class="pricing-section" data-section="tbmq-ce">
				<CommunityEditionCard data={tbmqCeData} />
			</section>

			<!-- TBMQ Self-managed -->
			<section class="pricing-section active" data-section="tbmq-pe">
				<div class="pricing-section-header-row">
					<div class="pricing-section-header">
						<h2>Your self-managed MQTT broker instance</h2>
						<p data-billing-subtitle="tbmq-sm-billing" data-payg-text="The TBMQ Professional Edition's highly flexible, consumption-based licensing model" data-perpetual-text="The TBMQ Professional Edition's long-term asset ownership model">The TBMQ Professional Edition's highly flexible, consumption-based licensing model</p>
					</div>
					<BillingToggle
						leftLabel="Pay-as-you-go"
						rightLabel="Perpetual"
						leftValue="payg"
						rightValue="perpetual"
						id="tbmq-sm-billing"
					/>
				</div>
				<div data-billing-content="payg" data-billing-group="tbmq-sm-billing">
					<TbmqPaygCalculator />
				</div>
				<div data-billing-content="perpetual" data-billing-group="tbmq-sm-billing" style="display:none;">
					<TbmqPerpetualCalculator />
				</div>
			</section>

			<!-- TBMQ Private Cloud -->
			<section class="pricing-section" data-section="tbmq-private-cloud">
				<div class="pricing-section-header">
					<h2>{tbmqPrivateCloudData.sectionTitle}</h2>
					<p>{tbmqPrivateCloudData.sectionSubtitle}</p>
				</div>
				<TbmqPrivateCloudCalculator />
			</section>
		</div>
		<!-- ═══ FAQ Section ═══ -->
		<div class="pricing-faq" id="faq">
			{pricingFaqData.map((faq) => (
				<div class="pricing-faq-block" data-faq-context={faq.contextId}>
					<h2 class="faq-main-title">{faq.title}</h2>
					<FaqSection contextId={faq.contextId} categories={faq.categories} />
				</div>
			))}
		</div>
	</main>

	<!-- Calculator modals (rendered outside main flow) -->
	<TbPaygCalculator />
	<TbPrivateCloudCalculator />
</BaseLayout>

<!-- ═══ URL state + tab/toggle logic ═══ -->
<script>
	function initPricing() {
		// ─── Helpers ───
		function $(sel: string, ctx: ParentNode = document): HTMLElement | null {
			return ctx.querySelector(sel);
		}
		function $$(sel: string, ctx: ParentNode = document): HTMLElement[] {
			return Array.from(ctx.querySelectorAll(sel));
		}

		let skipAnimation = true; // No animation on initial load

		// ─── Segment highlight animation ───
		function moveHighlight(container: HTMLElement) {
			const highlight = container.querySelector('.segment-highlight') as HTMLElement;
			const activeTab = container.querySelector('.segment-tab.active') as HTMLElement;
			if (!highlight || !activeTab) return;

			const containerRect = container.getBoundingClientRect();
			const tabRect = activeTab.getBoundingClientRect();
			const offsetLeft = tabRect.left - containerRect.left;

			highlight.style.width = tabRect.width + 'px';
			highlight.style.transform = `translateX(${offsetLeft - 4}px)`;
		}

		// Init all segment highlights on load
		function initAllHighlights() {
			$$('.segment-tabs').forEach((seg) => moveHighlight(seg));
		}

		// ─── URL state ───
		const params = new URLSearchParams(window.location.search);

		// Legacy param mapping: section=thingsboard-pe-options → product=thingsboard
		const sectionParam = params.get('section');
		const productParam = params.get('product');
		const solutionParam = params.get('solution');

		let activeProduct = 'thingsboard';
		let activeSubTab: string | null = null;
		let activeBilling: string | null = null;

		if (sectionParam === 'tbmq-options' || productParam?.startsWith('tbmq')) {
			activeProduct = 'tbmq';
		}

		if (productParam) {
			activeSubTab = productParam;
		}

		if (solutionParam === 'payg' || solutionParam === 'perpetual') {
			activeBilling = solutionParam;
		}

		// ─── Product tabs ───
		function activateProductTab(product: string) {
			$$('.product-tab').forEach((tab) => {
				const isActive = tab.dataset.product === product;
				tab.classList.toggle('active', isActive);
				tab.setAttribute('aria-current', isActive ? 'true' : 'false');
			});
			$$('.pricing-product-content').forEach((el) => {
				const pEl = el as HTMLElement;
				const isActive = el.dataset.productContent === product;
				pEl.style.display = isActive ? '' : 'none';
				if (!skipAnimation) {
					pEl.classList.remove('fade-in');
					if (isActive) {
						void pEl.offsetHeight;
						pEl.classList.add('fade-in');
						pEl.addEventListener('animationend', () => pEl.classList.remove('fade-in'), { once: true });
					}
				}
				if (isActive) {
					requestAnimationFrame(() => {
						if (typeof initAllSliders === 'function') initAllSliders(pEl);
					});
				}
			});
			activeProduct = product;

			// Animate product tab highlight
			const productNav = $('.segment-tabs--product');
			if (productNav) moveHighlight(productNav);

			// Re-position sub-tab highlight and re-activate the active section
			const visibleContent = $(`.pricing-product-content[data-product-content="${product}"]`);
			if (visibleContent) {
				const subNav = $('.segment-tabs--sub', visibleContent);
				if (subNav) moveHighlight(subNav);

				// Find the active sub-tab and re-activate its section (ensures visible class)
				const activeTab = $('.sub-tab.active', visibleContent);
				if (activeTab) {
					activateSubTab((activeTab as HTMLElement).dataset.subtab!);
				}
			}

			updateUrl();
		}

		$$('.product-tab').forEach((tab) => {
			tab.addEventListener('click', () => {
				activateProductTab(tab.dataset.product!);
			});
		});

		// ─── FAQ context mapping ───
		// Maps sub-tab ID to FAQ context ID(s)
		const faqContextMap: Record<string, string[]> = {
			'thingsboard-ce': ['thingsboard-ce'],
			'thingsboard-cloud': ['thingsboard-cloud'],
			'thingsboard-private-cloud': ['thingsboard-private-cloud'],
			'thingsboard-pe': ['thingsboard-pe'],
			'tbmq-ce': ['tbmq-ce'],
			'tbmq-pe': ['tbmq-pe-payg', 'tbmq-pe-perpetual'],
			'tbmq-private-cloud': ['tbmq-private-cloud'],
		};

		function updateFaqVisibility(sectionId: string) {
			const contexts = faqContextMap[sectionId] || [];
			$$('.pricing-faq-block').forEach((el) => {
				const ctx = el.dataset.faqContext;
				const show = ctx && contexts.includes(ctx);
				(el as HTMLElement).style.display = show ? 'block' : 'none';
			});

			// For thingsboard-pe, hide FAQ when perpetual is active (perpetual has no FAQ)
			if (sectionId === 'thingsboard-pe') {
				const billingToggle = $('[data-billing-toggle="tb-sm-billing"]') as HTMLInputElement | null;
				const isPerpetual = billingToggle?.checked ?? false;
				if (isPerpetual) {
					$$('.pricing-faq-block').forEach((el) => {
						const ctx = el.dataset.faqContext;
						if (ctx === 'thingsboard-pe') {
							(el as HTMLElement).style.display = 'none';
						}
					});
				}
			}

			// For tbmq-pe, show PAYG or Perpetual FAQ based on billing toggle
			if (sectionId === 'tbmq-pe') {
				const billingToggle = $('[data-billing-toggle="tbmq-sm-billing"]') as HTMLInputElement | null;
				const isPerpetual = billingToggle?.checked ?? false;
				const showCtx = isPerpetual ? 'tbmq-pe-perpetual' : 'tbmq-pe-payg';
				$$('.pricing-faq-block').forEach((el) => {
					const ctx = el.dataset.faqContext;
					if (ctx === 'tbmq-pe-payg' || ctx === 'tbmq-pe-perpetual') {
						(el as HTMLElement).style.display = ctx === showCtx ? 'block' : 'none';
					}
				});
			}

			// Hide the entire FAQ wrapper if no FAQ blocks are visible
			const faqWrapper = document.getElementById('faq');
			if (faqWrapper) {
				const anyVisible = !!faqWrapper.querySelector('.pricing-faq-block[style*="display: block"]');
				faqWrapper.style.display = anyVisible ? '' : 'none';
			}
		}

		// ─── Sub-tabs ───
		function activateSubTab(sectionId: string) {
			// Find the parent product content (visible one)
			const productContent = document.querySelector(
				`.pricing-product-content:not([style*="display: none"]):not([style*="display:none"])`
			) as HTMLElement;
			if (!productContent) return;

			// Toggle sub-tab active state
			$$('.sub-tab', productContent).forEach((tab) => {
				const isActive = tab.dataset.subtab === sectionId;
				tab.classList.toggle('active', isActive);
				tab.setAttribute('aria-current', isActive ? 'true' : 'false');
			});

			// Show/hide sections with slide-in animation
			$$('.pricing-section', productContent).forEach((section) => {
				const el = section as HTMLElement;
				const isActive = el.dataset.section === sectionId;
				if (isActive) {
					el.classList.remove('visible');
					el.style.display = '';
					el.classList.add('active');
					if (skipAnimation) {
						el.classList.add('visible');
					} else {
						void el.offsetWidth;
						requestAnimationFrame(() => el.classList.add('visible'));
					}
					// Re-init slider tick marks now that section is visible
					requestAnimationFrame(() => {
						if (typeof initAllSliders === 'function') initAllSliders(el);
					});
				} else {
					el.classList.remove('active', 'visible');
					el.style.display = 'none';
				}
			});

			activeSubTab = sectionId;
			updateFaqVisibility(sectionId);

			// Animate sub-tab highlight
			const subNav = $('.segment-tabs--sub', productContent);
			if (subNav) moveHighlight(subNav);

			updateUrl();
		}

		$$('.sub-tab').forEach((tab) => {
			tab.addEventListener('click', () => {
				activateSubTab(tab.dataset.subtab!);
			});
		});

		// ─── Helper: scroll to FAQ item (handles hidden, category, expand) ───
		function scrollToFaqItem(faqId: string) {
			const targetItem = document.getElementById(faqId);
			if (!targetItem?.classList.contains('faq-item')) return;

			const faqSection = targetItem.closest('.faq-section') as HTMLElement;
			const catContent = targetItem.closest('.faq-category-content') as HTMLElement;
			if (!faqSection || !catContent) return;

			// Activate the right FAQ category tab
			const catId = catContent.dataset.faqCatContent;
			if (catId) {
				$$('.faq-cat-tab', faqSection).forEach((t) =>
					t.classList.toggle('active', (t as HTMLElement).dataset.faqCat === catId)
				);
				$$('.faq-category-content', faqSection).forEach((c) =>
					c.classList.toggle('active', (c as HTMLElement).dataset.faqCatContent === catId)
				);
			}

			// Reveal if hidden behind "Show more"
			if (targetItem.classList.contains('faq-item--hidden')) {
				$$('.faq-item--hidden', catContent).forEach((el) =>
					el.classList.remove('faq-item--hidden')
				);
				const loadMoreBtn = catContent.querySelector('.faq-load-more');
				if (loadMoreBtn) loadMoreBtn.classList.add('faq-load-more--used');
			}

			// Expand and scroll
			targetItem.classList.add('expanded');
			const questionBtn = targetItem.querySelector('.faq-question');
			if (questionBtn) questionBtn.setAttribute('aria-expanded', 'true');
			setTimeout(() => targetItem.scrollIntoView({ behavior: 'smooth', block: 'center' }), 100);
		}

		// ─── Tooltip info icon click → scroll to FAQ ───
		$$('.sub-tab-info').forEach((info) => {
			info.addEventListener('click', (e) => {
				e.stopPropagation();
				const faqId = (info as HTMLElement).dataset.faqId;
				if (faqId) scrollToFaqItem(faqId);
			});
		});

		// ─── Shared tooltip system: JS-only visibility ───
		let activePricingTip: { trigger: Element; tooltip: HTMLElement } | null = null;
		let pricingTipShowTimer: ReturnType<typeof setTimeout> | null = null;
		let pricingTipHideTimer: ReturnType<typeof setTimeout> | null = null;

		function forceHidePricingTip() {
			if (pricingTipShowTimer) { clearTimeout(pricingTipShowTimer); pricingTipShowTimer = null; }
			if (pricingTipHideTimer) { clearTimeout(pricingTipHideTimer); pricingTipHideTimer = null; }
			if (activePricingTip) {
				activePricingTip.tooltip.classList.remove('pricing-tooltip--visible', 'pricing-tooltip--interactive');
				activePricingTip.tooltip.style.left = '-9999px';
				activePricingTip = null;
			}
		}

		function showTooltip(trigger: Element, tooltip: HTMLElement) {
			if (pricingTipHideTimer) { clearTimeout(pricingTipHideTimer); pricingTipHideTimer = null; }
			if (activePricingTip && activePricingTip.tooltip !== tooltip) {
				forceHidePricingTip();
			}
			if (pricingTipShowTimer) clearTimeout(pricingTipShowTimer);

			const rect = trigger.getBoundingClientRect();
			tooltip.style.left = `${rect.right + 4}px`;
			tooltip.style.top = `${rect.top + rect.height / 2}px`;
			tooltip.style.transform = 'translateY(-50%)';
			activePricingTip = { trigger, tooltip };

			pricingTipShowTimer = setTimeout(() => {
				tooltip.classList.add('pricing-tooltip--visible');
				if (tooltip.querySelector('a, [class*="readmore"]')) {
					tooltip.classList.add('pricing-tooltip--interactive');
				}
			}, 150);
		}

		function scheduleHidePricingTip() {
			if (pricingTipShowTimer) { clearTimeout(pricingTipShowTimer); pricingTipShowTimer = null; }
			if (!activePricingTip) return;
			const isInteractive = activePricingTip.tooltip.classList.contains('pricing-tooltip--interactive');
			if (isInteractive) {
				pricingTipHideTimer = setTimeout(() => forceHidePricingTip(), 300);
			} else {
				forceHidePricingTip();
			}
		}

		// Bind triggers
		function bindPricingTooltip(trigger: Element, tooltip: HTMLElement) {
			trigger.addEventListener('mouseenter', () => showTooltip(trigger, tooltip));
			trigger.addEventListener('mouseleave', () => {
				// Only hide if this trigger is still the active one
				if (activePricingTip && activePricingTip.trigger !== trigger) return;
				scheduleHidePricingTip();
			});

			// When mouse enters the tooltip body, cancel hide
			tooltip.addEventListener('mouseenter', () => {
				if (pricingTipHideTimer) { clearTimeout(pricingTipHideTimer); pricingTipHideTimer = null; }
			});
			// When mouse leaves the tooltip body, hide
			tooltip.addEventListener('mouseleave', () => {
				forceHidePricingTip();
			});
		}

		$$('.sub-tab-info').forEach((info) => {
			const tooltip = info.querySelector('.sub-tab-tooltip') as HTMLElement | null;
			if (!tooltip) return;
			bindPricingTooltip(info, tooltip);
		});

		// ─── Plan feature tooltip positioning ───
		$$('.plan-feature-info').forEach((info) => {
			const tooltip = info.querySelector('.plan-feature-tooltip') as HTMLElement | null;
			if (!tooltip) return;
			bindPricingTooltip(info, tooltip);
		});

		// ─── Plan feature tooltip click → scroll to FAQ ───
		$$('.plan-feature-info').forEach((info) => {
			info.addEventListener('click', (e) => {
				e.stopPropagation();
				const faqId = (info as HTMLElement).dataset.faqId;
				if (faqId) scrollToFaqItem(faqId);
			});
		});

		// ─── Addon tooltip positioning (fixed, escapes stacking contexts) ───
		$$('.addon-tooltip-trigger').forEach((trigger) => {
			const tooltip = trigger.querySelector('.addon-tooltip') as HTMLElement | null;
			if (!tooltip) return;
			bindPricingTooltip(trigger, tooltip);
		});

		// ─── Comparison table tooltip positioning + click → scroll to FAQ ───
		$$('.comparison-tooltip-trigger').forEach((trigger) => {
			const tooltip = trigger.querySelector('.comparison-tooltip') as HTMLElement | null;
			if (tooltip) {
				bindPricingTooltip(trigger, tooltip);
			}

			trigger.addEventListener('click', () => {
				const faqId = (trigger as HTMLElement).dataset.faqId;
				if (faqId) scrollToFaqItem(faqId);
			});
		});

		// ─── Addon tooltip click → scroll to FAQ ───
		$$('.addon-tooltip-trigger').forEach((trigger) => {
			trigger.addEventListener('click', (e) => {
				e.stopPropagation();
				const faqId = (trigger as HTMLElement).dataset.faqId;
				if (faqId) scrollToFaqItem(faqId);
			});
		});

		// ─── Upsell card switch ───
		$$('.upsell-card-btn').forEach((btn) => {
			btn.addEventListener('click', () => {
				const target = btn.dataset.switchTo;
				if (target === 'contact') {
					window.open('/contact-us/', '_blank');
				} else if (target) {
					activateSubTab(target);
				}
			});
		});

		// ─── Region toggle ───
		const regionCheckbox = $('#region-select') as HTMLInputElement | null;
		if (regionCheckbox) {
			function setRegion(isEu: boolean) {
				$$('[data-region-content]').forEach((el) => {
					(el as HTMLElement).style.display =
						el.dataset.regionContent === (isEu ? 'eu' : 'na') ? '' : 'none';
				});
				$$('.region-toggle-label').forEach((lbl) => {
					lbl.classList.toggle('active', lbl.dataset.region === (isEu ? 'eu' : 'na'));
				});

				// Persist in cookie
				try {
					document.cookie = `cloudServer=${isEu ? 'eu' : 'na'};path=/;max-age=31536000`;
				} catch {}
			}

			regionCheckbox.addEventListener('change', () => {
				setRegion(regionCheckbox.checked);
			});

			$$('.region-toggle-label').forEach((lbl) => {
				lbl.addEventListener('click', () => {
					const isEu = lbl.dataset.region === 'eu';
					regionCheckbox.checked = isEu;
					setRegion(isEu);
				});
			});

			// Restore from cookie (supports both new "eu"/"na" and old "/docs/paas/eu/" format)
			const cookieMatch = document.cookie.match(/cloudServer=([^;]+)/);
			if (cookieMatch?.[1] === 'eu' || cookieMatch?.[1]?.includes('/eu')) {
				regionCheckbox.checked = true;
				setRegion(true);
			}
		}

		// ─── Billing toggles ───
		$$('[data-billing-toggle]').forEach((input) => {
			const toggleId = (input as HTMLInputElement).dataset.billingToggle!;
			const checkbox = input as HTMLInputElement;

			function setBilling(isRight: boolean) {
				const group = `[data-billing-group="${toggleId}"]`;
				$$(group).forEach((el) => {
					(el as HTMLElement).style.display =
						el.dataset.billingContent === (isRight ? 'perpetual' : 'payg') ? '' : 'none';
				});
				const toggle = checkbox.closest('.billing-toggle');
				if (toggle) {
					$$('.billing-toggle-label', toggle).forEach((lbl, i) => {
						lbl.classList.toggle('active', isRight ? i === 1 : i === 0);
					});
				}
				// Update subtitle text based on billing mode
				const subtitle = document.querySelector(`[data-billing-subtitle="${toggleId}"]`) as HTMLElement | null;
				if (subtitle) {
					subtitle.textContent = isRight ? (subtitle.dataset.perpetualText || '') : (subtitle.dataset.paygText || '');
				}
			}

			checkbox.addEventListener('change', () => {
				setBilling(checkbox.checked);
				if (activeSubTab) updateFaqVisibility(activeSubTab);
				updateUrl();
				// Re-init slider ticks in newly visible content
				requestAnimationFrame(() => {
					if (typeof initAllSliders === 'function') {
						$$(`[data-billing-group="${toggleId}"]`).forEach((el) => {
							if ((el as HTMLElement).style.display !== 'none') initAllSliders(el as HTMLElement);
						});
					}
				});
			});

			// Label click
			const toggle = checkbox.closest('.billing-toggle');
			if (toggle) {
				$$('.billing-toggle-label', toggle).forEach((lbl, i) => {
					lbl.addEventListener('click', () => {
						checkbox.checked = i === 1;
						setBilling(i === 1);
						if (activeSubTab) updateFaqVisibility(activeSubTab);
						updateUrl();
					});
				});
			}
		});

		// ─── getLicense — plan card CTA clicks for self-managed plans ───
		function getLicense(productId: string, planId: string) {
			let url = 'https://license.thingsboard.io/signup?createSubscription=true';
			url += '&productId=' + productId;
			url += '&planId=' + planId;
			// Append UTM params from localStorage
			const utmRaw = localStorage.getItem('utm');
			if (utmRaw) {
				try {
					const utm = JSON.parse(utmRaw);
					Object.keys(utm).forEach((key) => {
						url += '&' + key + '=' + encodeURIComponent(utm[key]);
					});
				} catch (e) {}
			}
			const fpr = localStorage.getItem('fpr');
			if (fpr) url += '&fpr=' + encodeURIComponent(fpr);
			window.open(url, '_blank');
		}

		// Intercept plan card CTA clicks that have productId/planId
		$$('.plan-card-cta[data-product-id][data-plan-id]').forEach((btn) => {
			btn.addEventListener('click', (e) => {
				e.preventDefault();
				const productId = (btn as HTMLElement).dataset.productId!;
				const planId = (btn as HTMLElement).dataset.planId!;
				getLicense(productId, planId);
			});
		});

		// ─── Top-ups accordion ───
		$$('.topup-header').forEach((header) => {
			header.addEventListener('click', () => {
				const item = header.closest('.topup-item');
				if (item) {
					item.classList.toggle('expanded');
					header.setAttribute('aria-expanded', String(item.classList.contains('expanded')));
				}
			});
		});

		// ─── FAQ accordion (independent — multiple can be open) ───
		$$('.faq-question').forEach((btn) => {
			btn.addEventListener('click', () => {
				const item = btn.closest('.faq-item');
				if (!item) return;
				item.classList.toggle('expanded');
				btn.setAttribute('aria-expanded', String(item.classList.contains('expanded')));
			});
		});

		// ─── FAQ "Show more" ───
		$$('.faq-load-more').forEach((btn) => {
			btn.addEventListener('click', () => {
				const content = btn.closest('.faq-category-content');
				if (!content) return;
				$$('.faq-item--hidden', content).forEach((el) =>
					el.classList.remove('faq-item--hidden')
				);
				btn.classList.add('faq-load-more--used');
			});
		});

		// ─── FAQ category tabs ───
		$$('.faq-cat-tab').forEach((tab) => {
			tab.addEventListener('click', () => {
				const section = tab.closest('.faq-section');
				if (!section) return;
				const catId = (tab as HTMLElement).dataset.faqCat;
				$$('.faq-cat-tab', section).forEach((t) => {
					const isActive = (t as HTMLElement).dataset.faqCat === catId;
					t.classList.toggle('active', isActive);
					t.setAttribute('aria-current', isActive ? 'true' : 'false');
				});
				$$('.faq-category-content', section).forEach((c) =>
					c.classList.toggle(
						'active',
						(c as HTMLElement).dataset.faqCatContent === catId
					)
				);
			});
		});

		// ─── FAQ copy link ───
		$$('.faq-copy-link').forEach((btn) => {
			btn.addEventListener('click', (e) => {
				e.stopPropagation();
				e.preventDefault();
				const faqId = (btn as HTMLElement).dataset.faqId;
				if (!faqId?.trim()) return;
				const url = new URL(window.location.href);
				url.hash = faqId;
				navigator.clipboard.writeText(url.toString()).then(() => {
					btn.classList.add('copied');
					setTimeout(() => btn.classList.remove('copied'), 2000);
				});
			});
		});

		// ─── FAQ category from URL ───
		const faqSectionParam = params.get('faqSection');
		if (faqSectionParam) {
			// Activate the specified FAQ category tab in the visible FAQ section
			$$('.faq-section').forEach((section) => {
				if ((section as HTMLElement).style.display !== 'none') {
					const tab = section.querySelector(`.faq-cat-tab[data-faq-cat="${faqSectionParam}"]`);
					if (tab) {
						(tab as HTMLElement).click();
					}
				}
			});
		}

		// ─── FAQ deep-link on load ───
		const hash = window.location.hash.slice(1);
		if (hash) {
			const targetItem = document.getElementById(hash);
			if (targetItem?.classList.contains('faq-item')) {
				// Find which FAQ section this belongs to and activate the right product/sub-tab
				const faqBlock = targetItem.closest('.pricing-faq-block') as HTMLElement;
				if (faqBlock) {
					const ctx = faqBlock.dataset.faqContext;
					if (ctx) {
						for (const [tabId, contexts] of Object.entries(faqContextMap)) {
							if (contexts.includes(ctx)) {
								if (tabId.startsWith('tbmq')) {
									activateProductTab('tbmq');
								} else {
									activateProductTab('thingsboard');
								}
								activateSubTab(tabId);
								break;
							}
						}
					}
				}
				// scrollToFaqItem handles category tab, hidden reveal, expand, and scroll
				scrollToFaqItem(hash);
			}
		}

		// ─── URL update ───
		function updateUrl() {
			const p = new URLSearchParams();
			if (activeProduct === 'tbmq') {
				p.set('section', 'tbmq-options');
			} else {
				p.set('section', 'thingsboard-pe-options');
			}
			if (activeSubTab) {
				p.set('product', activeSubTab);
			}
			const newUrl = `${window.location.pathname}?${p.toString()}`;
			history.replaceState(null, '', newUrl);
		}

		// ─── Initialize from URL ───
		activateProductTab(activeProduct);
		if (activeSubTab) {
			activateSubTab(activeSubTab);
		} else {
			// Activate default sub-tab
			const defaultTab = $(
				`.pricing-product-content:not([style*="display: none"]):not([style*="display:none"]) .sub-tab.active`
			);
			if (defaultTab) {
				activateSubTab(defaultTab.dataset.subtab!);
			}
		}

		// Set billing toggle from URL
		if (activeBilling === 'perpetual') {
			$$('[data-billing-toggle]').forEach((input) => {
				const checkbox = input as HTMLInputElement;
				checkbox.checked = true;
				checkbox.dispatchEvent(new Event('change'));
			});
		}

		// Handle calculator param — open the calculator for the active sub-tab
		if (params.has('calculator')) {
			const calcMap: Record<string, string> = {
				'thingsboard-cloud': 'openTbPaygCalc',
				'thingsboard-private-cloud': 'openTbPcCalc',
				'thingsboard-pe': 'openTbPaygCalc',
			};
			const tab = activeSubTab || 'thingsboard-cloud';
			const fn = calcMap[tab];
			if (fn) {
				setTimeout(() => (window as any)[fn]?.(), 300);
			}
		}

		// Position segment highlights on init and resize
		initAllHighlights();
		window.addEventListener('resize', () => initAllHighlights());

		// Enable animations after initial render
		skipAnimation = false;
	}

	initPricing();
	document.addEventListener('astro:page-load', initPricing);
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

