		--color-pricing-shadow: 0 26px 40px 0 rgba(42, 125, 236, 0.08);
		--color-pricing-bg-light: #f4f8fe;
	}

	[data-theme='dark'] {
		--color-pricing-border: rgba(42, 125, 236, 0.24);
		--color-pricing-shadow: 0 26px 40px 0 rgba(0, 0, 0, 0.25);
		--color-pricing-bg-light: rgba(42, 125, 236, 0.06);
	}

	// Dark mode: tell Safari to use dark native controls (select dropdowns, etc.)
	#pricing[data-theme='dark'] {
		color-scheme: dark;
	}

	// Make sections transparent so wave background shows through
	#pricing section {
		background-color: transparent;
	}

	// Light mode: body transparent too (white canvas is fine behind waves)
	#pricing:not([data-theme='dark']) body {
		background-color: transparent;
	}

	.pricing-page {
		max-width: 1152px;
		margin: 0 auto;
		padding: calc(#{$header-height} + #{$spacing-8}) $spacing-5 $spacing-20;

		// Remove browser tap highlight from all interactive elements
		button, a, input, select, label, summary, [role='button'] {
			-webkit-tap-highlight-color: transparent;
			outline: none;
		}
	}

	.pricing-section {
		display: none;
		opacity: 0;
		transition: opacity 0.35s ease;

		&.active {
			display: block;
		}

		&.visible {
			opacity: 1;
		}
	}

	.pricing-product-content {
		&.fade-in {
			animation: pricing-fade-in 0.3s ease forwards;
		}
	}

	@keyframes pricing-fade-in {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	.pricing-section-header-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: $spacing-5;
		margin-bottom: $spacing-8;

		.pricing-section-header {
			margin-bottom: 0;
		}

		// Toggles inside header row lose their own margins
		.region-toggle,
		.billing-toggle {
			margin-bottom: 0;
			flex-shrink: 0;
		}

		@include media-down(md) {
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: $spacing-3;
		}
	}

	.pricing-section-header {
		text-align: left;
		margin-bottom: $spacing-8;

		@include media-down(md) {
			text-align: center;
		}

		h2 {
			@include subsection-title;
			color: var(--color-text);
			margin: 0 0 $spacing-2;
		}

		p {
			@include text-m;
			color: var(--color-text-secondary);
			margin: 0;
		}
	}

	.perpetual-bottom-cta {
		text-align: center;
		padding: $spacing-12 0 $spacing-4;

		h3 {
			@include section-title;
			color: var(--color-text);
			margin: 0 0 $spacing-6;
		}
	}

	.pricing-faq {
		margin-top: $spacing-16;
		padding-top: $spacing-12;

		// Hide all FAQ blocks by default; JS shows the active one
		.pricing-faq-block {
			display: none;
		}
	}

	.faq-main-title {
		@include section-title;
		color: var(--color-text);
		text-align: left;
		margin: 0 0 $spacing-8;
	}

	.calc-open-row {
		display: flex;
		justify-content: center;
		margin-bottom: $spacing-8;
	}

	.calc-open-btn {
		padding: $spacing-3 $spacing-6;
		font-size: $font-size-sm;
		font-weight: $font-weight-medium;
		color: $color-primary;
		background: transparent;
		border: 1px solid $color-primary;
		border-radius: $radius-sm;
		cursor: pointer;
		transition: background-color $transition-fast, color $transition-fast;

		&:hover {
			background: $color-primary;
			color: #fff;
		}
	}
</style>
