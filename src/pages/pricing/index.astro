---
import BaseLayout from '@layouts/BaseLayout.astro';
import PricingHero from '../../components/Pricing/PricingHero.astro';
import ProductTabs from '../../components/Pricing/ProductTabs.astro';
import ProductSubTabs from '../../components/Pricing/ProductSubTabs.astro';
import PlanCardGrid from '../../components/Pricing/PlanCardGrid.astro';
import CommunityEditionCard from '../../components/Pricing/CommunityEditionCard.astro';
import RegionToggle from '../../components/Pricing/RegionToggle.astro';
import BillingToggle from '../../components/Pricing/BillingToggle.astro';
import UpsellCard from '../../components/Pricing/UpsellCard.astro';
import AddOnsSection from '../../components/Pricing/AddOnsSection.astro';
import TopUpsSection from '../../components/Pricing/TopUpsSection.astro';
import PerpetualBenefits from '../../components/Pricing/PerpetualBenefits.astro';
import TbPaygCalculator from '../../components/Pricing/TbPaygCalculator.astro';
import TbPrivateCloudCalculator from '../../components/Pricing/TbPrivateCloudCalculator.astro';
import TbmqPaygCalculator from '../../components/Pricing/TbmqPaygCalculator.astro';
import TbmqPerpetualCalculator from '../../components/Pricing/TbmqPerpetualCalculator.astro';
import TbmqPrivateCloudCalculator from '../../components/Pricing/TbmqPrivateCloudCalculator.astro';
import PricingBackground from '../../components/Pricing/PricingBackground.astro';
import NButton from '../../components/Landing/NButton.astro';
import ComparisonTable from '../../components/Pricing/ComparisonTable.astro';

import { tbCeData } from '@data/pricing/tb-ce.ts';
import { tbCloudData, tbCloudTopUps } from '@data/pricing/tb-cloud.ts';
import { tbPrivateCloudData, tbPrivateCloudAddOns } from '@data/pricing/tb-private-cloud.ts';
import {
	tbSelfManagedData,
	tbSelfManagedAddOns,
	tbPerpetualHero,
	tbPerpetualAddOns,
} from '@data/pricing/tb-self-managed.ts';
import { tbmqCeData } from '@data/pricing/tbmq-ce.ts';
import { tbmqSelfManagedData } from '@data/pricing/tbmq-self-managed.ts';
import { tbmqPrivateCloudData } from '@data/pricing/tbmq-private-cloud.ts';
import { cloudAddOns } from '@data/pricing/add-ons.ts';
import { pcFeatureHeaders, pcFeatureRows } from '@data/pricing/tb-private-cloud-features.ts';
import type { PlanCard as PlanCardType } from '@data/pricing/types';
import FaqSection from '../../components/Pricing/FaqSection.astro';
import { pricingFaqData } from '@data/pricing/faq';

import ceIcon from '../../assets/pricing/community-edition-icon.svg?raw';
import cloudIcon from '../../assets/pricing/cloud-icon.svg?raw';
import pcIcon from '../../assets/pricing/private-cloud-icon.svg?raw';
import smIcon from '../../assets/pricing/self-icon.svg?raw';

// Build a faqId → answer lookup from all FAQ data (strip HTML, truncate for tooltip)
const faqAnswerMap = new Map<string, string>();
for (const section of pricingFaqData) {
	for (const cat of section.categories) {
		for (const item of cat.items) {
			const plain = item.answer
				.replace(/<[^>]+>/g, '')
				.trim()
				.replace(/\s+/g, ' ');
			const maxChars = 120;
			const truncated = plain.length > maxChars ? plain.slice(0, maxChars).replace(/\s+\S*$/, '') + '\u2026' : plain;
			faqAnswerMap.set(item.id, truncated);
		}
	}
}

// Auto-fill faqTooltip from FAQ answer when not explicitly provided
function enrichTabs(
	tabs: {
		id: string;
		label: string;
		icon?: string;
		gtmId?: string;
		faqId?: string;
		faqTooltip?: string;
		default?: boolean;
	}[]
) {
	return tabs.map((tab) => {
		const autoFill = !tab.faqTooltip && tab.faqId ? faqAnswerMap.get(tab.faqId) : undefined;
		return {
			...tab,
			faqTooltip: tab.faqTooltip || autoFill || undefined,
			autoTooltip: !!autoFill,
		};
	});
}

// Auto-fill faqTooltip on plan features that have faqId but no explicit tooltip
function enrichPlans(plans: PlanCardType[]): PlanCardType[] {
	return plans.map((plan) => ({
		...plan,
		features: plan.features.map((f) => ({
			...f,
			faqTooltip: f.faqTooltip || (f.faqId && faqAnswerMap.get(f.faqId)) || undefined,
		})),
	}));
}

// Auto-fill faqTooltip on comparison rows that have faqId but no explicit tooltip
function enrichRows(
	rows: import('../../data/pricing/types').ComparisonRow[]
): import('../../data/pricing/types').ComparisonRow[] {
	return rows.map((row) => {
		const autoFill = !row.faqTooltip && row.faqId ? faqAnswerMap.get(row.faqId) : undefined;
		return {
			...row,
			faqTooltip: row.faqTooltip || autoFill || undefined,
			autoTooltip: !!autoFill,
		};
	});
}

const tbSubTabs = enrichTabs([
	{
		id: 'thingsboard-ce',
		label: 'Community Edition',
		icon: ceIcon,
		gtmId: 'Pricing_CE',
		faqId: 'what-is-tb-ce',
		faqTooltip:
			'Community Edition is the free, open-source starting point\u2014perfect for fast pilots and proof-of-value. Start small, validate quickly, and scale up when you\u2019re ready.',
	},
	{
		id: 'thingsboard-cloud',
		label: 'Public Cloud',
		icon: cloudIcon,
		default: true,
		gtmId: 'Pricing_PE_Cloud',
		faqId: 'tb-cloud-definition',
		faqTooltip:
			'Public Cloud is fully managed ThingsBoard\u2014built for speed. We handle infrastructure, upgrades, and reliability so your team can focus on shipping IoT solutions faster.',
	},
	{
		id: 'thingsboard-private-cloud',
		label: 'Private Cloud',
		icon: pcIcon,
		gtmId: 'Pricing_PE_PrivateCloud',
		faqId: 'tb-private-cloud-what-does-thingsboard-private-cloud-stand-for',
		faqTooltip:
			'Private Cloud is a dedicated, isolated ThingsBoard Professional Edition cluster run by us for you. You get enterprise-grade control and security\u2014without the ops overhead.',
	},
	{
		id: 'thingsboard-pe',
		label: 'Self-managed',
		icon: smIcon,
		gtmId: 'Pricing_PE_SM',
		faqId: 'pe-pay-as-you-go-self-managed-definition',
		faqTooltip:
			'Self-managed lets you run ThingsBoard on your own infrastructure (on-prem or cloud). Ideal when you need full environment control and prefer to manage operations in-house.',
	},
]);

const tbmqSubTabs = enrichTabs([
	{
		id: 'tbmq-ce',
		label: 'Community Edition',
		icon: ceIcon,
		gtmId: 'Pricing_TBMQ_CE',
		faqId: 'what-is-tbmq-ce',
	},
	{
		id: 'tbmq-pe',
		label: 'Self-managed',
		icon: smIcon,
		default: true,
		gtmId: 'Pricing_TBMQ_PE',
		faqId: 'tbmq-payg-sm-definition',
	},
	{
		id: 'tbmq-private-cloud',
		label: 'Private Cloud',
		icon: pcIcon,
		gtmId: 'Pricing_TBMQ_PrivateCloud',
		faqId: 'tbmq-stand-for',
	},
]);
---

<BaseLayout
	headerVariant="transparent-hover"
	showSearch={false}
	title="Pricing"
	description="ThingsBoard IoT Platform pricing — compare Free, Cloud, Private Cloud, and Self-Managed plans with transparent subscription and perpetual licensing."
>
	<PricingBackground />
	<main class="pricing-page">
		<PricingHero />
		<ProductTabs />

		<!-- ═══ ThingsBoard product sections ═══ -->
		<div class="pricing-product-content" data-product-content="thingsboard">
			<ProductSubTabs product="thingsboard" tabs={tbSubTabs} />

			<!-- TB CE -->
			<section class="pricing-section" data-section="thingsboard-ce">
				<CommunityEditionCard data={tbCeData} />
			</section>

			<!-- TB Public Cloud -->
			<section class="pricing-section active" data-section="thingsboard-cloud">
				<div class="pricing-section-header-row">
					<div class="pricing-section-header">
						<h2>{tbCloudData.na.sectionTitle}</h2>
						<p>{tbCloudData.na.sectionSubtitle}</p>
					</div>
					<RegionToggle />
				</div>
				<div data-region-content="na">
					<PlanCardGrid plans={enrichPlans(tbCloudData.na.plans)}>
						<UpsellCard
							heading="Require dedicated infrastructure for unique enterprise needs?"
							ctaText="See Private Cloud Options"
							targetSection="thingsboard-private-cloud"
						/>
					</PlanCardGrid>
					<AddOnsSection addOns={cloudAddOns.na} />
					<TopUpsSection topUps={tbCloudTopUps.na} />
				</div>
				<div data-region-content="eu" style="display:none;">
					<PlanCardGrid plans={enrichPlans(tbCloudData.eu.plans)}>
						<UpsellCard
							heading="Require dedicated infrastructure for unique enterprise needs?"
							ctaText="See Private Cloud Options"
							targetSection="thingsboard-private-cloud"
						/>
					</PlanCardGrid>
					<AddOnsSection addOns={cloudAddOns.eu} />
					<TopUpsSection topUps={tbCloudTopUps.eu} />
				</div>
			</section>

			<!-- TB Private Cloud -->
			<section class="pricing-section" data-section="thingsboard-private-cloud">
				<div class="pricing-section-header-row">
					<div class="pricing-section-header">
						<h2>{tbPrivateCloudData.sectionTitle}</h2>
						<p>{tbPrivateCloudData.sectionSubtitle}</p>
					</div>
					<div class="pc-billing-toggle-wrap">
						<BillingToggle
							leftLabel="Monthly"
							rightLabel="Annual"
							leftValue="monthly"
							rightValue="annual"
							id="tb-pc-billing"
						/>
						<p class="pc-billing-hint">Save 10% on annual plans</p>
					</div>
				</div>
				<PlanCardGrid plans={enrichPlans(tbPrivateCloudData.plans)}>
					<UpsellCard
						heading="Not sure which plan fits?"
						subtitle="Use our calculator to estimate the best plan for your needs."
						ctaText="Estimate your cost"
						onclick="window.openTbPcCalc?.()"
					/>
				</PlanCardGrid>
				<AddOnsSection addOns={tbPrivateCloudAddOns} />
				<ComparisonTable headers={pcFeatureHeaders} rows={enrichRows(pcFeatureRows)} />
			</section>

			<!-- TB Self-managed -->
			<section class="pricing-section" data-section="thingsboard-pe">
				<div class="pricing-section-header-row">
					<div class="pricing-section-header">
						<h2
							data-billing-heading="tb-sm-billing"
							data-payg-text="Subscription plans"
							data-perpetual-text="Perpetual license"
						>
							Subscription plans
						</h2>
						<p
							data-billing-subtitle="tb-sm-billing"
							data-payg-text="All subscription plans include unlimited customers, dashboards, integrations, api calls, data points & messages."
							data-perpetual-text="One-time payment, run forever on your infrastructure."
						>
							All subscription plans include unlimited customers, dashboards, integrations, api calls, data points &
							messages.
						</p>
					</div>
					<BillingToggle
						leftLabel="Pay-as-you-go"
						rightLabel="Perpetual"
						leftValue="payg"
						rightValue="perpetual"
						id="tb-sm-billing"
						leftGtmId="Pricing_PE_SM_PayAsYouGo"
						rightGtmId="Pricing_PE_SM_Perpetual"
						leftFaqId="pe-pay-as-you-go-self-managed-subscription-plans"
						leftFaqTooltip="Pay-as-you-go is a flexible monthly subscription. Scale up as you grow and pay for the capacity you need (tiers based on devices/assets)."
						rightFaqId="pe-pay-as-you-go-self-managed-purchase-perpetual-license"
						rightFaqTooltip="Perpetual is a one-time license that turns your IoT platform into a long-term asset — predictable costs, full control of your roadmap, and a strong foundation for enterprise scale."
					/>
				</div>
				<div data-billing-content="payg" data-billing-group="tb-sm-billing">
					<PlanCardGrid plans={enrichPlans(tbSelfManagedData.payg.plans)}>
						<UpsellCard
							heading="Not sure which plan fits?"
							subtitle="Use our calculator to estimate the best plan for your needs."
							ctaText="Estimate your cost"
							onclick="window.openTbPaygCalc?.()"
						/>
					</PlanCardGrid>
					<AddOnsSection addOns={tbSelfManagedAddOns} />
				</div>
				<div data-billing-content="perpetual" data-billing-group="tb-sm-billing" style="display:none;">
					<CommunityEditionCard data={tbPerpetualHero} />
					{
						tbSelfManagedData.perpetual.benefits && (
							<PerpetualBenefits benefits={tbSelfManagedData.perpetual.benefits} />
						)
					}
					<AddOnsSection addOns={tbPerpetualAddOns} />
					<div class="perpetual-bottom-cta">
						<h3>Let us help you identify the best option for your business</h3>
						<NButton href="/contact-us/?subject=ThingsBoard%20Products" variant="filled" size="md">Contact Us</NButton>
					</div>
				</div>
			</section>
		</div>

		<!-- ═══ TBMQ product sections ═══ -->
		<div class="pricing-product-content" data-product-content="tbmq" style="display:none;">
			<ProductSubTabs product="tbmq" tabs={tbmqSubTabs} />

			<!-- TBMQ CE -->
			<section class="pricing-section" data-section="tbmq-ce">
				<CommunityEditionCard data={tbmqCeData} />
			</section>

			<!-- TBMQ Self-managed -->
			<section class="pricing-section active" data-section="tbmq-pe">
				<div class="pricing-section-header-row">
					<div class="pricing-section-header">
						<h2>Your self-managed MQTT broker instance</h2>
						<p
							data-billing-subtitle="tbmq-sm-billing"
							data-payg-text="The TBMQ Professional Edition's highly flexible, consumption-based licensing model"
							data-perpetual-text="The TBMQ Professional Edition's long-term asset ownership model"
						>
							The TBMQ Professional Edition's highly flexible, consumption-based licensing model
						</p>
					</div>
					<BillingToggle
						leftLabel="Pay-as-you-go"
						rightLabel="Perpetual"
						leftValue="payg"
						rightValue="perpetual"
						id="tbmq-sm-billing"
						leftGtmId="Pricing_TBMQ_PE_PAYG"
						rightGtmId="Pricing_TBMQ_PE_Perpetual"
						leftFaqId="tbmq-payg-plans"
						leftFaqTooltip={faqAnswerMap.get('tbmq-payg-plans')}
						leftAutoTooltip={true}
						rightFaqId="tbmq-perp-def"
						rightFaqTooltip={faqAnswerMap.get('tbmq-perp-def')}
						rightAutoTooltip={true}
					/>
				</div>
				<div data-billing-content="payg" data-billing-group="tbmq-sm-billing">
					<TbmqPaygCalculator />
				</div>
				<div data-billing-content="perpetual" data-billing-group="tbmq-sm-billing" style="display:none;">
					<TbmqPerpetualCalculator />
					{
						tbmqSelfManagedData.perpetual.benefits && (
							<PerpetualBenefits benefits={tbmqSelfManagedData.perpetual.benefits} />
						)
					}
					<div class="perpetual-bottom-cta">
						<h3>Let us help you identify the best option for your business</h3>
						<NButton href="/contact-us/?subject=ThingsBoard%20Products" variant="filled" size="md">Contact Us</NButton>
					</div>
				</div>
			</section>

			<!-- TBMQ Private Cloud -->
			<section class="pricing-section" data-section="tbmq-private-cloud">
				<div class="pricing-section-header">
					<h2>{tbmqPrivateCloudData.sectionTitle}</h2>
					<p>{tbmqPrivateCloudData.sectionSubtitle}</p>
				</div>
				<TbmqPrivateCloudCalculator />
				<div class="tbmq-pc-subscription-cta">
					<h2>Want to know more about the subscription?</h2>
					<NButton href="/docs/mqtt-broker/pe/subscription/" variant="outlined" size="md">See full details</NButton>
				</div>
			</section>
		</div>

		{/* Pre-paint state sync. Runs synchronously during body parsing — after
		    all `.product-tab` / `.sub-tab` / `.pricing-section` /
		    `.pricing-product-content` nodes are in the DOM but before first
		    paint. Resolves URL→state via the shared window.__resolvePricingState()
		    (defined just below) so the correct tabs are highlighted and the
		    correct section is visible from frame 1, even when arriving via a
		    deep-link URL. Without this, visitors using `?product=…` / `?section=…`
		    URLs see the SSR-default state painted briefly before initPricing()
		    swaps it post-parse.

		    initPricing() later calls the same resolver — no-op for state that's
		    already correct. */}
		<script is:inline>
			(function () {
				// Single source of truth for the URL→state mapping. Defined on
				// `window` from this is:inline script — which runs during body
				// parsing, before the deferred initPricing() module — so BOTH this
				// pre-paint block and initPricing() resolve identical state from one
				// pure function (params → { activeProduct, activeSubTab, activeBilling }).
				// The DOM application differs between the two callers and stays
				// separate in each.
				window.__resolvePricingState = function (search) {
					const p = new URLSearchParams(search);
					const sectionParam = p.get('section');
					const productParam = p.get('product');
					const solutionParam = p.get('solution');
					const sectionMap = {
						'thingsboard-pe-options': { product: 'thingsboard', subtab: 'thingsboard-pe' },
						'tbmq-options': { product: 'tbmq' },
					};
					let activeProduct = 'thingsboard';
					let activeSubTab = null;
					let activeBilling = null;
					if (sectionParam && sectionMap[sectionParam]) {
						activeProduct = sectionMap[sectionParam].product;
						if (sectionMap[sectionParam].subtab) activeSubTab = sectionMap[sectionParam].subtab;
					}
					if (productParam && productParam.startsWith('tbmq')) activeProduct = 'tbmq';
					if (productParam) activeSubTab = productParam;
					if (solutionParam) {
						const sol = solutionParam.replace(/^pe-/, '');
						if (sol === 'payg' || sol === 'perpetual') activeBilling = sol;
					}
					return { activeProduct, activeSubTab, activeBilling };
				};

				try {
					const state = window.__resolvePricingState(location.search);
					const activeProduct = state.activeProduct;
					const activeBilling = state.activeBilling;
					let activeSubTab = state.activeSubTab;

					// Mirror initPricing()'s billing-toggle flip so visitors landing on
					// `?solution=pe-perpetual` don't see PAYG plans flash before JS runs.
					if (activeBilling === 'perpetual') {
						document.querySelectorAll('[data-billing-toggle]').forEach(function (input) {
							input.checked = true;
							const toggleId = input.dataset.billingToggle;
							document.querySelectorAll('[data-billing-group="' + toggleId + '"]').forEach(function (el) {
								el.style.display = el.dataset.billingContent === 'perpetual' ? '' : 'none';
							});
							const toggle = input.closest('.billing-toggle');
							if (toggle) {
								toggle.querySelectorAll('.billing-toggle-label').forEach(function (lbl, i) {
									lbl.classList.toggle('active', i === 1);
								});
							}
							const heading = document.querySelector('[data-billing-heading="' + toggleId + '"]');
							if (heading && heading.dataset.perpetualText) heading.textContent = heading.dataset.perpetualText;
							const subtitle = document.querySelector('[data-billing-subtitle="' + toggleId + '"]');
							if (subtitle && subtitle.dataset.perpetualText) subtitle.textContent = subtitle.dataset.perpetualText;
						});
					}

					// Product-tab active class
					document.querySelectorAll('.product-tab').forEach(function (tab) {
						const isActive = tab.dataset.product === activeProduct;
						tab.classList.toggle('active', isActive);
						tab.setAttribute('aria-current', isActive ? 'true' : 'false');
					});

					// Product-content visibility
					document.querySelectorAll('.pricing-product-content').forEach(function (el) {
						el.style.display = el.dataset.productContent === activeProduct ? '' : 'none';
					});

					// Inside the visible product, swap sub-tab + section state
					const visible = document.querySelector('.pricing-product-content[data-product-content="' + activeProduct + '"]');
					if (!visible) return;

					// Default sub-tab = whichever was SSR'd with .active inside the visible product
					if (!activeSubTab) {
						const def = visible.querySelector('.sub-tab.active');
						if (def) activeSubTab = def.dataset.subtab;
					}
					if (!activeSubTab) return;

					visible.querySelectorAll('.sub-tab').forEach(function (tab) {
						const isActive = tab.dataset.subtab === activeSubTab;
						tab.classList.toggle('active', isActive);
						tab.setAttribute('aria-current', isActive ? 'true' : 'false');
					});

					visible.querySelectorAll('.pricing-section').forEach(function (s) {
						const isActive = s.dataset.section === activeSubTab;
						if (isActive) {
							s.classList.add('active', 'visible');
							s.style.display = '';
						} else {
							s.classList.remove('active', 'visible');
							s.style.display = 'none';
						}
					});
				} catch { /* fall back to SSR defaults */ }
			})();
		</script>

		<!-- ═══ FAQ Section ═══ -->
		<div class="pricing-faq" id="faq">
			{
				pricingFaqData.map((faq) => (
					<div class="pricing-faq-block" data-faq-context={faq.contextId}>
						<h2 class="faq-main-title">{faq.title}</h2>
						<FaqSection contextId={faq.contextId} categories={faq.categories} />
					</div>
				))
			}
		</div>
	</main>

	<!-- Calculator modals (rendered outside main flow) -->
	<TbPaygCalculator />
	<TbPrivateCloudCalculator />
</BaseLayout>

<!-- ═══ URL state + tab/toggle logic ═══ -->
<script>
	declare function gtag(...args: any[]): void;
	declare function initAllSliders(root?: HTMLElement | Document): void;

	function initPricing() {
		// ─── Helpers ───
		function $(sel: string, ctx: ParentNode = document): HTMLElement | null {
			return ctx.querySelector(sel);
		}
		function $$(sel: string, ctx: ParentNode = document): HTMLElement[] {
			return Array.from(ctx.querySelectorAll(sel));
		}

		// ─── GTM Analytics ───
		function reportPriceOpen(sectionId: string) {
			if (typeof gtag !== 'undefined' && sectionId) gtag('event', 'PriceOpen', { event_category: sectionId });
		}
		function reportPriceLink(link: string, product: string) {
			if (typeof gtag !== 'undefined' && link)
				gtag('event', 'PriceLink', { event_category: product, event_label: link });
		}

		let skipAnimation = true; // No animation on initial load

		// ─── URL state ───
		// Resolved via the shared window.__resolvePricingState() (defined in the
		// pre-paint is:inline script near the top of <body>) — the single source
		// of truth for the param→state mapping, so deep-link first paint and this
		// post-parse pass can't drift.
		const params = new URLSearchParams(window.location.search);

		// These stay `let`: activateProductTab(), activateSubTab() and the billing
		// toggle reassign them as the user navigates. They're seeded with the
		// SSR-default state so they remain valid even if the resolver is absent.
		let activeProduct = 'thingsboard';
		let activeSubTab: string | null = null;
		let activeBilling: string | null = null;
		// Guard the resolver call: __resolvePricingState is defined by the
		// pre-paint is:inline script, which could fail to run (e.g. a CSP that
		// blocks inline scripts, or a future syntax error in that block). Rather
		// than let an undefined call throw and abort all of initPricing() —
		// killing every tab, toggle, accordion and calculator on the page — we
		// fall back to the SSR defaults above. The only degradation is that a
		// deep-link's tab/section highlighting isn't applied; the page stays
		// fully interactive.
		const resolvePricingState = (window as any).__resolvePricingState;
		if (typeof resolvePricingState === 'function') {
			({ activeProduct, activeSubTab, activeBilling } = resolvePricingState(
				window.location.search,
			));
		}

		// ─── Single delegated click listener on the pricing root ───
		// Replaces 10+ per-element forEach(addEventListener('click', …)) loops.
		// initPricing() runs exactly once per full page load — this project has
		// no ClientRouter / View Transitions, so the document is never reused
		// across navigations. A single plain listener on the persistent
		// `main.pricing-page` root is all that's needed; no AbortController or
		// per-run bookkeeping.
		{
			const pricingRoot = document.querySelector('main.pricing-page');
			pricingRoot?.addEventListener('click', (e) => {
				const t = e.target as HTMLElement;
				if (!t || typeof t.closest !== 'function') return;

				// Tooltip-info icons that double as "scroll to FAQ" buttons.
				// Skip if the click landed on a link inside the tooltip body.
				const faqJump = t.closest<HTMLElement>('.sub-tab-info, .plan-feature-info, .addon-tooltip-trigger, .comparison-tooltip-trigger');
				if (faqJump) {
					if (t.closest('a')) return;
					e.stopPropagation();
					forceHidePricingTip();
					const faqId = faqJump.dataset.faqId;
					if (faqId) scrollToFaqItem(faqId);
					return;
				}

				// Plan-card CTAs that should route through getLicense() instead
				// of following their href.
				const planCta = t.closest<HTMLElement>('.plan-card-cta[data-product-id][data-plan-id]');
				if (planCta) {
					e.preventDefault();
					getLicense(planCta.dataset.productId!, planCta.dataset.planId!);
					return;
				}

				// Upsell card switch.
				const upsell = t.closest<HTMLElement>('.upsell-card-btn');
				if (upsell) {
					const target = upsell.dataset.switchTo;
					if (target === 'contact') window.open('/contact-us/', '_blank');
					else if (target) activateSubTab(target);
					return;
				}

				// Top-ups accordion.
				const topupHeader = t.closest<HTMLElement>('.topup-header');
				if (topupHeader) {
					const item = topupHeader.closest('.topup-item');
					if (item) {
						item.classList.toggle('expanded');
						topupHeader.setAttribute('aria-expanded', String(item.classList.contains('expanded')));
					}
					return;
				}

				// Product-tab click (top-level tabs).
				const productTab = t.closest<HTMLElement>('.product-tab');
				if (productTab) {
					activateProductTab(productTab.dataset.product!);
					return;
				}

				// Sub-tab click.
				const subTab = t.closest<HTMLElement>('.sub-tab');
				if (subTab) {
					activateSubTab(subTab.dataset.subtab!);
					return;
				}

				// Region-toggle label click → flip #region-select, fire change.
				const regionLabel = t.closest<HTMLElement>('.region-toggle-label');
				if (regionLabel) {
					const cb = document.getElementById('region-select') as HTMLInputElement | null;
					if (cb) {
						cb.checked = regionLabel.dataset.region === 'eu';
						cb.dispatchEvent(new Event('change', { bubbles: true }));
					}
					return;
				}

				// Billing-toggle label click → flip the related checkbox, fire change.
				const billingLabel = t.closest<HTMLElement>('.billing-toggle-label');
				if (billingLabel) {
					const toggle = billingLabel.closest('.billing-toggle');
					const cb = toggle?.querySelector<HTMLInputElement>('[data-billing-toggle]');
					if (cb && toggle) {
						const labels = Array.from(toggle.querySelectorAll('.billing-toggle-label'));
						const idx = labels.indexOf(billingLabel);
						cb.checked = idx === 1;
						cb.dispatchEvent(new Event('change', { bubbles: true }));
					}
					return;
				}
			});
		}

		// ─── Product tabs ───
		function activateProductTab(product: string, skipSubTabActivation = false) {
			$$('.product-tab').forEach((tab) => {
				const isActive = tab.dataset.product === product;
				tab.classList.toggle('active', isActive);
				tab.setAttribute('aria-current', isActive ? 'true' : 'false');
			});
			$$('.pricing-product-content').forEach((el) => {
				const pEl = el as HTMLElement;
				const isActive = el.dataset.productContent === product;
				pEl.style.display = isActive ? '' : 'none';
				if (!skipAnimation) {
					pEl.classList.remove('fade-in');
					if (isActive) {
						void pEl.offsetHeight;
						pEl.classList.add('fade-in');
						pEl.addEventListener('animationend', () => pEl.classList.remove('fade-in'), { once: true });
					}
				}
				if (isActive) {
					requestAnimationFrame(() => {
						if (typeof initAllSliders === 'function') initAllSliders(pEl);
					});
				}
			});
			activeProduct = product;
			reportPriceOpen(product);
			document.dispatchEvent(new CustomEvent('pricing:product-activated', { detail: product }));

			// Active tab background is now CSS-only — no JS positioning needed.

			// Re-activate the visible product's active sub-tab section.
			const visibleContent = $(`.pricing-product-content[data-product-content="${product}"]`);
			if (visibleContent) {
				if (!skipSubTabActivation) {
					// Find the active sub-tab and re-activate its section (ensures visible class)
					const activeTab = $('.sub-tab.active', visibleContent);
					if (activeTab) {
						activateSubTab((activeTab as HTMLElement).dataset.subtab!);
					}
				}
			}

			updateUrl();
		}

		// `.product-tab` click is delegated above on `main.pricing-page`.

		// ─── FAQ context mapping ───
		// Maps sub-tab ID to FAQ context ID(s)
		const faqContextMap: Record<string, string[]> = {
			'thingsboard-ce': ['thingsboard-ce'],
			'thingsboard-cloud': ['thingsboard-cloud'],
			'thingsboard-private-cloud': ['thingsboard-private-cloud'],
			'thingsboard-pe': ['thingsboard-pe'],
			'tbmq-ce': ['tbmq-ce'],
			'tbmq-pe': ['tbmq-pe-payg', 'tbmq-pe-perpetual'],
			'tbmq-private-cloud': ['tbmq-private-cloud'],
		};

		function updateFaqVisibility(sectionId: string) {
			const contexts = faqContextMap[sectionId] || [];
			$$('.pricing-faq-block').forEach((el) => {
				const ctx = el.dataset.faqContext;
				const show = ctx && contexts.includes(ctx);
				(el as HTMLElement).style.display = show ? 'block' : 'none';
			});

			// For thingsboard-pe, hide FAQ when perpetual is active (perpetual has no FAQ)
			if (sectionId === 'thingsboard-pe') {
				const billingToggle = $('[data-billing-toggle="tb-sm-billing"]') as HTMLInputElement | null;
				const isPerpetual = billingToggle?.checked ?? false;
				if (isPerpetual) {
					$$('.pricing-faq-block').forEach((el) => {
						const ctx = el.dataset.faqContext;
						if (ctx === 'thingsboard-pe') {
							(el as HTMLElement).style.display = 'none';
						}
					});
				}
			}

			// For tbmq-pe, show PAYG or Perpetual FAQ based on billing toggle
			if (sectionId === 'tbmq-pe') {
				const billingToggle = $('[data-billing-toggle="tbmq-sm-billing"]') as HTMLInputElement | null;
				const isPerpetual = billingToggle?.checked ?? false;
				const showCtx = isPerpetual ? 'tbmq-pe-perpetual' : 'tbmq-pe-payg';
				$$('.pricing-faq-block').forEach((el) => {
					const ctx = el.dataset.faqContext;
					if (ctx === 'tbmq-pe-payg' || ctx === 'tbmq-pe-perpetual') {
						(el as HTMLElement).style.display = ctx === showCtx ? 'block' : 'none';
					}
				});
			}

			// Hide the entire FAQ wrapper if no FAQ blocks are visible
			const faqWrapper = document.getElementById('faq');
			if (faqWrapper) {
				const anyVisible = !!faqWrapper.querySelector('.pricing-faq-block[style*="display: block"]');
				faqWrapper.style.display = anyVisible ? '' : 'none';
			}
		}

		// ─── Sub-tabs ───
		function activateSubTab(sectionId: string) {
			// Find the parent product content (visible one)
			const productContent = document.querySelector(
				`.pricing-product-content:not([style*="display: none"]):not([style*="display:none"])`
			) as HTMLElement;
			if (!productContent) return;

			// Toggle sub-tab active state
			$$('.sub-tab', productContent).forEach((tab) => {
				const isActive = tab.dataset.subtab === sectionId;
				tab.classList.toggle('active', isActive);
				tab.setAttribute('aria-current', isActive ? 'true' : 'false');
			});

			// Show/hide sections with slide-in animation
			$$('.pricing-section', productContent).forEach((section) => {
				const el = section as HTMLElement;
				const isActive = el.dataset.section === sectionId;
				if (isActive) {
					el.classList.remove('visible');
					el.style.display = '';
					el.classList.add('active');
					if (skipAnimation) {
						el.classList.add('visible');
					} else {
						void el.offsetWidth;
						requestAnimationFrame(() => el.classList.add('visible'));
					}
					// Re-init slider tick marks now that section is visible
					requestAnimationFrame(() => {
						if (typeof initAllSliders === 'function') initAllSliders(el);
					});
				} else {
					el.classList.remove('active', 'visible');
					el.style.display = 'none';
				}
			});

			activeSubTab = sectionId;
			reportPriceOpen(sectionId);
			updateFaqVisibility(sectionId);

			updateUrl();
		}

		// `.sub-tab` click is delegated above on `main.pricing-page`.

		// ─── Helper: scroll to FAQ item (handles hidden, category, expand) ───
		function scrollToFaqItem(faqId: string) {
			const targetItem = document.getElementById(faqId);
			if (!targetItem?.classList.contains('faq-item')) return;

			// Activate the sub-tab whose FAQ context contains this item
			const faqBlock = targetItem.closest('.pricing-faq-block') as HTMLElement;
			if (faqBlock) {
				const ctx = faqBlock.dataset.faqContext;
				if (ctx) {
					for (const [tabId, contexts] of Object.entries(faqContextMap)) {
						if (contexts.includes(ctx)) {
							// Activate the right product tab first
							if (tabId.startsWith('tbmq') && activeProduct !== 'tbmq') {
								activateProductTab('tbmq');
							} else if (!tabId.startsWith('tbmq') && activeProduct !== 'thingsboard') {
								activateProductTab('thingsboard');
							}
							activateSubTab(tabId);
							break;
						}
					}
				}
			}

			const faqSection = targetItem.closest('.faq-section') as HTMLElement;
			const catContent = targetItem.closest('.faq-category-content') as HTMLElement;
			if (!faqSection || !catContent) return;

			// Activate the right FAQ category tab
			const catId = catContent.dataset.faqCatContent;
			if (catId) {
				$$('.faq-cat-tab', faqSection).forEach((t) =>
					t.classList.toggle('active', (t as HTMLElement).dataset.faqCat === catId)
				);
				$$('.faq-category-content', faqSection).forEach((c) =>
					c.classList.toggle('active', (c as HTMLElement).dataset.faqCatContent === catId)
				);
			}

			// Reveal if hidden behind "Show more"
			if (targetItem.classList.contains('faq-item--hidden')) {
				$$('.faq-item--hidden', catContent).forEach((el) => el.classList.remove('faq-item--hidden'));
				const loadMoreBtn = catContent.querySelector('.faq-load-more');
				if (loadMoreBtn) loadMoreBtn.classList.add('faq-load-more--used');
			}

			// Expand and scroll
			targetItem.classList.add('expanded');
			const questionBtn = targetItem.querySelector('.faq-question');
			if (questionBtn) questionBtn.setAttribute('aria-expanded', 'true');
			setTimeout(() => targetItem.scrollIntoView({ behavior: 'smooth', block: 'center' }), 100);
		}

		// `.sub-tab-info` click (FAQ scroll) is delegated above on `main.pricing-page`.

		// ─── Shared tooltip system: JS-only visibility ───
		let activePricingTip: { trigger: Element; tooltip: HTMLElement } | null = null;
		let pricingTipShowTimer: ReturnType<typeof setTimeout> | null = null;
		let pricingTipHideTimer: ReturnType<typeof setTimeout> | null = null;

		// Mobile browsers don't fire mouseleave after a tap, so a tooltip
		// opened on (i)-icon tap stays pinned at its `position: fixed` slot
		// when the user scrolls. Dismiss on any window scroll as a safety net.
		// Guard: this window-level listener must be installed only once.
		// initPricing() runs a single time per page load (no ClientRouter / View
		// Transitions), but the flag keeps registration idempotent if it's ever
		// invoked again. Resolve the visible tooltip via DOM query, not closure
		// state.
		if (!(window as any)._pricingScrollInit) {
			(window as any)._pricingScrollInit = true;
			window.addEventListener(
				'scroll',
				() => {
					document.querySelectorAll('.pricing-tooltip--visible').forEach((tip) => {
						tip.classList.remove(
							'pricing-tooltip--visible',
							'pricing-tooltip--interactive',
							'pricing-tooltip--flipped'
						);
						(tip as HTMLElement).style.left = '-9999px';
					});
				},
				{ passive: true }
			);
		}

		function forceHidePricingTip() {
			if (pricingTipShowTimer) {
				clearTimeout(pricingTipShowTimer);
				pricingTipShowTimer = null;
			}
			if (pricingTipHideTimer) {
				clearTimeout(pricingTipHideTimer);
				pricingTipHideTimer = null;
			}
			if (activePricingTip) {
				activePricingTip.tooltip.classList.remove(
					'pricing-tooltip--visible',
					'pricing-tooltip--interactive',
					'pricing-tooltip--flipped'
				);
				activePricingTip.tooltip.style.left = '-9999px';
				activePricingTip = null;
			}
		}

		function showTooltip(trigger: Element, tooltip: HTMLElement) {
			if (pricingTipHideTimer) {
				clearTimeout(pricingTipHideTimer);
				pricingTipHideTimer = null;
			}
			if (activePricingTip && activePricingTip.tooltip !== tooltip) {
				forceHidePricingTip();
			}
			if (pricingTipShowTimer) clearTimeout(pricingTipShowTimer);

			const rect = trigger.getBoundingClientRect();
			// Position to the right by default
			tooltip.style.left = `${rect.right + 4}px`;
			tooltip.style.top = `${rect.top + rect.height / 2}px`;
			tooltip.style.transform = 'translateY(-50%)';
			activePricingTip = { trigger, tooltip };

			// Check if tooltip overflows viewport and reposition
			requestAnimationFrame(() => {
				const tipRect = tooltip.getBoundingClientRect();
				const arrow = tooltip.querySelector(
					'.plan-feature-tooltip-arrow, .addon-tooltip-arrow, .comparison-tooltip-arrow, .sub-tab-tooltip-arrow'
				) as HTMLElement | null;
				let left = rect.right + 4;
				let flipped = false;
				let clamped = false;
				// Flip to left if overflowing right
				if (tipRect.right > window.innerWidth - 8) {
					left = rect.left - tipRect.width - 4;
					flipped = true;
				}
				// Clamp so tooltip never goes off-screen left
				if (left < 8) {
					left = 8;
					clamped = true;
				}
				// Also clamp right (for very narrow screens)
				if (left + tipRect.width > window.innerWidth - 8) {
					left = Math.max(8, window.innerWidth - tipRect.width - 8);
					clamped = true;
				}
				tooltip.style.left = `${left}px`;

				if (clamped) {
					if (arrow) arrow.style.display = 'none';
					tooltip.classList.remove('pricing-tooltip--flipped');
				} else if (flipped) {
					if (arrow) arrow.style.display = '';
					tooltip.classList.add('pricing-tooltip--flipped');
				} else {
					if (arrow) arrow.style.display = '';
					tooltip.classList.remove('pricing-tooltip--flipped');
				}

				if (tipRect.top < 8) {
					tooltip.style.top = '8px';
					tooltip.style.transform = 'none';
				} else if (tipRect.bottom > window.innerHeight - 8) {
					tooltip.style.top = `${window.innerHeight - tipRect.height - 8}px`;
					tooltip.style.transform = 'none';
				}
			});

			pricingTipShowTimer = setTimeout(() => {
				tooltip.classList.add('pricing-tooltip--visible');
				if (tooltip.querySelector('a, [class*="readmore"]')) {
					tooltip.classList.add('pricing-tooltip--interactive');
				}
			}, 150);
		}

		function scheduleHidePricingTip() {
			if (pricingTipShowTimer) {
				clearTimeout(pricingTipShowTimer);
				pricingTipShowTimer = null;
			}
			if (!activePricingTip) return;
			const isInteractive = activePricingTip.tooltip.classList.contains('pricing-tooltip--interactive');
			if (isInteractive) {
				pricingTipHideTimer = setTimeout(() => forceHidePricingTip(), 300);
			} else {
				forceHidePricingTip();
			}
		}

		// Bind triggers
		function bindPricingTooltip(trigger: Element, tooltip: HTMLElement) {
			trigger.addEventListener('mouseenter', () => showTooltip(trigger, tooltip));
			trigger.addEventListener('mouseleave', () => {
				// Only hide if this trigger is still the active one
				if (activePricingTip && activePricingTip.trigger !== trigger) return;
				scheduleHidePricingTip();
			});

			// When mouse enters the tooltip body, cancel hide
			tooltip.addEventListener('mouseenter', () => {
				if (pricingTipHideTimer) {
					clearTimeout(pricingTipHideTimer);
					pricingTipHideTimer = null;
				}
			});
			// When mouse leaves the tooltip body, hide
			tooltip.addEventListener('mouseleave', () => {
				forceHidePricingTip();
			});
		}

		// Tooltip mouseenter/mouseleave bindings (per-element, ~hundreds of
		// triggers across plan cards, addons, comparison table, sub-tab info
		// icons). `mouseenter` doesn't bubble, so we can't fully delegate;
		// instead, defer the bind work until the browser is idle so it
		// doesn't compete with the LCP frame. First hover within ~50 ms of
		// page-load might miss a tooltip; acceptable trade-off since the
		// content isn't blocked, just the tooltip behavior.
		// `.plan-feature-info` / `.addon-tooltip-trigger` / `.comparison-tooltip-trigger`
		// click → scroll-to-FAQ is delegated above on `main.pricing-page`.
		const bindAllPricingTooltips = () => {
			$$('.sub-tab-info').forEach((info) => {
				const tooltip = info.querySelector('.sub-tab-tooltip') as HTMLElement | null;
				if (tooltip) bindPricingTooltip(info, tooltip);
			});
			$$('.plan-feature-info').forEach((info) => {
				const tooltip = info.querySelector('.plan-feature-tooltip') as HTMLElement | null;
				if (tooltip) bindPricingTooltip(info, tooltip);
			});
			$$('.addon-tooltip-trigger').forEach((trigger) => {
				const tooltip = trigger.querySelector('.addon-tooltip') as HTMLElement | null;
				if (tooltip) bindPricingTooltip(trigger, tooltip);
			});
			$$('.comparison-tooltip-trigger').forEach((trigger) => {
				const tooltip = trigger.querySelector('.comparison-tooltip') as HTMLElement | null;
				if (tooltip) bindPricingTooltip(trigger, tooltip);
			});
		};
		(window.requestIdleCallback || ((cb: () => void) => setTimeout(cb, 200)))(bindAllPricingTooltips, { timeout: 1500 });

		// ─── Region toggle ───
		const regionCheckbox = $('#region-select') as HTMLInputElement | null;
		// Rewrite hrefs on any FAQ/plan link tagged `.pricing-paas-link`
		// so they point at the selected PaaS region's docs (NA → /docs/paas/,
		// EU → /docs/paas/eu/). The default href in the HTML stays NA so
		// crawlers and no-JS users still get a valid link.
		function updatePaasLinks(isEu: boolean) {
			const prefix = isEu ? '/docs/paas/eu' : '/docs/paas';
			$$('a.pricing-paas-link').forEach((a) => {
				const path = (a as HTMLAnchorElement).dataset.paasPath ?? '/';
				(a as HTMLAnchorElement).href = `${prefix}${path}`;
			});
		}
		if (regionCheckbox) {
			function setRegion(isEu: boolean) {
				$$('[data-region-content]').forEach((el) => {
					(el as HTMLElement).style.display = el.dataset.regionContent === (isEu ? 'eu' : 'na') ? '' : 'none';
				});
				$$('.region-toggle-label').forEach((lbl) => {
					lbl.classList.toggle('active', lbl.dataset.region === (isEu ? 'eu' : 'na'));
				});

				// Persist in cookie
				try {
					document.cookie = `cloudServer=${isEu ? 'eu' : 'na'};path=/;max-age=31536000`;
				} catch {
					/* ignore cookie write failure */
				}

				updatePaasLinks(isEu);
			}

			regionCheckbox.addEventListener('change', () => {
				setRegion(regionCheckbox.checked);
			});
			// `.region-toggle-label` click is delegated above on `main.pricing-page`;
			// it flips `regionCheckbox.checked` and dispatches `change`, which
			// the handler above picks up.

			// Restore from cookie (supports both new "eu"/"na" and old "/docs/paas/eu/" format)
			const cookieMatch = document.cookie.match(/cloudServer=([^;]+)/);
			if (cookieMatch?.[1] === 'eu' || cookieMatch?.[1]?.includes('/eu')) {
				regionCheckbox.checked = true;
				setRegion(true);
			}
		}

		// ─── Billing toggles ───
		$$('[data-billing-toggle]').forEach((input) => {
			const toggleId = (input as HTMLInputElement).dataset.billingToggle!;
			const checkbox = input as HTMLInputElement;

			function setBilling(isRight: boolean) {
				const group = `[data-billing-group="${toggleId}"]`;
				$$(group).forEach((el) => {
					(el as HTMLElement).style.display =
						el.dataset.billingContent === (isRight ? 'perpetual' : 'payg') ? '' : 'none';
				});
				const toggle = checkbox.closest('.billing-toggle');
				if (toggle) {
					$$('.billing-toggle-label', toggle).forEach((lbl, i) => {
						lbl.classList.toggle('active', isRight ? i === 1 : i === 0);
					});
				}
				// Update subtitle text based on billing mode
				const subtitle = document.querySelector(`[data-billing-subtitle="${toggleId}"]`) as HTMLElement | null;
				if (subtitle) {
					subtitle.textContent = isRight ? subtitle.dataset.perpetualText || '' : subtitle.dataset.paygText || '';
				}
				// Update heading text based on billing mode (mirrors subtitle pattern)
				const heading = document.querySelector(`[data-billing-heading="${toggleId}"]`) as HTMLElement | null;
				if (heading) {
					heading.textContent = isRight ? heading.dataset.perpetualText || '' : heading.dataset.paygText || '';
				}
				// Track billing state for URL
				activeBilling = isRight ? 'perpetual' : 'payg';
			}

			checkbox.addEventListener('change', () => {
				setBilling(checkbox.checked);
				if (activeSubTab) updateFaqVisibility(activeSubTab);
				updateUrl();
				// Re-init slider ticks in newly visible content
				requestAnimationFrame(() => {
					if (typeof initAllSliders === 'function') {
						$$(`[data-billing-group="${toggleId}"]`).forEach((el) => {
							if ((el as HTMLElement).style.display !== 'none') initAllSliders(el as HTMLElement);
						});
					}
				});
			});
			// `.billing-toggle-label` click is delegated above on `main.pricing-page`;
			// it flips `checkbox.checked` and dispatches `change`, which the
			// handler above picks up.
		});

		// ─── Private Cloud billing toggle (monthly/annual) ───
		const pcBillingCheckbox = $('[data-billing-toggle="tb-pc-billing"]') as HTMLInputElement | null;
		if (pcBillingCheckbox) {
			const pcSection = pcBillingCheckbox.closest('.pricing-section');
			function setPcBilling(isAnnual: boolean) {
				if (!pcSection) return;
				pcSection.querySelectorAll('.plan-card').forEach((card) => {
					const el = card as HTMLElement;
					const monthly = el.dataset.monthlyPrice;
					const annual = el.dataset.annualPrice;
					if (!monthly || !annual) return;
					const price = isAnnual ? Number(annual) : Number(monthly);
					const amountEl = el.querySelector('.plan-card-amount');
					if (amountEl) amountEl.textContent = '$' + price.toLocaleString('en-US').replace(/,/g, ' ');
				});
				const toggle = pcBillingCheckbox!.closest('.billing-toggle');
				if (toggle) {
					$$('.billing-toggle-label', toggle).forEach((lbl, i) => {
						lbl.classList.toggle('active', isAnnual ? i === 1 : i === 0);
					});
				}
			}
			pcBillingCheckbox.addEventListener('change', () => setPcBilling(pcBillingCheckbox.checked));
			// `.billing-toggle-label` click for the PC toggle is also delegated
			// above; the change event handler above picks up the result.
		}

		// ─── getLicense — plan card CTA clicks for self-managed plans ───
		function getLicense(productId: string, planId: string) {
			let url = 'https://license.thingsboard.io/signup?createSubscription=true';
			url += '&productId=' + productId;
			url += '&planId=' + planId;
			// Append UTM params from localStorage
			const utmRaw = localStorage.getItem('utm');
			if (utmRaw) {
				try {
					const utm = JSON.parse(utmRaw);
					Object.keys(utm).forEach((key) => {
						url += '&' + key + '=' + encodeURIComponent(utm[key]);
					});
				} catch {
					/* ignore malformed utm */
				}
			}
			const fpr = localStorage.getItem('fpr');
			if (fpr) url += '&fpr=' + encodeURIComponent(fpr);
			reportPriceLink(url, productId + '/' + planId);
			window.open(url, '_blank');
		}

		// `.plan-card-cta[data-product-id][data-plan-id]` click is delegated above.
		// `.topup-header` click (accordion) is delegated above.

		// ─── FAQ — single delegated listener for all FAQ interactions ───
		// Guard: register this document-level listener only once. initPricing()
		// runs a single time per page load (no ClientRouter / View Transitions),
		// but the flag keeps registration idempotent if it's ever invoked again —
		// a second run would otherwise stack duplicate handlers and fire twice.
		if (!(window as any)._pricingClickInit) {
			(window as any)._pricingClickInit = true;
			document.addEventListener('click', (e) => {
				const target = e.target as HTMLElement;

				// FAQ copy link (check BEFORE question toggle — it's nested inside .faq-question)
				const copyLink = target.closest('.faq-copy-link') as HTMLElement | null;
				if (copyLink) {
					e.stopPropagation();
					e.preventDefault();
					const faqId = copyLink.dataset.faqId;
					if (!faqId?.trim()) return;
					const url = new URL(window.location.href);
					url.hash = faqId;
					navigator.clipboard
						.writeText(url.toString())
						.then(() => {
							copyLink.classList.add('copied');
							setTimeout(() => copyLink.classList.remove('copied'), 2000);
						})
						.catch(() => {});
					return;
				}

				// FAQ accordion toggle
				const question = target.closest('.faq-question') as HTMLElement | null;
				if (question) {
					const item = question.closest('.faq-item');
					if (item) {
						item.classList.toggle('expanded');
						question.setAttribute('aria-expanded', String(item.classList.contains('expanded')));
					}
					return;
				}

				// FAQ "Show more"
				const loadMore = target.closest('.faq-load-more') as HTMLElement | null;
				if (loadMore) {
					const content = loadMore.closest('.faq-category-content');
					if (content) {
						$$('.faq-item--hidden', content).forEach((el) => el.classList.remove('faq-item--hidden'));
						loadMore.classList.add('faq-load-more--used');
					}
					return;
				}

				// FAQ calculator-open link (replaces former inline onclick in FAQ HTML)
				const calcLink = target.closest('[data-open-calc]') as HTMLElement | null;
				if (calcLink) {
					e.preventDefault();
					const which = calcLink.dataset.openCalc;
					const fnName = which === 'pc' ? 'openTbPcCalc' :  'openTbPaygCalc';
					(window as any)[fnName]?.();
					window.scrollTo({ top: 0, behavior: 'smooth' });
					return;
				}

				// FAQ category tabs
				const catTab = target.closest('.faq-cat-tab') as HTMLElement | null;
				if (catTab) {
					const section = catTab.closest('.faq-section');
					if (section) {
						const catId = catTab.dataset.faqCat;
						$$('.faq-cat-tab', section).forEach((t) => {
							const isActive = (t as HTMLElement).dataset.faqCat === catId;
							t.classList.toggle('active', isActive);
							t.setAttribute('aria-current', isActive ? 'true' : 'false');
						});
						$$('.faq-category-content', section).forEach((c) =>
							c.classList.toggle('active', (c as HTMLElement).dataset.faqCatContent === catId)
						);
					}
					return;
				}
			});
		}

		// ─── FAQ category from URL (?faqSection=…) ───
		// Deferred to idle — activating a category tab below the fold isn't
		// LCP-critical. The hash-based deep-link below stays SYNCHRONOUS so
		// `/pricing/#faq-foo` URLs land on the right item without jank.
		const faqSectionParam = params.get('faqSection');
		if (faqSectionParam) {
			const activateFaqCategory = () => {
				$$('.faq-section').forEach((section) => {
					if ((section as HTMLElement).style.display !== 'none') {
						const tab = section.querySelector(`.faq-cat-tab[data-faq-cat="${faqSectionParam}"]`);
						if (tab) (tab as HTMLElement).click();
					}
				});
			};
			(window.requestIdleCallback || ((cb: () => void) => setTimeout(cb, 200)))(activateFaqCategory, { timeout: 2000 });
		}

		// ─── FAQ deep-link on load (synchronous — preserves /pricing/#faq-id) ───
		const hash = window.location.hash.slice(1);
		if (hash) {
			const targetItem = document.getElementById(hash);
			if (targetItem?.classList.contains('faq-item')) {
				// Find which FAQ section this belongs to and activate the right product/sub-tab
				const faqBlock = targetItem.closest('.pricing-faq-block') as HTMLElement;
				if (faqBlock) {
					const ctx = faqBlock.dataset.faqContext;
					if (ctx) {
						for (const [tabId, contexts] of Object.entries(faqContextMap)) {
							if (contexts.includes(ctx)) {
								if (tabId.startsWith('tbmq')) {
									activateProductTab('tbmq');
								} else {
									activateProductTab('thingsboard');
								}
								activateSubTab(tabId);
								break;
							}
						}
					}
				}
				// scrollToFaqItem handles category tab, hidden reveal, expand, and scroll
				scrollToFaqItem(hash);
			}
		}

		// ─── URL update ───
		function updateUrl() {
			const p = new URLSearchParams();
			if (activeProduct === 'tbmq') {
				p.set('section', 'tbmq-options');
			} else {
				p.set('section', 'thingsboard-pe-options');
			}
			if (activeSubTab) {
				p.set('product', activeSubTab);
			}
			if (activeBilling && activeBilling !== 'payg') {
				p.set('solution', `pe-${activeBilling}`);
			}
			const newUrl = `${window.location.pathname}?${p.toString()}`;
			history.replaceState(null, '', newUrl);
		}

		// ─── Initialize from URL ───
		activateProductTab(activeProduct, !!activeSubTab);
		if (activeSubTab) {
			activateSubTab(activeSubTab);
		} else {
			// Activate default sub-tab
			const defaultTab = $(
				`.pricing-product-content:not([style*="display: none"]):not([style*="display:none"]) .sub-tab.active`
			);
			if (defaultTab) {
				activateSubTab(defaultTab.dataset.subtab!);
			}
		}


		// Set billing toggle from URL
		if (activeBilling === 'perpetual') {
			$$('[data-billing-toggle]').forEach((input) => {
				const checkbox = input as HTMLInputElement;
				checkbox.checked = true;
				checkbox.dispatchEvent(new Event('change'));
			});
		}

		// Segment highlight is now per-tab CSS — no JS positioning or resize
		// observer needed.

		// Enable animations after initial render
		skipAnimation = false;
	}

	initPricing();
</script>

<style lang="scss" is:global>
