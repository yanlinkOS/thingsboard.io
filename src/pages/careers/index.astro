---
import BaseLayout from '@layouts/BaseLayout.astro';
import JobsSection from '../../components/Careers/JobsSection.astro';
import TechStackSection from '../../components/Careers/TechStackSection.astro';
import AboutSection from '../../components/Careers/AboutSection.astro';
import BenefitsSection from '../../components/Careers/BenefitsSection.astro';
---

<BaseLayout
	headerVariant="solid-shadow"
	forceLightTheme
	title="Careers | ThingsBoard"
	description="ThingsBoard Careers — join our team."
	pageId="careers"
	noIndex
>
	<div class="careers-overflow-guard">
		<div class="careers-page">
			<JobsSection />
			<TechStackSection />
			<AboutSection />
			<BenefitsSection />
		</div>
	</div>
</BaseLayout>

<style>
	.careers-overflow-guard {
		overflow-x: hidden;
	}

	.careers-page {
		position: relative;
		width: calc(100% - 468px);
		margin: auto;
		padding-top: 40px;
		color: #212529;

		@media (max-width: 1500px) {
			width: calc(100% - 200px);
		}

		@media (max-width: 1025px) {
			width: 100%;
			padding-left: 20px;
			padding-right: 20px;
		}

		@media (min-width: 1920px) {
			width: 1500px;
		}
	}
</style>
