---
import BaseLayout from '@layouts/BaseLayout.astro';
import { jobs } from '@data/careers/jobs';

export function getStaticPaths() {
	return jobs.map((job) => ({
		params: { slug: job.slug },
		props: { job },
	}));
}

const { job } = Astro.props;
---

<BaseLayout
	headerVariant="solid-shadow"
	forceLightTheme
	title={job.position}
	description={`${job.position} — ${job.location}`}
	noIndex
>
	<div class="careers-overflow-guard">
		<div class="careers-page">
			<a class="back" href="/careers/">
				<img src="/images/careers/back_arrow.svg" alt="Back arrow" width="24" height="24" />
				Back to Careers
			</a>

			<div class="vacancy">
				<div class="vacancy-head">
					<h1>{job.position}</h1>
					<div class="vacancy-meta">
						<div class="location">
							{job.location}
							<img src="/images/careers/location_icon.svg" alt="" width="20" height="20" />
						</div>
						{job.dateString && <p class="date">{job.dateString}</p>}
					</div>
				</div>

				{
					job.intro && (
						<div class="intro">
							{job.intro.split('\n\n').map((paragraph) => (
								<p>{paragraph}</p>
							))}
						</div>
					)
				}

				{
					job.sections.map((section) => (
						<div class="job-section">
							<h3>{section.title}:</h3>
							<ul>
								{section.items.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</div>
					))
				}

				<div class="mail-block-wrap">
					<div class="mail-block">
						<div class="mail-left">
							<p class="mail-title">Send your CV on mail:</p>
							<a class="mail" href="mailto:hr@thingsboard.io?subject=Job application in ThingsBoard">
								hr@thingsboard.io
							</a>
						</div>
						<a class="btn-apply" href="mailto:hr@thingsboard.io?subject=Job application in ThingsBoard"> APPLY NOW </a>
					</div>
				</div>
			</div>
		</div>
	</div>
</BaseLayout>

<style>
	.careers-overflow-guard {
		overflow-x: hidden;
	}

	.careers-page {
		position: relative;
		width: calc(100% - 468px);
		margin: auto;
		padding-top: 40px;
		color: #212529;

		@media (max-width: 1500px) {
			width: calc(100% - 200px);
		}

		@media (max-width: 1025px) {
			width: 100%;
			padding-left: 20px;
			padding-right: 20px;
		}

		@media (min-width: 1920px) {
			width: 1500px;
		}
	}

	.back {
		display: flex;
		align-items: center;
		gap: 16px;
		color: #212529;
		font-size: 32px;
		font-weight: 300;
		margin-bottom: 50px;
		text-decoration: none;

		&:hover {
			text-decoration: none;
			color: #212529;
		}
	}

	.vacancy-head {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 48px;

		@media (max-width: 750px) {
			flex-direction: column;
			gap: 16px;
		}
	}

	h1 {
		color: #212529;
		font-weight: 300;
		font-size: 48px;
		line-height: 56px;
		margin: 0;
		flex: 1;

		@media (max-width: 750px) {
			font-size: 36px;
			line-height: 44px;
		}
	}

	.vacancy-meta {
		width: 240px;
		text-align: right;
		flex-shrink: 0;

		@media (max-width: 750px) {
			width: auto;
			text-align: left;
		}
	}

	.location {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 12px;
		font-weight: 500;
		font-size: 24px;
		line-height: 28px;
		color: #212529;
		margin-bottom: 12px;

		@media (max-width: 750px) {
			justify-content: flex-start;
		}
	}

	.date {
		font-size: 18px;
		line-height: 21px;
		color: #9a9a9a;
		margin: 0;
		text-align: right;

		@media (max-width: 750px) {
			text-align: left;
		}
	}

	.intro p {
		font-size: 18px;
		line-height: 30px;
		color: #212529;
		margin-bottom: 16px;
	}

	.job-section {
		h3 {
			font-size: 24px;
			font-weight: 600;
			line-height: 28px;
			color: #212529;
			margin: 48px 0 18px;
		}

		ul {
			padding-left: 18px;
		}

		li {
			font-size: 18px;
			line-height: 30px;
			color: #212529;
			margin-bottom: 8px;
			list-style-type: disc;
			display: list-item;
		}
	}

	.mail-block-wrap {
		position: relative;
		margin: 48px 0 52px;

		&::before {
			content: '';
			position: absolute;
			width: 300%;
			height: 100%;
			background-color: #fafafa;
			left: -100%;
			top: 0;
			z-index: -1;
		}
	}

	.mail-block {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 44px 0;

		@media (max-width: 750px) {
			flex-direction: column;
			align-items: flex-start;
			gap: 24px;
		}
	}

	.mail-left {
		display: flex;
		align-items: center;
		gap: 6px;
		flex-wrap: wrap;
	}

	.mail-title {
		font-weight: 600;
		font-size: 24px;
		line-height: 28px;
		color: #212529;
		margin: 0;
	}

	.mail {
		font-size: 24px;
		line-height: 28px;
		color: #2a7dec;
		text-decoration: none;

		&:hover {
			text-decoration: underline;
		}
	}

	.btn-apply {
		color: #fff;
		font-weight: 500;
		font-size: 16px;
		text-align: center;
		background-color: #2a7dec;
		border-radius: 3px;
		height: 56px;
		width: 296px;
		padding: 18px;
		text-decoration: none;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;

		&:hover {
			background-color: #4f97f8;
			text-decoration: none;
			color: #fff;
			transition-duration: 0.3s;
		}

		&:active {
			background-color: #2a7dec;
		}

		@media (max-width: 1280px) {
			width: 200px;
		}

		@media (max-width: 750px) {
			width: 100%;
		}
	}
</style>
