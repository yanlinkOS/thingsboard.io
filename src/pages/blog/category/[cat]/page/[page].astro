---
import { BLOG_CATEGORIES } from '~/data/blog/categories';

export function getStaticPaths() {
	const paths: { params: { cat: string; page: string } }[] = [];
	for (const cat of BLOG_CATEGORIES) {
		for (let i = 2; i <= 5; i++) {
			paths.push({ params: { cat, page: String(i) } });
		}
	}
	return paths;
}

const { cat } = Astro.params;
return Astro.redirect(`/blog/?category=${cat}`, 301);
