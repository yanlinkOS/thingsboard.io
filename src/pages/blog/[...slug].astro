---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';
import { getAuthor } from '~/data/blog/authors';
import { CATEGORY_LABELS, type BlogCategory } from '~/data/blog/categories';
import { Icon } from 'astro-icon/components';
import type { z } from 'astro/zod';
import type { blogSchema } from '~/content.config';

type BlogData = z.infer<typeof blogSchema>;
type BlogPost = { id: string; data: BlogData; collection: 'blog' };

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props as { post: BlogPost };
const { Content, headings } = await render(post as any);
const author = getAuthor(post.data.author);
const siteOrigin = new URL(Astro.site!).origin;
const homeUrl = new URL('/', Astro.site).href;
const blogUrl = new URL('/blog/', Astro.site).href;
const postUrl = new URL(`/blog/${post.id}/`, Astro.site).href;
// Separate percent-encoded form for social share query params.
const postUrlEncoded = encodeURIComponent(postUrl);
const shareTitle = encodeURIComponent(post.data.title);
const allPosts = (await getCollection('blog', ({ data }) => !(data as BlogData).draft)) as unknown as BlogPost[];
const relatedPosts = allPosts
	.filter((p) => p.id !== post.id && p.data.categories.some((c: string) => post.data.categories.includes(c)))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);

// Filter headings for TOC — include h2, h3, h4
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 4);
const tocMinDepth = tocHeadings.length > 0 ? Math.min(...tocHeadings.map((h) => h.depth)) : 2;

// SEO: JSON-LD structured data
const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'BlogPosting',
			'@id': `${postUrl}#blogposting`,
			headline: post.data.title,
			description: post.data.description,
			datePublished: post.data.date.toISOString(),
			...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
			inLanguage: 'en-US',
			mainEntityOfPage: { '@id': `${postUrl}#webpage` },
			image: post.data.featuredImage ? {
				'@type': 'ImageObject',
				url: new URL(post.data.featuredImage, Astro.site).href,
			} : undefined,
			author: author ? {
				'@type': 'Person',
				name: author.name,
				url: new URL(`/blog/author/${author.slug}/`, Astro.site).href,
				...(author.avatar && { image: { '@type': 'ImageObject', url: author.avatar } }),
			} : undefined,
			publisher: {
				'@type': 'Organization',
				name: 'ThingsBoard',
				url: siteOrigin,
				logo: { '@type': 'ImageObject', url: new URL('/images/thingsboard_logo_blue.svg', Astro.site).href },
			},
		},
		{
			'@type': 'BreadcrumbList',
			'@id': `${postUrl}#breadcrumblist`,
			itemListElement: [
				{ '@type': 'ListItem', position: 1, name: 'Home', item: homeUrl },
				{ '@type': 'ListItem', position: 2, name: 'Blog', item: blogUrl },
				{ '@type': 'ListItem', position: 3, name: post.data.title },
			],
		},
		{
			'@type': 'WebPage',
			'@id': `${postUrl}#webpage`,
			url: postUrl,
			name: post.data.title,
			description: post.data.description,
			inLanguage: 'en-US',
			isPartOf: { '@id': `${blogUrl}#website` },
		},
		{
			'@type': 'WebSite',
			'@id': `${blogUrl}#website`,
			url: blogUrl,
			name: 'ThingsBoard Blog',
			inLanguage: 'en-US',
			publisher: { '@id': `${homeUrl}#organization` },
		},
	],
};
---

<BlogLayout
	title={post.data.title}
	description={post.data.description}
	ogImage={post.data.featuredImage}
	ogType="article"
	publishedTime={post.data.date.toISOString()}
	modifiedTime={post.data.updatedDate?.toISOString()}
	authorName={author?.name}
	jsonLd={jsonLd}
>
	<article class="blog-post">
		<div class="post-outer">
			{/* Main bordered content */}
			<div class="post-container" style="margin:0">
				{/* Breadcrumbs */}
				<nav class="breadcrumbs">
					<a href="/blog/">Blog</a>
					<span class="breadcrumbs__sep">&rsaquo;</span>
					<span class="breadcrumbs__current">{post.data.title}</span>
				</nav>

				{/* Date with accent bar */}
				<time class="post-date" datetime={post.data.date.toISOString()}>
					{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
				</time>

				{/* Title */}
				<h1>{post.data.title}</h1>

				{/* Author card */}
				{author && (
					<div class="post-author-card">
						<a href={`/blog/author/${author.slug}/`} class="post-author-link">
							<img src={author.avatar} alt={author.name} class="post-author-avatar" />
							<div class="post-author-info">
								<span class="post-author-name">{author.name}</span>
								{author.role && <span class="post-author-role">{author.role}</span>}
							</div>
						</a>
					</div>
				)}

				{/* Content */}
				<div class="blog-content">
					<Content />
				</div>

				{/* Author bio */}
				{author && (
					<div class="post-author-bio">
						<a href={`/blog/author/${author.slug}/`} class="author-bio-card">
							<img src={author.avatar} alt={author.name} class="author-bio-avatar" />
							<div>
								<strong>{author.name}</strong>
								{author.bio && <p>{author.bio}</p>}
							</div>
						</a>
					</div>
				)}

				{/* Bottom breadcrumbs */}
				<nav class="breadcrumbs breadcrumbs--bottom">
					<a href="/blog/">Blog</a>
					<span class="breadcrumbs__sep">&rsaquo;</span>
					<span class="breadcrumbs__current">{post.data.title}</span>
				</nav>
			</div>

		</div>

		{/* TOC Sidebar — fixed position, placed by JS */}
		{tocHeadings.length > 0 && (
			<aside class="toc-sidebar" id="toc-sidebar">
				<h3 class="toc-title">On this page</h3>
				<ul class="toc-list">
					{tocHeadings.map((h) => (
						<li style={h.depth > tocMinDepth ? `padding-left: ${(h.depth - tocMinDepth) * 12}px` : undefined}>
							<a href={`#${h.slug}`} class="toc-link">{h.text}</a>
						</li>
					))}
				</ul>
			</aside>
		)}

		{/* Share row */}
		<div class="share-row">
			<div class="share-inner">
				<span class="share-label">Share:</span>
				<div class="share-icons">
					<a href={`https://www.facebook.com/sharer/sharer.php?u=${postUrlEncoded}`} target="_blank" rel="noopener noreferrer" class="share-icon" aria-label="Share on Facebook">
						<Icon name="tabler:brand-facebook" size={20} />
					</a>
					<a href={`https://t.me/share/url?url=${postUrlEncoded}&text=${shareTitle}`} target="_blank" rel="noopener noreferrer" class="share-icon" aria-label="Share on Telegram">
						<Icon name="tabler:brand-telegram" size={20} />
					</a>
					<a href={`https://www.linkedin.com/sharing/share-offsite/?url=${postUrlEncoded}`} target="_blank" rel="noopener noreferrer" class="share-icon" aria-label="Share on LinkedIn">
						<Icon name="tabler:brand-linkedin" size={20} />
					</a>
					<a href={`https://twitter.com/intent/tweet?url=${postUrlEncoded}&text=${shareTitle}`} target="_blank" rel="noopener noreferrer" class="share-icon" aria-label="Share on X">
						<Icon name="tabler:brand-x" size={20} />
					</a>
				</div>
			</div>
		</div>

		{/* Newsletter section */}
		<div class="newsletter-section">
			<div class="newsletter-inner">
				<h2 class="newsletter-heading">Join ThingsBoard community</h2>
				<p class="newsletter-subtitle">Stay tuned and get first-hand updates and access to insights.</p>
				{/* Mailerlite wrapper structure — required for webforms.min.js to
				    intercept the submit, AJAX-post, and toggle in the inline
				    success state. Without it, target="_blank" lands on a blank
				    Mailerlite response page (designed for their iframe). */}
				<div id="mlb2-z9h4b4-blog-post" class="ml-subscribe-form ml-subscribe-form-z9h4b4 newsletter-ml-wrap">
					<div class="subscribe-form ml-block-success" style="display:none" role="status" aria-live="polite" tabindex="-1">
						<p class="newsletter-success">Thank you! You're subscribed.</p>
					</div>
					<form class="newsletter-form ml-block-form" action="https://static.mailerlite.com/webforms/submit/z9h4b4" data-id="6028548" data-code="z9h4b4" method="post">
						<input type="email" name="fields[email]" placeholder="Your email address*" required class="newsletter-input" aria-label="Email address" />
						<input type="hidden" name="ml-submit" value="1" />
						<button type="submit" class="newsletter-submit">
							<span class="newsletter-submit-label">Subscribe</span>
							<span class="newsletter-submit-spinner" aria-hidden="true"></span>
						</button>
					</form>
				</div>
			</div>
		</div>

		{/* Related Posts */}
		{relatedPosts.length > 0 && (
			<section class="related-posts">
				<div class="container-wide">
					<h2>Related Posts</h2>
					<div class="related-grid">
						{relatedPosts.map((rp) => (
							<a href={`/blog/${rp.id}/`} class="related-card">
								<div class="related-card-image">
									<img src={rp.data.featuredImage} alt={rp.data.featuredImageAlt} loading="lazy" />
								</div>
								<div class="related-card-body">
									<span class="related-card-category">
										{CATEGORY_LABELS[rp.data.categories[0] as BlogCategory] || rp.data.categories[0]}
									</span>
									<h3>{rp.data.title}</h3>
									<time datetime={rp.data.date.toISOString()}>
										{rp.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
									</time>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>
		)}
	</article>
</BlogLayout>

<script>
	const tocSidebar = document.getElementById('toc-sidebar');
	const tocLinks = document.querySelectorAll('.toc-link');
	const postContainer = document.querySelector('.post-container');
	const blogContent = document.querySelector('.blog-content');

	if (tocSidebar && postContainer && blogContent) {
		// Position TOC to the right of the article
		function positionToc() {
			const rect = postContainer!.getBoundingClientRect();
			const rightEdge = rect.right;
			const spaceRight = window.innerWidth - rightEdge;
			const contentBottom = blogContent!.getBoundingClientRect().bottom;
			const pastContent = contentBottom < window.innerHeight * 0.5;

			if (spaceRight < 260 || pastContent) {
				tocSidebar!.style.display = 'none';
			} else {
				tocSidebar!.style.display = '';
				tocSidebar!.style.left = `${rightEdge + 12}px`;
			}
		}

		// Active heading tracking
		const headingEls = Array.from(tocLinks).map((link) => {
			const id = link.getAttribute('href')?.slice(1);
			return id ? document.getElementById(id) : null;
		}).filter(Boolean) as HTMLElement[];

		function updateToc() {
			let active = 0;
			const offset = 120;
			for (let i = headingEls.length - 1; i >= 0; i--) {
				if (headingEls[i].getBoundingClientRect().top <= offset) {
					active = i;
					break;
				}
			}
			tocLinks.forEach((link, i) => {
				link.classList.toggle('active', i === active);
			});
		}

		positionToc();
		window.addEventListener('scroll', () => { updateToc(); positionToc(); }, { passive: true });
		window.addEventListener('resize', positionToc, { passive: true });
		updateToc();

		// Intercept TOC clicks so each click replaces the URL hash instead of pushing a history entry.
		// Without this, the browser back button walks through every heading visited before leaving the post.
		for (const link of Array.from(tocLinks)) {
			link.addEventListener('click', (e) => {
				const href = link.getAttribute('href');
				if (!href?.startsWith('#')) return;
				const target = document.getElementById(href.slice(1));
				if (!target) return;
				e.preventDefault();
				// behavior: 'auto' defers to CSS scroll-behavior (which already respects prefers-reduced-motion).
				target.scrollIntoView({ behavior: 'auto', block: 'start' });
				history.replaceState(null, '', href);
			});
		}
	}

	// ── Blog Image Lightbox ──
	const contentImages = document.querySelectorAll('.blog-content img') as NodeListOf<HTMLImageElement>;
	if (contentImages.length) {
		const overlay = document.createElement('div');
		overlay.className = 'blog-lightbox';
		overlay.innerHTML = '<img alt="Enlarged image" /><button class="blog-lightbox__close" aria-label="Close">&times;</button>';
		document.body.appendChild(overlay);

		const lbImg = overlay.querySelector('img')!;
		const closeBtn = overlay.querySelector('.blog-lightbox__close')!;

		function openLightbox(src: string, alt: string) {
			lbImg.src = src;
			lbImg.alt = alt;
			overlay.classList.add('active');
			document.body.style.overflow = 'hidden';
		}

		function closeLightbox() {
			overlay.classList.remove('active');
			document.body.style.overflow = '';
		}

		contentImages.forEach(img => {
			img.style.cursor = 'pointer';
			img.addEventListener('click', () => openLightbox(img.src, img.alt));
		});

		overlay.addEventListener('click', (e) => { if (e.target === overlay || e.target === closeBtn) closeLightbox(); });
		document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
	}

	// ── Newsletter (Mailerlite) — lazy-load webforms.min.js on first focus
	// of the email input. Mirrors the pattern used on the blog index page.
	// Submit directly via fetch — same pattern as /blog/ index. The lazy
	// Mailerlite intercept script was race-prone and got blocked by some
	// ad-blockers; the /webforms/submit/ endpoint accepts cross-origin
	// fire-and-forget POSTs so the email still lands without the script.
	(function initBlogPostNewsletter() {
		const wrap = document.getElementById('mlb2-z9h4b4-blog-post');
		if (!wrap) return;
		const form = wrap.querySelector<HTMLFormElement>('form.ml-block-form');
		const success = wrap.querySelector<HTMLElement>('.ml-block-success');
		const emailInput = wrap.querySelector<HTMLInputElement>('input[type="email"]');
		const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
		if (!form || !success || !emailInput || !submitBtn) return;

		let submitted = false;
		form.addEventListener('submit', (e) => {
			e.preventDefault();
			if (submitted) return;
			if (!form.checkValidity()) return;
			submitted = true;
			submitBtn.disabled = true;
			submitBtn.setAttribute('aria-busy', 'true');
			submitBtn.classList.add('is-loading');

			fetch(form.action, {
				method: 'POST',
				body: new FormData(form),
				mode: 'no-cors',
				credentials: 'omit',
			}).catch(() => {
				// Network failure — keep optimistic-success behavior.
			});

			emailInput.value = '';
			form.style.setProperty('display', 'none', 'important');
			success.style.setProperty('display', 'block', 'important');
			// Move focus into the success region for SR + keyboard users.
			success.focus();
		});
	})();
</script>

<style lang="scss" is:global>
	@use '../../styles/_variables.scss' as *;

	// ── Layout ──

	// Smooth scroll for TOC anchor clicks on blog posts.
	// Affects only same-document anchor nav + scrollIntoView — cross-document loads still land instantly.
	html:has(.blog-post) {
		scroll-behavior: smooth;
	}

	@media (prefers-reduced-motion: reduce) {
		html:has(.blog-post) {
			scroll-behavior: auto;
		}
	}

	.post-outer {
		@include container;
		max-width: 860px;
		position: relative;
	}

	.post-container {
		border-left: 1px solid var(--color-border);
		border-right: 1px solid var(--color-border);
		padding: var(--spacing-6) var(--spacing-4) var(--spacing-10);

		@include media-down(lg) {
			border: none;
			padding: var(--spacing-6) 0 0;
		}
	}

	.container-wide {
		@include container;
		max-width: 860px;
	}

	// ── Breadcrumbs ──

	.breadcrumbs {
		display: flex;
		align-items: center;
		gap: var(--spacing-2);
		@include text-s;
		color: var(--color-text-muted);
		margin-bottom: var(--spacing-6);

		a {
			color: var(--color-primary);
			text-decoration: none;
			&:hover { text-decoration: underline; }
		}
	}

	.breadcrumbs__current {
		color: var(--color-text-muted);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 500px;
	}

	.breadcrumbs--bottom {
		margin-bottom: 0;
		margin-top: var(--spacing-6);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	// ── Date ──

	.post-date {
		display: block;
		@include text-s;
		color: var(--color-primary);
		font-weight: $font-weight-medium;
		margin-bottom: var(--spacing-3);
		margin-left: calc(-1 * var(--spacing-4) - 1px);
		padding-left: calc(var(--spacing-4) - 2px);
		border-left: 3px solid var(--color-primary);

		@include media-down(lg) {
			margin-left: 0;
			padding-left: var(--spacing-4);
		}
	}

	// ── Title ──

	h1 {
		font-size: 40px;
		font-weight: $font-weight-semibold;
		line-height: 1.2;
		letter-spacing: -0.02em;
		color: var(--color-text);
		margin-bottom: var(--spacing-6);

		@include media-down(md) {
			font-size: 28px;
			line-height: 1.25;
		}
	}

	// ── Author Card ──

	.post-author-card {
		padding: var(--spacing-5) 0;
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--spacing-8);
	}

	.post-author-link {
		display: flex;
		align-items: center;
		gap: var(--spacing-4);
		text-decoration: none;
		color: inherit;
	}

	.post-author-avatar {
		width: 56px;
		height: 56px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	.post-author-info {
		display: flex;
		flex-direction: column;
	}

	.post-author-name {
		font-size: $font-size-base;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
	}

	.post-author-role {
		@include text-s;
		color: var(--color-text-muted);
	}

	// ── Blog Content ──

	.blog-content {
		margin-bottom: var(--spacing-10);

		h2 {
			font-size: $font-size-3xl;
			font-weight: $font-weight-semibold;
			color: var(--color-text);
			margin: var(--spacing-10) 0 var(--spacing-4);
			line-height: 1.3;
			scroll-margin-top: calc(#{$header-height} + #{$spacing-6});
		}

		h3 {
			font-size: $font-size-2xl;
			font-weight: $font-weight-semibold;
			color: var(--color-text);
			margin: var(--spacing-8) 0 var(--spacing-3);
			line-height: 1.3;
			scroll-margin-top: calc(#{$header-height} + #{$spacing-6});
		}

		h4 {
			font-size: $font-size-xl;
			font-weight: $font-weight-semibold;
			color: var(--color-text);
			margin: var(--spacing-6) 0 var(--spacing-3);
			scroll-margin-top: calc(#{$header-height} + #{$spacing-6});
		}

		h5 {
			font-size: $font-size-lg;
			font-weight: $font-weight-semibold;
			color: var(--color-text);
			margin: var(--spacing-4) 0 var(--spacing-2);
		}

		p {
			@include text-m;
			color: var(--color-text-secondary);
			margin: 0 0 var(--spacing-6);
			line-height: 1.8;
		}

		img {
			max-width: 100%;
			height: auto;
			border-radius: var(--radius-md);
			margin: var(--spacing-4) 0;
			display: block;
		}

		// Caption pattern: a paragraph containing only an image, immediately followed by
		// a paragraph whose only element child is an <em> — typical markdown caption shape
		// `![](img)\n\n*caption*`. Scoped this way because a bare `p > em:only-child` selector
		// also matches inline italics surrounded by text (CSS :only-child ignores text nodes).
		p:has(> img:only-child) + p > em:only-child {
			display: block;
			@include text-s;
			color: var(--color-text-muted);
			text-align: center;
			margin-top: calc(-1 * var(--spacing-2));
			margin-bottom: var(--spacing-4);
		}

		figure {
			margin: var(--spacing-6) 0;

			figcaption {
				@include text-s;
				color: var(--color-text-muted);
				text-align: center;
				margin-top: var(--spacing-2);
			}
		}

		blockquote {
			border-left: 3px solid var(--color-primary);
			padding: var(--spacing-3) var(--spacing-5);
			margin: var(--spacing-6) 0;
			background: color-mix(in srgb, var(--color-primary) 4%, transparent);
			border-radius: 0 var(--radius-md) var(--radius-md) 0;
			color: var(--color-text-secondary);
		}

		a {
			color: var(--color-primary);
			&:hover { text-decoration: underline; }
		}

		ul {
			margin: 0 0 var(--spacing-4);
			padding-left: var(--spacing-6);
			list-style: disc !important;
		}

		ol {
			margin: 0 0 var(--spacing-4);
			padding-left: var(--spacing-6);
			list-style: decimal !important;
		}

		li {
			@include text-m;
			color: var(--color-text-secondary);
			margin-bottom: var(--spacing-2);
			line-height: 1.75;
		}

		table {
			width: 100%;
			border-collapse: collapse;
			margin: var(--spacing-6) 0;

			th,
			td {
				padding: var(--spacing-2) var(--spacing-3);
				border: 1px solid var(--color-border);
				@include text-s;
			}

			th {
				background: var(--color-bg-surface);
				font-weight: $font-weight-semibold;
			}
		}

		hr {
			border: none;
			border-top: 1px solid var(--color-border);
