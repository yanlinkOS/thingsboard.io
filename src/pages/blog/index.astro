---
import BlogLayout from '../../layouts/BlogLayout.astro';
import Pagination from '@components/Pagination/Pagination.astro';
import Carousel from '@components/Carousel/Carousel.astro';
import CarouselSlide from '@components/Carousel/CarouselSlide.astro';
import { getSortedBlogPosts } from '@data/blog/posts';
import { getAuthor } from '~/data/blog/authors';
import { Icon } from 'astro-icon/components';
import {
	BLOG_CATEGORIES,
	CATEGORY_LABELS,
	type BlogCategory,
} from '~/data/blog/categories';
import { recordSitemapLastmod } from '@util/sitemap-lastmod';
const posts = await getSortedBlogPosts();

recordSitemapLastmod(
	'/blog/',
	posts.map((p) => (p.data.updatedDate ?? p.data.date).valueOf()),
);

const featuredPosts = posts
	.filter((p) => !p.data.excludeFromCarousel)
	.sort((a, b) => Number(b.data.pinned) - Number(a.data.pinned))
	.slice(0, 5);

const siteOrigin = new URL(Astro.site!).origin;
const blogUrl = new URL('/blog/', Astro.site).href;
---

<BlogLayout
	title="Blog"
	description="ThingsBoard blog — product updates, technical guides, and IoT solutions."
	jsonLd={{
		'@context': 'https://schema.org',
		'@type': 'Blog',
		'@id': `${blogUrl}#blog`,
		name: 'ThingsBoard Blog',
		description: 'ThingsBoard blog — product updates, technical guides, and IoT solutions.',
		url: blogUrl,
		publisher: {
			'@type': 'Organization',
			name: 'ThingsBoard',
			url: siteOrigin,
			logo: { '@type': 'ImageObject', url: new URL('/images/thingsboard_logo_blue.svg', Astro.site).href },
		},
	}}
>
	<main class="blog-page">
		{/* Runs synchronously before children are parsed so CSS animation's "from" keyframe
		    is in effect the moment elements exist — no flash of final state. */}
		<script is:inline>
			{
				const el = document.currentScript.parentElement;
				const atTop = (window.scrollY || 0) < 50;
				const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				const hasParams = window.location.search.length > 0;
				if (atTop && !reduced) {
					el.classList.add('is-entering');
					if (hasParams) el.classList.add('is-entering--no-grid');
				}
			}
		</script>
		<div class="blog-blobs" aria-hidden="true">
			<div class="blog-blob blog-blob--blue"></div>
			<div class="blog-blob blog-blob--pink"></div>
			<div class="blog-blob blog-blob--purple"></div>
			<div class="blog-blob blog-blob--green"></div>
		</div>
		<div class="blog-container">
			<h1 class="blog-title">Blog</h1>

			{/* ── Featured Carousel ── */}
			{featuredPosts.length > 0 && (
				<div class="carousel-section">
					<Carousel
						class="featured-carousel"
						autoplay={true}
						showArrows={false}
						showDots={featuredPosts.length > 1}
						slideCount={featuredPosts.length}
						bleed={true}
						ariaLabel="Featured posts"
					>
						{featuredPosts.map((post, i) => {
							const author = getAuthor(post.data.author);
							const cat = post.data.categories[0] as BlogCategory;
							return (
								<CarouselSlide index={i} total={featuredPosts.length}>
									<div class="carousel__card">
										<div class="carousel__text">
											<span class="carousel__badge" data-cat={cat}>
												{CATEGORY_LABELS[cat] || cat}
											</span>
											<h2 class="carousel__title">{post.data.title}</h2>
											{author && (
												<div class="carousel__author">
													<img src={author.avatar} alt={author.name} class="carousel__avatar" />
													<div>
														<span class="carousel__author-name">{author.name}</span>
														{author.role && <span class="carousel__author-role">{author.role}</span>}
													</div>
												</div>
											)}
											<p class="carousel__excerpt">{post.data.description}</p>
											<a href={`/blog/${post.id}/`} class="carousel__cta">
												Read more <span class="sr-only">about {post.data.title}</span><Icon name="tabler:chevron-right" size={18} />
											</a>
										</div>
										<div class="carousel__image">
											<img src={post.data.featuredImage} alt={post.data.featuredImageAlt} loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : undefined} decoding="async" />
										</div>
									</div>
								</CarouselSlide>
							);
						})}
					</Carousel>
				</div>
			)}

			{/* ── Category Chips ── */}
			<div class="filter-bar">
				<div class="category-chips">
					<a href="/blog/" class="category-chip active" data-category="">All</a>
					{BLOG_CATEGORIES.map((cat) => (
						<a href={`/blog/?category=${cat}`} class="category-chip" data-category={cat}>
							{CATEGORY_LABELS[cat]}
						</a>
					))}
					<a href="/blog/" class="clear-all" id="clear-all" style="display:none">Clear all</a>
				</div>
				<p class="article-count" id="article-count">{posts.length} {posts.length === 1 ? 'article' : 'articles'}</p>
			</div>

			{/*
				── Post Grid (first 6 visible; rest hidden, revealed via filter/pagination) ──
				NOTE: every post ships in the initial HTML (with `.post-card--hidden` on ones past the first 6).
				`loading="lazy"` on images + `display: none` on hidden cards means browsers don't
				decode off-screen images, so the image-cost concern is already mitigated.
				TODO(perf): if the archive grows past ~150 posts, switch to build-time pagination
				(e.g. `/blog/page/N` via getStaticPaths) so initial payload scales sub-linearly.
			*/}
			<div class="post-grid" id="post-grid-top">
				{posts.map((post, i) => {
					const author = getAuthor(post.data.author);
					return (
						<a
							href={`/blog/${post.id}/`}
							class={`post-card${i >= 6 ? ' post-card--hidden' : ''}`}
							data-title={post.data.title.toLowerCase()}
							data-description={post.data.description.toLowerCase()}
							data-categories={post.data.categories.join(' ').toLowerCase()}
							data-date={`${post.data.date.getFullYear()}-${String(post.data.date.getMonth() + 1).padStart(2, '0')}`}
						>
							<div class="post-card__image">
								<img src={post.data.featuredImage} alt={post.data.featuredImageAlt} loading="lazy" />
								<div class="post-card__badges">
									{post.data.categories.slice(0, 2).map((cat) => (
											<span class="post-card__badge" data-cat={cat}>
												{CATEGORY_LABELS[cat as BlogCategory] || cat}
											</span>
									))}
								</div>
							</div>
							<div class="post-card__body">
								<h3 class="post-card__title">{post.data.title}</h3>
								<span class="post-card__meta">
									{author && `By ${author.name} · `}
									{post.data.date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' })}
								</span>
								<p class="post-card__excerpt">{post.data.description}</p>
							</div>
						</a>
					);
				})}
			</div>
			<p class="no-posts" id="no-posts" style="display:none">No posts match your filters.</p>

			{/* ── Community CTA ── */}
			<div class="community-cta">
				<div class="community-cta__left">
					<h2 class="community-cta__title">Join ThingsBoard community</h2>
					<p class="community-cta__subtitle">Stay tuned and get first-hand updates and access to insights.</p>
					{/* Mailerlite wrapper structure — required for webforms.min.js to
					    intercept the submit, AJAX-post, and toggle in the inline
					    success state. Without it, target="_blank" lands on a blank
					    Mailerlite response page (designed to be rendered in their iframe). */}
					<div id="mlb2-z9h4b4-blog-index" class="ml-subscribe-form ml-subscribe-form-z9h4b4 community-cta__ml-wrap">
						{/* `role="status"` + `aria-live="polite"` so screen readers
						    announce the success message when JS reveals it via
						    `display: block`. `tabindex="-1"` so the JS handler
						    can focus it for keyboard users. */}
						<div class="subscribe-form ml-block-success" style="display:none" role="status" aria-live="polite" tabindex="-1">
							<p class="community-cta__success">Thank you! You're subscribed.</p>
						</div>
						<form
							action="https://static.mailerlite.com/webforms/submit/z9h4b4"
							data-id="6028548"
							data-code="z9h4b4"
							method="post"
							target="_blank"
							class="community-cta__form ml-block-form"
						>
							<input type="email" name="fields[email]" placeholder="Your email address" required class="community-cta__input" aria-label="Email address" />
							<input type="hidden" name="ml-submit" value="1" />
							<button type="submit" class="community-cta__btn">
								<span class="community-cta__btn-label">Subscribe</span>
								<span class="community-cta__btn-spinner" aria-hidden="true"></span>
							</button>
						</form>
					</div>
				</div>
				<div class="community-cta__right">
					<h3 class="community-cta__brand">
						<img src="/images/pricing/thingsboard-icon.svg" alt="" class="community-cta__logo" />
						ThingsBoard
					</h3>
					<p class="community-cta__desc">ThingsBoard is an open-source IoT platform for data collection, processing, visualization, and device management.<br/>ThingsBoard combines scalability, fault-tolerance and performance so you will never lose your data.</p>
					<div class="community-cta__socials">
						<a href="https://github.com/thingsboard/thingsboard" target="_blank" rel="noopener noreferrer" aria-label="GitHub"><Icon name="simple-icons:github" size={26} /></a>
						<a href="https://www.facebook.com/thingsboard/" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><Icon name="simple-icons:facebook" size={26} /></a>
						<a href="https://www.linkedin.com/company/thingsboard/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><Icon name="simple-icons:linkedin" size={26} /></a>
						<a href="https://stackoverflow.com/questions/tagged/thingsboard" target="_blank" rel="noopener noreferrer" aria-label="Stack Overflow"><Icon name="simple-icons:stackoverflow" size={26} /></a>
						<a href="https://twitter.com/thingsboard" target="_blank" rel="noopener noreferrer" aria-label="X"><Icon name="simple-icons:x" size={26} /></a>
						<a href="https://www.youtube.com/thingsboard" target="_blank" rel="noopener noreferrer" aria-label="YouTube"><Icon name="simple-icons:youtube" size={26} /></a>
					</div>
				</div>
			</div>

			{/* ── Pagination ── */}
			<div class="blog-pagination">
				<Pagination mode="interactive" hidden ariaLabel="Blog pagination" />
			</div>
		</div>
	</main>
</BlogLayout>

<script>
	import { updatePagination } from '@components/Pagination/pagination-client';

	const POSTS_PER_PAGE = 6;

	const gridTop = document.getElementById('post-grid-top')!;
	const paginationNav = document.querySelector<HTMLElement>('[data-tb-pagination]')!;
	const noPostsMsg = document.getElementById('no-posts')!;
	const categoryChips = document.querySelectorAll('.category-chip') as NodeListOf<HTMLAnchorElement>;
	const clearAll = document.getElementById('clear-all')!;
	const articleCount = document.getElementById('article-count')!;

	const allItems = Array.from(gridTop.querySelectorAll('.post-card')) as HTMLElement[];

	let currentCategory = '';
	let currentDate = '';
	let currentPage = 1;

	function readUrlParams() {
		const params = new URLSearchParams(window.location.search);
		currentCategory = params.get('category') || '';
		currentDate = params.get('date') || '';
		currentPage = parseInt(params.get('page') || '1', 10);
	}

	function updateUrl() {
		const params = new URLSearchParams();
		if (currentCategory) params.set('category', currentCategory);
		if (currentDate) params.set('date', currentDate);
		if (currentPage > 1) params.set('page', String(currentPage));
		const qs = params.toString();
		history.replaceState(null, '', '/blog/' + (qs ? '?' + qs : ''));
	}

	function getFilteredItems(): HTMLElement[] {
		return allItems.filter((el) =>
			(!currentCategory || (el.dataset.categories || '').includes(currentCategory)) &&
			(!currentDate || el.dataset.date === currentDate)
		);
	}

	function render() {
		const filtered = getFilteredItems();
		const total = filtered.length;
		const totalPages = Math.ceil(total / POSTS_PER_PAGE);
		if (currentPage > totalPages) currentPage = Math.max(1, totalPages);

		const start = (currentPage - 1) * POSTS_PER_PAGE;
		const visibleSet = new Set(filtered.slice(start, start + POSTS_PER_PAGE));

		for (const item of allItems) {
			item.classList.toggle('post-card--hidden', !visibleSet.has(item));
		}

		noPostsMsg.style.display = total === 0 ? '' : 'none';
		articleCount.textContent = `${total} article${total !== 1 ? 's' : ''}`;

		categoryChips.forEach((chip) => chip.classList.toggle('active', (chip.dataset.category || '') === currentCategory));
		clearAll.style.display = currentCategory ? '' : 'none';

		updatePagination(paginationNav, { currentPage, totalPages, hideOnSinglePage: true });
		updateUrl();
	}

	paginationNav.addEventListener('tb-pagination:page-change', (e) => {
		currentPage = (e as CustomEvent<{ page: number }>).detail.page;
		render();
		window.scrollTo({ top: gridTop.offsetTop - 120, behavior: 'smooth' });
	});

	categoryChips.forEach((chip) => {
		chip.addEventListener('click', (e) => {
			e.preventDefault();
			currentCategory = chip.dataset.category || '';
			currentDate = '';
			currentPage = 1;
			render();
		});
	});

	clearAll.addEventListener('click', (e) => {
		e.preventDefault();
		currentCategory = '';
		currentDate = '';
		currentPage = 1;
		render();
	});

	window.addEventListener('popstate', () => { readUrlParams(); render(); });

	readUrlParams();

	// The inline script at the top of <main> may have added .is-entering before children painted.
	// Clean it up after animations finish so future filter/pagination doesn't re-trigger anything.
	const blogPage = document.querySelector('.blog-page') as HTMLElement | null;
	if (blogPage?.classList.contains('is-entering')) {
		setTimeout(() => blogPage.classList.remove('is-entering', 'is-entering--no-grid'), 1600);
	}

	render();

	// ── Newsletter (Mailerlite) — submit directly via fetch instead of
	// loading Mailerlite's webforms.min.js. The lazy-loaded intercept script
	// was racing with the user's submit click on slower networks (form's
	// native `target="_blank"` fallback opened a useless ML response tab
	// before the script could bind), and was blocked outright by some
	// ad-blockers. The /webforms/submit/ endpoint accepts cross-origin
	// fire-and-forget POSTs, so the email lands even without the script.
	(function initBlogNewsletter() {
		const wrap = document.getElementById('mlb2-z9h4b4-blog-index');
		if (!wrap) return;
		const form = wrap.querySelector<HTMLFormElement>('form.ml-block-form');
		const success = wrap.querySelector<HTMLElement>('.ml-block-success');
		const emailInput = wrap.querySelector<HTMLInputElement>('input[type="email"]');
		const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
		if (!form || !success || !emailInput || !submitBtn) return;

		let submitted = false;
		form.addEventListener('submit', (e) => {
			e.preventDefault();
			if (submitted) return;
			if (!form.checkValidity()) return;
			submitted = true;
			submitBtn.disabled = true;
			submitBtn.setAttribute('aria-busy', 'true');
			submitBtn.classList.add('is-loading');

			// Fire-and-forget POST. `no-cors` means we can't read the response,
			// but Mailerlite's endpoint returns 200 for valid emails and the
			// signup still lands. Show success optimistically.
			fetch(form.action, {
				method: 'POST',
				body: new FormData(form),
				mode: 'no-cors',
				credentials: 'omit',
			}).catch(() => {
				// Network failure (offline, DNS, etc.) — still optimistic since
				// retry-flicker is a worse UX than a phantom "subscribed" state
				// the user can re-verify in their inbox.
			});

			emailInput.value = '';
			form.style.setProperty('display', 'none', 'important');
			success.style.setProperty('display', 'block', 'important');
			// Move keyboard focus into the success region — combined with
			// `role="status" aria-live="polite"` on the wrapper, this makes
			// the confirmation discoverable for screen-reader + keyboard users
			// (otherwise the form just silently vanishes from underneath them).
			success.focus();
		});
	})();
</script>

<style lang="scss" is:global>
	@use '../../styles/_variables.scss' as *;

	.blog-page {
		position: relative;
		overflow: hidden;
	}

	// ── Entrance animations (first paint at top of page only) ──

	@keyframes blog-enter-down {
		from {
			opacity: 0;
			transform: translate3d(0, -24px, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}

	@keyframes blog-enter-up {
		from {
			opacity: 0;
			transform: translate3d(0, 24px, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}

	.blog-page.is-entering {
		.blog-title         { animation: blog-enter-down 0.55s cubic-bezier(0.22, 1, 0.36, 1) both; }
		.carousel-section   { animation: blog-enter-down 0.65s cubic-bezier(0.22, 1, 0.36, 1) 0.08s both; }
		.filter-bar         { animation: blog-enter-up   0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.22s both; }
		.post-grid          { animation: blog-enter-up   0.65s cubic-bezier(0.22, 1, 0.36, 1) 0.30s both; }
	}

	// Skip grid animation when URL has active filters (grid re-renders mid-animation otherwise).
	.blog-page.is-entering--no-grid .post-grid { animation: none; }

	@media (prefers-reduced-motion: reduce) {
		.blog-page.is-entering,
		.blog-page.is-entering--no-grid {
			.blog-title, .carousel-section, .filter-bar, .post-grid { animation: none; }
		}
	}

	.blog-blobs {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		overflow: hidden;
	}

	.blog-blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(180px);
		opacity: 0.18;
		// Promote each blob to its own GPU layer so Safari rasterizes the huge
		// 180px blur once instead of every time a sibling (e.g. the carousel)
		// transforms. translateZ(0) is the cheaper cousin of will-change here —
		// these elements don't animate, they just need a stable cached bitmap.
		transform: translateZ(0);

		[data-theme='dark'] & {
			opacity: 0.05;
		}
	}

	.blog-blob--blue {
		width: 1100px;
		height: 1100px;
		background: #a8b4f0;
		top: 0;
		right: -500px;
	}

	.blog-blob--pink {
		width: 900px;
		height: 900px;
		background: #f5a0c0;
		top: 1400px;
		left: -400px;
	}

	.blog-blob--purple {
		width: 1200px;
		height: 1200px;
		background: #c090e0;
		top: 3000px;
		right: -500px;
	}

	.blog-blob--green {
		width: 800px;
		height: 800px;
		background: #80d0a0;
		top: 4500px;
		left: -350px;
	}

	.blog-container {
		@include container;
		max-width: 1080px;
		border-left: 1px solid var(--color-border);
		border-right: 1px solid var(--color-border);
		padding: var(--spacing-6) 0 0;
		position: relative;
		z-index: 1;

		@include media-down(lg) { border: none; padding-left: var(--spacing-4); padding-right: var(--spacing-4); }
	}

	.blog-title {
		font-size: 48px;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
		margin-bottom: var(--spacing-8);
		letter-spacing: -0.02em;
		padding-left: var(--spacing-5);
		padding-right: var(--spacing-5);
		@include media-down(md) { font-size: 36px; }
	}

	// ── Carousel ──

	.carousel-section {
		margin-bottom: var(--spacing-4);
		padding-left: var(--spacing-5);
		padding-right: var(--spacing-5);
		// Section provides the spacing; zero the shared Carousel's own margins
		--carousel-margin: 0;

		// Full-bleed on mobile: cancel .blog-container's gutter so the featured
		// card spans edge-to-edge. Below 1024px the container drops its border and
		// uses var(--spacing-4) side padding, so we offset by exactly that. Negative
		// margins (not 100vw/transform) so we don't clash with the transform-based
		// .carousel-section entrance animation above.
		@include media-down(md) {
			margin-left: calc(-1 * var(--spacing-4));
			margin-right: calc(-1 * var(--spacing-4));
			padding-left: 0;
			padding-right: 0;
		}
	}
	// Safari fix: isolate the carousel into its own paint/composite layer.
	// Without `contain: paint` and a GPU-layer hint, the slide transform
	// invalidates the giant blurred .blog-blob backgrounds (filter: blur(180px))
	// every frame, which Safari re-rasterizes — causing the slide-transition lag.
	// Chrome happens to layerize this on its own; Safari needs the explicit hint.
	.featured-carousel .carousel-viewport {
		contain: paint;
	}
	.featured-carousel .carousel-container {
		will-change: transform;
		transform: translateZ(0);
		// Full-viewport featured cards sit flush — no inter-slide gap (the shared
		// default is 20px). Override `gap` on the container directly: the wrapper
		// self-declares --carousel-gap, so a parent-level custom-prop override is
		// shadowed, and this 2-class selector beats the component's scoped rule.
		gap: 0;
	}

	.carousel__card {
		height: 100%;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0;
		background: linear-gradient(180deg, var(--color-bg-surface) 65%, #e4ecfb 100%);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		min-height: 420px;

		[data-theme='dark'] & {
			background: linear-gradient(180deg, var(--color-bg-surface) 65%, #1a2030 100%);
		}

		@include media-down(md) {
			grid-template-columns: 1fr;
			min-height: auto;
			// Card is flush to the screen edges here — rounded corners and side
			// borders would hug the viewport edge, so drop them.
			border-radius: 0;
			border-left: none;
			border-right: none;
		}
	}

	.carousel__text {
		padding: var(--spacing-8);
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: var(--spacing-3);
	}

	.carousel__badge {
		display: inline-block;
		width: fit-content;
		padding: 2px 8px;
		border-radius: 8px;
		font-size: $font-size-xs;
		font-weight: $font-weight-semibold;
		letter-spacing: 0.02em;
		border: 1.5px solid #0F1C8A;
		background: #EBEDFF;
		color: #0F1C8A;

