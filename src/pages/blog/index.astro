---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import { getAuthor } from '~/data/blog/authors';
import { Icon } from 'astro-icon/components';
import {
	BLOG_CATEGORIES,
	CATEGORY_LABELS,
	type BlogCategory,
} from '~/data/blog/categories';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredPosts = posts.slice(0, 5);
---

<BlogLayout
	title="Blog"
	description="ThingsBoard blog — product updates, technical guides, and IoT solutions."
	jsonLd={{
		'@context': 'https://schema.org',
		'@type': 'Blog',
		'@id': 'https://thingsboard.io/blog/#blog',
		name: 'ThingsBoard Blog',
		description: 'ThingsBoard blog — product updates, technical guides, and IoT solutions.',
		url: 'https://thingsboard.io/blog/',
		publisher: {
			'@type': 'Organization',
			name: 'ThingsBoard',
			url: 'https://thingsboard.io',
			logo: { '@type': 'ImageObject', url: 'https://thingsboard.io/images/thingsboard_logo_blue.svg' },
		},
	}}
>
	<section class="blog-page">
		<div class="blog-blobs" aria-hidden="true">
			<div class="blog-blob blog-blob--blue"></div>
			<div class="blog-blob blog-blob--pink"></div>
			<div class="blog-blob blog-blob--purple"></div>
			<div class="blog-blob blog-blob--green"></div>
		</div>
		<div class="blog-container">
			<h1 class="blog-title">Blog</h1>

			{/* ── Featured Carousel ── */}
			{featuredPosts.length > 0 && (
				<div class="carousel-section">
					<div class="carousel" id="featured-carousel">
						<div class="carousel__viewport">
							<div class="carousel__container">
								{featuredPosts.map((post) => {
									const author = getAuthor(post.data.author);
									const cat = post.data.categories[0] as BlogCategory;
									return (
										<div class="carousel__slide">
											<div class="carousel__text">
												<span class="carousel__badge" data-cat={cat}>
													{CATEGORY_LABELS[cat] || cat}
												</span>
												<h2 class="carousel__title">{post.data.title}</h2>
												{author && (
													<div class="carousel__author">
														<img src={author.avatar} alt={author.name} class="carousel__avatar" />
														<div>
															<span class="carousel__author-name">{author.name}</span>
															{author.role && <span class="carousel__author-role">{author.role}</span>}
														</div>
													</div>
												)}
												<p class="carousel__excerpt">{post.data.description}</p>
												<a href={`/blog/${post.id}/`} class="carousel__cta">
													Read more <Icon name="tabler:chevron-right" size={18} />
												</a>
											</div>
											<div class="carousel__image">
												<img src={post.data.featuredImage} alt={post.data.featuredImageAlt} />
											</div>
										</div>
									);
								})}
							</div>
						</div>
						<div class="carousel__dots" id="carousel-dots"></div>
					</div>
				</div>
			)}

			{/* ── Category Chips ── */}
			<div class="filter-bar">
				<div class="category-chips">
					<a href="/blog/" class="category-chip active" data-category="">All</a>
					{BLOG_CATEGORIES.map((cat) => (
						<a href={`/blog/?category=${cat}`} class="category-chip" data-category={cat}>
							{CATEGORY_LABELS[cat]}
						</a>
					))}
					<a href="/blog/" class="clear-all" id="clear-all" style="display:none">Clear all</a>
				</div>
				<p class="article-count" id="article-count"></p>
			</div>

			{/* ── Hidden card source ── */}
			<div id="card-source" style="display:none">
				{posts.map((post) => {
					const author = getAuthor(post.data.author);
					return (
						<a
							href={`/blog/${post.id}/`}
							class="post-card"
							data-title={post.data.title.toLowerCase()}
							data-description={post.data.description.toLowerCase()}
							data-categories={post.data.categories.join(' ').toLowerCase()}
							data-date={`${post.data.date.getFullYear()}-${String(post.data.date.getMonth() + 1).padStart(2, '0')}`}
						>
							<div class="post-card__image">
								<img src={post.data.featuredImage} alt={post.data.featuredImageAlt} loading="lazy" />
								<div class="post-card__badges">
									{post.data.categories.slice(0, 2).map((cat) => (
											<span class="post-card__badge" data-cat={cat}>
												{CATEGORY_LABELS[cat as BlogCategory] || cat}
											</span>
									))}
								</div>
							</div>
							<div class="post-card__body">
								<span class="post-card__meta">
									{author && `By ${author.name} · `}
									{post.data.date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' })}
								</span>
								<h3 class="post-card__title">{post.data.title}</h3>
								<p class="post-card__excerpt">{post.data.description}</p>
							</div>
						</a>
					);
				})}
			</div>

			{/* ── Post Grid (6 posts per page) ── */}
			<div class="post-grid" id="post-grid-top"></div>
			<p class="no-posts" id="no-posts" style="display:none">No posts match your filters.</p>

			{/* ── Community CTA ── */}
			<div class="community-cta">
				<div class="community-cta__left">
					<h2 class="community-cta__title">Join ThingsBoard community</h2>
					<p class="community-cta__subtitle">Stay tuned and get first-hand updates and access to insights.</p>
					<form
						action="https://thingsboard.us15.list-manage.com/subscribe/post?u=ef0e79cf5e18a386741e07661&id=295e227f23"
						method="post"
						target="_blank"
						class="community-cta__form"
					>
						<input type="email" name="EMAIL" placeholder="Your email address" required class="community-cta__input" />
						<button type="submit" class="community-cta__btn">Subscribe</button>
					</form>
				</div>
				<div class="community-cta__right">
					<h3 class="community-cta__brand">
						<img src="/images/pricing/thingsboard-icon.svg" alt="" class="community-cta__logo" />
						ThingsBoard
					</h3>
					<p class="community-cta__desc">ThingsBoard is an open-source IoT platform for data collection, processing, visualization, and device management.<br/>ThingsBoard combines scalability, fault-tolerance and performance so you will never lose your data.</p>
					<div class="community-cta__socials">
						<a href="https://github.com/thingsboard/thingsboard" target="_blank" rel="noopener noreferrer" aria-label="GitHub"><Icon name="simple-icons:github" size={26} /></a>
						<a href="https://www.facebook.com/thingsboard/" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><Icon name="simple-icons:facebook" size={26} /></a>
						<a href="https://www.linkedin.com/company/thingsboard/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><Icon name="simple-icons:linkedin" size={26} /></a>
						<a href="https://stackoverflow.com/questions/tagged/thingsboard" target="_blank" rel="noopener noreferrer" aria-label="Stack Overflow"><Icon name="simple-icons:stackoverflow" size={26} /></a>
						<a href="https://twitter.com/thingsboard" target="_blank" rel="noopener noreferrer" aria-label="X"><Icon name="simple-icons:x" size={26} /></a>
						<a href="https://www.youtube.com/thingsboard" target="_blank" rel="noopener noreferrer" aria-label="YouTube"><Icon name="simple-icons:youtube" size={26} /></a>
					</div>
				</div>
			</div>

			{/* ── Pagination ── */}
			<nav class="pagination" id="pagination" aria-label="Blog pagination"></nav>
		</div>
	</section>
</BlogLayout>

<script>
	import EmblaCarousel from 'embla-carousel';
	import Autoplay from 'embla-carousel-autoplay';

	const POSTS_PER_PAGE = 6;

	const cardSource = document.getElementById('card-source')!;
	const gridTop = document.getElementById('post-grid-top')!;
	const pagination = document.getElementById('pagination')!;
	const noPostsMsg = document.getElementById('no-posts')!;
	const categoryChips = document.querySelectorAll('.category-chip') as NodeListOf<HTMLAnchorElement>;
	const clearAll = document.getElementById('clear-all')!;
	const articleCount = document.getElementById('article-count')!;

	const allItems = Array.from(cardSource.querySelectorAll('.post-card')) as HTMLElement[];
	// Detach all items
	const fragment = document.createDocumentFragment();
	for (const item of allItems) fragment.appendChild(item);

	let currentCategory = '';
	let currentDate = '';
	let currentPage = 1;

	function readUrlParams() {
		const params = new URLSearchParams(window.location.search);
		currentCategory = params.get('category') || '';
		currentDate = params.get('date') || '';
		currentPage = parseInt(params.get('page') || '1', 10);
	}

	function updateUrl() {
		const params = new URLSearchParams();
		if (currentCategory) params.set('category', currentCategory);
		if (currentDate) params.set('date', currentDate);
		if (currentPage > 1) params.set('page', String(currentPage));
		const qs = params.toString();
		history.replaceState(null, '', '/blog/' + (qs ? '?' + qs : ''));
	}

	function getFilteredItems(): HTMLElement[] {
		return allItems.filter((el) => {
			if (currentCategory && !(el.dataset.categories || '').includes(currentCategory)) return false;
			if (currentDate && el.dataset.date !== currentDate) return false;
			return true;
		});
	}

	function renderPagination(totalItems: number) {
		const totalPages = Math.ceil(totalItems / POSTS_PER_PAGE);
		if (totalPages <= 1) { pagination.innerHTML = ''; return; }

		const pages: (number | '...')[] = [];
		if (totalPages <= 7) {
			for (let i = 1; i <= totalPages; i++) pages.push(i);
		} else {
			pages.push(1);
			if (currentPage > 3) pages.push('...');
			for (let i = Math.max(2, currentPage - 1); i <= Math.min(totalPages - 1, currentPage + 1); i++) pages.push(i);
			if (currentPage < totalPages - 2) pages.push('...');
			pages.push(totalPages);
		}

		let html = '<div class="pagination__pages">';
		for (const p of pages) {
			if (p === '...') html += `<span class="pagination__ellipsis">&hellip;</span>`;
			else if (p === currentPage) html += `<span class="pagination__page pagination__page--active">${p}</span>`;
			else html += `<button class="pagination__page" data-page="${p}">${p}</button>`;
		}
		html += '</div>';

		pagination.innerHTML = html;
		pagination.querySelectorAll('[data-page]').forEach((btn) => {
			btn.addEventListener('click', () => {
				currentPage = parseInt((btn as HTMLElement).dataset.page!, 10);
				render();
				window.scrollTo({ top: gridTop.offsetTop - 120, behavior: 'smooth' });
			});
		});
	}

	function render() {
		const filtered = getFilteredItems();
		const total = filtered.length;
		const totalPages = Math.ceil(total / POSTS_PER_PAGE);
		if (currentPage > totalPages) currentPage = Math.max(1, totalPages);

		const start = (currentPage - 1) * POSTS_PER_PAGE;
		const visible = filtered.slice(start, start + POSTS_PER_PAGE);

		gridTop.innerHTML = '';
		for (const item of visible) gridTop.appendChild(item);

		noPostsMsg.style.display = total === 0 ? '' : 'none';
		articleCount.textContent = `${total} article${total !== 1 ? 's' : ''}`;

		categoryChips.forEach((chip) => chip.classList.toggle('active', (chip.dataset.category || '') === currentCategory));
		clearAll.style.display = currentCategory ? '' : 'none';

		renderPagination(total);
		updateUrl();
	}

	categoryChips.forEach((chip) => {
		chip.addEventListener('click', (e) => {
			e.preventDefault();
			currentCategory = chip.dataset.category || '';
			currentDate = '';
			currentPage = 1;
			render();
		});
	});

	clearAll.addEventListener('click', (e) => {
		e.preventDefault();
		currentCategory = '';
		currentDate = '';
		currentPage = 1;
		render();
	});

	window.addEventListener('popstate', () => { readUrlParams(); render(); });

	// Carousel
	function initCarousel() {
		const viewport = document.querySelector('#featured-carousel .carousel__viewport');
		const dotsContainer = document.getElementById('carousel-dots');
		if (!viewport || !dotsContainer) return;

		const embla = EmblaCarousel(viewport as HTMLElement, { loop: true, align: 'center' }, [Autoplay({ delay: 5000, stopOnInteraction: true })]);
		const slides = embla.slideNodes();
		if (slides.length <= 1) return;

		Object.assign(dotsContainer.style, {
			display: 'flex', justifyContent: 'center', alignItems: 'center',
			gap: '8px', marginTop: '12px',
			background: 'var(--color-bg-light)', borderRadius: '100px',
			padding: '8px 14px', width: 'fit-content',
			marginLeft: 'auto', marginRight: 'auto',
			border: '1px solid var(--color-border)',
		});

		const dotBase = 'width:8px;height:8px;border-radius:50%;border:none;background:var(--color-text-muted);cursor:pointer;padding:0;transition:all .3s ease;';
		const dotActive = 'width:28px;height:8px;border-radius:100px;background:var(--color-primary);';

		slides.forEach((_, i) => {
			const dot = document.createElement('button');
			dot.style.cssText = dotBase;
			dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
			dot.addEventListener('click', () => embla.scrollTo(i));
			dotsContainer.appendChild(dot);
		});

		const dots = Array.from(dotsContainer.querySelectorAll('button'));
		function updateDots() {
			const selected = embla.selectedScrollSnap();
			dots.forEach((dot, i) => { dot.style.cssText = i === selected ? dotBase + dotActive : dotBase; });
		}
		embla.on('select', updateDots);
		updateDots();
	}

	readUrlParams();
	render();
	gridTop.style.display = '';
	initCarousel();
</script>

<style lang="scss" is:global>
	@use '~/styles/_variables.scss' as *;

	.blog-page {
		padding: #{$header-height} 0 0;
		position: relative;
		overflow: hidden;
	}

	.blog-blobs {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		overflow: hidden;
	}

	.blog-blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(180px);
		opacity: 0.18;

		[data-theme='dark'] & {
			opacity: 0.05;
		}
	}

	.blog-blob--blue {
		width: 1100px;
		height: 1100px;
		background: #a8b4f0;
		top: 0;
		right: -500px;
	}

	.blog-blob--pink {
		width: 900px;
		height: 900px;
		background: #f5a0c0;
		top: 1400px;
		left: -400px;
	}

	.blog-blob--purple {
		width: 1200px;
		height: 1200px;
		background: #c090e0;
		top: 3000px;
		right: -500px;
	}

	.blog-blob--green {
		width: 800px;
		height: 800px;
		background: #80d0a0;
		top: 4500px;
		left: -350px;
	}

	.blog-container {
		@include container;
		max-width: 1080px;
		border-left: 1px solid var(--color-border);
		border-right: 1px solid var(--color-border);
		padding: var(--spacing-6) 0 0;
		position: relative;
		z-index: 1;

		@include media-down(lg) { border: none; padding-left: var(--spacing-4); padding-right: var(--spacing-4); }
	}

	.blog-title {
		font-size: 48px;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
		margin-bottom: var(--spacing-8);
		letter-spacing: -0.02em;
		padding-left: var(--spacing-5);
		padding-right: var(--spacing-5);
		@include media-down(md) { font-size: 36px; }
	}

	// ── Carousel ──

	.carousel-section {
		margin-bottom: var(--spacing-4);
		padding-left: var(--spacing-5);
		padding-right: var(--spacing-5);
	}
	.carousel { position: relative; }
	.carousel__viewport { overflow: hidden; }
	.carousel__container { display: flex; }

	.carousel__slide {
		flex: 0 0 100%;
		min-width: 0;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0;
		background: linear-gradient(180deg, var(--color-bg-surface) 65%, #e4ecfb 100%);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		min-height: 420px;

		[data-theme='dark'] & {
			background: linear-gradient(180deg, var(--color-bg-surface) 65%, #1a2030 100%);
		}

		@include media-down(md) {
			grid-template-columns: 1fr;
			min-height: auto;
		}
	}

	.carousel__text {
		padding: var(--spacing-8);
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: var(--spacing-3);
	}

	.carousel__badge {
		display: inline-block;
		width: fit-content;
		padding: 2px 8px;
		border-radius: 8px;
		font-size: $font-size-xs;
		font-weight: $font-weight-semibold;
		letter-spacing: 0.02em;
		border: 1.5px solid #0F1C8A;
		background: #EBEDFF;
		color: #0F1C8A;

		[data-theme='dark'] & {
			background: #1e2240;
			color: #8b9af0;
			border-color: #3a4280;
		}
	}

	.carousel__title {
		font-size: $font-size-2xl;
		font-weight: $font-weight-bold;
		color: var(--color-text);
		line-height: 1.3;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.carousel__author {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
	}

	.carousel__avatar {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	.carousel__author-name {
		display: block;
		font-size: $font-size-sm;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
	}

	.carousel__author-role {
		display: block;
		font-size: $font-size-xs;
		color: var(--color-text-muted);
	}

	.carousel__excerpt {
		@include text-s;
		color: var(--color-text-secondary);
		display: -webkit-box;
		-webkit-line-clamp: 4;
		-webkit-box-orient: vertical;
		overflow: hidden;
		line-height: 1.65;
	}

	.carousel__cta {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		width: fit-content;
		padding: 10px 24px;
		background: var(--color-primary);
		color: var(--sl-color-black);
		font-weight: $font-weight-semibold;
		font-size: $font-size-sm;
		border-radius: $radius-md;
		text-decoration: none;
		transition: opacity 0.2s;
		margin-top: var(--spacing-2);

		&:hover { opacity: 0.85; }

		svg { width: 16px; height: 16px; }
	}

	.carousel__image {
		padding: var(--spacing-5);

		img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
			border-radius: var(--radius-lg);
		}

		@include media-down(md) {
			min-height: 200px;
			padding: 0 var(--spacing-3) var(--spacing-3);
		}
	}

	// ── Filter Bar ──

	.filter-bar {
		margin-bottom: var(--spacing-4);
		padding-left: var(--spacing-5);
		padding-right: var(--spacing-5);
	}

	.category-chips {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-2);
	}

	.category-chip {
		display: inline-flex;
		align-items: center;
		padding: 6px 16px;
		border: 1px solid var(--color-border);
		border-radius: $radius-full;
		@include text-s;
		color: var(--color-text-secondary);
		text-decoration: none;
		cursor: pointer;
		transition: all 0.15s;
		background: transparent;

		&:hover {
			border-color: var(--color-primary);
			color: var(--color-primary);
		}

		&.active {
			border-color: var(--color-primary);
			background: var(--color-primary);
			color: var(--sl-color-black);
			font-weight: $font-weight-medium;
		}
	}

	.clear-all {
		@include text-s;
		color: var(--color-primary);
		text-decoration: none;
		font-weight: $font-weight-medium;
		margin-left: var(--spacing-2);
		cursor: pointer;
		&:hover { text-decoration: underline; }
	}

	.article-count {
		@include text-s;
		color: var(--color-text-muted);
		margin: 0;
	}

	// ── Post Grid ──

	.post-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-8);

		@include media-down(md) { grid-template-columns: 1fr; }
	}

	.post-card {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
		background: none;
		box-shadow: none;
		border-radius: 0;
		padding: 0;
	}

	.post-card__image {
		position: relative;
		aspect-ratio: 2 / 1;
		overflow: hidden;
		border-radius: var(--radius-md);
		background: var(--color-bg-light);

		img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
	}

	.post-card__badges {
		position: absolute;
		top: var(--spacing-3);
		left: var(--spacing-3);
		display: flex;
		gap: var(--spacing-1);
	}

	.post-card__badge {
		padding: 2px 8px;
		border-radius: 4px;
		font-size: $font-size-xs;
		font-weight: $font-weight-semibold;
		border: 1.5px solid #0F1C8A;
		background: #EBEDFF;
		color: #0F1C8A;

		[data-theme='dark'] & {
			background: #1e2240;
			color: #8b9af0;
			border-color: #3a4280;
		}
	}

	.post-card__body {
		padding: var(--spacing-3) var(--spacing-4) var(--spacing-5);
	}

	.post-card__meta {
		font-size: $font-size-sm;
		color: var(--color-text);
