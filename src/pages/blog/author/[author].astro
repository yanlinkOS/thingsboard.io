---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import BlogCard from '~/components/Blog/BlogCard.astro';
import { getCollection } from 'astro:content';
import { BLOG_AUTHORS, type BlogAuthor } from '~/data/blog/authors';
import { blogSchema } from '~/content.config';
import type { z } from 'astro/zod';

type BlogData = z.infer<typeof blogSchema>;

export function getStaticPaths() {
	return BLOG_AUTHORS.map((author) => ({
		params: { author: author.slug },
		props: { author },
	}));
}

const { author } = Astro.props as { author: BlogAuthor };
type BlogPost = { id: string; data: BlogData; collection: 'blog' };
const allPosts = (await getCollection('blog', ({ data }) => !(data as BlogData).draft && (data as BlogData).author === author.slug)) as unknown as BlogPost[];
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BlogLayout title={`${author.name} — Blog`} description={`Blog posts by ${author.name}.`} noIndex={true}>
	<section class="author-page">
		<div class="author-container">
			<nav class="breadcrumb">
				<a href="/blog/">Blog</a>
				<span>/</span>
				<span>{author.name}</span>
			</nav>

			<div class="author-profile">
				<img src={author.avatar} alt={author.name} class="author-avatar" />
				<div>
					<h1>{author.name}</h1>
					{author.bio && <p class="author-bio">{author.bio}</p>}
					<p class="author-post-count">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
				</div>
			</div>

			<div class="blog-grid">
				{posts.length === 0 ? (
					<p class="no-posts">No posts by this author yet.</p>
				) : (
					posts.map((post) => (
						<BlogCard post={post} />
					))
				)}
			</div>
		</div>
	</section>
</BlogLayout>

<style lang="scss" is:global>
	@use '../../../styles/_variables.scss' as *;

	.author-page .author-container { @include container; max-width: 1200px; }
	.author-page { padding: calc(#{$header-height} + #{$spacing-10}) 0 #{$spacing-16}; }

	.breadcrumb {
		display: flex; align-items: center; gap: var(--spacing-2);
		@include text-s; color: var(--color-text-muted); margin-bottom: var(--spacing-6);
		a { color: var(--color-primary); text-decoration: none; &:hover { text-decoration: underline; } }
	}

	.author-profile {
		display: flex; align-items: center; gap: var(--spacing-5);
		margin-bottom: var(--spacing-8); padding-bottom: var(--spacing-8); border-bottom: 1px solid var(--color-border);
		h1 { @include section-title; color: var(--color-text); margin-bottom: var(--spacing-1); }
	}

	.author-avatar { width: 80px; height: 80px; border-radius: 50%; flex-shrink: 0; }
	.author-bio { @include text-m; color: var(--color-text-secondary); margin-bottom: var(--spacing-1); }
	.author-post-count { @include text-s; color: var(--color-text-muted); }

	.blog-grid {
		display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--spacing-6);
		@include media-down(lg) { grid-template-columns: repeat(2, 1fr); }
		@include media-down(sm) { grid-template-columns: 1fr; }
	}

	.no-posts { @include text-m; color: var(--color-text-secondary); text-align: center; grid-column: 1 / -1; padding: var(--spacing-10); }
</style>
