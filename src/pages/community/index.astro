---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
	title="IoT Community | ThingsBoard"
	description="Join the ThingsBoard community — calendar of events, social channels, GitHub project, and forums for discussions and support."
	customTitle={true}
>
	<section id="hero" class="light-text"></section>

	<section id="encyclopedia">
		<div id="docsContent" class="noToc">
			<div id="content">
				<h1>Community</h1>
				<h3>Events</h3>
				<div id="calendarWrapper">
					<iframe
						src="https://calendar.google.com/calendar/b/1/embed?src=thingsboard.io_vvdkrvseju3jjahct9pk00nh0o@group.calendar.google.com"
						width="100%"
						height="100%"
					></iframe>
				</div>

				<section id="talkToUs">
					<h3>Talk to Us!</h3>
					<h4>We would love to hear from you, how you are using ThingsBoard,<br /> and what we can do to make it better.</h4>
					<div id="bigSocial">
						<a href="https://twitter.com/thingsboard">
							<h5 class="social-heading">@thingsboard</h5>
							<p>Get the latest news and updates.</p>
						</a>
						<a href="https://github.com/thingsboard/thingsboard">
							<h5 class="social-heading">Github Project</h5>
							<p>Check out the project and consider contributing.</p>
						</a>
						<a href="https://stackoverflow.com/questions/tagged/thingsboard">
							<h5 class="social-heading">Stack Overflow</h5>
							<p>The ThingsBoard team will also monitor posts tagged thingsboard. If there aren't any existing questions that help, please ask a new one!</p>
						</a>
					</div>
				</section>
			</div>
		</div>
	</section>
</BaseLayout>

<style lang="scss">
	@use '../../styles/variables' as *;

	#encyclopedia {
		position: relative;
		padding: 50px 30px 20px 30px;
		overflow: hidden;
		font-size: 14px;
	}

	#docsContent {
		position: relative;
		width: 100%;
	}

	#content {
		padding-bottom: 30px;
		max-width: 1200px;
		margin: auto;

		h1:first-of-type {
			margin-bottom: 40px;
		}

		h3 {
			font-size: 20px;
			font-weight: 600;
			margin-bottom: 16px;
			color: var(--color-text);
		}

		h4 {
			font-size: 16px;
			font-weight: 400;
			color: var(--color-text-secondary);
			margin-bottom: 24px;
			line-height: 1.5;
		}
	}

	#calendarWrapper {
		height: 300px;
		margin-bottom: 48px;

		iframe {
			width: 100%;
			height: 100%;
			border: 0;
		}
	}

	#talkToUs {
		padding: 0;
		margin-bottom: 48px;
	}

	#bigSocial {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-start;

		a {
			position: relative;
			display: block;
			cursor: pointer;
			text-decoration: none;
			margin-top: 20px;
			padding: 66px 24px 24px;
			background-position: 24px 24px;
			background-size: 32px;
			background-repeat: no-repeat;
			border: 1px solid #ebebeb;
			border-radius: 4px;
			color: #212529;
			width: 100%;

			&::after {
				content: '';
				background-image: url('/images/link-arrow.svg');
				background-size: contain;
				display: block;
				position: absolute;
				right: 14px;
				top: 14px;
				width: 8px;
				height: 9px;
				border: none;
			}

			&:hover {
				border: 4px solid #2a7dec;
				padding: 63px 21px 21px;
				background-position: 21px 21px;
				box-shadow: 0px 0px 30px rgba(0, 0, 0, 0.05), 0px 30px 30px -20px rgba(0, 0, 0, 0.15);

				&::after {
					right: 11px;
					top: 11px;
				}
			}

			h5.social-heading {
				color: #2a7dec;
				font-weight: 500;
				font-size: 18px;
				line-height: 27px;
				padding: 0;
				margin: 0 0 2px;
			}

			p {
				font-weight: 300;
				font-size: 16px;
				line-height: 24px;
				padding: 0;
				margin: 0;
				color: #212529;
			}

			&:nth-child(1) { background-image: url('/images/twitter_icon.png'); }
			&:nth-child(2) { background-image: url('/images/github_icon.png'); }
			&:nth-child(3) { background-image: url('/images/stackoverflow_icon.png'); }

			@media screen and (min-width: 640px) {
				width: calc((100% - 16px) / 2);

				&:nth-child(even) {
					margin-left: 16px;
				}
			}

			@media screen and (min-width: 1280px) {
				width: calc((100% - 16px * (4 - 1)) / 4);

				&:nth-child(even) {
					margin-left: 0;
				}

				&:not(:first-child) {
					margin-left: 16px;
				}
			}
		}
	}
</style>
