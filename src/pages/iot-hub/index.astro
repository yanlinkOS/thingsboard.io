---
import BaseLayout from '~/layouts/BaseLayout.astro';
import IotHubHero from '~/components/IotHub/IotHubHero.astro';
import CategorySection from '~/components/IotHub/CategorySection.astro';
import { getCollection } from 'astro:content';
import { IOT_HUB_CATEGORIES, HOME_PER_CATEGORY } from '~/config/iot-hub';

const all = await getCollection('iotHubListings');

// Collection already sorted by installCount DESC inside the loader, per category in API order.
// Re-group by itemType to be defensive about any future loader changes.
const grouped = IOT_HUB_CATEGORIES.map((cat) => ({
	cat,
	entries: all
		.filter((e) => e.data.itemType === cat.itemType)
		.sort((a, b) => b.data.installCount - a.data.installCount)
		.slice(0, HOME_PER_CATEGORY),
}));

const title = 'IoT Hub | ThingsBoard';
const description =
	'Discover devices, solution templates, widgets, calculated fields, alarm rules, and rule chains published to the ThingsBoard IoT Hub.';
---

<BaseLayout title={title} description={description}>
	<main class="iot-hub-home">
		<IotHubHero />
		{
			grouped.map(({ cat, entries }) => (
				<CategorySection
					categorySlug={cat.slug}
					categoryLabel={cat.label}
					entries={entries}
				/>
			))
		}
	</main>
</BaseLayout>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-home {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem 4rem;
	}
</style>
