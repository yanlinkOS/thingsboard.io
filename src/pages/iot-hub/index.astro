---
import BaseLayout from '@layouts/BaseLayout.astro';
import IotHubHero from '@components/IotHub/IotHubHero.astro';
import CategoryTilesGrid from '@components/IotHub/CategoryTilesGrid.astro';
import CategorySection from '@components/IotHub/CategorySection.astro';
import CreatorCTA from '@components/IotHub/CreatorCTA.astro';
import { getCollection } from 'astro:content';
import { IOT_HUB_CATEGORIES, HOME_PER_CATEGORY } from '@models/iot-hub';

const categories = await getCollection('iotHubCategories');
const byId = new Map(categories.map((c) => [c.id, c.data]));

// `items` inside each category is already in API order (installCount DESC).
const grouped = IOT_HUB_CATEGORIES.map((cat) => ({
	cat,
	items: byId.get(cat.slug)?.items.slice(0, HOME_PER_CATEGORY) ?? [],
}));

const title = 'IoT Hub | ThingsBoard';
const description =
	'Discover devices, solution templates, widgets, calculated fields, alarm rules, and rule chains published to the ThingsBoard IoT Hub.';
---

<BaseLayout title={title} description={description}>
	<main class="iot-hub-home">
		<section class="iot-hub-home__top">
			<div class="iot-hub-home__bg" aria-hidden="true">
				<div class="iot-hub-home__pattern"></div>
				<span class="iot-hub-home__blob iot-hub-home__blob--left"></span>
				<span class="iot-hub-home__blob iot-hub-home__blob--right"></span>
			</div>
			<div class="iot-hub-home__top-inner">
				<IotHubHero />
				<CategoryTilesGrid />
			</div>
		</section>
		<div class="iot-hub-home__divider"></div>
		<div class="iot-hub-home__container">
			<div class="iot-hub-home__items">
				<h2 class="iot-hub-home__heading">Most popular in IoT Hub</h2>
				{
					grouped.map(({ cat, items }) => (
						<CategorySection
							categorySlug={cat.slug}
							categoryLabel={cat.label}
							items={items}
						/>
					))
				}
			</div>
		</div>
		<div class="iot-hub-home__divider"></div>
		<div class="iot-hub-home__container">
			<CreatorCTA />
		</div>
	</main>
</BaseLayout>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-home__top {
		position: relative;
		overflow: hidden;
		isolation: isolate;
		// `--iot-hub-active-accent` is set on this element by the IotHubHero
		// cycle/hover script (see IotHubHero.astro) and inherited by both the
		// highlighted word and the background blobs below, so they always
		// share the same current category color.
	}

	.iot-hub-home__top-inner {
		position: relative;
		max-width: 1080px;
		margin: 0 auto;
		// Figma: 80px gap from the category tiles to the divider that follows.
		padding-bottom: 80px;
		// Hairline side borders flanking the 1080px content column (Figma).
		border-right: 1px solid var(--hairline---sl-color-hairline, #edeef3);
		border-left: 1px solid var(--hairline---sl-color-hairline, #edeef3);
	}

	.iot-hub-home__bg {
		position: absolute;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		overflow: hidden;
	}

	.iot-hub-home__pattern {
		position: absolute;
		inset: 0;
		background-image: radial-gradient(
			circle,
			rgba(23, 24, 28, 0.1) 1px,
			transparent 1.2px
		);
		background-size: 24px 24px;
		background-position: 0 0;

		[data-theme='dark'] & {
			background-image: radial-gradient(
				circle,
				rgba(228, 229, 231, 0.05) 1px,
				transparent 1.2px
			);
		}
	}

	.iot-hub-home__blob {
		position: absolute;
		width: 568px;
		height: 568px;
		border-radius: 50%;
		pointer-events: none;
		// Follows the active category accent (see `.iot-hub-home__top` above);
		// transition smooths the cross-fade when the hero script swaps the var.
		background-color: var(--iot-hub-active-accent, #4c63cc);
		opacity: 0.16;
		filter: blur(120px);
		transition: background-color $transition-fast;

		&--left {
			top: 120px;
			left: -284px;
		}

		&--right {
			top: 335px;
			right: -284px;
		}
	}

	.iot-hub-home__container {
		max-width: 1080px;
		margin: 0 auto;
		// Hairline side borders flanking the 1080px content column (Figma).
		border-right: 1px solid var(--hairline---sl-color-hairline, #edeef3);
		border-left: 1px solid var(--hairline---sl-color-hairline, #edeef3);
	}

	.iot-hub-home__divider {
		height: 1px;
		// Hairline token from Figma; falls back to the literal #EDEEF3 if the
		// CSS variable isn't defined in the active theme.
		background: var(--hairline---sl-color-hairline, #edeef3);
	}

	.iot-hub-home__items {
		// 80px gap from the divider above to the "Most popular" heading (Figma).
		// Owns the full distance so the heading itself carries no top margin.
		padding-top: 80px;
		// 16px bottom padding so the last section's 64px margin-bottom can't
		// collapse through this wrapper — combined gap to the divider below
		// is then 64px + 16px = 80px (Figma).
		padding-bottom: 16px;
	}

	.iot-hub-home__heading {
		font-size: 32px;
		font-weight: $font-weight-semibold;
		line-height: 40px;
		// No bottom spacing — the first iot-hub-section's 64px margin-top
		// alone provides the heading -> first section gap (Figma).
		margin: 0 1rem;
		color: var(--color-text);

		@include media-down(md) {
			font-size: 24px;
			line-height: 32px;
		}
	}
</style>
