---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import {
	IOT_HUB_API_URL,
	resolveImage,
	type IotHubNodeInfo,
	type ListingDetail,
} from '@models/iot-hub';
import BaseLayout from '@layouts/BaseLayout.astro';
import CreatorCTA from '@components/IotHub/CreatorCTA.astro';
import DetailHero from '@components/IotHub/DetailHero.astro';
import DetailMeta from '@components/IotHub/DetailMeta.astro';
import DetailRuleNodes from '@components/IotHub/DetailRuleNodes.astro';
import IotHubMarkdown from '@components/IotHub/IotHubMarkdown.astro';
import { fetchWithRetry } from '@util/fetch-utils';

// Pure-numeric slugs are excluded to avoid colliding with pagination URLs
// (`/iot-hub/{cat}/2/`, `/3/`, …) produced by the sibling `[...page]` route.
export const getStaticPaths = (async () => {
	const categories = await getCollection('iotHubCategories');
	return categories.flatMap((catEntry) =>
		catEntry.data.items
			.filter((item) => !/^\d+$/.test(item.slug))
			.map((item) => ({
				params: { category: catEntry.id, slug: item.slug },
				props: { item },
			}))
	);
}) satisfies GetStaticPaths;

const { item } = Astro.props;
const { category } = Astro.params;

async function loadDetail(slug: string): Promise<ListingDetail | null> {
	try {
		const res = await fetchWithRetry(
			`${IOT_HUB_API_URL}/api/listings/public/by-slug/${slug}`
		);
		return (await res.json()) as ListingDetail;
	} catch (e) {
		if (import.meta.env.DEV) {
			const msg = e instanceof Error ? e.message : String(e);
			console.warn(`[iot-hub] detail fetch failed in dev for ${slug}: ${msg}`);
			return null;
		}
		throw e;
	}
}

const detail = await loadDetail(item.slug);

const title = detail?.seoTitle ?? detail?.name ?? item.name;
const description =
	detail?.seoMetaDescription ?? detail?.description ?? item.description ?? '';
const ogImageUrl =
	resolveImage(detail?.ogImage ?? null) ??
	resolveImage(detail?.image ?? item.image) ??
	undefined;

// Rule-chain only: extract NodeInfo[] from the primary variant's
// dataDescriptor and render the chip row. Other item
// types skip this section entirely.
const ruleNodes: IotHubNodeInfo[] =
	detail?.itemType === 'RULE_CHAIN' &&
	detail.dataDescriptor &&
	typeof detail.dataDescriptor === 'object'
		? ((detail.dataDescriptor as { nodes?: IotHubNodeInfo[] }).nodes ?? [])
		: [];
---

<BaseLayout title={title} description={description} ogImage={ogImageUrl}>
	<main class="iot-hub-detail">
		{
			detail ? (
				<>
					<div class="iot-hub-detail__center">
						<div class="iot-hub-detail__container">
							<DetailHero detail={detail} categorySlug={category!} />
							<DetailMeta detail={detail} />
							{ruleNodes.length > 0 && <DetailRuleNodes nodes={ruleNodes} />}
							{detail.readmeContent && (
								<div class="iot-hub-detail__readme">
									<IotHubMarkdown markdown={detail.readmeContent} listingDetail={detail} />
								</div>
							)}
						</div>
					</div>
					<div class="iot-hub-detail__divider" />
					<div class="iot-hub-detail__center">
						<div class="iot-hub-detail__container">
							<CreatorCTA />
						</div>
					</div>
				</>
			) : (
				<div class="iot-hub-detail__center">
					<div class="iot-hub-detail__container">
						<p class="iot-hub-detail__empty">
							Listing details are temporarily unavailable.
						</p>
					</div>
				</div>
			)
		}
	</main>
</BaseLayout>

<style lang="scss">
	@use '../../../styles/_variables.scss' as *;
	@use '../../../styles/_iot-hub.scss' as *;

	.iot-hub-detail {
		@include iot-hub-hairline-token;
	}

	.iot-hub-detail__center {
		@include iot-hub-center;
	}

	.iot-hub-detail__container {
		@include iot-hub-container;
	}

	.iot-hub-detail__divider {
		@include iot-hub-divider;
	}

	.iot-hub-detail__readme {
		padding: 16px 16px 40px 16px;
		@include media-down(sm) {
			padding: 16px 12px 40px 12px;
		}
	}

	.iot-hub-detail__empty {
		text-align: center;
		color: var(--color-text-muted);
		padding: 4rem 1rem;
	}
</style>
