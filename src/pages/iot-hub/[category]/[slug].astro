---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import {
	IOT_HUB_API_URL,
	IOT_HUB_CATEGORIES,
	resolveImage,
	type ListingDetail,
} from '@models/iot-hub';
import DetailHero from '@components/IotHub/DetailHero.astro';
import DetailMeta from '@components/IotHub/DetailMeta.astro';
import DetailGallery from '@components/IotHub/DetailGallery.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { fetchWithRetry } from '@util/fetch-utils';

// Pure-numeric slugs are excluded to avoid colliding with pagination URLs
// (`/iot-hub/{cat}/2/`, `/3/`, …) produced by the sibling `[...page]` route.
export const getStaticPaths = (async () => {
	const all = await getCollection('iotHubListings');
	return IOT_HUB_CATEGORIES.flatMap((cat) =>
		all
			.filter((e) => e.data.itemType === cat.itemType && !/^\d+$/.test(e.data.slug))
			.map((entry) => ({
				params: { category: cat.slug, slug: entry.data.slug },
				props: { entry, categoryLabel: cat.label },
			}))
	);
}) satisfies GetStaticPaths;

const { entry, categoryLabel } = Astro.props;
const { category } = Astro.params;

// Module-scoped processor so the unified/remark/rehype pipeline is created
// once per build worker, not once per detail page.
const markdownProcessor = await createMarkdownProcessor();

async function loadDetail(slug: string): Promise<ListingDetail | null> {
	try {
		const res = await fetchWithRetry(
			`${IOT_HUB_API_URL}/api/listings/public/by-slug/${slug}`
		);
		return await res.json() as ListingDetail;
	} catch (e) {
		if (import.meta.env.DEV) {
			const msg = e instanceof Error ? e.message : String(e);
			console.warn(`[iot-hub] detail fetch failed in dev for ${slug}: ${msg}`);
			return null;
		}
		throw e;
	}
}

const detail = await loadDetail(entry.data.slug);

// Render readmeContent → HTML using Astro's own markdown processor.
let readmeHtml: string | null = null;
if (detail?.readmeContent) {
	const result = await markdownProcessor.render(detail.readmeContent);
	readmeHtml = result.code;
}

const title = detail?.seoTitle ?? detail?.name ?? entry.data.name;
const description =
	detail?.seoMetaDescription ?? detail?.description ?? entry.data.description ?? '';
const ogImageUrl =
	resolveImage(detail?.ogImage ?? null) ??
	resolveImage(detail?.image ?? entry.data.image) ??
	undefined;
---

<BaseLayout title={title} description={description} ogImage={ogImageUrl}>
	{
		detail ? (
			<>
				<nav class="iot-hub-detail-crumbs" aria-label="Breadcrumb">
					<a href="/iot-hub/">IoT Hub</a>
					<span aria-hidden="true">/</span>
					<a href={`/iot-hub/${category}/`}>{categoryLabel}</a>
				</nav>
				<DetailHero detail={detail} />
				<DetailMeta detail={detail} />
				<DetailGallery screenshots={detail.screenshots} listingName={detail.name} />
				{readmeHtml ? (
					<section class="iot-hub-detail-readme">
						<h2>About</h2>
						<div set:html={readmeHtml} />
					</section>
				) : null}
			</>
		) : (
			<p>Listing details are temporarily unavailable.</p>
		)
	}
</BaseLayout>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-detail-crumbs {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.875rem;
		color: var(--color-text-muted, #6b7280);
		margin-bottom: 0.5rem;

		a {
			color: var(--color-accent, #305680);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}

	.iot-hub-detail-readme {
		margin-top: 2rem;
	}
</style>
