---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import CategoryHero from '@components/IotHub/CategoryHero.astro';
import CreatorCTA from '@components/IotHub/CreatorCTA.astro';
import FilterPanel from '@components/IotHub/FilterPanel.astro';
import ListingCard from '@components/IotHub/ListingCard.astro';
import ListingGrid from '@components/IotHub/ListingGrid.astro';
import ListingsFilterBar from '@components/IotHub/ListingsFilterBar.astro';
import PaginationLink from '@components/IotHub/PaginationLink.astro';
import { getCollection } from 'astro:content';
import {
	IOT_HUB_CATEGORIES,
	IOT_HUB_STRINGS,
	PAGE_SIZE,
	getCardVariant,
	type ItemTypeFilterInfo,
	type IotHubItemType,
} from '@models/iot-hub';

export const getStaticPaths = (async ({ paginate }) => {
	const categories = await getCollection('iotHubCategories');
	return categories.flatMap((catEntry) =>
		paginate(
			catEntry.data.items.filter((item) => !/^\d+$/.test(item.slug)),
			{
				params: { category: catEntry.id },
				pageSize: PAGE_SIZE,
				props: {
					itemType: catEntry.data.itemType,
					filterInfo: catEntry.data.filterInfo,
				},
			}
		)
	);
}) satisfies GetStaticPaths;

interface Props {
	page: import('astro').Page;
	itemType: IotHubItemType;
	filterInfo: ItemTypeFilterInfo;
}

const { page, itemType, filterInfo } = Astro.props as Props;
const { category } = Astro.params;
const basePath = `/iot-hub/${category}/`;
const variant = getCardVariant(page.data[0]?.itemType ?? '');
const catConfig = IOT_HUB_CATEGORIES.find((c) => c.slug === category);
const heroTitle = catConfig?.tileLabel ?? '';

const title = `${heroTitle} | IoT Hub | ThingsBoard`;
const description =
	catConfig?.heroDescription ??
	`Browse ${heroTitle.toLowerCase()} published to the ThingsBoard IoT Hub.`;
const searchPlaceholder = heroTitle
	? `Search ${heroTitle.toLowerCase()}...`
	: 'Search...';
---

<BaseLayout title={title} description={description}>
	<main class="iot-hub-cat">
		<div class="iot-hub-cat__center">
			<div class="iot-hub-cat__container">
				<CategoryHero categorySlug={category!} />
			</div>
		</div>
		<div class="iot-hub-cat__divider"></div>
		<div class="iot-hub-cat__center">
			<div class="iot-hub-cat__container">
				<div
					class="iot-hub-cat__listings-wrap"
					data-iot-hub-listings-wrap
					data-filter-open="false"
				>
					<FilterPanel itemType={itemType} filterInfo={filterInfo} />
					<div
						class="iot-hub-cat__backdrop"
						data-iot-hub-filter-backdrop
						aria-hidden="true"
					>
					</div>
					<div class="iot-hub-cat__listings">
						<ListingsFilterBar
							totalCount={page.total}
							searchPlaceholder={searchPlaceholder}
						/>
						{
							page.data.length > 0 ? (
								<>
									<ListingGrid variant={variant}>
										{page.data.map((item) => (
											<ListingCard item={item} categorySlug={category!} />
										))}
									</ListingGrid>
									<PaginationLink
										currentPage={page.currentPage}
										totalPages={page.lastPage}
										basePath={basePath}
									/>
								</>
							) : (
								<p class="iot-hub-cat__empty">{IOT_HUB_STRINGS.emptyState}</p>
							)
						}
					</div>
				</div>
			</div>
		</div>
		<div class="iot-hub-cat__divider"></div>
		<div class="iot-hub-cat__center">
			<div class="iot-hub-cat__container">
				<CreatorCTA />
			</div>
		</div>
	</main>
</BaseLayout>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.iot-hub-cat {
		--iot-hub-hairline: var(--hairline---sl-color-hairline, #edeef3);

		:global([data-theme='dark']) & {
			--iot-hub-hairline: var(--hairline---sl-color-hairline, #23262f);
		}
	}

	.iot-hub-cat__center {
		margin: 0 auto;
		max-width: calc(#{$container-max-width} + 32px);

		@include media-down(sm) {
			max-width: calc(#{$container-max-width} + 16px);
		}
	}

	.iot-hub-cat__container {
		max-width: $container-max-width;
		margin: 0 16px;
		border-right: 1px solid var(--iot-hub-hairline);
		border-left: 1px solid var(--iot-hub-hairline);

		@include media-down(sm) {
			margin: 0 8px;
		}
	}

	.iot-hub-cat__divider {
		height: 1px;
		background: var(--iot-hub-hairline);
	}

	.iot-hub-cat__listings-wrap {
		position: relative;
		display: flex;
		align-items: stretch;
		min-height: 0;
	}

	.iot-hub-cat__listings {
		display: flex;
		flex-direction: column;
		gap: 24px;
		padding-bottom: 40px;
		flex: 1 1 0;
		min-width: 0;
	}

	.iot-hub-cat__backdrop {
		display: none;

		@include media-down(lg) {
			.iot-hub-cat__listings-wrap[data-filter-open='true'] & {
				display: block;
				position: fixed;
				// Start below the sticky site header so the header stays
				// tappable. `$header-height` not `var(--sl-nav-height)` —
				// see FilterPanel.astro for why the CSS var is wrong here.
				inset: $header-height 0 0 0;
				background: rgba(0, 0, 0, 0.4);
				// Just below the panel (z-index 100) so click-outside works.
				z-index: 95;
			}
		}
	}

	.iot-hub-cat__empty {
		text-align: center;
		color: var(--color-text-muted);
		padding: 4rem 1rem;
	}
</style>

<script>
	import { lockScroll, unlockScroll } from '@util/scroll-lock';

	document
		.querySelectorAll<HTMLElement>('[data-iot-hub-listings-wrap]')
		.forEach((wrap) => {
			const panel = wrap.querySelector<HTMLElement>('[data-iot-hub-filter-panel]');
			const toggle = wrap.querySelector<HTMLButtonElement>(
				'[data-iot-hub-filter-toggle]'
			);
			const backdrop = wrap.querySelector<HTMLElement>(
				'[data-iot-hub-filter-backdrop]'
			);
			if (!panel || !toggle) return;

			// 1023px === Sass `media-down(lg)` so JS + CSS agree on the
			// breakpoint where the panel switches to overlay-drawer.
			const mobileMq = window.matchMedia('(max-width: 1023px)');

			// Scroll lock while the mobile drawer is open. The shared util also
			// compensates the fixed site header so it doesn't jump wider.
			const setScrollLock = (lock: boolean) => {
				if (lock) lockScroll();
				else unlockScroll();
			};

			const setOpen = (open: boolean) => {
				const wasOpen = panel.dataset.open === 'true';
				panel.dataset.open = open ? 'true' : 'false';
				wrap.dataset.filterOpen = open ? 'true' : 'false';
				toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
				setScrollLock(open && mobileMq.matches);
				// Gate focus restoration on focus being inside the panel
				// so we don't steal focus when the user closed via a
				// click outside while focus was already elsewhere.
				if (wasOpen && !open && panel.contains(document.activeElement)) {
					toggle.focus();
				}
			};

			toggle.addEventListener('click', () => {
				setOpen(panel.dataset.open !== 'true');
			});
			wrap.addEventListener('iot-hub-filter-close', () => setOpen(false));
			backdrop?.addEventListener('click', () => setOpen(false));
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && panel.dataset.open === 'true') setOpen(false);
			});
			// Drop the lock when the viewport grows past lg while open
			// (e.g. rotated tablet) so desktop layout doesn't stay frozen.
			mobileMq.addEventListener('change', (e) => {
				setScrollLock(panel.dataset.open === 'true' && e.matches);
			});
		});
</script>
