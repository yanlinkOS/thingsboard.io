---
/**
 * Redirects old /docs/iot-gateway/install/[...slug] URLs
 * to the new /docs/iot-gateway/installation/[...slug] structure.
 */
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const CONTENT_PREFIX = 'docs/iot-gateway/installation';
	const docs = await getCollection('docs');
	const entries = docs.filter(
		(e) => e.id === CONTENT_PREFIX || e.id.startsWith(CONTENT_PREFIX + '/')
	);

	return entries.map((entry) => {
		const slug =
			entry.id === CONTENT_PREFIX
				? undefined
				: entry.id.replace(CONTENT_PREFIX + '/', '');
		return { params: { slug } };
	});
}

const { slug } = Astro.params;
const target = slug ? `/docs/iot-gateway/installation/${slug}/` : `/docs/iot-gateway/installation/`;

return Astro.redirect(target, 301);
---