---
/**
 * Redirects old /docs/pe/mqtt-broker/[...slug] URLs to the new /docs/mqtt-broker/pe/[...slug] structure.
 * Uses getStaticPaths so Astro generates a static redirect page for every existing
 * docs/mqtt-broker/pe/* content entry — including new pages added in the future.
 *
 * Starlight's docsLoader() generates entry IDs without a trailing slash for index files:
 *   src/content/docs/docs/mqtt-broker/pe/index.mdx  →  id: "docs/mqtt-broker/pe"
 *   src/content/docs/docs/mqtt-broker/pe/some-page.mdx  →  id: "docs/mqtt-broker/pe/some-page"
 */
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	const entries = docs.filter(
		(e) => e.id === 'docs/mqtt-broker/pe' || e.id.startsWith('docs/mqtt-broker/pe/')
	);

	return entries.map((entry) => {
		const slug =
			entry.id === 'docs/mqtt-broker/pe'
				? undefined
				: entry.id.replace(/^docs\/mqtt-broker\/pe\//, '');
		return { params: { slug } };
	});
}

const { slug } = Astro.params;
const target = slug ? `/docs/mqtt-broker/pe/${slug}/` : '/docs/mqtt-broker/pe/';

return Astro.redirect(target, 301);
---
