---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { UPGRADE_FAMILIES, getFamilySlug, getUpgradeStepVersions } from '~/models/upgrade-instructions';
import { Products } from '~/models/site.models';
import LinuxUpgradeSteps from '~/components/upgrade-instructions/LinuxUpgradeSteps.astro';
import WindowsUpgradeSteps from '~/components/upgrade-instructions/WindowsUpgradeSteps.astro';
import DockerUpgradeSteps from '~/components/upgrade-instructions/DockerUpgradeSteps.astro';
import DockerComposeUpgradeSteps from '~/components/upgrade-instructions/DockerComposeUpgradeSteps.astro';

type Platform = 'ubuntu' | 'centos' | 'windows' | 'docker' | 'docker-compose';

const PLATFORM_LABELS: Record<Platform, string> = {
	ubuntu: 'Ubuntu',
	centos: 'CentOS/RHEL',
	windows: 'Windows',
	docker: 'Docker',
	'docker-compose': 'Docker Compose',
};

export function getStaticPaths() {
	const platforms: Platform[] = ['ubuntu', 'centos', 'windows', 'docker', 'docker-compose'];
	const paths = [];
	for (const family of UPGRADE_FAMILIES) {
		const familySlug = getFamilySlug(family);
		for (const platform of platforms) {
			paths.push({ params: { platform, familySlug }, props: { family } });
		}
	}
	return paths;
}

const { platform } = Astro.params;
const { family } = Astro.props as { family: string };

const product = Products.PE;

const platformLabel = PLATFORM_LABELS[platform as Platform] ?? platform;
const title = `ThingsBoard PE ${platformLabel} ${family}.x Upgrade Instructions`;
const description = `Step-by-step instructions to upgrade ThingsBoard Professional Edition on ${platformLabel} from version ${family}.x.`;

const familyVersions = getUpgradeStepVersions(family);
const headings = familyVersions.map((v) => ({
	depth: 2,
	slug: v.anchor,
	text: v.patch
		? `Upgrading ThingsBoard PE to latest ${v.baseVersion} (${v.displayVersion})`
		: `Upgrading ThingsBoard PE to ${v.displayVersion}`,
}));

const backUrl = '/docs/pe/installation/upgrade-instructions/';
---

<StarlightPage frontmatter={{ title, description, tableOfContents: true }} headings={headings}>
	<p><a href={backUrl}>&larr; Back to all versions</a></p>

	{platform === 'ubuntu' && (
		<LinuxUpgradeSteps product={product} platform="ubuntu" filterFamily={family} />
	)}
	{platform === 'centos' && (
		<LinuxUpgradeSteps product={product} platform="centos" filterFamily={family} />
	)}
	{platform === 'windows' && <WindowsUpgradeSteps product={product} filterFamily={family} />}
	{platform === 'docker' && <DockerUpgradeSteps product={product} filterFamily={family} />}
	{platform === 'docker-compose' && (
		<DockerComposeUpgradeSteps product={product} filterFamily={family} />
	)}
</StarlightPage>