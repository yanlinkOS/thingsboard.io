---
/**
 * Redirects old /docs/pe/edge/[...slug] URLs to the new /docs/edge/pe/[...slug] structure.
 * Uses getStaticPaths so Astro generates a static redirect page for every existing
 * docs/edge/pe/* content entry — including new pages added in the future.
 *
 * Starlight's docsLoader() generates entry IDs without a trailing slash for index files:
 *   src/content/docs/docs/edge/pe/index.mdx  →  id: "docs/edge/pe"
 *   src/content/docs/docs/edge/pe/some-page.mdx  →  id: "docs/edge/pe/some-page"
 */
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	const entries = docs.filter((e) => e.id === 'docs/edge/pe' || e.id.startsWith('docs/edge/pe/'));

	return entries.map((entry) => {
		const slug =
			entry.id === 'docs/edge/pe' ? undefined : entry.id.replace(/^docs\/edge\/pe\//, '');
		return { params: { slug } };
	});
}

const { slug } = Astro.params;
const target = slug ? `/docs/edge/pe/${slug}/` : '/docs/edge/pe/';

return Astro.redirect(target, 301);
---
