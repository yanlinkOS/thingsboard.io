---
export function getStaticPaths() {
	const redirects: Record<string, string> = {
		'widgets-development-before-3.0': '/docs/user-guide/contribution/widgets-development/',
	};
	return Object.keys(redirects).map((slug) => ({
		params: { slug },
		props: { target: redirects[slug] },
	}));
}

const { target } = Astro.props as { target: string };
return Astro.redirect(target, 301);
---
