---

<BaseLayout
	title="ThingsBoard - Open-source IoT Platform"
	description="ThingsBoard is an open-source IoT platform for device management, data collection, processing, and visualization for your IoT projects."
	pageId="home"
	customTitle={true}
>
	<!-- HERO -->
	<main>
		<Hero
			product={Products.CE}
			title={['ThingsBoard', 'Open-source IoT Platform']}
			subtitle="Device management, data collection, processing and visualization for your IoT solution"
			buttons={[{ text: 'Learn More', href: '#intro', variant: 'outline' }]}
			anchorLink="#intro"
		/>

		<section id="overflow">
			<!-- Customers Logo Section -->
			<CustomersLogo productTag="ce" />

			<IntroSection />

			<!-- Manage Section -->
			<section id="manage">
				<div class="main-div">
					<div id="features-top">
						<div class="background">
							<div class="main1"></div>
							<div class="small1"></div>
							<div class="small2"></div>
							<div class="small3"></div>
							<div class="small4"></div>
						</div>
						<div class="block">
							<div class="feature-des">
								<h3 class="phrase-heading">Provision and manage devices and assets</h3>
								<p>
									Provision, monitor and control your IoT entities in secure way using rich
									server-side APIs. Define relations between your devices, assets, customers or any
									other entities.
								</p>
								<ReadMoreLink
									href="/docs/user-guide/entities-and-relations/"
									text="Read more about entities and relations"
								/>
							</div>
							<div class="manage">
								<SmartImage
									class="device-list"
									src="/src/assets/images/device-list.svg"
									alt="Device list with checkboxes"
									width="626"
									height="335"
									loading="lazy"
								/>
								<SmartImage
									class="device-manage"
									src="/src/assets/images/device-manage.svg"
									alt="Device managing panel"
									width="543"
									height="509"
									loading="lazy"
								/>
							</div>
						</div>
						<div class="block vis">
							<div class="visualize">
								<SmartImage
									class="vis1"
									src="/src/assets/images/visualize1.svg"
									alt="Linear chart"
									width="668"
									height="263"
									loading="lazy"
								/>
								<SmartImage
									class="vis2"
									src="/src/assets/images/visualize2.svg"
									alt="Common chart with points"
									width="457"
									height="263"
									loading="lazy"
								/>
								<SmartImage
									class="vis3"
									src="/src/assets/images/visualize3.svg"
									alt="Digital level chart"
									width="197"
									height="263"
									loading="lazy"
								/>
							</div>
							<div class="feature-des">
								<h3 class="phrase-heading">Collect and visualize data</h3>
								<p>
									Collect and store telemetry data in scalable and fault-tolerant way. Visualize
									your data with built-in or custom widgets and flexible dashboards. Share
									dashboards with your customers.
								</p>
								<ReadMoreLink
									href="/iot-data-visualization/"
									text="Read more about visualization"
								/>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- SCADA Section -->
			<section id="scada">
				<div class="main-div">
					<div id="features-top-1">
						<div class="background">
							<div class="main2"></div>
						</div>
						<div class="block scada">
							<div class="feature-des">
								<div class="scada-mode-selector">
									<div class="mode active gtm_button" data-mode="performance">
										<span>High-performance</span>
									</div>
									<div class="mode gtm_button" data-mode="traditional">
										<span>Traditional</span>
									</div>
								</div>
								<h3 class="phrase-heading scada-title">SCADA High-performance</h3>
								<p>
									Monitor and control your industrial processes in real time with SCADA. Use SCADA
									symbols on dashboards to create and manage any workflow, offering full flexibility
									to design and oversee operations according to your requirements.
								</p>
								<ReadMoreLink href="/use-cases/scada/" text="Read more about SCADA" />
							</div>
							<div class="scada-svg">
								<SmartImage
									class="scada-scheme high-perf"
									src="/src/assets/images/high-perf-scada-background.svg"
									alt="SCADA background block schema"
									width="1144"
									height="655"
									loading="lazy"
								/>
								<SmartImage
									class="scada-scheme trad hidden"
									src="/src/assets/images/scada-background.svg"
									alt="SCADA background block schema"
									width="1144"
									height="655"
									loading="lazy"
								/>
								<div class="scada-fade"></div>
								<div class="scada-background"></div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- React Section -->
			<section id="react">
				<div class="main-div">
					<div id="features-top-2">
						<div class="background">
							<div class="main3"></div>
							<SmartImage
								src="/src/assets/images/grid.svg"
								alt="Grid background"
								loading="lazy"
								height=""
								width=""
							/>
							<div class="small5"></div>
							<div class="small6"></div>
						</div>
						<div class="block dark">
							<div class="process">
								<SmartImage
									class="react-img"
									src="/src/assets/images/react.svg"
									alt="Rule nodes chain"
									width="1031"
									height="230"
									loading="lazy"
								/>
								<SmartImage
									class="add-rule"
									src="/src/assets/images/add-rule.svg"
									alt="Add rule node example"
									width="626"
									height="482"
									loading="lazy"
								/>
							</div>
							<div class="feature-des">
								<h3 class="phrase-heading">Process and React</h3>
								<p>
									Define data processing rule chains. Transform and normalize your device data.
									Raise alarms on incoming telemetry events, attribute updates, device inactivity
									and user actions.
								</p>
								<ReadMoreLink
									href="/docs/user-guide/rule-engine-2-0/re-getting-started/"
									text="Read more about rule engine"
									variant="light"
								/>
							</div>
						</div>
						<div class="block micro">
							<div class="feature-des microservices">
								<h3 class="phrase-heading">Microservices</h3>
								<p>
									Construct your ThingsBoard cluster and get maximum scalability and fault-tolerance
									with microservices architecture. ThingsBoard also supports both cloud and
									on-premises deployments.
								</p>
								<ReadMoreLink href="/docs/reference/msa/" text="Read more about microservices" />
							</div>
							<SmartImage
								src="/src/assets/images/microservices.svg"
								alt="Microservices block schema"
								width="569"
								height="327"
								loading="lazy"
							/>
						</div>
					</div>
				</div>
			</section>

			<!-- Products Section -->
			<section id="products">
				<div class="main-div">
					<div class="background">
						<div class="products"></div>
						<div class="small7"></div>
						<div class="small8"></div>
					</div>
					<SectionHeader title="Products" theme="dark" />
					<div class="product-list">
						<ProductCard
							name="Community Edition"
							productLabel="ThingsBoard"
							description="Bring your ideas to life"
							image="/src/assets/images/community.svg"
							href="/docs/"
							linkText="See Community Edition documentation"
						/>
						<ProductCard
							name="Cloud"
							productLabel="ThingsBoard"
							description="Keep everything in a secure cloud"
							image="/src/assets/images/cloud.svg"
							href="/products/paas/"
							linkText="See Cloud documentation"
							featured={true}
						/>
						<ProductCard
							name="Professional Edition"
							productLabel="ThingsBoard"
							description="Get all the functions of ThingsBoard"
							image="/src/assets/images/professional.svg"
							href="/products/thingsboard-pe/"
							linkText="See Professional Edition documentation"
						/>
					</div>
				</div>
			</section>

			<!-- Product Ecosystem Section -->
			<section id="product-ecosystem">
				<div class="main-div">
					<div class="background">
						<div class="product-ecosystem"></div>
					</div>
					<SectionHeader title="Product ecosystem" />
					<div class="product-ecosystem-list">
						{
							ecosystem.map((product) => (
								<EcosystemCard
									name={product.name}
									description={product.description}
									icon={product.icon}
									href={product.href}
								/>
							))
						}
					</div>
				</div>
			</section>

			<!-- Dashboard Description Section -->
			<section id="dashboard_description">
				<div class="main-div">
					<div class="background">
						<div class="dashboards"></div>
						<div class="small9"></div>
						<div class="small10"></div>
					</div>
					<SectionHeader
						title="Real-Time IoT Dashboards"
						subtitle="ThingsBoard allows you to create rich IoT Dashboards for data visualization and remote device control in real-time. More than 600 customizable widgets allows you to build end-user custom dashboards for most IoT use-cases."
						align="left"
					/>
					<Carousel
						items={usecaseCarouselItems}
						variant="usecase"
						showDots={true}
						showArrows={true}
						loop={true}
						autoplay={true}
						autoplayInterval={15000}
					/>
				</div>
				<div class="row justify-content-center">
					<a href="/products/">View all products</a>
				</div>
			</section>

			<!-- Rule Engine Section -->
			<section id="rule-engine">
				<div class="main-div">
					<div class="rule">
						<a
							class="rule-button img-button"
							href="/docs/user-guide/rule-engine-2-0/re-getting-started/"
						>
							<div class="overlay">
								<div class="eye">
									<Icon name="fa-regular:eye" class="icon" />
									See more about IoT Rule Engine
								</div>
							</div>
							<GifVideo
								height="375"
								width="890"
								srcMp4="/src/assets/images/send-email-rule-chain.mp4"
								srcWebm="/src/assets/images/send-email-rule-chain.webm"
							/>
						</a>
						<div class="des">
							<h3>IoT Rule Engine</h3>
							<p>
								ThingsBoard allows you to create complex <a
									href="/docs/user-guide/rule-engine-2-0/re-getting-started/">Rule Chains</a
								> to process data from your devices and match your application specific use cases.
							</p>
							<ReadMoreLink
								href="/docs/user-guide/rule-engine-2-0/re-getting-started/"
								text="Read more about rule engine"
							/>
						</div>
					</div>
				</div>
			</section>

			<!-- Bottom Features Section -->
			<section id="bottom-features">
				<div class="main-div">
					<div class="background">
						<div class="bottom-features1"></div>
						<div class="bottom-features2"></div>
						<div class="small11"></div>
						<div class="small12"></div>
						<div class="bottom-features3"></div>
						<div class="small13"></div>
						<div class="small14"></div>
						<div class="small15"></div>
					</div>
					<SectionHeader title="ThingsBoard Features" />
					<div id="cards">
						{
							features.map((feature) => (
								<FeatureCard
									icon={feature.icon}
									title={feature.title}
									description={feature.description}
									href={feature.href}
								/>
							))
						}
					</div>
				</div>
			</section>
		</section>
	</main>
</BaseLayout>

<script>
	// SCADA mode selector
	document.addEventListener('DOMContentLoaded', () => {
		const scadaModes = document.querySelectorAll('.scada-mode-selector .mode');
		scadaModes.forEach((mode) => {
			mode.addEventListener('click', () => {
				if (mode.classList.contains('active')) return;

				scadaModes.forEach((m) => m.classList.remove('active'));
				mode.classList.add('active');

				const isPerformance = mode.getAttribute('data-mode') === 'performance';
				const schemes = document.querySelectorAll('.scada-scheme');
				schemes[0].classList.toggle('hidden', !isPerformance);
				schemes[1].classList.toggle('hidden', isPerformance);

				const title = document.querySelector('.scada-title');
				if (title) {
					title.textContent = isPerformance ? 'SCADA High-performance' : 'SCADA Traditional';
				}
			});
		});
	});
</script>
