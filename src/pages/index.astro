---
import BaseLayout from '@layouts/BaseLayout.astro';
import CustomersLogo from '../components/Landing/CustomersLogo.astro';
import Hero from '../components/Landing/Hero.astro';
import Carousel from '@components/Carousel/Carousel.astro';
import CarouselSlide from '@components/Carousel/CarouselSlide.astro';
import DashboardSlide from '@components/Landing/DashboardSlide.astro';
import { Products } from '@models/site.models';
import IntroSection from '@components/Landing/IntroSection.astro';
import FeatureCard from '@components/Landing/FeatureCard.astro';
import ProductCard from '@components/Landing/ProductCard.astro';
import EcosystemCard from '@components/Landing/EcosystemCard.astro';
import SectionHeader from '@components/Landing/SectionHeader.astro';
import ManageSection from '@components/Landing/ManageSection.astro';
import RuleEngineSection from '@components/Landing/RuleEngineSection.astro';
import ScadaSection from '@components/Landing/ScadaSection.astro';
import ReactSection from '@components/Landing/ReactSection.astro';
import { homeFeatures } from '~/data/homeFeatures';
import { homeEcosystem } from '~/data/homeEcosystem';
import { homeCarouselItems } from '~/data/homeCarousel';
---

<BaseLayout
	headerVariant="transparent"
	forceLightTheme
	title="ThingsBoard - Open-source IoT Platform"
	description="ThingsBoard is an open-source IoT platform for device management, data collection, processing, and visualization for your IoT projects."
	customTitle={true}
	preloadLcpImage="/images/hero/tb-cover.webp"
>
	<!-- HERO -->
	<Hero
		product={Products.CE}
		title={['ThingsBoard', 'Open-source IoT Platform']}
		subtitle="Device management, data collection, processing and visualization for your IoT solution"
		buttons={[
			{ text: 'Try It Now', href: '/installations/', variant: 'white' },
			{
				text: 'Learn More',
				href: '/docs/pe/',
				variant: 'outline',
				target: '_blank',
				ariaLabel: 'Learn more about ThingsBoard in the documentation',
			},
		]}
		anchorLink="#intro"
		videoBackground={{
			webm: 'https://video.thingsboard.io/tb-cover2.webm',
			mp4: 'https://video.thingsboard.io/tb-cover2.mp4',
		}}
	/>

	<section id="overflow">
		<!-- Customers Logo Section -->
		<CustomersLogo productTag="ce" />

		<IntroSection />

		<!-- Manage Section -->
		<ManageSection />

		<!-- SCADA Section -->
		<ScadaSection />

		<!-- React Section -->
		<ReactSection />

		<!-- Products Section -->
		<section id="products">
			<div class="main-div">
				<div class="background" aria-hidden="true">
					<div class="products"></div>
					<div class="small7"></div>
					<div class="small8"></div>
				</div>
				<SectionHeader title="Products" theme="dark" />
				<div class="product-list">
					<ProductCard
						name="Community Edition"
						productLabel="ThingsBoard"
						description="Bring your ideas to life"
						image="/src/assets/images/landings/ce/community.svg"
						imageWidth={228}
						imageHeight={134}
						href="/docs/"
						linkText="See Community Edition documentation"
					/>
					<ProductCard
						name="Cloud"
						productLabel="ThingsBoard"
						description="Keep everything in a secure cloud"
						image="/src/assets/images/landings/ce/cloud.svg"
						imageWidth={280}
						imageHeight={164}
						href="/products/paas/"
						linkText="See Cloud documentation"
						featured={true}
					/>
					<ProductCard
						name="Professional Edition"
						productLabel="ThingsBoard"
						description="Get all the functions of ThingsBoard"
						image="/src/assets/images/landings/ce/professional.svg"
						imageWidth={228}
						imageHeight={140}
						href="/products/thingsboard-pe/"
						linkText="See Professional Edition documentation"
					/>
				</div>
			</div>
		</section>

		<!-- Product Ecosystem Section -->
		<section id="product-ecosystem">
			<div class="main-div">
				<div class="background" aria-hidden="true">
					<div class="product-ecosystem"></div>
				</div>
				<SectionHeader title="Product ecosystem" />
				<div class="product-ecosystem-list">
					{
						homeEcosystem.map((product) => (
							<EcosystemCard
								name={product.name}
								description={product.description}
								icon={product.icon}
								href={product.href}
							/>
						))
					}
				</div>
			</div>
		</section>

		<!-- Dashboard Description Section -->
		<section id="dashboard_description">
			<div class="main-div">
				<div class="background" aria-hidden="true">
					<div class="dashboards"></div>
					<div class="small9"></div>
					<div class="small10"></div>
				</div>
				<SectionHeader
					title="Real-Time IoT Dashboards"
					subtitle="ThingsBoard allows you to create rich IoT Dashboards for data visualization and remote device control in real-time. More than 600 customizable widgets allows you to build end-user custom dashboards for most IoT use-cases."
					align="left"
				/>
				<Carousel
					showDots={true}
					showArrows={true}
					loop={true}
					autoplay={true}
					autoplayInterval={15000}
					slideCount={homeCarouselItems.length}
					ariaLabel="IoT dashboard examples"
				>
					{
						homeCarouselItems.map((item, i) => (
							<CarouselSlide index={i} total={homeCarouselItems.length}>
								<DashboardSlide item={item} />
							</CarouselSlide>
						))
					}
				</Carousel>
				<div class="view-all-link">
					<a href="/products/">View all products</a>
				</div>
			</div>
		</section>

		<!-- Rule Engine Section -->
		<RuleEngineSection />

		<!-- Bottom Features Section -->
		<section id="bottom-features">
			<div class="main-div">
				<div class="background hidden" aria-hidden="true">
					<div class="bottom-features1"></div>
					<div class="bottom-features2"></div>
					<div class="small11"></div>
					<div class="small12"></div>
					<div class="bottom-features3"></div>
					<div class="small13"></div>
					<div class="small14"></div>
					<div class="small15"></div>
				</div>
				<SectionHeader title="ThingsBoard Features" />
				<div id="cards">
					{
						homeFeatures.map((feature) => (
							<FeatureCard
								icon={feature.icon}
								title={feature.title}
								description={feature.description}
								href={feature.href}
							/>
						))
					}
				</div>
			</div>
		</section>
	</section>
</BaseLayout>

<style is:global lang="scss">
	@use '../styles/landing';
	@use '../styles/variables' as *;

	// Remove white section backgrounds on home page
	:root section {
		background: none;
	}

	// Overflow container
	#overflow {
		overflow: hidden;

		@include media-down(md) {
			#react {
				margin-top: $spacing-12;
			}
		}
	}

	// Products section
	#products,
	#product-ecosystem {
		width: 100%;
		padding-top: $spacing-24;
		position: relative;

		@include media-down(md) {
			padding-top: 60px;
			margin-bottom: 60px;
		}
	}

	#products .section-header,
	#product-ecosystem .section-header {
		margin-bottom: 72px;
	}

	#bottom-features .section-header {
		margin-bottom: 50px;
	}

	.product-list {
		display: flex;
		margin: 0 $spacing-10;

		@include media-down(lg) {
			flex-direction: column;
			margin: 0;
		}

		@include media-up(lg) {
			margin: 0 30px;
		}
	}

	.product-ecosystem-list {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: $spacing-10;
		margin: 0;

		@include media-down(lg) {
			grid-template-columns: repeat(2, 1fr);
		}

		@include media-down(md) {
			grid-template-columns: 1fr;
		}
	}

	// Dashboard section
	#dashboard_description {
		margin-top: 186px;
		margin-bottom: $spacing-30;
		background-color: var(--color-bg-light);

		@include media-down(md) {
			margin-top: $spacing-5;
			margin-bottom: 60px;
		}

		.view-all-link {
			text-align: center;
			margin-top: $spacing-8;

			a {
				font-size: $font-size-lg;
				font-weight: $font-weight-medium;
				color: #1a6fd4;

				&:hover {
					text-decoration: underline;
				}
			}
		}

		.carousel-wrapper {
			margin-top: $spacing-10;
		}
	}

	// Bottom features section
	#bottom-features {
		padding-bottom: $spacing-20;
		background-color: var(--color-bg-light);
	}

	#cards {
		padding-top: 50px;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
	}

	// Decorative background base (shared by products, dashboard, bottom-features sections)
	.background {
		z-index: -1;
		position: absolute;
		top: 524px;
		left: 50%;

		div {
			position: absolute;
			transform: skewY(-6deg);
			width: 436px;
			height: 90px;
		}

		.products {
			top: -590px;
			width: 2560px;
			height: 200px;
			left: -1280px;
			background-color: $color-primary-dark;
		}

		.small7 {
			top: -742px;
			left: 732px;
			background-color: $color-primary;
		}

		.small8 {
			top: -350px;
			right: 736px;
			border: 4px solid $color-primary;
			background: transparent;
		}

		.product-ecosystem {
			top: -590px;
			width: 2560px;
			height: 200px;
			left: -1280px;
			background-color: var(--color-bg-light);
		}

		.dashboards {
			top: -550px;
			width: 2560px;
			height: 845px;
			left: -1280px;
			background-color: var(--color-bg-light);
		}

		.small9 {
			top: -653px;
			left: 466px;
			border: 4px solid $color-primary-darker;
			background: transparent;
		}

		.small10 {
			top: -708px;
			left: 658px;
			background-color: $color-primary;
		}

		.bottom-features1 {
			top: -700px;
			width: 2560px;
			height: 3000px;
			left: -1280px;
			transform: none;
			background-color: var(--color-bg-light);
		}

		.bottom-features2 {
			top: -240px;
			width: 2560px;
			height: 525px;
			left: -1280px;
			background-color: $color-dark-alt;
		}

		.small11 {
			top: -382px;
			left: 757px;
			background-color: $color-primary;
		}

		.small12 {
			top: 334px;
			right: 589px;
			border: 4px solid $color-primary-dark;
			background: transparent;
		}

		.bottom-features3 {
			top: 1008px;
			width: 2560px;
			height: 525px;
			left: -1280px;
			background-color: $color-dark-alt;
		}

		.small13 {
			top: 1071px;
			right: 646px;
			background-color: $color-primary-dark;
		}

		.small14 {
			top: 1009px;
			right: 408px;
			background-color: $color-primary;
		}

		.small15 {
			top: 1373px;
			left: 830px;
			border: 4px solid $color-primary;
			background: transparent;
		}
	}
</style>
