---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you are looking for doesn't exist or has been moved."
  pageId="common"
>
  <main class="error-page">
    <div class="error-page__container">
      <div class="error-page__code">404</div>
      <h1 class="error-page__title">Page Not Found</h1>
      <p class="error-page__description">
        The page you are looking for doesn't exist or has been moved.
      </p>
      <div class="error-page__actions">
        <a href="/" class="error-page__button error-page__button--primary">
          Go to Homepage
        </a>
        <a href="/docs/" class="error-page__button error-page__button--outline">
          Browse Documentation
        </a>
      </div>
      <div class="error-page__links">
        <p>Or try one of these:</p>
        <ul>
          <li><a href="/docs/getting-started-guides/what-is-thingsboard/">What is ThingsBoard?</a></li>
          <li><a href="/installations/">Installation Guide</a></li>
          <li><a href="/products/">Products</a></li>
          <li><a href="/pricing/">Pricing</a></li>
        </ul>
      </div>
    </div>
  </main>
</BaseLayout>

<style lang="scss">
  @use '../styles/variables' as *;

  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc($header-height + $spacing-8) $spacing-5 $spacing-8;
    background-color: $color-bg-light;

    @include media-down(md) {
      padding: calc($header-height + $spacing-5) $spacing-4 $spacing-5;
    }

    &__container {
      text-align: center;
      max-width: 500px;
    }

    &__code {
      font-size: 120px;
      font-weight: $font-weight-bold;
      line-height: 1;
      color: $color-primary;
      margin-bottom: $spacing-2;
      text-shadow: 3px 3px 0 rgba($color-primary-dark, 0.15);

      @include media-down(md) {
        font-size: 80px;
      }
    }

    &__title {
      font-size: $font-size-4xl;
      font-weight: $font-weight-semibold;
      color: $color-text-primary;
      margin-bottom: $spacing-3;

      @include media-down(md) {
        font-size: $font-size-3xl;
      }
    }

    &__description {
      font-size: $font-size-base;
      color: $color-text-secondary;
      margin-bottom: $spacing-8;
      line-height: $line-height-relaxed;

      @include media-down(md) {
        font-size: $font-size-sm;
        margin-bottom: $spacing-6;
      }
    }

    &__actions {
      display: flex;
      gap: $spacing-3;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: $spacing-8;

      @include media-down(md) {
        flex-direction: column;
        align-items: center;
        margin-bottom: $spacing-6;
      }
    }

    &__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 24px;
      font-size: $font-size-sm;
      font-weight: $font-weight-medium;
      text-decoration: none;
      border-radius: $radius-sm;
      transition: all $transition-base;

      @include media-down(md) {
        width: 100%;
        max-width: 220px;
      }

      &--primary {
        background-color: $color-primary;
        color: $color-white;

        &:hover {
          box-shadow: var(--shadow-primary);
        }
      }

      &--outline {
        background-color: transparent;
        color: $color-text-primary;
        border: 1px solid $color-border;

        &:hover {
          border-color: $color-text-primary;
        }
      }
    }

    &__links {
      p {
        font-size: $font-size-xs;
        color: $color-text-muted;
        margin-bottom: $spacing-2;
      }

      ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: $spacing-1 $spacing-4;
      }

      li a {
        font-size: $font-size-xs;
        color: $color-primary;
        text-decoration: none;

        &:hover {
          text-decoration: underline;
        }
      }
    }
  }
</style>