---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InnerNavigation from '../../components/Services/InnerNavigation.astro';
import ProductSection from '../../components/Installations/ProductSection.astro';
import { products, productTabs } from '~/data/installations';
---

<BaseLayout
	title="ThingsBoard Installations"
	description="ThingsBoard is an open-source IoT platform for device management, data collection, processing and visualization for your IoT projects"
	pageId="installations"
>
	<div class="install-header">
		<InnerNavigation tabs={productTabs} paramName="product" />
	</div>

	{
		products.map((product, i) => (
			<div
				id={`tab-${product.id}`}
				class="tab-content install-content"
				style={i > 0 ? 'display:none' : undefined}
			>
				<ProductSection data={product} />
			</div>
		))
	}
</BaseLayout>

<style lang="scss">
	:global(#installations) {
		color: #212529;
		background-color: #fff;
	}

	.install-header {
		margin-bottom: 0;
		padding-top: var(--header-height, 80px);
		max-width: 1400px;
		width: 100%;
		margin-left: auto;
		margin-right: auto;
		padding-left: 20px;
		padding-right: 20px;

		// Override InnerNavigation defaults: bigger tabs, no icon space
		:global(.inner-navigation .menu-item a) {
			padding: 16px 28px;

			@media (max-width: 600px) {
				padding: 8px 16px;
			}

			&::before {
				display: none;
			}
		}
	}

	:global(.install-content) {
		position: relative;
		z-index: 4;
		padding-top: 0;
		background-color: #f4f8fe;
		overflow: hidden;

		:global(.install-content-header) {
			flex-direction: row;
			padding-top: 10px;

			&:global(.margin-bottom) {
				margin-bottom: 28px;
			}

			:global(h1) {
				font-size: 28px;
				line-height: 44px;
				font-weight: 500;
				color: #202021;

				@media (min-width: 1200px) {
					font-size: 30px;
					line-height: 46px;
				}

				@media (min-width: 1400px) {
					font-size: 36px;
					line-height: 54px;
				}
			}

			:global(.install-content-description) {
				padding-top: 18px;

				@media (min-width: 992px) {
					padding-top: 32px;
				}

				:global(.button-container) {
					margin: 32px 0 16px 0;
					padding: 0;
					justify-content: center;
					align-items: center;
					gap: 25px;

					@media (min-width: 992px) {
						margin-bottom: 90px;
						justify-content: start;
					}
				}
			}

			:global(.margin-mobile) {
				margin: 50px 0;
			}

			:global(.install-content-details) {
				padding-top: 12px;
				color: #3b3c3d;

				:global(p) {
					font-weight: 400;
					font-size: 18px;
					line-height: 30px;
				}
			}

			:global(.image-content) {
				position: relative;
				width: 100%;
				padding-top: 60%;

				&:global(.width-85) {
					width: 85%;
				}

				@media (min-width: 768px) {
					padding-top: 50%;
				}

				:global(img) {
					width: 75%;
					position: absolute;
					box-shadow: 0 18px 60px rgba(0, 0, 0, 0.127868);
					border-radius: 4px;

					&:global(.bg) {
						top: 0;
						right: 0;
						z-index: 1;
						opacity: 0.5;
					}

					&:global(.main) {
						left: 0;
						top: 3rem;
						z-index: 2;
					}

					&:global(.left-negative) {
						left: -40px;

						@media (max-width: 600px) {
							left: 0;
						}
					}
				}
			}
		}

		:global(a.btn-blue),
		:global(button.btn-blue) {
			min-width: 200px;
			padding: 10px 50px;
			background-color: #2a7dec;
			color: #fff;
			text-align: center;
			font-size: 18px;
			font-weight: 500;
			outline: none;
			border-radius: 4px;
			border: solid 1px #2a7dec;
			line-height: 28px;
			letter-spacing: -0.03em;
			text-decoration: none;

			&:hover {
				filter: brightness(1.3);
			}

			&:global(.secondary) {
				background-color: transparent;
				color: #2a7dec;
			}

			@media (max-width: 600px) {
				width: 100%;
			}
		}

		:global(.feature) {
			display: flex;
			flex-direction: column;
			gap: 28px;
			margin-bottom: 100px;

			@media (min-width: 992px) {
				flex-direction: row;
			}

			:global(.column) {
				flex: 1;

				:global(.item-row) {
					display: flex;
					padding-right: 0;

					@media (min-width: 992px) {
						padding-right: 70px;
					}

					&::before {
						content: '•';
						font-weight: 600;
						font-size: 26px;
						line-height: 30px;
						margin-right: 22px;
						color: #2a7dec;
						display: inline-block;
					}

					:global(.item-text) {
						:global(.item-title) {
							color: #2a7dec;
							font-weight: 400;
							font-size: 20px;
							line-height: 32px;
							margin-bottom: 2px;
							text-decoration: none;
							display: block;
						}

						:global(p) {
							font-size: 16px;
							font-weight: 400;
							line-height: 28px;
							color: #202021;
						}
					}

					&:not(:last-of-type) {
						margin-bottom: 28px;
					}
				}
			}
		}

	}
</style>
