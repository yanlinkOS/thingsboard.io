---
import BaseLayout from '@layouts/BaseLayout.astro';
import DeviceLibrary from '../../components/DeviceLibrary/DeviceLibrary.astro';
import { getCollection } from 'astro:content';
import { resolveDeviceImage } from '../../util/device-images';

const deviceEntries = await getCollection('devices');
const allDevices = await Promise.all(
	deviceEntries.map(async (entry) => {
		const img = await resolveDeviceImage(entry.data.deviceImageFileName, 500);
		return {
			id: entry.id,
			title: entry.data.title,
			vendor: entry.data.vendor,
			imageSrc: img?.src ?? '',
			imageWidth: img?.width,
			imageHeight: img?.height,
			hardwareType: entry.data.hardwareType,
			connectivity: entry.data.connectivity,
			industry: entry.data.industry,
			useCase: entry.data.useCase,
			platforms: entry.data.platforms,
		};
	})
);
---

<BaseLayout
	headerVariant="base"
	title="Device library"
	description="Browse the ThingsBoard Device Library — a catalog of supported IoT hardware with connection guides and code snippets for popular development boards and sensors."
	pageId="device-library"
>
	<section class="device-library-hero">
		<div class="container hero-layout">
			<div class="hero-text">
				<h1>ThingsBoard Device Library</h1>
				<p>
					The Device Library is a collection of guides and code snippets that explain how to connect popular IoT
					development boards to the ThingsBoard platform. We intentionally concentrate on the code snippets for
					programmable devices to boost the productivity of the firmware engineers. Device Library is a constantly
					extending resource. We encourage our community members to <a href="/device-library/guidelines/">contribute</a
					>.
				</p>
			</div>
			<div class="hero-cta-card">
				<img src="/images/devices-library-icon.svg" alt="" class="hero-cta-icon" />
				<h2>Wish to integrate existing sensors?</h2>
				<a href="/docs/user-guide/connectivity-guide/" class="hero-cta-button">See instruction</a>
			</div>
		</div>
	</section>

	<section class="device-library-content">
		<div class="container">
			<DeviceLibrary devices={allDevices} />
		</div>
	</section>
</BaseLayout>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.container {
		max-width: 1152px;
		margin: 0 auto;
		padding: 0 var(--spacing-5);
	}

	.device-library-hero {
		padding: var(--spacing-16) 0 var(--spacing-10);
		background: var(--color-bg-surface);
	}

	.hero-layout {
		display: flex;
		align-items: center;
		gap: var(--spacing-8);

		@include media-down(md) {
			flex-direction: column;
			text-align: center;
		}
	}

	.hero-text {
		flex: 1;

		h1 {
			@include page-title;
			margin-bottom: var(--spacing-4);
		}

		p {
			@include text-m;
			color: var(--color-text-secondary);
			line-height: 1.6;
		}

		a {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}

	.hero-cta-card {
		position: relative;
		flex-shrink: 0;
		width: 280px;
		padding: var(--spacing-6);
		padding-top: var(--spacing-8);
		background: var(--color-bg);
		border-radius: var(--radius-xl);
		border: 1px solid var(--color-border);
		text-align: left;
		overflow: hidden;

		@include media-down(md) {
			width: 100%;
			max-width: 320px;
			text-align: center;
		}

		h2 {
			@include text-m;
			font-weight: $font-weight-semibold;
			line-height: 1.4;
			color: var(--color-text);
			margin: 0 0 var(--spacing-4);
		}
	}

	.hero-cta-icon {
		position: absolute;
		top: -10px;
		right: -10px;
		width: 120px;
		height: auto;
		opacity: 0.6;

		@include media-down(md) {
			top: -10px;
			right: -10px;
		}
	}

	.hero-cta-button {
		display: block;
		padding: 0.625rem 1.5rem;
		text-align: center;
		background: var(--color-primary);
		border: none;
		border-radius: var(--radius-md);
		font-weight: $font-weight-semibold;
		@include text-s;
		color: #fff;
		text-decoration: none;
		transition: opacity 0.2s;

		&:hover {
			opacity: 0.85;
		}

		:global([data-theme='dark']) & {
			color: #1a1a2e;
		}
	}

	.device-library-content {
		padding: var(--spacing-8) 0 var(--spacing-8);
	}
</style>
