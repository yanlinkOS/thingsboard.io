---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
---

<BaseLayout
	headerVariant="base"
	title="How to add your device to the Device Library"
	description="Submission guidelines for adding your device integration guide to the ThingsBoard Device Library."
>
	<section class="guidelines-hero" aria-labelledby="guidelines-title">
		<div class="container">
			<div class="guidelines-breadcrumb">
				<Breadcrumbs
					jsonLd
					items={[
						{ label: 'Device Library', href: '/device-library/' },
						{ label: 'Submission guidelines' },
					]}
				/>
			</div>
			<h1 id="guidelines-title">How to add your device to the Device Library?</h1>
			<p class="hero-lede">
				If you want to add your device to the Device Library, please follow the steps below. We review every submission
				and work with you to make sure it ships at the same quality bar as the rest of the catalog.
			</p>
		</div>
	</section>

	<section class="guidelines-content" aria-label="Submission steps">
		<div class="container">
			<ol class="steps">
				<li>
					<h2>Create a structured guide</h2>
					<p>Use the following heading structure so the guide stays consistent with the rest of the Device Library:</p>
					<pre><code>## Introduction
### Prerequisites
## Create device on ThingsBoard
## Install required libraries and tools (Optional)
## Connect device to ThingsBoard
## Check data on ThingsBoard
## Synchronize device state using client and shared attribute requests (Optional)
## Control device using shared attributes (Optional)
## Control device using RPC (Optional)
## Conclusion</code></pre>
				</li>
				<li>
					<h2>Pick a format</h2>
					<p>
						Use <strong>docx</strong>, plain <strong>txt</strong>, or <strong>Markdown</strong>. Markdown is preferred —
						it lets us drop the guide into the docs site with the least amount of conversion work.
					</p>
				</li>
				<li>
					<h2>Bundle the guide with images</h2>
					<p>
						If you write in Markdown or txt, ship the screenshots and diagrams alongside the document — either as an
						archive (zip / tar.gz) or as a public GitHub repository we can clone.
					</p>
				</li>
				<li>
					<h2>Submit it for review</h2>
					<p>
						Email the guide to <a href="mailto:devices@thingsboard.io">devices@thingsboard.io</a>. Include a short
						description of the device and a link to its product page so we can cross-reference your hardware in the
						catalog.
					</p>
				</li>
				<li>
					<h2>We review it with you</h2>
					<p>
						We may make edits for accuracy, clarity, and consistency with our other guides. We'll loop you in on
						anything material so the final wording reflects how the device actually behaves.
					</p>
				</li>
				<li>
					<h2>It goes live in the Device Library</h2>
					<p>
						Once accepted, your guide is added to the catalog and is discoverable to every developer browsing the Device
						Library.
					</p>
				</li>
			</ol>

			<aside class="contact-note">
				<p>
					Questions or feedback before you submit? Reach out at <a href="mailto:devices@thingsboard.io"
						>devices@thingsboard.io</a
					> — we're happy to help you scope the guide before you start writing.
				</p>
			</aside>

			<div class="cta-row">
				<a href="/device-library/" class="cta-back">← Back to Device Library</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.container {
		max-width: 800px;
		margin: 0 auto;
		padding: 0 var(--spacing-5);
	}

	.guidelines-hero {
		padding: var(--spacing-12) 0 var(--spacing-8);
		background: var(--color-bg-surface);
	}

	.guidelines-breadcrumb {
		margin-bottom: var(--spacing-4);
	}

	.guidelines-hero h1 {
		@include page-title;
		margin-bottom: var(--spacing-4);
	}

	.hero-lede {
		@include text-m;
		color: var(--color-text-secondary);
		line-height: 1.6;
		margin: 0;
	}

	.guidelines-content {
		padding: var(--spacing-10) 0 var(--spacing-12);
	}

	.steps {
		list-style: none;
		counter-reset: step;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-6);
	}

	.steps > li {
		counter-increment: step;
		position: relative;
		padding: var(--spacing-5) var(--spacing-6) var(--spacing-5) calc(var(--spacing-6) + 2.5rem);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);

		&::before {
			content: counter(step);
			position: absolute;
			left: var(--spacing-5);
			top: var(--spacing-5);
			width: 2rem;
			height: 2rem;
			border-radius: 50%;
			background: color-mix(in srgb, var(--color-primary) 12%, transparent);
			color: var(--color-primary);
			display: flex;
			align-items: center;
			justify-content: center;
			font-weight: $font-weight-semibold;
			@include text-s;
		}

		h2 {
			@include text-m;
			font-weight: $font-weight-semibold;
			color: var(--color-text);
			margin: 0 0 var(--spacing-2);
		}

		p {
			@include text-m;
			color: var(--color-text-secondary);
			line-height: 1.65;
			margin: 0;
		}

		p + p {
			margin-top: var(--spacing-3);
		}

		a {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}

		strong {
			color: var(--color-text);
			font-weight: $font-weight-semibold;
		}

		pre {
			margin-top: var(--spacing-3);
			padding: var(--spacing-4);
			background: var(--color-bg-light, var(--color-bg-surface));
			border: 1px solid var(--color-border);
			border-radius: var(--radius-md);
			overflow-x: auto;

			code {
				@include text-s;
				font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
				color: var(--color-text);
				background: none;
				padding: 0;
				white-space: pre;
			}
		}
	}

	.contact-note {
		margin-top: var(--spacing-8);
		padding: var(--spacing-5) var(--spacing-6);
		border-left: 3px solid var(--color-primary);
		background: color-mix(in srgb, var(--color-primary) 5%, transparent);
		border-radius: 0 var(--radius-md) var(--radius-md) 0;

		p {
			@include text-m;
			color: var(--color-text-secondary);
			margin: 0;
			line-height: 1.65;
		}

		a {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}

	.cta-row {
		margin-top: var(--spacing-8);
	}

	.cta-back {
		@include text-s;
		color: var(--color-primary);
		text-decoration: none;
		font-weight: $font-weight-medium;

		&:hover {
			text-decoration: underline;
		}
	}
</style>
