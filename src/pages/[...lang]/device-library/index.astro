---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import DeviceLibrary from '~/components/DeviceLibrary/DeviceLibrary.astro';
import { getCollection } from 'astro:content';

import { DEFAULT_LOCALE } from '~/util/language-router';
import { locales, type Lang } from '~/content/devices/i18n.ts';

export function getStaticPaths() {
	return Object.keys(locales).map((langKey) => {
		const langParam = langKey === DEFAULT_LOCALE ? undefined : langKey;
		return { params: { lang: langParam } };
	});
}

const { lang: langParam } = Astro.params;
const lang = (langParam || DEFAULT_LOCALE) as Lang;
const { title } = locales[lang];

const deviceEntries = await getCollection('devices');
const allDevices = deviceEntries
	.filter((entry) => entry.id.startsWith(`${lang}/`))
	.map((entry) => ({
		id: entry.id,
		title: entry.data.title,
		vendor: entry.data.vendor,
		imageSrc: `/images/devices/${entry.data.deviceImageFileName}`,
		hardwareType: entry.data.hardwareType,
		connectivity: entry.data.connectivity,
		industry: entry.data.industry,
		useCase: entry.data.useCase,
	}));
---

<StarlightPage frontmatter={{ title, template: 'splash' }}>
	<DeviceLibrary devices={allDevices} lang={lang} />
</StarlightPage>

<style is:global>
	.device-library-page .main-pane {
		max-width: 100%;
	}
	.content-panel {
		--sl-content-width: 100%;
	}
</style>
