---
import { getCollection, render } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import LanguageSwitcher from '~/components/LanguageSwitcher.astro';

import { DEFAULT_LOCALE } from '~/util/language-router';

export async function getStaticPaths() {
	const devices = await getCollection('devices');

	return devices.map((device) => {
		// device.id format: "en/eg8200-gateway" or "uk/eg8200-gateway"
		const [lang, ...slugParts] = device.id.split('/');
		const slug = slugParts.join('/');
		const langParam = lang === DEFAULT_LOCALE ? undefined : lang;

		return {
			params: { lang: langParam, slug },
			props: { device, lang },
		};
	});
}

const { device, lang } = Astro.props;
const { Content } = await render(device);

const backLink = lang === DEFAULT_LOCALE ? '/device-library/' : `/${lang}/device-library/`;
---

<StarlightPage frontmatter={{ title: device.data.title, template: 'splash' }}>
	<div class="device-page-header">
		<a href={backLink} class="back-link">&larr; {lang === 'uk' ? 'Назад до бібліотеки' : 'Back to library'}</a>
		<div class="language-switcher">
			<LanguageSwitcher />
		</div>
	</div>

	<div class="device-page">
		<div class="device-header">
			<div class="device-image">
				<img src={`/src/assets/devices/${device.data.deviceImageFileName}`} alt={device.data.title} />
			</div>
			<div class="device-info">
				<h1>{device.data.title}</h1>
				{device.data.vendor && <p class="vendor">{device.data.vendor}</p>}

				<dl class="device-specs">
					<dt>{lang === 'uk' ? 'Тип обладнання' : 'Hardware Type'}</dt>
					<dd>{device.data.hardwareType}</dd>

					<dt>{lang === 'uk' ? 'Підключення' : 'Connectivity'}</dt>
					<dd>{device.data.connectivity.join(', ')}</dd>

					{device.data.chip && (
						<>
							<dt>{lang === 'uk' ? 'Чіп' : 'Chip'}</dt>
							<dd>{device.data.chip}</dd>
						</>
					)}

					<dt>{lang === 'uk' ? 'Галузь' : 'Industry'}</dt>
					<dd>{device.data.industry.join(', ')}</dd>

					<dt>{lang === 'uk' ? 'Сфера застосування' : 'Use Case'}</dt>
					<dd>{device.data.useCase.join(', ')}</dd>
				</dl>
			</div>
		</div>

		<div class="device-content">
			<Content />
		</div>
	</div>
</StarlightPage>

<style>
	.device-page-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.5rem;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.back-link {
		color: var(--sl-color-text-accent);
		text-decoration: none;
	}

	.back-link:hover {
		text-decoration: underline;
	}

	.language-switcher {
		width: 180px;
		--sl-content-gap-y: 0;
	}

	.device-page {
		--sl-content-gap-y: 0;
	}

	.device-header {
		display: flex;
		gap: 2rem;
		margin-bottom: 2rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}

	.device-image {
		flex-shrink: 0;
		width: 200px;
		height: 200px;
		background: var(--sl-color-gray-6);
		border-radius: 0.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	.device-image img {
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
	}

	.device-info {
		flex: 1;
	}

	.device-info h1 {
		margin: 0 0 0.5rem 0;
		font-size: 1.5rem;
	}

	.vendor {
		color: var(--sl-color-gray-2);
		margin: 0 0 1rem 0;
	}

	.device-specs {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.5rem 1rem;
		margin: 0;
	}

	.device-specs dt {
		font-weight: 600;
		color: var(--sl-color-gray-2);
	}

	.device-specs dd {
		margin: 0;
	}

	.device-content {
		margin-top: 1.5rem;
	}

	@media (max-width: 600px) {
		.device-header {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}

		.device-specs {
			grid-template-columns: 1fr;
			text-align: left;
		}

		.device-specs dt {
			margin-top: 0.5rem;
		}
	}
</style>
