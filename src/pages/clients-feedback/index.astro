---
import BaseLayout from '@layouts/BaseLayout.astro';
import NButton from '../../components/Landing/NButton.astro';
import FeedbackCard from '../../components/Feedback/FeedbackCard.astro';
import { feedbackCategories, feedbackEntries } from '@data/clients-feedback';

// Build flat list with duplicate markers for "All" view
const seen = new Set<string>();
const allCards = feedbackCategories.flatMap((cat) =>
	(feedbackEntries[cat.key] || []).map((entry) => {
		const baseId = entry.id.replace(/-(sb|sc|t|i4)$/, '');
		const isDupe = seen.has(baseId);
		seen.add(baseId);
		return { entry, category: cat.key, isDupe };
	})
);
---

<BaseLayout
	headerVariant="solid-border"
	title="Clients Feedback | Open-source IoT Platform"
	description="Read what our clients say about ThingsBoard IoT platform. Real feedback from companies in smart energy, agriculture, smart buildings, telecom, and more."
	customTitle={true}
>
	<main class="cf-index">
		{/* Hero */}
		<section class="cf-hero">
			<h1>ThingsBoard Clients Feedback</h1>
			<p>See what our customers say about their experience with ThingsBoard</p>
		</section>

		{/* Category filter pills */}
		<div class="cf-filter" id="cf-filter">
			<button class="cf-filter-pill active" data-category="all">All</button>
			{
				feedbackCategories.map((cat) => (
					<button class="cf-filter-pill" data-category={cat.key}>
						{cat.label}
					</button>
				))
			}
		</div>

		{/* Feedback grid — render all cards grouped by category */}
		<div class="cf-grid" id="cf-grid">
			{
				allCards.map(({ entry, category, isDupe }) => (
					<FeedbackCard entry={entry} category={category} duplicate={isDupe} />
				))
			}
		</div>

		{/* No results */}
		<div class="cf-no-results" id="cf-no-results" hidden>No feedback entries match this category.</div>

		{/* CTA */}
		<div class="cf-cta">
			<div class="cf-cta-content">
				<h2>Got a success story to tell?</h2>
				<p>Real stories, real impact — share your experience with ThingsBoard!</p>
			</div>
			<NButton href="/contact-us/" target="_blank">Contact Us</NButton>
		</div>
	</main>
</BaseLayout>

<script>
	function initFeedbackIndex() {
		const pills = document.querySelectorAll<HTMLButtonElement>('.cf-filter-pill');
		const cards = document.querySelectorAll<HTMLElement>('.cf-card');
		const noResults = document.getElementById('cf-no-results')!;

		let currentCategory = 'all';

		// Restore from URL
		const params = new URLSearchParams(window.location.search);
		const urlCat = params.get('category');
		if (urlCat) {
			currentCategory = urlCat;
		}

		function render() {
			const isAll = currentCategory === 'all';
			let visibleCount = 0;
			cards.forEach((card) => {
				const matchesCat = isAll || card.dataset.category === currentCategory;
				const isDupe = isAll && card.classList.contains('cf-dupe');
				if (matchesCat && !isDupe) {
					card.classList.remove('cf-hidden');
					visibleCount++;
				} else {
					card.classList.add('cf-hidden');
				}
			});

			noResults.hidden = visibleCount > 0;

			pills.forEach((pill) => {
				pill.classList.toggle('active', pill.dataset.category === currentCategory);
			});

			// Update URL
			const url = new URL(window.location.href);
			if (currentCategory === 'all') {
				url.searchParams.delete('category');
			} else {
				url.searchParams.set('category', currentCategory);
			}
			window.history.replaceState({}, '', url.toString());
		}

		pills.forEach((pill) => {
			pill.addEventListener('click', () => {
				currentCategory = pill.dataset.category || 'all';
				render();
			});
		});

		render();
	}

	document.addEventListener('DOMContentLoaded', initFeedbackIndex);
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.cf-index {
		@include container;
		padding-top: $spacing-8;
		padding-bottom: $spacing-20;
	}

	// ─── Hero ───
	.cf-hero {
		margin-bottom: $spacing-10;

		h1 {
			@include page-title;
			color: var(--color-text);
			margin: 0 0 $spacing-3;
		}

		p {
			@include text-m;
			color: var(--color-text-secondary);
			margin: 0;
		}
	}

	// ─── Filter pills ───
	.cf-filter {
		display: flex;
		flex-wrap: wrap;
		gap: $spacing-2;
		margin-bottom: $spacing-8;
	}

	.cf-filter-pill {
		display: inline-flex;
		align-items: center;
		padding: 6px $spacing-4;
		border: 1px solid var(--color-border);
		border-radius: $radius-full;
		font-size: $font-size-sm;
		font-weight: $font-weight-medium;
		color: var(--color-text-secondary);
		background: transparent;
		cursor: pointer;
		transition:
			border-color $transition-fast,
			background-color $transition-fast,
			color $transition-fast;
		user-select: none;

		&:hover {
			border-color: $color-primary;
			color: $color-primary;
		}

		&.active {
			background: $color-primary;
			border-color: $color-primary;
			color: #fff;
		}
	}

	// ─── Card grid ───
	.cf-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: $spacing-6;

		@include media-down(lg) {
			grid-template-columns: 1fr;
		}
	}

	// ─── No results ───
	.cf-no-results {
		text-align: center;
		padding: $spacing-12 $spacing-4;
		@include text-m;
		color: var(--color-text-secondary);

		&[hidden] {
			display: none;
		}
	}

	// ─── CTA ───
	.cf-cta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: $spacing-6;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: $radius-xl;
		padding: $spacing-8;
		margin-top: $spacing-10;

		@include media-down(md) {
			flex-direction: column;
			text-align: center;
		}

		.cf-cta-content {
			h2 {
				@include subsection-title;
				color: var(--color-text);
				margin: 0 0 $spacing-2;
			}

			p {
				@include text-s;
				margin: 0;
			}
		}
	}
</style>
