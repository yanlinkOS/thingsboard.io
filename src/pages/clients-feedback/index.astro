---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NButton from '../../components/Landing/NButton.astro';
import FeedbackCard from '../../components/Feedback/FeedbackCard.astro';
import { feedbackCategories, feedbackEntries } from '../../data/clients-feedback';

// Build flat list with duplicate markers for "All" view
const seen = new Set<string>();
const allCards = feedbackCategories.flatMap((cat) =>
	(feedbackEntries[cat.key] || []).map((entry) => {
		const baseId = entry.id.replace(/-(sb|sc|t|i4)$/, '');
		const isDupe = seen.has(baseId);
		seen.add(baseId);
		return { entry, category: cat.key, isDupe };
	}),
);
---

<BaseLayout
	title="Clients Feedback | ThingsBoard IoT Platform"
	description="Read what our clients say about ThingsBoard IoT platform. Real feedback from companies in smart energy, agriculture, smart buildings, telecom, and more."
	pageId="industries"
>
	<main class="cf-index">
		{/* Hero */}
		<section class="cf-hero">
			<h1>Clients Feedback</h1>
			<p>See what our customers say about their experience with ThingsBoard</p>
		</section>

		{/* Category filter pills */}
		<div class="cf-filter" id="cf-filter">
			<button class="cf-filter-pill active" data-category="all">All</button>
			{feedbackCategories.map((cat) => (
				<button class="cf-filter-pill" data-category={cat.key}>
					{cat.label}
				</button>
			))}
		</div>

		{/* Feedback grid — render all cards grouped by category */}
		<div class="cf-grid" id="cf-grid">
			{allCards.map(({ entry, category, isDupe }) => (
				<FeedbackCard entry={entry} category={category} duplicate={isDupe} />
			))}
		</div>

		{/* No results */}
		<div class="cf-no-results" id="cf-no-results" hidden>
			No feedback entries match this category.
		</div>

		{/* CTA */}
		<div class="cf-cta">
			<div class="cf-cta-content">
				<h2>Got a success story to tell?</h2>
				<p>Real stories, real impact — share your experience with ThingsBoard!</p>
			</div>
			<NButton href="/contact-us/" target="_blank">Contact Us</NButton>
		</div>
	</main>
</BaseLayout>

<script>
	function initFeedbackIndex() {
		const pills = document.querySelectorAll<HTMLButtonElement>('.cf-filter-pill');
		const cards = document.querySelectorAll<HTMLElement>('.cf-card');
		const grid = document.getElementById('cf-grid')!;
		const noResults = document.getElementById('cf-no-results')!;

		let currentCategory = 'all';

		// Restore from URL
		const params = new URLSearchParams(window.location.search);
		const urlCat = params.get('category');
		if (urlCat) {
			currentCategory = urlCat;
		}

		function render() {
			const isAll = currentCategory === 'all';
			let visibleCount = 0;
			cards.forEach((card) => {
				const matchesCat = isAll || card.dataset.category === currentCategory;
				const isDupe = isAll && card.classList.contains('cf-dupe');
				if (matchesCat && !isDupe) {
					card.classList.remove('cf-hidden');
					visibleCount++;
				} else {
					card.classList.add('cf-hidden');
				}
			});

			noResults.hidden = visibleCount > 0;

			pills.forEach((pill) => {
				pill.classList.toggle('active', pill.dataset.category === currentCategory);
			});

			// Update URL
			const url = new URL(window.location.href);
			if (currentCategory === 'all') {
				url.searchParams.delete('category');
			} else {
				url.searchParams.set('category', currentCategory);
			}
			window.history.replaceState({}, '', url.toString());
		}

		pills.forEach((pill) => {
			pill.addEventListener('click', () => {
				currentCategory = pill.dataset.category || 'all';
				render();
			});
		});

		render();

		// "Read more" toggle for long cards
		document.querySelectorAll<HTMLButtonElement>('.cf-read-more').forEach((btn) => {
			btn.addEventListener('click', () => {
				const card = btn.closest('.cf-card')!;
				const body = card.querySelector('.cf-card-body')!;
				const expanded = body.classList.toggle('cf-card-body--expanded');
				const textEl = btn.querySelector('.cf-read-more-text')!;
				textEl.textContent = expanded ? 'Show less' : 'Read more';
				btn.classList.toggle('cf-read-more--expanded', expanded);
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initFeedbackIndex);
	document.addEventListener('astro:page-load', initFeedbackIndex);
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.cf-index {
		@include container;
		padding-top: calc(#{$header-height} + #{$spacing-8});
		padding-bottom: $spacing-20;
	}

	// ─── Hero ───
	.cf-hero {
		margin-bottom: $spacing-10;

		h1 {
			@include page-title;
			color: var(--color-text);
			margin: 0 0 $spacing-3;
		}

		p {
			@include text-m;
			color: var(--color-text-secondary);
			margin: 0;
		}
	}

	// ─── Filter pills ───
	.cf-filter {
		display: flex;
		flex-wrap: wrap;
		gap: $spacing-2;
		margin-bottom: $spacing-8;
	}

	.cf-filter-pill {
		display: inline-flex;
		align-items: center;
		padding: 6px $spacing-4;
		border: 1px solid var(--color-border);
		border-radius: $radius-full;
		font-size: $font-size-sm;
		font-weight: $font-weight-medium;
		color: var(--color-text-secondary);
		background: transparent;
		cursor: pointer;
		transition: border-color $transition-fast, background-color $transition-fast, color $transition-fast;
		user-select: none;

		&:hover {
			border-color: $color-primary;
			color: $color-primary;
		}

		&.active {
			background: $color-primary;
			border-color: $color-primary;
			color: #fff;
		}
	}

	// ─── Card grid ───
	.cf-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: $spacing-6;

		@include media-down(lg) {
			grid-template-columns: 1fr;
		}
	}

	// ─── Card ───
	.cf-card {
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: $radius-xl;
		padding: $spacing-6;
		transition: border-color $transition-fast;

		&:hover {
			border-color: var(--color-border-light);
		}

		&.cf-hidden {
			display: none;
		}
	}

	.cf-card-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: $spacing-4;
		margin-bottom: $spacing-5;

		@include media-down(sm) {
			flex-direction: column;
		}
	}

	.cf-card-author {
		display: flex;
		align-items: center;
		gap: $spacing-3;
	}

	.cf-card-avatar {
		width: 64px;
		height: 64px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;

		&--placeholder {
			display: flex;
			align-items: center;
			justify-content: center;
			background: rgba($color-primary, 0.1);
			color: $color-primary;
			font-size: $font-size-2xl;
			font-weight: $font-weight-semibold;
		}
	}

	.cf-card-author-info {
		min-width: 0;
	}

	.cf-card-name {
		@include text-m;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
		margin: 0;
		line-height: 1.3;
	}

	.cf-card-position {
		@include text-s;
		color: var(--color-text-secondary);
		margin: 2px 0 0;
	}

	.cf-card-company {
		flex-shrink: 0;

		a {
			display: block;
			text-decoration: none;
			opacity: 0.8;
			transition: opacity $transition-fast;

			&:hover {
				opacity: 1;
			}
		}

		img {
			display: block;
			max-width: 140px;
			max-height: 48px;
			width: auto;
			height: auto;
			object-fit: contain;

			[data-theme='dark'] & {
				background: rgba(255, 255, 255, 0.9);
				padding: 6px 10px;
				border-radius: $radius-md;
			}
		}
	}

	.cf-card-body {
		position: relative;

		&--clamped:not(&--expanded) {
			max-height: 220px;
			overflow: hidden;

			// Fade-out gradient at the bottom of clamped text
			&::after {
				content: '';
				position: absolute;
				bottom: 0;
				left: 0;
				right: 0;
				height: 60px;
				background: linear-gradient(to bottom, transparent, var(--color-bg-surface));
				pointer-events: none;
			}
		}
	}

	.cf-card-tagline {
		@include text-m;
		font-weight: $font-weight-medium;
		color: var(--color-text);
		margin: 0 0 $spacing-3;
	}

	.cf-card-text {
		@include text-s;
		color: var(--color-text-secondary);
		margin: 0 0 $spacing-2;

		&:last-child {
			margin-bottom: 0;
		}
	}

	// ─── Card actions bar ───
	.cf-card-actions {
		display: flex;
		align-items: center;
		gap: $spacing-4;
		margin-top: $spacing-4;
		padding-top: $spacing-4;
		border-top: 1px solid var(--color-border);
	}

	// ─── Read more toggle ───
	.cf-read-more {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 0;
		border: none;
		background: none;
		color: var(--color-text-secondary);
		font-size: $font-size-sm;
		font-weight: $font-weight-medium;
		cursor: pointer;
		transition: color $transition-fast;

		&:hover {
			color: var(--color-text);
		}

		.cf-read-more-icon {
			width: 10px;
			height: 10px;
			transition: transform 0.25s ease;
		}

		&--expanded .cf-read-more-icon {
			transform: rotate(180deg);
		}
	}

	// ─── Case study pill ───
	.cf-case-study-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		margin-left: auto;
		padding: 5px $spacing-3;
		font-size: $font-size-xs;
		font-weight: $font-weight-medium;
		color: $color-primary;
		text-decoration: none;
		border: 1px solid rgba($color-primary, 0.25);
		border-radius: $radius-full;
		background: rgba($color-primary, 0.04);
		transition: background-color $transition-fast, border-color $transition-fast;

		&:hover {
			background: rgba($color-primary, 0.1);
			border-color: rgba($color-primary, 0.5);
		}

		.cf-cs-icon {
			width: 11px;
			height: 11px;
			opacity: 0.7;
		}

		.cf-cs-arrow {
			width: 10px;
			height: 10px;
			opacity: 0.5;
			transition: transform $transition-fast, opacity $transition-fast;
		}

		&:hover .cf-cs-arrow {
			transform: translateX(2px);
			opacity: 0.8;
		}
	}

	// ─── No results ───
	.cf-no-results {
		text-align: center;
		padding: $spacing-12 $spacing-4;
		@include text-m;
		color: var(--color-text-secondary);

		&[hidden] {
			display: none;
		}
	}

	// ─── CTA ───
	.cf-cta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: $spacing-6;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: $radius-xl;
		padding: $spacing-8;
		margin-top: $spacing-10;

		@include media-down(md) {
			flex-direction: column;
			text-align: center;
		}

		.cf-cta-content {
			h2 {
				@include subsection-title;
				color: var(--color-text);
				margin: 0 0 $spacing-2;
			}

			p {
				@include text-s;
				margin: 0;
			}
		}
	}
</style>
