---
import BaseLayout from '@layouts/BaseLayout.astro';
import NButton from '../../components/Landing/NButton.astro';
import SmartImage from '../../components/SmartImage.astro';
import UseCaseCard from '../../components/UseCase/UseCaseCard.astro';
import ContactUsBanner from '../../components/UseCase/ContactUsBanner.astro';
import { useCaseItems } from '@data/use-cases';
---

<BaseLayout
	headerVariant="solid-border"
	title="IoT Use Cases"
	description="Explore ThingsBoard IoT use cases — smart energy, SCADA, fleet tracking, healthcare, environment monitoring with ready-to-use dashboards and architectures."
>
	<main class="uc-index">
		{/* Hero */}
		<section class="uc-index-hero">
			<div class="uc-index-hero-left">
				<h1>IoT Use Cases</h1>
				<p class="uc-index-hero-desc">
					ThingsBoard supports various IoT use cases with flexible out-of-the-box features. Each use case below is
					equipped with a PoC dashboard and reference solution architecture. Need a tailored implementation? Explore our <a
						href="/services/development-services/">IoT development service.</a
					>
				</p>
			</div>
			<div class="uc-index-hero-right">
				<div class="uc-index-contact-card">
					<div class="uc-index-contact-icon">
						<SmartImage src="/src/assets/images/usecases/email-icon.svg" alt="Contact us" width={120} height={84} />
					</div>
					<p class="uc-index-contact-title">Have any comments or questions?</p>
					<NButton variant="outlined" href="/contact-us/" size="sm"> Contact us </NButton>
				</div>
			</div>
		</section>

		{/* Filter tabs */}
		<div class="uc-filter" id="uc-filter">
			<button class="uc-filter-tab active" data-filter="all">
				<svg class="uc-filter-check" width="14" height="10" viewBox="0 0 14 10" fill="none">
					<path d="M1 5L5 9L13 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
					></path>
				</svg>
				All
			</button>
			<button class="uc-filter-tab" data-filter="General">
				<svg class="uc-filter-check" width="14" height="10" viewBox="0 0 14 10" fill="none">
					<path d="M1 5L5 9L13 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
					></path>
				</svg>
				General
			</button>
			<button class="uc-filter-tab" data-filter="SCADA">
				<svg class="uc-filter-check" width="14" height="10" viewBox="0 0 14 10" fill="none">
					<path d="M1 5L5 9L13 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
					></path>
				</svg>
				SCADA
			</button>
		</div>

		{/* Cards grid */}
		<div class="uc-card-grid" id="uc-card-grid">
			{useCaseItems.map((item, index) => <UseCaseCard item={item} featured={(index + 1) % 3 === 0} />)}
		</div>

		<ContactUsBanner
			buttons={[
				{ label: 'Contact Us', href: '/contact-us/' },
				{ label: 'IoT development services', href: '/services/development-services/', variant: 'outlined' },
			]}
		/>
	</main>
</BaseLayout>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	// ============================================
	// Index Page Layout
	// ============================================

	:root {
		--sl-color-bg-nav: var(--color-bg-surface);
	}

	.uc-index {
		@include container;
		padding-top: $spacing-10;
		padding-bottom: $spacing-20;
	}

	// Hero
	.uc-index-hero {
		display: flex;
		gap: $spacing-10;
		margin-bottom: $spacing-12;

		@include media-down(lg) {
			flex-direction: column;
		}
	}

	.uc-index-hero-left {
		flex: 1;

		h1 {
			@include page-title;
			color: var(--color-text);
			margin: 0 0 $spacing-6;
		}
	}

	.uc-index-hero-desc {
		@include text-m;
		line-height: $line-height-base;
		margin: 0;

		a {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}

	.uc-index-hero-right {
		flex-shrink: 0;
		width: 280px;

		@include media-down(lg) {
			width: 100%;
		}
	}

	.uc-index-contact-card {
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: $radius-lg;
		padding: $spacing-6;
		text-align: center;
		overflow: hidden;
	}

	.uc-index-contact-icon {
		margin-bottom: $spacing-4;

		img {
			margin: 0 auto;
		}
	}

	.uc-index-contact-title {
		@include text-tab;
		color: var(--color-text);
		margin: 0 0 $spacing-4;
	}

	// ============================================
	// Filter Tabs
	// ============================================

	.uc-filter {
		display: flex;
		gap: $spacing-2;
		margin-bottom: $spacing-10;
	}

	.uc-filter-tab {
		display: inline-flex;
		align-items: center;
		gap: $spacing-1;
		padding: $spacing-2 $spacing-4;
		font-size: $font-size-sm;
		font-weight: $font-weight-medium;
		background: transparent;
		border: 1px solid var(--color-border);
		border-radius: $radius-full;
		cursor: pointer;
		color: var(--color-text-secondary);
		transition: all $transition-base;

		.uc-filter-check {
			display: none;
			width: 14px;
			height: 10px;
		}

		&:hover {
			border-color: var(--color-primary);
			color: var(--color-primary);
		}

		&.active {
			border-color: var(--color-primary);
			color: var(--color-primary);

			.uc-filter-check {
				display: block;
			}
		}
	}

	// ============================================
	// Cards Grid
	// ============================================

	.uc-card-grid {
		display: grid;
		gap: $spacing-8;
		grid-template-columns: repeat(2, 1fr);
		grid-auto-flow: row dense;

		@include media-down(lg) {
			grid-template-columns: 1fr;
		}
	}

	// ============================================
	// Use Case Card
	// ============================================

	.uc-card {
		display: block;
		overflow: hidden;
		background: var(--color-bg-surface);
		padding: $spacing-4;
		border-radius: $radius-sm;
		border: 1px solid var(--color-border);
		height: 100%;
		text-decoration: none;
		color: inherit;
		cursor: pointer;
		transition:
			border-color $transition-fast,
			transform $transition-fast,
			box-shadow $transition-fast;

		&.filter-hidden {
			display: none;
		}

		&:hover {
			border-color: var(--color-primary);
			transform: translateY(-2px);
			box-shadow: var(--shadow-sm);

			.uc-card-title {
				color: var(--color-primary);
			}
		}

		// Featured (every 3rd) — full-width
		&.uc-card--featured {
			grid-column: span 2;

			@include media-down(lg) {
				grid-column: span 1;
			}

			.uc-card-flex {
				flex-direction: row-reverse;
				align-items: stretch;
				gap: $spacing-8;
				height: auto;

				@include media-down(lg) {
					flex-direction: column;
					height: 100%;
				}
			}

			.uc-card-media {
				width: 50%;

				@include media-down(lg) {
					width: 100%;
				}
			}

			.uc-card-text {
				width: 50%;
				padding: 0;
				gap: $spacing-4;
				justify-content: center;

				@include media-down(lg) {
					width: 100%;
				}
			}

			// Every 6th (even featured): normal direction
			&:nth-child(6n) .uc-card-flex {
				flex-direction: row;

				@include media-down(lg) {
					flex-direction: column;
				}
			}
		}
	}

	.uc-card-content {
		height: 100%;
	}

	.uc-card-flex {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: $spacing-4;
		height: 100%;
	}

	// Tablet-only title
	.uc-card-title--tablet {
		display: none;
	}

	@include media-down(lg) {
		@include media-up(sm) {
			.uc-card-title--tablet {
				display: block;
			}

			.uc-card-text .uc-card-title {
				display: none;
			}
		}
	}

	// Media (image + video)
	.uc-card-media {
		display: block;
		width: 100%;
		border-radius: $radius-md;
		position: relative;
		overflow: hidden;
	}

	.uc-card-frame {
		position: relative;
		aspect-ratio: 16 / 9;
		border-radius: $radius-md;
		overflow: hidden;

		img,
		video {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			display: block;
			object-fit: cover;
			object-position: top left;
		}
	}

	.uc-card-overlay {
		position: absolute;
		inset: 0;
		background: rgba($color-dark-alt, 0.15);
		border-radius: $radius-md;
		opacity: 0;
		transition: opacity $transition-base;
		pointer-events: none;

		@include media-down(lg) {
			display: none;
		}
	}

	.uc-card:hover .uc-card-overlay {
		opacity: 1;
	}

	// Text
	.uc-card-text {
		width: 100%;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: $spacing-2;

		.uc-card-title {
			@include card-title-lg;
			margin: 0;
			color: var(--color-text);
			transition: color $transition-base;
		}
	}

	.uc-card-title--tablet {
		@include card-title-lg;
		color: var(--color-text);
		margin: $spacing-4 0 0;
		padding: 0;
	}

	.uc-card-description {
		@include text-card;
		margin: 0;
		color: var(--color-text-secondary);

		@include media-down(sm) {
			@include text-card-sm;
			color: var(--color-text-secondary);
		}
	}

	.uc-card-badge {
		@include text-xs;
		display: inline-block;
		color: var(--color-primary);
		background: color-mix(in srgb, var(--color-primary) 8%, transparent);
		padding: $spacing-1 $spacing-2;
		border-radius: $radius-full;
		width: fit-content;
	}
</style>

<script>
	function initUseCasesIndex() {
		const grid = document.getElementById('uc-card-grid');
		const filterBtns = document.querySelectorAll<HTMLButtonElement>('.uc-filter-tab');
		if (!grid) return;

		const allCards = Array.from(grid.querySelectorAll<HTMLElement>('.uc-card'));
		let currentFilter = 'all';

		// Video hover — videos are pre-marked with js-initialized to skip GifVideo's observer
		allCards.forEach((card) => {
			const video = card.querySelector('video');
			if (!video) return;

			card.addEventListener('mouseenter', () => {
				// Swap data-src → src on first hover (GifVideo uses lazy sources)
				const sources = video.querySelectorAll('source');
				let changed = false;
				sources.forEach((source) => {
					if (source.dataset.src) {
						source.src = source.dataset.src;
						delete source.dataset.src;
						changed = true;
					}
				});
				if (changed) video.load();

				video.play();
			});

			card.addEventListener('mouseleave', () => {
				video.currentTime = 0;
				video.pause();
			});
		});

		function render() {
			allCards.forEach((card) => {
				if (currentFilter === 'all' || card.dataset.type === currentFilter) {
					card.classList.remove('filter-hidden');
				} else {
					card.classList.add('filter-hidden');
				}
			});
		}

		// Filter tabs
		filterBtns.forEach((btn) => {
			btn.addEventListener('click', () => {
				filterBtns.forEach((b) => b.classList.remove('active'));
				btn.classList.add('active');
				currentFilter = btn.dataset.filter || 'all';
				render();
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initUseCasesIndex);
</script>
