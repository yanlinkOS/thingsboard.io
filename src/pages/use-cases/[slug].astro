---
import type { UseCaseData } from '@data/use-cases/types';
import { useCaseBySlug } from '@data/use-cases';
import UseCaseLayout from '../../layouts/UseCaseLayout.astro';
import AboutSection from '../../components/UseCase/AboutSection.astro';
import ImageComparison from '../../components/UseCase/ImageComparison.astro';
import UseCaseCarousel from '../../components/UseCase/UseCaseCarousel.astro';
import ContactUsBanner from '../../components/UseCase/ContactUsBanner.astro';
import ComparisonTable from '../../components/UseCase/ComparisonTable.astro';
import SolutionStructure from '../../components/UseCase/SolutionStructure.astro';
import BenefitsSection from '../../components/UseCase/BenefitsSection.astro';
import KeyFunctionsSection from '../../components/UseCase/KeyFunctionsSection.astro';
import ScadaDualModeSection from '../../components/UseCase/ScadaDualModeSection.astro';
import DashboardStructure from '../../components/UseCase/DashboardStructure.astro';
import ApplicationsSection from '../../components/UseCase/ApplicationsSection.astro';
import SummarySection from '../../components/UseCase/SummarySection.astro';
import AdvantagesSection from '../../components/Landing/AdvantagesSection.astro';

export async function getStaticPaths() {
	return Object.values(useCaseBySlug).map((data) => ({
		params: { slug: data.pageSlug },
		props: { data },
	}));
}

interface Props {
	data: UseCaseData;
}

const { data } = Astro.props;
---

<UseCaseLayout title={data.pageTitle} description={data.description} pageSlug={data.pageSlug}>
	<h1 class="usecase-title">{data.title}</h1>

	<AboutSection
		shortText={data.about.shortText}
		longText={data.about.longText}
		demoUrl={data.about.demoUrl}
		demoButtonId={data.about.demoButtonId}
	/>

	{/* Overview — comparison slider, carousel, or SCADA traditional/high-performance slider */}
	{
		data.overview?.type === 'comparison' && (
			<ImageComparison
				baseImage={data.overview.baseImage!}
				baseImageAlt={data.overview.baseImageAlt}
				baseImageTitle={data.overview.baseImageTitle}
				overlayImage={data.overview.overlayImage!}
				overlayImageAlt={data.overview.overlayImageAlt}
				overlayImageTitle={data.overview.overlayImageTitle}
			/>
		)
	}
	{
		data.overview?.type === 'carousel' && data.overview.carouselImages && (
			<UseCaseCarousel images={data.overview.carouselImages} />
		)
	}
	{
		data.scadaOverview && (
			<ImageComparison
				baseImage={data.scadaOverview.baseImage}
				baseImageAlt="Traditional SCADA dashboard"
				overlayImage={data.scadaOverview.overlayImage}
				overlayImageAlt="High-performance SCADA dashboard"
			/>
		)
	}

	<ContactUsBanner />

	{
		data.scadaOverview && (
			<ComparisonTable title="SCADA overview" rows={data.scadaOverview.comparisonRows} />
		)
	}

	{
		data.solutionStructure && (
			<SolutionStructure
				title={data.solutionStructure.title}
				badge={data.solutionStructure.badge}
				shortText={data.solutionStructure.shortText}
				longText={data.solutionStructure.longText}
				schemeSrc={data.solutionStructure.schemeSrc}
				schemeAlt={data.solutionStructure.schemeAlt}
				schemeCaption={data.solutionStructure.schemeCaption}
			/>
		)
	}

	{
		data.benefits && (
			<BenefitsSection
				title={data.benefits.title}
				badge={data.benefits.badge}
				subtitle={data.benefits.subtitle}
				benefits={data.benefits.benefits}
			/>
		)
	}

	{
		data.scadaKeyFunctions && data.scadaKeyFunctions.highPerformance.length > 0 && (
			<KeyFunctionsSection
				highPerformance={data.scadaKeyFunctions.highPerformance}
				traditional={data.scadaKeyFunctions.traditional}
			/>
		)
	}

	{/* Dashboard — SCADA dual-mode wrapper, otherwise a single dashboard */}
	{
		data.scadaDashboardStructure && (
			<ScadaDualModeSection
				highPerformance={data.scadaDashboardStructure.highPerformance}
				traditional={data.scadaDashboardStructure.traditional}
			/>
		)
	}
	{
		!data.scadaDashboardStructure && data.dashboardStructure && (
			<DashboardStructure
				title={data.dashboardStructure.title}
				badge={data.dashboardStructure.badge}
				subtitle={data.dashboardStructure.subtitle}
				panels={data.dashboardStructure.panels}
				demoUrl={data.dashboardStructure.demoUrl}
				demoButtonId={data.dashboardStructure.demoButtonId}
				contactUsId={data.dashboardStructure.contactUsId}
			/>
		)
	}

	{
		data.applications && (
			<ApplicationsSection
				title={data.applications.title}
				badge={data.applications.badge}
				subtitle={data.applications.subtitle}
				applications={data.applications.applications}
			/>
		)
	}

	<AdvantagesSection />

	{
		data.summary && (
			<SummarySection
				title={data.summary.title}
				text={data.summary.text}
				icon={data.summary.icon}
				iconAlt={data.summary.iconAlt}
			/>
		)
	}
</UseCaseLayout>
