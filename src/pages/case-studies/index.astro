---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NButton from '../../components/Landing/NButton.astro';
import { Icon } from 'astro-icon/components';
import { caseStudyCards, caseStudyCategories, featuredCard } from '@data/case-studies';

const PAGE_SIZE = 9;

// Build filter values with counts
const categoryCountMap = new Map<string, number>();
caseStudyCards.forEach((card) => {
	card.categories.forEach((cat) => {
		categoryCountMap.set(cat, (categoryCountMap.get(cat) || 0) + 1);
	});
});

const filterValues = caseStudyCategories.map((cat) => ({
	value: cat,
	count: categoryCountMap.get(cat) || 0,
}));

const initialCards = caseStudyCards.slice(0, PAGE_SIZE);

const cardsWithHref = caseStudyCards.map((card) => ({
	...card,
	href: `/case-studies/${card.slug}/`,
}));
---

<BaseLayout
	title="IoT Case Studies"
	description="Discover how companies in retail, energy, logistics, and more drive digital transformation with ThingsBoard's IoT platform to boost efficiency, growth, and innovation."
	pageId="case-studies"
	customTitle={true}
>
	<main class="cs-index">
		<!-- Hero featured card -->
		<section class="cs-index-hero">
			<h1>Case studies</h1>
			<h2>Learn how ThingsBoard helps clients build and improve their businesses</h2>
			<a href={`/case-studies/${featuredCard.slug}/`} class="cs-hero-card">
				<div class="cs-hero-card-image" style={`--hero-bg: url('${featuredCard.backgroundImage}')`}>
					<img src={featuredCard.logo} alt={featuredCard.logoAlt} />
				</div>
				<div class="cs-hero-card-text">
					<p class="cs-hero-card-category">{featuredCard.category}</p>
					<h3>{featuredCard.title}</h3>
					<p class="cs-hero-card-desc">{featuredCard.description}</p>
					<span class="cs-hero-card-link">
						Learn more
						<Icon name="tabler:chevron-right" class="cs-hero-arrow" />
					</span>
				</div>
			</a>
		</section>

		<!-- Search + filters -->
		<div class="cs-toolbar">
			<div class="cs-search-bar">
				<Icon name="tabler:search" class="cs-search-icon" />
				<input type="text" id="cs-search" class="cs-search-input" placeholder="Search case studies..." autocomplete="off" aria-label="Search case studies" />
				<button type="button" class="cs-search-clear" id="cs-search-clear" hidden aria-label="Clear search">
					<Icon name="tabler:x" class="cs-search-clear-icon" />
				</button>
			</div>
			<div class="cs-filter-pills">
				{filterValues.map((item) => (
					<h2 class="cs-filter-pill">
						<label>
							<input type="checkbox" name="category" value={item.value} />
							<span class="cs-filter-pill-label">{item.value}</span>
						</label>
					</h2>
				))}
				<button type="button" class="cs-filter-clear" id="cs-clear-filters" hidden>Clear all</button>
			</div>
		</div>

			<!-- Card grid -->
		<div class="cs-card-grid" id="cs-card-grid">
			{initialCards.map((card) => (
				<a href={`/case-studies/${card.slug}/`} class="cs-client-card" style={`--card-bg: linear-gradient(0deg, rgba(0,0,0,0.30) 0%, rgba(0,0,0,0.30) 100%), url('${card.backgroundImage}')`}>
					<div class="cs-card-content">
						<div class="cs-card-top">
							<img
								class="cs-card-logo"
								src={card.logo}
								alt={card.logoAlt}
								style={card.logoHeight ? `height: ${card.logoHeight}px` : undefined}
							/>
						</div>
						<div class="cs-card-bottom">
							<div class="cs-card-categories">
								{card.categories.map((cat) => (
									<span class="cs-card-category">{cat}</span>
								))}
							</div>
							<h3 class="cs-card-title">{card.title}</h3>
							<p class="cs-card-link">
								Learn more
								<Icon name="tabler:arrow-right" class="cs-card-arrow" />
							</p>
						</div>
					</div>
				</a>
			))}
		</div>

		<!-- No results -->
		<div class="cs-no-results" id="cs-no-results" hidden>
			No case studies match your filters.
		</div>

		<!-- Pagination -->
		<nav class="cs-pagination" id="cs-pagination" hidden aria-label="Pagination">
			<button type="button" class="cs-page-btn cs-page-prev" id="cs-page-prev" disabled>
				<Icon name="tabler:chevron-left" class="cs-page-chevron" />
				<span class="cs-page-btn-text">Previous</span>
			</button>
			<div class="cs-page-numbers" id="cs-page-numbers"></div>
			<button type="button" class="cs-page-btn cs-page-next" id="cs-page-next" disabled>
				<span class="cs-page-btn-text">Next</span>
				<Icon name="tabler:chevron-right" class="cs-page-chevron" />
			</button>
		</nav>

		<!-- Success story CTA -->
		<div class="cs-success-cta" id="cs-success-cta">
			<div class="cs-success-content">
				<h2>Got a success story to tell?</h2>
				<p>Real stories, real impact — share your experience with ThingsBoard!</p>
			</div>
			<NButton href="/contact-us/" target="_blank">Contact Us</NButton>
		</div>
	</main>
</BaseLayout>

<script is:inline define:vars={{ cardsWithHref }}>
	window.__CS_DATA__ = cardsWithHref;
</script>

<script>
	interface CSCard {
		slug: string;
		categories: string[];
		title: string;
		description: string;
		logo: string;
		logoAlt: string;
		logoHeight?: number;
		backgroundImage: string;
		href: string;
	}

	function initCaseStudyIndex() {
		const allCards = (window as any).__CS_DATA__ as CSCard[];
		if (!allCards) return;

		const PAGE_SIZE = 9;
		let currentPage = 1;
		let debounceTimer: ReturnType<typeof setTimeout>;

		const grid = document.getElementById('cs-card-grid')!;
		const noResults = document.getElementById('cs-no-results')!;
		const searchInput = document.getElementById('cs-search') as HTMLInputElement;
		const searchClear = document.getElementById('cs-search-clear') as HTMLButtonElement;
		const clearFilters = document.getElementById('cs-clear-filters') as HTMLButtonElement;
		const checkboxes = document.querySelectorAll<HTMLInputElement>('.cs-filter-pills input[type="checkbox"]');
		const pagination = document.getElementById('cs-pagination')!;
		const pageNumbers = document.getElementById('cs-page-numbers')!;
		const pagePrev = document.getElementById('cs-page-prev') as HTMLButtonElement;
		const pageNext = document.getElementById('cs-page-next') as HTMLButtonElement;
		const successCta = document.getElementById('cs-success-cta')!;

		function getActiveCategories(): string[] {
			const cats: string[] = [];
			checkboxes.forEach((cb) => { if (cb.checked) cats.push(cb.value); });
			return cats;
		}

		function search(query: string, categories: string[], page: number) {
			let filtered = allCards;

			if (query) {
				const q = query.toLowerCase();
				filtered = filtered.filter((c) =>
					c.title.toLowerCase().includes(q) ||
					c.description.toLowerCase().includes(q) ||
					c.categories.some((cat) => cat.toLowerCase().includes(q))
				);
			}

			if (categories.length > 0) {
				filtered = filtered.filter((c) =>
					categories.some((cat) => c.categories.includes(cat))
				);
			}

			const total = filtered.length;
			const totalPages = Math.ceil(total / PAGE_SIZE) || 1;
			const curPage = Math.min(Math.max(1, page), totalPages);
			const start = (curPage - 1) * PAGE_SIZE;
			const items = filtered.slice(start, start + PAGE_SIZE);

			return { items, total, totalPages, currentPage: curPage };
		}

		function renderCard(card: CSCard): string {
			const logoStyle = card.logoHeight ? ` style="height: ${card.logoHeight}px"` : '';
			const categories = card.categories.map((cat) => `<span class="cs-card-category">${cat}</span>`).join('');
			return `<a href="${card.href}" class="cs-client-card" style="--card-bg: linear-gradient(0deg, rgba(0,0,0,0.30) 0%, rgba(0,0,0,0.30) 100%), url('${card.backgroundImage}')">
				<div class="cs-card-content">
					<div class="cs-card-top">
						<img class="cs-card-logo" src="${card.logo}" alt="${card.logoAlt}"${logoStyle} />
					</div>
					<div class="cs-card-bottom">
						<div class="cs-card-categories">${categories}</div>
						<h3 class="cs-card-title">${card.title}</h3>
						<p class="cs-card-link">Learn more <svg class="cs-card-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" fill="currentColor"><path d="m190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3"/></svg></p>
					</div>
				</div>
			</a>`;
		}

		function renderPagination(current: number, total: number) {
			if (total <= 1) {
				pagination.hidden = true;
				return;
			}
			pagination.hidden = false;
			pagePrev.disabled = current <= 1;
			pageNext.disabled = current >= total;

			const pages: (number | string)[] = [];
			const maxVisible = 5;
			if (total <= maxVisible) {
				for (let i = 1; i <= total; i++) pages.push(i);
			} else {
				pages.push(1);
				if (current > 3) pages.push('...');
				const start = Math.max(2, current - 1);
				const end = Math.min(total - 1, current + 1);
				for (let i = start; i <= end; i++) { if (!pages.includes(i)) pages.push(i); }
				if (current < total - 2) pages.push('...');
				if (!pages.includes(total)) pages.push(total);
			}

			pageNumbers.innerHTML = pages.map((p) =>
				typeof p === 'number'
					? `<button type="button" class="cs-num-btn${p === current ? ' active' : ''}" data-page="${p}">${p}</button>`
					: `<span class="cs-page-ellipsis">${p}</span>`
			).join('');
		}

		function saveState() {
			const state: Record<string, string> = {};
			const q = searchInput.value.trim();
			if (q) state.q = q;
			const cats = getActiveCategories();
			if (cats.length) state.category = cats.join(',');
			if (currentPage > 1) state.page = String(currentPage);
			sessionStorage.setItem('cs-index-state', JSON.stringify(state));
		}

		function updateDisplay() {
			const result = search(searchInput.value.trim(), getActiveCategories(), currentPage);
			if (result.items.length > 0) {
				grid.innerHTML = result.items.map(renderCard).join('');
				noResults.hidden = true;
			} else {
				grid.innerHTML = '';
				noResults.hidden = false;
			}

			currentPage = result.currentPage;
			renderPagination(result.currentPage, result.totalPages);
			searchClear.hidden = !searchInput.value;

			// Show "Clear all" only when filters are active
			const hasActiveFilters = getActiveCategories().length > 0;
			clearFilters.hidden = !hasActiveFilters;
			// Toggle active class on pills
			checkboxes.forEach((cb) => {
				const pill = cb.closest('.cs-filter-pill') as HTMLElement;
				if (pill) pill.classList.toggle('active', cb.checked);
			});

			// Show success CTA only on last page or when few results
			successCta.style.display = (result.currentPage >= result.totalPages) ? '' : 'none';

			saveState();
		}

		function resetAndUpdate() {
			currentPage = 1;
			updateDisplay();
		}

		// Restore state only when navigating back from a case study detail page
		function restoreState() {
			const referrer = document.referrer;
			const cameFromCaseStudy = referrer && /\/case-studies\/[^/]+\//.test(referrer);
			if (!cameFromCaseStudy) {
				sessionStorage.removeItem('cs-index-state');
				return;
			}
			const raw = sessionStorage.getItem('cs-index-state');
			if (!raw) return;
			try {
				const state = JSON.parse(raw);
				if (state.q) searchInput.value = state.q;
				if (state.category) {
					const catList = state.category.split(',');
					checkboxes.forEach((cb) => { cb.checked = catList.includes(cb.value); });
				}
				if (state.page) currentPage = parseInt(state.page, 10);
			} catch { /* ignore malformed state */ }
		}

		// Event listeners
		checkboxes.forEach((cb) => cb.addEventListener('change', resetAndUpdate));

		clearFilters?.addEventListener('click', () => {
			checkboxes.forEach((cb) => { cb.checked = false; });
			searchInput.value = '';
			resetAndUpdate();
		});

		searchInput.addEventListener('input', () => {
			clearTimeout(debounceTimer);
			debounceTimer = setTimeout(resetAndUpdate, 300);
		});

		searchClear?.addEventListener('click', () => {
			searchInput.value = '';
			resetAndUpdate();
			searchInput.focus();
		});

		pagePrev?.addEventListener('click', () => {
			if (currentPage > 1) { currentPage--; updateDisplay(); }
		});

		pageNext?.addEventListener('click', () => {
			currentPage++; updateDisplay();
		});

		pageNumbers?.addEventListener('click', (e) => {
			const target = e.target as HTMLElement;
			if (target.classList.contains('cs-num-btn')) {
				const page = parseInt(target.dataset.page || '1', 10);
				if (page !== currentPage) { currentPage = page; updateDisplay(); }
			}
		});

		restoreState();
		updateDisplay();
	}

	initCaseStudyIndex();
	document.addEventListener('astro:page-load', initCaseStudyIndex);
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.cs-index {
		max-width: 1080px;
		margin: 0 auto;
		padding: calc(#{$header-height} + #{$spacing-8}) $spacing-5 $spacing-20;
	}

	// ─── Toolbar (search + filter pills) ───
	.cs-toolbar {
		display: flex;
		flex-direction: column;
		gap: $spacing-4;
		margin-bottom: $spacing-6;
	}

	.cs-filter-pills {
		display: flex;
		flex-wrap: wrap;
		gap: $spacing-2;
		align-items: center;
	}

	.cs-filter-pill {
		display: inline-flex;
		align-items: center;
		cursor: pointer;
		border: 1px solid var(--color-border);
		border-radius: 100px;
		font-size: $font-size-sm;
		font-weight: $font-weight-normal;
		line-height: normal;
		color: var(--color-text);
		background: var(--color-bg-surface);
		transition: border-color $transition-fast, background-color $transition-fast, color $transition-fast;
		user-select: none;
		margin: 0;

		> label {
			display: inline-flex;
			align-items: center;
			padding: 6px $spacing-4;
			cursor: pointer;
		}

		input[type='checkbox'] {
			display: none;
		}

		&:hover {
			border-color: $color-primary;
		}

		&.active {
			background: $color-primary;
			border-color: $color-primary;
			color: #fff;
		}
	}

	.cs-filter-clear {
		background: none;
		border: none;
		color: $color-primary;
		cursor: pointer;
		font-size: $font-size-sm;
		padding: 4px $spacing-2;

		&:hover {
			text-decoration: underline;
		}

		&[hidden] {
			display: none;
		}
	}

	// ─── Hero ───
	.cs-index-hero {
		margin-bottom: $spacing-10;

		h1 {
			@include page-title;
			color: var(--color-text);
			margin: 0 0 $spacing-3;
		}

		h2 {
			@include text-m;
			color: var(--color-text-secondary);
			font-weight: $font-weight-normal;
			margin: 0 0 $spacing-8;
		}
	}

	.cs-hero-card {
		display: flex;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: $radius-xl;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		&:hover {
			.cs-hero-card-image::after {
				transform: scale(1.1);
			}

			.cs-hero-card-link {
				transform: translateY(0);
				opacity: 1;
			}
		}

		@include media-down(lg) {
			flex-direction: column;
		}
	}

	.cs-hero-card-image {
		flex: 0 0 380px;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: var(--color-bg-light);
		padding: $spacing-8;
		overflow: hidden;

		&::after {
			content: '';
			position: absolute;
			inset: 0;
			background-image: var(--hero-bg);
			background-size: cover;
			background-position: center;
			transition: transform 0.3s ease;
		}

		img {
			position: relative;
			z-index: 1;
			max-width: 240px;
			height: auto;
		}

		@include media-down(lg) {
			flex: auto;
			padding: $spacing-6;
		}
	}

	.cs-hero-card-text {
		flex: 1;
		padding: $spacing-8;

		@include media-down(md) {
			padding: $spacing-6;
		}

		.cs-hero-card-category {
			@include text-s;
			font-weight: $font-weight-semibold;
			text-transform: uppercase;
			color: $color-primary;
			letter-spacing: 0.5px;
			margin: 0 0 $spacing-2;
		}

		h3 {
			@include card-title;
			color: var(--color-text);
			margin: 0 0 $spacing-4;
		}

		.cs-hero-card-desc {
			@include text-s;
			margin: 0 0 $spacing-4;
			display: -webkit-box;
			-webkit-line-clamp: 4;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		.cs-hero-card-link {
			@include action-link;
			color: $color-primary;
			display: inline-flex;
			align-items: center;
			gap: $spacing-1;
			transform: translateY(8px);
			opacity: 0;
			transition: transform 0.25s ease, opacity 0.25s ease;

			.cs-hero-arrow {
				width: 12px;
				height: 12px;
			}
		}
	}

	// ─── Search bar ───
	.cs-search-bar {
		position: relative;
		display: flex;
		align-items: center;
		width: 100%;
	}

	.cs-search-icon {
		position: absolute;
		left: 12px;
		width: 18px;
		height: 18px;
		color: var(--color-text-secondary);
		pointer-events: none;
	}

	.cs-search-clear-icon {
		width: 16px;
		height: 16px;
	}

	.cs-search-input {
		width: 100%;
		padding: 8px 40px;
		font-size: $font-size-sm;
		border: 1px solid var(--color-border);
		border-radius: $radius-sm;
		background: var(--color-bg-surface);
		color: var(--color-text);
		transition: border-color $transition-fast;

		&::placeholder {
			color: var(--color-text-secondary);
		}

		&:focus {
			outline: none;
			border-color: $color-primary;
		}
	}

	.cs-search-clear {
		position: absolute;
		right: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		padding: 0;
		border: none;
		background: none;
		color: var(--color-text-secondary);
		cursor: pointer;
		border-radius: $radius-sm;

		&:hover {
			color: var(--color-text);
			background: var(--color-bg-light);
		}

		&[hidden] {
			display: none;
		}
	}

	// ─── Card grid ───
	.cs-card-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: $spacing-6;

		@include media-down(xl) {
			grid-template-columns: repeat(2, 1fr);
		}

		@include media-down(md) {
			grid-template-columns: 1fr;
		}
	}

	.cs-client-card {
		position: relative;
		display: block;
		text-decoration: none;
		border-radius: $radius-xl;
		overflow: hidden;
		height: 340px;
		color: $color-white;

		// Background image layer with zoom effect
		&::after {
			content: '';
			position: absolute;
			inset: 0;
			background-image: var(--card-bg);
			background-size: cover;
			background-position: center;
			transform-origin: center;
			transition: transform 0.3s ease;
		}

		&:hover {
			&::after {
				transform: scale(1.1);
			}

			.cs-card-link {
				transform: translateY(0);
				opacity: 1;
			}
		}

		@include media-down(md) {
			height: 300px;
		}
	}

	.cs-card-content {
		position: relative;
		z-index: 1;
		height: 100%;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: $spacing-6;
	}

	.cs-card-top {
		display: flex;
		align-items: flex-start;
	}

	.cs-card-logo {
		height: 56px;
		width: auto;
		max-width: 200px;
		object-fit: contain;
		object-position: left;
		filter: brightness(0) invert(1);
	}

	.cs-card-bottom {
		display: flex;
		flex-direction: column;
		gap: $spacing-2;
	}

	.cs-card-categories {
		display: flex;
		flex-wrap: wrap;
		gap: $spacing-1;
	}

	.cs-card-category {
		@include text-xs;
		display: inline-block;
		padding: 2px 10px;
		background: rgba(255, 255, 255, 0.2);
		backdrop-filter: blur(4px);
		border-radius: 100px;
		color: $color-white;
	}

	.cs-card-title {
		@include text-overlay;
		color: $color-white;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.cs-card-link {
		font-size: $font-size-base;
		font-weight: $font-weight-medium;
		color: $color-white;
		display: inline-flex;
		align-items: center;
		gap: $spacing-2;
		margin: 0;
		transform: translateY(8px);
		opacity: 0;
		transition: transform 0.25s ease, opacity 0.25s ease;
		white-space: nowrap;
	}

	.cs-card-arrow {
		width: 14px;
		height: 14px;
	}

