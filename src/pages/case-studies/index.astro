---
import BaseLayout from '@layouts/BaseLayout.astro';
import NButton from '../../components/Landing/NButton.astro';
import { Icon } from 'astro-icon/components';
import { caseStudyCards, caseStudyCategories, featuredCard } from '@data/case-studies';

const PAGE_SIZE = 9;

// Build filter values with counts
const categoryCountMap = new Map<string, number>();
caseStudyCards.forEach((card) => {
	card.categories.forEach((cat) => {
		categoryCountMap.set(cat, (categoryCountMap.get(cat) || 0) + 1);
	});
});

const filterValues = caseStudyCategories.map((cat) => ({
	value: cat,
	count: categoryCountMap.get(cat) || 0,
}));
---

<BaseLayout
	headerVariant="solid-border"
	title="IoT Case Studies"
	description="Discover how companies in retail, energy, logistics, and more drive digital transformation with ThingsBoard's IoT platform to boost efficiency, growth, and innovation."
	pageId="case-studies"
>
	<main class="cs-index">
		<!-- Hero featured card -->
		<section class="cs-index-hero">
			<h1>Case studies</h1>
			<h2>Learn how ThingsBoard helps clients build and improve their businesses</h2>
			<a href={`/case-studies/${featuredCard.slug}/`} class="cs-hero-card">
				<div class="cs-hero-card-image" style={`--hero-bg: url('${featuredCard.backgroundImage}')`}>
					<img src={featuredCard.logo} alt={featuredCard.logoAlt} />
				</div>
				<div class="cs-hero-card-text">
					<p class="cs-hero-card-category">{featuredCard.category}</p>
					<h3>{featuredCard.title}</h3>
					<p class="cs-hero-card-desc">{featuredCard.description}</p>
					<span class="cs-hero-card-link">
						Learn more
						<Icon name="tabler:chevron-right" class="cs-hero-arrow" />
					</span>
				</div>
			</a>
		</section>

		<!-- Search + filters -->
		<div class="cs-toolbar">
			<div class="cs-search-bar">
				<Icon name="tabler:search" class="cs-search-icon" />
				<input
					type="text"
					id="cs-search"
					class="cs-search-input"
					placeholder="Search case studies..."
					autocomplete="off"
					aria-label="Search case studies"
				/>
				<button type="button" class="cs-search-clear" id="cs-search-clear" hidden aria-label="Clear search">
					<Icon name="tabler:x" class="cs-search-clear-icon" />
				</button>
			</div>
			<div class="cs-filter-pills">
				{
					filterValues.map((item) => (
						<h2 class="cs-filter-pill">
							<label>
								<input type="checkbox" name="category" value={item.value} />
								<span class="cs-filter-pill-label">{item.value}</span>
							</label>
						</h2>
					))
				}
				<button type="button" class="cs-filter-clear" id="cs-clear-filters" hidden>Clear all</button>
			</div>
		</div>

		<!-- Card grid -->
		<div class="cs-card-grid" id="cs-card-grid">
			{
				caseStudyCards.map((card, index) => (
					<a
						href={`/case-studies/${card.slug}/`}
						class:list={['cs-client-card', { 'is-hidden': index >= PAGE_SIZE }]}
						style={`--card-bg: linear-gradient(0deg, rgba(0,0,0,0.30) 0%, rgba(0,0,0,0.30) 100%), url('${card.backgroundImage}')`}
						data-slug={card.slug}
						data-title={card.title}
						data-description={card.description}
						data-categories={JSON.stringify(card.categories)}
					>
						<div class="cs-card-content">
							<div class="cs-card-top">
								<img
									class="cs-card-logo"
									src={card.logo}
									alt={card.logoAlt}
									loading="lazy"
									style={card.logoHeight ? `height: ${card.logoHeight}px` : undefined}
								/>
							</div>
							<div class="cs-card-bottom">
								<div class="cs-card-categories">
									{card.categories.map((cat) => (
										<span class="cs-card-category">{cat}</span>
									))}
								</div>
								<h3 class="cs-card-title">{card.title}</h3>
								<p class="cs-card-link">
									Learn more
									<Icon name="tabler:arrow-right" class="cs-card-arrow" />
								</p>
							</div>
						</div>
					</a>
				))
			}
		</div>

		<!-- No results -->
		<div class="cs-no-results" id="cs-no-results" hidden>No case studies match your filters.</div>

		<!-- Pagination -->
		<nav class="cs-pagination" id="cs-pagination" hidden aria-label="Pagination">
			<button type="button" class="cs-page-btn cs-page-prev" id="cs-page-prev" disabled>
				<Icon name="tabler:chevron-left" class="cs-page-chevron" />
				<span class="cs-page-btn-text">Previous</span>
			</button>
			<div class="cs-page-numbers" id="cs-page-numbers"></div>
			<button type="button" class="cs-page-btn cs-page-next" id="cs-page-next" disabled>
				<span class="cs-page-btn-text">Next</span>
				<Icon name="tabler:chevron-right" class="cs-page-chevron" />
			</button>
		</nav>

		<!-- Success story CTA -->
		<div class="cs-success-cta" id="cs-success-cta">
			<div class="cs-success-content">
				<h2>Got a success story to tell?</h2>
				<p>Real stories, real impact — share your experience with ThingsBoard!</p>
			</div>
			<NButton href="/contact-us/" target="_blank">Contact Us</NButton>
		</div>
	</main>
</BaseLayout>

<script>
	interface CSCard {
		el: HTMLElement;
		slug: string;
		title: string;
		description: string;
		categories: string[];
		searchText: string;
	}

	function readCards(grid: HTMLElement): CSCard[] {
		return Array.from(grid.querySelectorAll<HTMLElement>('.cs-client-card')).map((el) => {
			const title = el.dataset.title || '';
			const description = el.dataset.description || '';
			const categories = JSON.parse(el.dataset.categories || '[]') as string[];
			return {
				el,
				slug: el.dataset.slug || '',
				title,
				description,
				categories,
				searchText: [title, description, ...categories].join(' ').toLowerCase(),
			};
		});
	}

	function initCaseStudyIndex() {
		const grid = document.getElementById('cs-card-grid');
		if (!grid) return;

		const PAGE_SIZE = 9;
		let currentPage = 1;
		let debounceTimer: ReturnType<typeof setTimeout>;

		const noResults = document.getElementById('cs-no-results')!;
		const searchInput = document.getElementById('cs-search') as HTMLInputElement;
		const searchClear = document.getElementById('cs-search-clear') as HTMLButtonElement;
		const clearFilters = document.getElementById('cs-clear-filters') as HTMLButtonElement;
		const pills = Array.from(document.querySelectorAll<HTMLElement>('.cs-filter-pill'));
		const checkboxes = pills.map((pill) => pill.querySelector<HTMLInputElement>('input[type="checkbox"]')!);
		const pagination = document.getElementById('cs-pagination')!;
		const pageNumbers = document.getElementById('cs-page-numbers')!;
		const pagePrev = document.getElementById('cs-page-prev') as HTMLButtonElement;
		const pageNext = document.getElementById('cs-page-next') as HTMLButtonElement;
		const successCta = document.getElementById('cs-success-cta')!;

		const allCards = readCards(grid);

		function getActiveCategories(): string[] {
			return checkboxes.filter((cb) => cb.checked).map((cb) => cb.value);
		}

		function search(query: string, categories: string[], page: number) {
			const q = query.toLowerCase();
			const filtered = allCards.filter(
				(c) =>
					(!q || c.searchText.includes(q)) &&
					(categories.length === 0 || categories.some((cat) => c.categories.includes(cat)))
			);

			const totalPages = Math.ceil(filtered.length / PAGE_SIZE) || 1;
			const curPage = Math.min(Math.max(1, page), totalPages);
			const start = (curPage - 1) * PAGE_SIZE;
			return {
				items: filtered.slice(start, start + PAGE_SIZE),
				totalPages,
				currentPage: curPage,
			};
		}

		function renderPagination(current: number, total: number) {
			pagination.hidden = total <= 1;
			if (total <= 1) return;

			pagePrev.disabled = current <= 1;
			pageNext.disabled = current >= total;

			const pages: (number | string)[] = [];
			if (total <= 5) {
				for (let i = 1; i <= total; i++) pages.push(i);
			} else {
				pages.push(1);
				if (current > 3) pages.push('...');
				const start = Math.max(2, current - 1);
				const end = Math.min(total - 1, current + 1);
				for (let i = start; i <= end; i++) pages.push(i);
				if (current < total - 2) pages.push('...');
				pages.push(total);
			}

			pageNumbers.innerHTML = pages
				.map((p) =>
					typeof p === 'number'
						? `<button type="button" class="cs-num-btn${p === current ? ' active' : ''}" data-page="${p}">${p}</button>`
						: `<span class="cs-page-ellipsis">${p}</span>`
				)
				.join('');
		}

		function saveState(query: string, categories: string[]) {
			const state: Record<string, string> = {};
			if (query) state.q = query;
			if (categories.length) state.category = categories.join(',');
			if (currentPage > 1) state.page = String(currentPage);
			sessionStorage.setItem('cs-index-state', JSON.stringify(state));
		}

		function updateDisplay() {
			const query = searchInput.value.trim();
			const categories = getActiveCategories();
			const result = search(query, categories, currentPage);

			const visibleSlugs = new Set(result.items.map((c) => c.slug));
			allCards.forEach((card) => {
				card.el.classList.toggle('is-hidden', !visibleSlugs.has(card.slug));
			});

			noResults.hidden = result.items.length > 0;
			searchClear.hidden = !query;
			clearFilters.hidden = categories.length === 0;
			pills.forEach((pill, i) => pill.classList.toggle('active', checkboxes[i].checked));
			successCta.style.display = result.currentPage >= result.totalPages ? '' : 'none';

			currentPage = result.currentPage;
			renderPagination(result.currentPage, result.totalPages);
			saveState(query, categories);
		}

		function resetAndUpdate() {
			currentPage = 1;
			updateDisplay();
		}

		// Restore state only when navigating back from a case study detail page
		function restoreState() {
			const cameFromCaseStudy = /\/case-studies\/[^/]+\//.test(document.referrer);
			if (!cameFromCaseStudy) {
				sessionStorage.removeItem('cs-index-state');
				return;
			}
			const raw = sessionStorage.getItem('cs-index-state');
			if (!raw) return;
			try {
				const state = JSON.parse(raw);
				if (state.q) searchInput.value = state.q;
				if (state.category) {
					const catList = state.category.split(',');
					checkboxes.forEach((cb) => {
						cb.checked = catList.includes(cb.value);
					});
				}
				if (state.page) currentPage = parseInt(state.page, 10);
			} catch {
				/* ignore malformed state */
			}
		}

		checkboxes.forEach((cb) => cb.addEventListener('change', resetAndUpdate));

		clearFilters.addEventListener('click', () => {
			checkboxes.forEach((cb) => {
				cb.checked = false;
			});
			searchInput.value = '';
			resetAndUpdate();
		});

		searchInput.addEventListener('input', () => {
			clearTimeout(debounceTimer);
			debounceTimer = setTimeout(resetAndUpdate, 300);
		});

		searchClear.addEventListener('click', () => {
			searchInput.value = '';
			resetAndUpdate();
			searchInput.focus();
		});

		pagePrev.addEventListener('click', () => {
			if (currentPage > 1) {
				currentPage--;
				updateDisplay();
			}
		});

		pageNext.addEventListener('click', () => {
			currentPage++;
			updateDisplay();
		});

		pageNumbers.addEventListener('click', (e) => {
			const target = e.target as HTMLElement;
			if (target.classList.contains('cs-num-btn')) {
				const page = parseInt(target.dataset.page || '1', 10);
				if (page !== currentPage) {
					currentPage = page;
					updateDisplay();
				}
			}
		});

		restoreState();
		updateDisplay();
	}

	initCaseStudyIndex();
	document.addEventListener('astro:page-load', initCaseStudyIndex);
</script>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.cs-index {
		max-width: 1080px;
		margin: 0 auto;
		padding: $spacing-8 $spacing-5 $spacing-20;
	}

	// ─── Toolbar (search + filter pills) ───
	.cs-toolbar {
		display: flex;
		flex-direction: column;
		gap: $spacing-4;
		margin-bottom: $spacing-6;
	}

	.cs-filter-pills {
		display: flex;
		flex-wrap: wrap;
		gap: $spacing-2;
		align-items: center;
	}

	.cs-filter-pill {
		display: inline-flex;
		align-items: center;
		cursor: pointer;
		border: 1px solid var(--color-border);
		border-radius: 100px;
		font-size: $font-size-sm;
		font-weight: $font-weight-normal;
		line-height: normal;
		color: var(--color-text);
		background: var(--color-bg-surface);
		transition:
			border-color $transition-fast,
			background-color $transition-fast,
			color $transition-fast;
		user-select: none;
		margin: 0;

		> label {
			display: inline-flex;
			align-items: center;
			padding: 6px $spacing-4;
			cursor: pointer;
		}

		input[type='checkbox'] {
			display: none;
		}

		&:hover {
			border-color: var(--color-primary);
		}

		&.active {
			background: var(--color-primary);
			border-color: var(--color-primary);
			color: #fff;
		}
	}

	.cs-filter-clear {
		background: none;
		border: none;
		color: var(--color-primary);
		cursor: pointer;
		font-size: $font-size-sm;
		padding: 4px $spacing-2;

		&:hover {
			text-decoration: underline;
		}
	}

	// ─── Hero ───
	.cs-index-hero {
		margin-bottom: $spacing-10;

		h1 {
			@include page-title;
			color: var(--color-text);
			margin: 0 0 $spacing-3;
		}

		h2 {
			@include text-m;
			color: var(--color-text-secondary);
			font-weight: $font-weight-normal;
			margin: 0 0 $spacing-8;
		}
	}

	.cs-hero-card {
		display: flex;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: $radius-xl;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		&:hover {
			.cs-hero-card-image::after {
				transform: scale(1.1);
			}

			.cs-hero-card-link {
				transform: translateY(0);
				opacity: 1;
			}
		}

		@include media-down(lg) {
			flex-direction: column;
		}
	}

	.cs-hero-card-image {
		flex: 0 0 380px;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: var(--color-bg-light);
		padding: $spacing-8;
		overflow: hidden;

		&::after {
			content: '';
			position: absolute;
			inset: 0;
			background-image: var(--hero-bg);
			background-size: cover;
			background-position: center;
			transition: transform 0.3s ease;
		}

		img {
			position: relative;
			z-index: 1;
			max-width: 240px;
			height: auto;
		}

		@include media-down(lg) {
			flex: auto;
			padding: $spacing-6;
		}
	}

	.cs-hero-card-text {
		flex: 1;
		padding: $spacing-8;

		@include media-down(md) {
			padding: $spacing-6;
		}

		.cs-hero-card-category {
			@include text-s;
			font-weight: $font-weight-semibold;
			text-transform: uppercase;
			color: var(--color-primary);
			letter-spacing: 0.5px;
			margin: 0 0 $spacing-2;
		}

		h3 {
			@include card-title;
			color: var(--color-text);
			margin: 0 0 $spacing-4;
		}

		.cs-hero-card-desc {
			@include text-s;
			margin: 0 0 $spacing-4;
			display: -webkit-box;
			-webkit-line-clamp: 4;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		.cs-hero-card-link {
			@include action-link;
			color: var(--color-primary);
			display: inline-flex;
			align-items: center;
			gap: $spacing-1;
			transform: translateY(8px);
			opacity: 0;
			transition:
				transform 0.25s ease,
				opacity 0.25s ease;

			.cs-hero-arrow {
				width: 12px;
				height: 12px;
			}
		}
	}

	// ─── Search bar ───
	.cs-search-bar {
		position: relative;
		display: flex;
		align-items: center;
		width: 100%;
	}

	.cs-search-icon {
		position: absolute;
		left: 12px;
		width: 18px;
		height: 18px;
		color: var(--color-text-secondary);
		pointer-events: none;
	}

	.cs-search-clear-icon {
		width: 16px;
		height: 16px;
	}

	.cs-search-input {
		width: 100%;
		padding: 8px 40px;
		font-size: $font-size-sm;
		border: 1px solid var(--color-border);
		border-radius: $radius-sm;
		background: var(--color-bg-surface);
		color: var(--color-text);
		transition: border-color $transition-fast;

		&::placeholder {
			color: var(--color-text-secondary);
		}

		&:focus {
			outline: none;
			border-color: var(--color-primary);
		}
	}

	.cs-search-clear {
		position: absolute;
		right: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		padding: 0;
		border: none;
		background: none;
		color: var(--color-text-secondary);
		cursor: pointer;
		border-radius: $radius-sm;

		&:hover {
			color: var(--color-text);
			background: var(--color-bg-light);
		}

		&[hidden] {
			display: none;
		}
	}

	// ─── Card grid ───
	.cs-card-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: $spacing-6;

		@include media-down(xl) {
			grid-template-columns: repeat(2, 1fr);
		}

		@include media-down(md) {
			grid-template-columns: 1fr;
		}
	}

	.cs-client-card {
		position: relative;
		display: block;
		text-decoration: none;
		border-radius: $radius-xl;
		overflow: hidden;
		height: 340px;
		color: $color-white;

		&.is-hidden {
			display: none;
		}

		// Background image layer with zoom effect
		&::after {
			content: '';
			position: absolute;
			inset: 0;
			background-image: var(--card-bg);
			background-size: cover;
			background-position: center;
			transform-origin: center;
			transition: transform 0.3s ease;
		}

		&:hover {
			&::after {
				transform: scale(1.1);
			}

			.cs-card-link {
				transform: translateY(0);
				opacity: 1;
			}
		}

		@include media-down(md) {
			height: 300px;
		}
	}

	.cs-card-content {
		position: relative;
		z-index: 1;
		height: 100%;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: $spacing-6;
	}

	.cs-card-top {
		display: flex;
		align-items: flex-start;
	}

	.cs-card-logo {
		height: 56px;
		width: auto;
		max-width: 200px;
		object-fit: contain;
		object-position: left;
		filter: brightness(0) invert(1);
	}

	.cs-card-bottom {
		display: flex;
		flex-direction: column;
		gap: $spacing-2;
	}

	.cs-card-categories {
		display: flex;
		flex-wrap: wrap;
		gap: $spacing-1;
	}

	.cs-card-category {
		@include text-xs;
		display: inline-block;
		padding: 2px 10px;
		background: rgba(255, 255, 255, 0.2);
		backdrop-filter: blur(4px);
		border-radius: 100px;
		color: $color-white;
	}

	.cs-card-title {
		@include text-overlay;
		color: $color-white;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.cs-card-link {
		font-size: $font-size-base;
		font-weight: $font-weight-medium;
		color: $color-white;
		display: inline-flex;
		align-items: center;
		gap: $spacing-2;
		margin: 0;
		transform: translateY(8px);
		opacity: 0;
		transition:
			transform 0.25s ease,
			opacity 0.25s ease;
		white-space: nowrap;
	}

	.cs-card-arrow {
		width: 14px;
		height: 14px;
	}

	// On mobile, always show learn more
	@include media-down(md) {
		.cs-client-card {
			.cs-card-link {
				transform: translateY(0);
				opacity: 1;
			}

			&:hover::after {
				transform: none;
			}
		}
	}

	// ─── No results ───
	.cs-no-results {
		text-align: center;
		padding: $spacing-12 $spacing-4;
		@include text-m;
		color: var(--color-text-secondary);
	}

	// ─── Pagination ───
	.cs-pagination {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: $spacing-2;
		margin-top: $spacing-8;

		&[hidden] {
			display: none;
		}
	}

	.cs-page-btn {
		display: flex;
		align-items: center;
		gap: $spacing-1;
		padding: 4px $spacing-3;
		font-size: $font-size-sm;
		border: 1px solid var(--color-border);
		border-radius: $radius-sm;
		background: var(--color-bg-surface);
		color: var(--color-text);
		cursor: pointer;
		transition: border-color $transition-fast;

		&:hover:not(:disabled) {
			border-color: var(--color-primary);
		}

		&:disabled {
			opacity: 0.5;
			cursor: not-allowed;
		}
	}

	.cs-page-chevron {
		width: 16px;
