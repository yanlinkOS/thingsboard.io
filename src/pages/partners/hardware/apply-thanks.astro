---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout
	title="Application Submitted - Hardware Partner Program"
	description="Thank you for applying to the ThingsBoard Hardware Partner Program."
	pageId="hardware-partner-apply-thanks"
>
	<section class="thanks-page">
		<div class="container">
			<div class="thanks-card">
				<div class="thanks-icon">
					<Icon name="fa-solid:check-circle" />
				</div>
				<h1>Thank you for your application!</h1>
				<p>We have received your Hardware Partner Program application. Our team will review it and get back to you shortly.</p>
				<a href="/partners/hardware/" class="back-link">Back to Hardware Partners</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.container {
		max-width: 720px;
		margin: 0 auto;
		padding: 0 var(--spacing-5);
	}

	.thanks-page {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: calc(100vh - 200px);
		padding: calc(#{$header-height} + #{$spacing-10}) 0 #{$spacing-16};
	}

	.thanks-card {
		text-align: center;
	}

	.thanks-icon {
		color: #16a34a;
		margin-bottom: var(--spacing-6);

		:global(svg) {
			width: 64px;
			height: 64px;
		}
	}

	h1 {
		@include section-title;
		margin-bottom: var(--spacing-4);
	}

	p {
		@include text-m;
		color: var(--color-text-secondary);
		max-width: 500px;
		margin: 0 auto var(--spacing-8);
	}

	.back-link {
		display: inline-block;
		padding: 0.75rem 2rem;
		background: var(--color-primary);
		border-radius: var(--radius-md);
		text-decoration: none;
		font-weight: $font-weight-semibold;
		color: #fff;
		transition: opacity 0.2s;

		&:hover {
			opacity: 0.85;
		}

		:global([data-theme='dark']) & {
			color: #1a1a2e;
		}
	}
</style>
