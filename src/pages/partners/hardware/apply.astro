---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Apply for Hardware Partner Program"
	description="Apply to become a ThingsBoard Hardware Partner. Fill out the form to get started with the Silver, Gold, or Platinum partnership."
	pageId="hardware-partner-apply"
	noIndex={true}
>
	<section class="apply-page">
		<div class="container">
			<!-- Silver Form -->
			<div id="form-silver" class="partner-form" style="display: none;">
				<form class="contact-form" action="https://app.mailerlite.com/webforms/submit/h5b7n2" data-id="1211392" data-code="h5b7n2" method="POST" target="_blank">
					<div class="form-header">
						<h1>Hardware Partner Program Silver Level</h1>
						<div class="tier-info">
							<img src="/images/partners/silver-partner.svg" alt="Silver Partner" class="tier-badge" />
							<p>Silver Partnership does not require any fees but assumes you have basic ThingsBoard knowledge and will prepare the online tutorial and demo dashboard on your own.</p>
						</div>
						<p class="form-instruction">Please fill this form to get further instructions.</p>
					</div>
					<div class="form-grid">
						<div class="form-field">
							<label for="silver-first-name">First name *</label>
							<input type="text" id="silver-first-name" name="fields[first_name]" required />
						</div>
						<div class="form-field">
							<label for="silver-last-name">Last name *</label>
							<input type="text" id="silver-last-name" name="fields[last_name]" required />
						</div>
						<div class="form-field">
							<label for="silver-email">Email address *</label>
							<input type="email" id="silver-email" name="fields[email]" required />
						</div>
						<div class="form-field">
							<label for="silver-company">Company *</label>
							<input type="text" id="silver-company" name="fields[company]" required />
						</div>
						<div class="form-field">
							<label for="silver-website">Company website *</label>
							<input type="text" id="silver-website" name="fields[company_website]" required />
						</div>
						<div class="form-field">
							<label for="silver-phone">Phone number</label>
							<input type="text" id="silver-phone" name="fields[phone]" />
						</div>
					</div>
					<input type="hidden" name="ml-submit" value="1" />
					<button type="submit" class="submit-button">Submit</button>
				</form>
			</div>

			<!-- Gold Form -->
			<div id="form-gold" class="partner-form" style="display: none;">
				<form class="contact-form" action="https://app.mailerlite.com/webforms/submit/d6b3t8" data-id="1211402" data-code="d6b3t8" method="POST" target="_blank">
					<div class="form-header">
						<h1>Hardware Partner Program Gold Level</h1>
						<div class="tier-info">
							<img src="/images/partners/gold-partner.svg" alt="Gold Partner" class="tier-badge" />
							<div>
								<p>Gold Partnership includes our support services and help with preparing online tutorials and dashboards that will become an ultimate selling tool for your devices.</p>
								<p class="tier-price">Yearly fee: <strong>$500</strong></p>
							</div>
						</div>
						<p class="form-instruction">Please fill this form to get further instructions.</p>
					</div>
					<div class="form-grid">
						<div class="form-field">
							<label for="gold-first-name">First name *</label>
							<input type="text" id="gold-first-name" name="fields[first_name]" required />
						</div>
						<div class="form-field">
							<label for="gold-last-name">Last name *</label>
							<input type="text" id="gold-last-name" name="fields[last_name]" required />
						</div>
						<div class="form-field">
							<label for="gold-email">Email address *</label>
							<input type="email" id="gold-email" name="fields[email]" required />
						</div>
						<div class="form-field">
							<label for="gold-company">Company *</label>
							<input type="text" id="gold-company" name="fields[company]" required />
						</div>
						<div class="form-field">
							<label for="gold-website">Company website *</label>
							<input type="text" id="gold-website" name="fields[company_website]" required />
						</div>
						<div class="form-field">
							<label for="gold-phone">Phone number</label>
							<input type="text" id="gold-phone" name="fields[phone]" />
						</div>
					</div>
					<input type="hidden" name="ml-submit" value="1" />
					<button type="submit" class="submit-button">Submit</button>
				</form>
			</div>

			<!-- Platinum Form -->
			<div id="form-platinum" class="partner-form" style="display: none;">
				<form class="contact-form" action="https://app.mailerlite.com/webforms/submit/r7f3c8" data-id="1211404" data-code="r7f3c8" method="POST" target="_blank">
					<div class="form-header">
						<h1>Hardware Partner Program Platinum Level</h1>
						<div class="tier-info">
							<img src="/images/partners/platinum-partner.svg" alt="Platinum Partner" class="tier-badge" />
							<div>
								<p>Platinum Partnership includes access to white-labeled partner portal, our support services and help with preparing online tutorials and dashboards that will become an ultimate selling tool for your devices.</p>
								<p class="tier-price">Yearly fee: <strong>$2000</strong></p>
							</div>
						</div>
						<p class="form-instruction">Please fill this form to get further instructions.</p>
					</div>
					<div class="form-grid">
						<div class="form-field">
							<label for="platinum-first-name">First name *</label>
							<input type="text" id="platinum-first-name" name="fields[first_name]" required />
						</div>
						<div class="form-field">
							<label for="platinum-last-name">Last name *</label>
							<input type="text" id="platinum-last-name" name="fields[last_name]" required />
						</div>
						<div class="form-field">
							<label for="platinum-email">Email address *</label>
							<input type="email" id="platinum-email" name="fields[email]" required />
						</div>
						<div class="form-field">
							<label for="platinum-company">Company *</label>
							<input type="text" id="platinum-company" name="fields[company]" required />
						</div>
						<div class="form-field">
							<label for="platinum-website">Company website *</label>
							<input type="text" id="platinum-website" name="fields[company_website]" required />
						</div>
						<div class="form-field">
							<label for="platinum-phone">Phone number</label>
							<input type="text" id="platinum-phone" name="fields[phone]" />
						</div>
					</div>
					<input type="hidden" name="ml-submit" value="1" />
					<button type="submit" class="submit-button">Submit</button>
				</form>
			</div>

			<p class="questions-note">Questions about partner programs? <a href="/contact-us/">Contact us</a>.</p>
		</div>
	</section>
</BaseLayout>

<script>
	function initApplyForm() {
		const params = new URLSearchParams(window.location.search);
		const program = params.get('program') || 'silver';
		const validPrograms = ['silver', 'gold', 'platinum'];
		const selected = validPrograms.includes(program) ? program : 'silver';

		document.querySelectorAll('.partner-form').forEach((form) => {
			(form as HTMLElement).style.display = 'none';
		});

		const activeForm = document.getElementById(`form-${selected}`);
		if (activeForm) {
			activeForm.style.display = '';
		}
	}
	initApplyForm();
	document.addEventListener('astro:page-load', initApplyForm);
</script>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.container {
		max-width: 720px;
		margin: 0 auto;
		padding: 0 var(--spacing-5);
	}

	.apply-page {
		padding: var(--spacing-15) 0;
	}

	.partner-form {
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-xl);
		padding: var(--spacing-8);

		@include media-down(sm) {
			padding: var(--spacing-5);
		}
	}

	.form-header {
		margin-bottom: var(--spacing-6);

		h1 {
			@include section-title;
			text-align: center;
			margin-bottom: var(--spacing-5);
		}
	}

	.tier-info {
		display: flex;
		gap: var(--spacing-5);
		align-items: flex-start;
		margin-bottom: var(--spacing-4);

		p {
			@include text-s;
			color: var(--color-text-secondary);
			line-height: 1.6;
		}
	}

	.tier-badge {
		width: 80px;
		height: auto;
		flex-shrink: 0;
	}

	.tier-price {
		margin-top: var(--spacing-2);
		color: var(--color-text);

		strong {
			font-size: 1.25rem;
			color: var(--color-primary);
		}
	}

	.form-instruction {
		@include text-s;
		color: var(--color-text-secondary);
	}

	.form-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-4);
		margin-bottom: var(--spacing-6);

		@include media-down(sm) {
			grid-template-columns: 1fr;
		}
	}

	.form-field {
		label {
			@include text-s;
			display: block;
			font-weight: $font-weight-medium;
			margin-bottom: 0.375rem;
		}

		input {
			width: 100%;
			padding: 0.625rem 0.75rem;
			border: 1px solid var(--color-border);
			border-radius: var(--radius-sm);
			font-size: $font-size-base;
			background: var(--color-bg);
			color: var(--color-text);
			transition: border-color 0.2s;

			&:focus {
				outline: none;
				border-color: var(--color-primary);
				box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 15%, transparent);
			}
		}
	}

	.submit-button {
		display: block;
		width: 100%;
		padding: 0.75rem;
		background: var(--color-primary);
		color: #fff;
		border: none;
		border-radius: var(--radius-md);
		font-size: $font-size-base;
		font-weight: $font-weight-semibold;
		cursor: pointer;
		transition: opacity 0.2s;

		:global([data-theme='dark']) & {
			color: #1a1a2e;
		}

		&:hover {
			opacity: 0.9;
		}
	}

	.questions-note {
		@include text-s;
		text-align: center;
		margin-top: var(--spacing-6);
		color: var(--color-text-secondary);

		a {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}
</style>
