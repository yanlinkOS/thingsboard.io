---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { HARDWARE_PARTNERS } from '~/data/partners/hardware-partners';
import type { HardwarePartner, PartnerLink } from '~/data/partners/types';

export function getStaticPaths() {
	return HARDWARE_PARTNERS.map((partner) => ({
		params: { slug: partner.slug },
		props: { partner },
	}));
}

interface Props {
	partner: HardwarePartner;
}

const { partner } = Astro.props;

const guideCategoryLabels: Record<string, string> = {
	sensorGuides: 'Sensor Guides',
	gatewayGuides: 'Gateway Guides',
	generalGuides: 'General Guides',
	generalGuide: 'General Guide',
	microcontrollersGuides: 'Microcontroller Guides',
	singleBoardComputersGuides: 'Single-Board Computer Guides',
	otherDevicesGuides: 'Other Device Guides',
	trackersGuides: 'Tracker Guides',
	otherGuides: 'Other Guides',
};

const linkCategories = Object.entries(partner.links).filter(
	([, links]) => links && links.length > 0
) as [string, PartnerLink[]][];
---

<BaseLayout
	title={`${partner.name} - ThingsBoard Hardware Partner`}
	description={partner.description}
	pageId="hardware-partner-detail"
>
	<section class="partner-detail">
		<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/partners/hardware/">Hardware Partners</a>
				<span class="separator">/</span>
				<span>{partner.name}</span>
			</nav>

			<div class="partner-header">
				<div class="partner-logo-wrapper">
					<img src={partner.logo} alt={partner.name} />
				</div>
				<div class="partner-header-info">
					<h1>{partner.name}</h1>
					<p class="partner-description">{partner.description}</p>
					{partner.website && (
						<a href={partner.website} class="partner-website" target="_blank" rel="noopener noreferrer">
							Visit website
							<Icon name="tabler:external-link" />
						</a>
					)}
				</div>
			</div>

			<div class="partner-body">
				<div class="specs-table">
					<h2>Specifications</h2>
					<table>
						{partner.connectivity.length > 0 && (
							<tr>
								<th>Connectivity</th>
								<td>
									<div class="chip-list">
										{partner.connectivity.map((c) => <span class="chip">{c}</span>)}
									</div>
								</td>
							</tr>
						)}
						{partner.industry.length > 0 && (
							<tr>
								<th>Industry</th>
								<td>
									<div class="chip-list">
										{partner.industry.map((i) => <span class="chip">{i}</span>)}
									</div>
								</td>
							</tr>
						)}
						{partner.useCase.length > 0 && (
							<tr>
								<th>Use Cases</th>
								<td>
									<div class="chip-list">
										{partner.useCase.map((u) => <span class="chip">{u}</span>)}
									</div>
								</td>
							</tr>
						)}
						{partner.hardwareTypes.length > 0 && (
							<tr>
								<th>Hardware Types</th>
								<td>
									<div class="chip-list">
										{partner.hardwareTypes.map((h) => <span class="chip">{h}</span>)}
									</div>
								</td>
							</tr>
						)}
					</table>
				</div>

				{linkCategories.length > 0 && (
					<div class="guides-section">
						<h2>Guides & Tutorials</h2>
						<div class="guides-grid">
							{linkCategories.map(([category, links]) => (
								<div class="guide-category">
									<h3>{guideCategoryLabels[category] || category}</h3>
									<ul class="guide-list">
										{links.map((link) => (
											<li>
												<a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
													{link.label}
												</a>
											</li>
										))}
									</ul>
								</div>
							))}
						</div>
					</div>
				)}

				{partner.showcases && partner.showcases.length > 0 && (
					<div class="showcases-section">
						<h2>Showcases</h2>
						<ul class="guide-list">
							{partner.showcases.map((showcase) => (
								<li>
									<a href={showcase.href} target="_blank" rel="noopener noreferrer">
										{showcase.label}
									</a>
								</li>
							))}
						</ul>
					</div>
				)}

				<div class="partner-cta">
					<div class="partner-cta-content">
						<h2>Want to become a Hardware Partner?</h2>
						<p>Join our partner program and get your devices listed on the ThingsBoard website with integration guides and showcases.</p>
					</div>
					<a href="/partners/hardware/program/" class="cta-button">Learn about the program</a>
				</div>
		</div>
	</section>
</BaseLayout>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.partner-detail {
		@include container;
		padding-top: calc(#{$header-height} + #{$spacing-6});
		padding-bottom: $spacing-16;
		border-left: 1px solid var(--color-border);
		border-right: 1px solid var(--color-border);
	}

	.breadcrumb {
		padding: var(--spacing-6) 0 var(--spacing-4);
		@include text-s;
		color: var(--color-text-secondary);

		a {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}

		.separator {
			margin: 0 0.5rem;
			color: var(--color-text-secondary);
		}
	}

	.partner-header {
		display: flex;
		gap: var(--spacing-8);
		align-items: center;
		padding-bottom: var(--spacing-8);
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--spacing-8);

		@include media-down(md) {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
	}

	.partner-logo-wrapper {
		flex-shrink: 0;
		width: 180px;
		height: 120px;
		background: #fff;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;

		:global([data-theme='dark']) & {
			background: #d5d7db;
		}

		img {
			max-width: 100%;
			max-height: 100%;
			object-fit: contain;
		}
	}

	.partner-header-info {
		flex: 1;

		h1 {
			@include page-title;
			margin-bottom: var(--spacing-3);
		}
	}

	.partner-description {
		@include text-m;
		color: var(--color-text-secondary);
		line-height: 1.6;
		margin-bottom: var(--spacing-4);
	}

	.partner-website {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		color: var(--color-primary);
		text-decoration: none;
		@include text-s;
		font-weight: $font-weight-medium;

		&:hover {
			text-decoration: underline;
		}

		:global(svg) {
			width: 16px;
			height: 16px;
		}
	}

	.specs-table {
		margin-bottom: var(--spacing-8);

		h2 {
			@include subsection-title;
			margin-bottom: var(--spacing-4);
		}

		table {
			width: 100%;
			border-collapse: collapse;
		}

		tr {
			border-bottom: 1px solid var(--color-border);
		}

		th {
			text-align: left;
			padding: 0.75rem 1rem 0.75rem 0;
			@include text-s;
			font-weight: $font-weight-semibold;
			white-space: nowrap;
			vertical-align: top;
			width: 140px;
			color: var(--color-text);
		}

		td {
			padding: 0.75rem 0;
		}
	}

	.chip-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.chip {
		@include text-xs;
		padding: 0.25rem 0.625rem;
		background: color-mix(in srgb, var(--color-primary) 12%, transparent);
		border-radius: 1rem;
		color: var(--color-primary);
		white-space: nowrap;
	}

	.guides-section,
	.showcases-section {
		margin-bottom: var(--spacing-8);

		h2 {
			@include subsection-title;
			margin-bottom: var(--spacing-6);
		}
	}

	.guides-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-6);

		@include media-down(md) {
			grid-template-columns: 1fr;
		}
	}

	.guide-category {
		h3 {
			@include text-s;
			font-weight: $font-weight-semibold;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: var(--color-text-secondary);
			margin-bottom: var(--spacing-3);
			padding-bottom: var(--spacing-2);
			border-bottom: 2px solid var(--color-primary);
			display: inline-block;
		}
	}

	.guide-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0;

		li {
			padding: 0;

			&:last-child a {
				border-bottom: none;
			}
		}

		a {
			display: flex;
			align-items: center;
			gap: 0.625rem;
			color: var(--color-text);
			text-decoration: none;
			@include text-s;
			padding: 0.75rem 0.75rem;
			border-bottom: 1px solid var(--color-border);
			border-radius: var(--radius-sm);
			transition: background 0.15s, color 0.15s;

			&::before {
				content: '';
				display: inline-block;
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--color-primary);
				flex-shrink: 0;
			}

			&:hover {
				background: color-mix(in srgb, var(--color-primary) 6%, transparent);
				color: var(--color-primary);
			}
		}
	}

	.partner-cta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--spacing-6);
		margin-top: var(--spacing-8);
		padding: var(--spacing-6) var(--spacing-8);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);

		@include media-down(md) {
			flex-direction: column;
			text-align: center;
			padding: var(--spacing-6);
		}

		h2 {
			@include text-m;
			font-weight: $font-weight-semibold;
			margin-bottom: var(--spacing-1);
		}

		p {
			@include text-s;
			color: var(--color-text-secondary);
			margin: 0;
			line-height: 1.5;
		}
	}

	.cta-button {
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		padding: 0.625rem 1.5rem;
		background: var(--color-primary);
		border: none;
		border-radius: var(--radius-md);
		font-weight: $font-weight-semibold;
		@include text-s;
		color: #fff;
		text-decoration: none;
		white-space: nowrap;
		transition: opacity 0.2s;

		&:hover {
			opacity: 0.85;
		}

		:global([data-theme='dark']) & {
			color: #1a1a2e;
		}
	}

</style>
