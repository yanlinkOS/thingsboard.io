---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { PROGRAM_TIERS, PROGRAM_FOOTNOTES } from '~/data/partners/program-tiers';
import { PROGRAM_FAQ } from '~/data/partners/program-faq';
import tbIconRaw from '~/assets/pricing/thingsboard-icon.svg?raw';

const featureKeys = Object.keys(PROGRAM_TIERS[0].features);
---

<BaseLayout
	title="Hardware Partner Program"
	description="Join the ThingsBoard Hardware Partner Program. Choose from Silver, Gold, or Platinum tiers to showcase your IoT devices."
	pageId="hardware-partner-program"
>
	<section class="program-intro">
		<div class="container">
			<h1>Hardware Partner Program</h1>
			<p>ThingsBoard helps you to sell your devices by enabling interactive visualization and control of your device behavior for specific IoT use case. As a hardware manufacturer, you benefit from marketing exposure to thousands of system integrator companies that use the ThingsBoard platform as a basis for their solutions.</p>
		</div>
	</section>

	<section class="program-matrix">
		<div class="container">
			<h2>Hardware Partner Programs</h2>
			<div class="table-wrapper">
				<table>
					<thead>
						<tr>
							<th class="feature-col"></th>
							{PROGRAM_TIERS.map((tier) => (
								<th class="tier-col">
									<div class="tier-header" style={`--tier-color: ${tier.color}`}>
										<span class="tier-tb-icon" set:html={tbIconRaw} />
										<div class="tier-label">
											<span class="tier-level">{tier.name}</span>
											<span class="tier-word">Partner</span>
										</div>
									</div>
								</th>
							))}
						</tr>
					</thead>
					<tbody>
						{featureKeys.map((feature) => (
							<tr>
								<th>{feature}</th>
								{PROGRAM_TIERS.map((tier) => {
									const val = tier.features[feature];
									const isChecked = val === true || (typeof val === 'string' && val.includes('true'));
									const footnote = typeof val === 'string' && val.startsWith('***') ? '***' : typeof val === 'string' && val.startsWith('**') ? '**' : '';
									return (
										<td>
											{isChecked ? (
												<span class="check-included" style={`--tier-color: ${tier.color}`}>
													<Icon name="tabler:check" />
													{footnote && <span class="footnote-mark">{footnote}</span>}
												</span>
											) : val === false ? (
												<span class="check-excluded">
													<Icon name="tabler:x" />
												</span>
											) : (
												<span class="feature-text">{String(val)}</span>
											)}
										</td>
									);
								})}
							</tr>
						))}
						<tr class="price-row">
							<th></th>
							{PROGRAM_TIERS.map((tier) => (
								<td>
									<span class="price">{tier.price}</span>
									{tier.period && <span class="period">{tier.period}</span>}
								</td>
							))}
						</tr>
						<tr class="apply-row">
							<th></th>
							{PROGRAM_TIERS.map((tier) => (
								<td>
									<a href={`/partners/hardware/apply/?program=${tier.slug}`} class="apply-button">Apply</a>
								</td>
							))}
						</tr>
					</tbody>
				</table>
			</div>
			<div class="footnotes">
				{PROGRAM_FOOTNOTES.map((note) => (
					<p>{note}</p>
				))}
			</div>
		</div>
	</section>

	<section class="program-faq">
		<div class="container">
			<h2>Frequently Asked Questions</h2>
			<div class="faq-list">
				{PROGRAM_FAQ.map((category) => (
					<div class="faq-category">
						<h3>{category.title}</h3>
						{category.items.map((item) => (
							<div class="faq-item">
								<button class="faq-question" aria-expanded="false">
									<span>{item.question}</span>
									<Icon name="tabler:chevron-down" class="faq-chevron" />
								</button>
								<div class="faq-answer">
									<p set:html={item.answer} />
								</div>
							</div>
						))}
					</div>
				))}
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	function initFaq() {
		document.querySelectorAll('.faq-question').forEach((btn) => {
			btn.addEventListener('click', () => {
				const item = btn.parentElement;
				if (!item) return;
				const isActive = item.classList.contains('active');
				if (isActive) {
					item.classList.remove('active');
					btn.setAttribute('aria-expanded', 'false');
				} else {
					item.classList.add('active');
					btn.setAttribute('aria-expanded', 'true');
				}
			});
		});
	}
	initFaq();
	document.addEventListener('astro:page-load', initFaq);
</script>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.container {
		max-width: 1080px;
		margin: 0 auto;
		padding: 0 var(--spacing-5);
	}

	.program-intro {
		padding-top: calc(#{$header-height} + #{$spacing-10});
		padding-bottom: var(--spacing-8);
		text-align: center;

		h1 {
			@include page-title;
			margin-bottom: var(--spacing-4);
		}

		p {
			@include text-m;
			color: var(--color-text-secondary);
			max-width: 800px;
			margin: 0 auto;
			line-height: 1.6;
		}
	}

	.program-matrix {
		padding: 0 0 var(--spacing-10);

		h2 {
			@include section-title;
			text-align: center;
			margin-bottom: var(--spacing-8);
		}
	}

	.table-wrapper {
		overflow-x: auto;
	}

	table {
		width: 100%;
		border-collapse: collapse;
		min-width: 600px;
	}

	thead th {
		padding: 1rem;
		text-align: center;
		border-bottom: 2px solid var(--color-border);
	}

	.tier-header {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.tier-tb-icon {
		display: flex;
		color: var(--tier-color);

		:global(svg) {
			width: 36px;
			height: 36px;
		}
	}

	.tier-label {
		display: flex;
		flex-direction: column;
		text-align: left;
		line-height: 1.2;
	}

	.tier-level {
		@include text-s;
		color: var(--tier-color);
		font-weight: $font-weight-semibold;
	}

	.tier-word {
		@include text-m;
		font-weight: $font-weight-bold;
		color: var(--color-text);
	}

	.feature-col {
		width: 40%;
	}

	.tier-col {
		width: 20%;
	}

	tbody th {
		text-align: left;
		padding: 0.75rem 1rem;
		@include text-s;
		font-weight: $font-weight-medium;
		color: var(--color-text);
		border-bottom: 1px solid var(--color-border);
	}

	tbody td {
		text-align: center;
		padding: 0.75rem 1rem;
		border-bottom: 1px solid var(--color-border);
		vertical-align: middle;
	}

	.check-included {
		display: inline-flex;
		align-items: center;
		color: var(--tier-color);

		:global(svg) {
			width: 22px;
			height: 22px;
		}
	}

	.check-excluded {
		display: inline-flex;
		align-items: center;
		color: var(--color-text-secondary);
		opacity: 0.35;

		:global(svg) {
			width: 20px;
			height: 20px;
		}
	}

	.feature-text {
		@include text-s;
		color: var(--color-text-secondary);
	}

	.footnote-mark {
		@include text-xs;
		vertical-align: super;
	}

	.price-row {
		th, td {
			padding: 0.75rem 1rem 0.5rem;
			border-bottom: none;
		}

		.price {
			@include text-m;
			font-weight: $font-weight-semibold;
			color: var(--color-text);
		}

		.period {
			display: block;
			@include text-s;
			color: var(--color-text-secondary);
		}
	}

	.apply-row {
		th, td {
			border-bottom: none;
			padding: 0.25rem 1rem 1.5rem;
		}
	}

	.apply-button {
		display: inline-block;
		padding: 0.5rem 1.75rem;
		background: var(--color-primary);
		border: none;
		border-radius: var(--radius-md);
		text-decoration: none;
		@include text-s;
		font-weight: $font-weight-medium;
		color: #fff;
		transition: opacity 0.2s;

		&:hover {
			opacity: 0.85;
		}

		:global([data-theme='dark']) & {
			color: #1a1a2e;
		}
	}

	.footnotes {
		margin-top: var(--spacing-4);

		p {
			@include text-s;
			color: var(--color-text-secondary);
			line-height: 1.6;
			margin: 0.25rem 0;
		}
	}

	.program-faq {
		padding: var(--spacing-10) 0 var(--spacing-15);

		h2 {
			@include section-title;
			text-align: center;
			margin-bottom: var(--spacing-8);
		}
	}

	.faq-category {
		margin-bottom: var(--spacing-6);

		h3 {
			@include subsection-title;
			margin-bottom: var(--spacing-4);
		}
	}

	.faq-item {
		border-bottom: 1px solid var(--color-border);
	}

	.faq-question {
		display: flex;
		justify-content: space-between;
		align-items: center;
		width: 100%;
		padding: 1rem 0;
		background: none;
		border: none;
		cursor: pointer;
		@include text-m;
		font-weight: $font-weight-medium;
		text-align: left;
		color: var(--color-text);
		gap: 1rem;

		:global(.faq-chevron) {
			flex-shrink: 0;
			width: 20px;
			height: 20px;
			transition: transform 0.3s;
		}
	}

	.faq-answer {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease;

		p {
			padding: 0 0 1rem;
			@include text-s;
			color: var(--color-text-secondary);
			line-height: 1.6;
		}

		:global(a) {
			color: var(--color-primary);
		}
	}

	.faq-item.active {
		:global(.faq-chevron) {
			transform: rotate(180deg);
		}

		.faq-answer {
			max-height: 500px;
		}
	}
</style>
