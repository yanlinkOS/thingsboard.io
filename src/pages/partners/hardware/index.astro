---
import BaseLayout from '@layouts/BaseLayout.astro';
import PartnerLibrary from '@components/Partners/PartnerLibrary.astro';
import { getSortedPartners } from '~/data/partners/hardware-partners';

const partners = getSortedPartners();
---

<BaseLayout
	headerVariant="solid-border"
	title="ThingsBoard Hardware Partners"
	description="Browse ThingsBoard official hardware partners. Find sensors, gateways, and IoT devices compatible with the ThingsBoard platform."
>
	<section class="hardware-partners-hero">
		<div class="container hero-layout">
			<div class="hero-text">
				<h1>ThingsBoard Hardware Partners</h1>
				<p>
					Hardware Partnership Program goal is to reduce time to market for ThingsBoard based solutions. Together with
					Hardware Partners we simplify implementation of the most challenging IoT projects by providing a rich set of
					integration tutorials, typical use cases and best practices.
				</p>
			</div>
			<div class="hero-cta-card">
				<img src="/images/partners/hardware-partners-icon.svg" alt="" class="hero-cta-icon" />
				<h2>Want to become ThingsBoard Hardware Partner?</h2>
				<a href="/contact-us/?subject=Partnership" class="hero-cta-button">Apply for program</a>
			</div>
		</div>
	</section>

	<section class="hardware-partners-content">
		<div class="container">
			<PartnerLibrary partners={partners} />
		</div>
	</section>
</BaseLayout>

<style lang="scss">
	@use '../../../styles/_variables.scss' as *;

	.container {
		max-width: 1152px;
		margin: 0 auto;
		padding: 0 var(--spacing-5);
	}

	.hardware-partners-hero {
		padding: var(--spacing-16) 0 var(--spacing-10);
		background: var(--color-bg-surface);
	}

	.hero-layout {
		display: flex;
		align-items: center;
		gap: var(--spacing-8);

		@include media-down(md) {
			flex-direction: column;
			text-align: center;
		}
	}

	.hero-text {
		flex: 1;

		h1 {
			@include page-title;
			margin-bottom: var(--spacing-4);
		}

		p {
			@include text-m;
			color: var(--color-text-secondary);
			line-height: 1.6;
		}
	}

	.hero-cta-card {
		position: relative;
		flex-shrink: 0;
		width: 280px;
		padding: var(--spacing-6);
		padding-top: var(--spacing-8);
		background: var(--color-bg);
		border-radius: var(--radius-xl);
		border: 1px solid var(--color-border);
		text-align: left;
		overflow: hidden;

		@include media-down(md) {
			width: 100%;
			max-width: 320px;
			text-align: center;
		}

		h2 {
			@include text-m;
			font-weight: $font-weight-semibold;
			line-height: 1.4;
			color: var(--color-text);
			margin: 0 0 var(--spacing-4);
		}
	}

	.hero-cta-icon {
		position: absolute;
		top: -10px;
		right: -10px;
		width: 120px;
		height: auto;
		opacity: 0.6;

		@include media-down(md) {
			top: -10px;
			right: -10px;
		}
	}

	.hero-cta-button {
		display: block;
		padding: 0.625rem 1.5rem;
		text-align: center;
		background: var(--color-primary);
		border: none;
		border-radius: var(--radius-md);
		font-weight: $font-weight-semibold;
		@include text-s;
		color: #fff;
		text-decoration: none;
		transition: opacity 0.2s;

		&:hover {
			opacity: 0.85;
		}

		:global([data-theme='dark']) & {
			color: #1a1a2e;
		}
	}

	.hardware-partners-content {
		padding: var(--spacing-8) 0 var(--spacing-8);
	}
</style>
