---
import BaseLayout from '@layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout
	headerVariant="transparent-hover"
	title="Affiliate Program - Earn Commission"
	description="Join the ThingsBoard Affiliate Program — earn 30% recurring commission on every sale plus a $100 community-growth bonus, ideal for IoT consultants and creators."
	pageId="affiliate"
>
	{
		/* Background pattern as a real DOM element (was previously an ::before
	    pseudo on `<html id="affiliate">`, which was failing to render on the
	    staging deploy despite identical CSS — likely a painting-order quirk
	    when a pseudo on the root element overlaps an opaque <body> bg). */
	}
	<div class="affiliate-bg-pattern" aria-hidden="true"></div>

	<section id="hero">
		<div class="affiliate-main">
			<div class="hero-content">
				<div class="hero-text">
					<div class="affiliate-tag">
						<span class="tag-dot"></span>
						<span>Affiliate Program is Live</span>
					</div>
					<h1>Empower the IoT community and <span class="blue-text">monetize your expertise</span></h1>
					<p class="hero-description">Earn recurring commission on every sale and a $100 bonus for community growth</p>
					<a
						href="https://affiliates.thingsboard.io/signup/"
						class="btn-primary"
						target="_blank"
						rel="noopener noreferrer"
					>
						Join the program
						<Icon name="tabler:chevron-right" />
						<span class="visually-hidden">Join ThingsBoard Affiliate Program</span>
					</a>
				</div>
				<div class="hero-image">
					<div class="chart-card">
						<img
							src="/images/affiliate/chart.svg"
							alt="Affiliate income chart"
							title="Affiliate income chart"
							class="chart-image"
						/>
						<div class="notification-card card-1">
							<div class="notification-icon">
								<img src="/images/affiliate/dollar-icon.svg" alt="Dollar icon" title="Dollar icon" />
							</div>
							<div class="notification-text">
								<span class="notification-brand">ThingsBoard</span>
								<span class="notification-title">Commission Earned</span>
							</div>
							<div class="notification-amount">
								<span class="notification-time">Now</span>
								<span class="notification-value">$536</span>
							</div>
						</div>
						<div class="notification-card card-2">
							<div class="notification-icon">
								<img src="/images/affiliate/dollar-icon.svg" alt="Dollar icon" title="Dollar icon" />
							</div>
							<div class="notification-text">
								<span class="notification-brand">ThingsBoard</span>
								<span class="notification-title">Commission Earned</span>
							</div>
							<div class="notification-amount">
								<span class="notification-time">Now</span>
								<span class="notification-value">$1 072</span>
							</div>
						</div>
						<div class="notification-card card-3">
							<div class="notification-icon">
								<img src="/images/affiliate/dollar-icon.svg" alt="Dollar icon" title="Dollar icon" />
							</div>
							<div class="notification-text">
								<span class="notification-brand">ThingsBoard</span>
								<span class="notification-title">Commission Earned</span>
							</div>
							<div class="notification-amount">
								<span class="notification-time">Now</span>
								<span class="notification-value">$360</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="calculator">
		<div class="affiliate-main">
			<div class="calculator-card">
				<div class="calculator-header">
					<h2>Estimate your profit</h2>
					<p>
						See your annual commission by bringing <a href="/pricing/" target="_blank" rel="noopener noreferrer"
							>Public Cloud Pilot</a
						> Customers
					</p>
				</div>
				<div class="slider-container">
					<input
						type="range"
						min="1"
						max="100"
						value="10"
						class="profit-slider"
						id="profitSlider"
						aria-label="Number of customers"
					/>
					<div class="slider-labels">
						<span>1 Customer</span>
						<span>100 Customers</span>
					</div>
				</div>
				<div class="profit-display">
					<span class="profit-amount" id="profitAmount">$5 360</span>
					<p>If you bring <span id="customerCount">10</span> Public Cloud Pilot Customers</p>
				</div>
			</div>
		</div>
	</section>

	<section id="commission">
		<div class="affiliate-main">
			<div class="commission-card">
				<div class="commission-item">
					<div class="commission-icon">
						<img src="/images/affiliate/public-cloud-icon.svg" alt="Public Cloud icon" title="Public Cloud icon" />
					</div>
					<p class="commission-rate">30% commission</p>
					<p>On all Public Cloud and Self-management subscriptions</p>
				</div>
				<div class="commission-item">
					<div class="commission-icon">
						<img src="/images/affiliate/private-cloud-icon.svg" alt="Private Cloud icon" title="Private Cloud icon" />
					</div>
					<p class="commission-rate">15% commission</p>
