---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { DISTRIBUTORS, REGIONS } from '~/data/partners/distributors';

const regionCountries: Record<string, string[]> = {};
REGIONS.forEach((region) => {
	const countries = new Set<string>();
	DISTRIBUTORS.forEach((d) => {
		if (d.regions.includes(region)) {
			d.countries.forEach((c) => countries.add(c));
		}
	});
	regionCountries[region] = Array.from(countries).sort();
});

const allCountries = Array.from(
	new Set(DISTRIBUTORS.flatMap((d) => d.countries)),
).sort();

const distributors = DISTRIBUTORS.map((d) => {
	const websiteCleaned = d.website.replace(/^https?:\/\//, '');
	const websiteHref = websiteCleaned ? `https://${websiteCleaned}` : '';
	const websiteLabel = websiteCleaned.replace(/^www\./, '');
	const isEmail = d.email.includes('@');
	const mailHref = isEmail ? `mailto:${d.email}?subject=Introduction request` : '';
	return {
		...d,
		websiteHref,
		websiteLabel,
		isEmail,
		mailHref,
	};
});
---

<BaseLayout
	title="IoT Distributors | Local partners"
	description="Meet our partners: local distributors and system integrators who can support you with ThingsBoard in your country."
	pageId="distributors"
>
	<section class="distributors-page">
		<div class="container">
			<h1>ThingsBoard Distributors</h1>
			<p id="des">Select a region using the map or the finder</p>

			<div class="map-wrapper">
				<object id="distributor-map" data="/images/partners/map-of-distributors.svg" type="image/svg+xml" aria-label="World map of ThingsBoard distributors"></object>
			</div>

			<h2 id="distributors-heading">Find a local ThingsBoard reseller</h2>

			<div class="distributors-grid-layout">
				<div class="finder-sidebar">
					<h3>Finder</h3>
					<div class="finder-form">
						<select id="region-select" class="drop-selector" aria-label="Region">
							<option value="" selected>All regions</option>
							{REGIONS.map((region) => (
								<option value={region}>{region}</option>
							))}
						</select>
						<select id="country-select" class="drop-selector" aria-label="Country">
							<option value="">All countries</option>
							{allCountries.map((c) => (
								<option value={c}>{c}</option>
							))}
						</select>
						<button type="button" id="reset-button" class="reset-btn" style="display: none;">Reset filters</button>
						<hr />
						<a href="/contact-us/" class="reseller-btn">BECOME A RESELLER</a>
					</div>
				</div>

				<div id="results-container" class="results-container">
					<p id="results-count" class="results-count">{distributors.length} distributors found</p>
					<div id="results-grid" class="results-grid">
						{distributors.map((d) => (
							<div
								class="distributor-box"
								data-regions={d.regions.join('|')}
								data-countries={d.countries.join('|')}
							>
								<p class="dist-title">{d.name}</p>
								{d.email && (
									<div class="dist-field">
										<span>Contact Us: </span>
										{d.isEmail ? (
											<a href={d.mailHref} class="dist-link">{d.email}</a>
										) : (
											<span class="dist-link">{d.email}</span>
										)}
									</div>
								)}
								{d.websiteHref && (
									<div class="dist-field">
										<span>Visit us at: </span>
										<a
											href={d.websiteHref}
											target="_blank"
											rel="noopener noreferrer"
											class="dist-link"
										>{d.websiteLabel}</a>
									</div>
								)}
							</div>
						))}
					</div>
					<p id="no-results" class="no-results" style="display: none;">Coming soon</p>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<script is:inline type="application/json" id="region-countries-data" set:html={JSON.stringify(regionCountries)}></script>

<script is:inline>
	const REGION_COUNTRIES = (() => {
		const el = document.getElementById('region-countries-data');
		try { return el ? JSON.parse(el.textContent) : {}; } catch { return {}; }
	})();

	function updateResetButton() {
		const regionSelect = document.getElementById('region-select');
		const countrySelect = document.getElementById('country-select');
		const resetBtn = document.getElementById('reset-button');
		if (!resetBtn || !regionSelect || !countrySelect) return;
		resetBtn.style.display = (regionSelect.value || countrySelect.value) ? '' : 'none';
	}

	function filterAndUpdate() {
		const regionSelect = document.getElementById('region-select');
		const countrySelect = document.getElementById('country-select');
		const grid = document.getElementById('results-grid');
		const noResults = document.getElementById('no-results');
		const resultsCount = document.getElementById('results-count');
		if (!regionSelect || !countrySelect || !grid) return;

		const region = regionSelect.value;
		const country = countrySelect.value;
		const cards = grid.querySelectorAll('.distributor-box');
		let visible = 0;

		cards.forEach(function(card) {
			const regions = (card.dataset.regions || '').split('|');
			const countries = (card.dataset.countries || '').split('|');
			let show = true;
			if (region && regions.indexOf(region) === -1) show = false;
			if (country && countries.indexOf(country) === -1) show = false;
			card.hidden = !show;
			if (show) visible++;
		});

		if (resultsCount) {
			resultsCount.textContent = visible
				? visible + ' distributor' + (visible !== 1 ? 's' : '') + ' found'
				: '';
		}
		if (noResults) noResults.style.display = visible ? 'none' : '';
		updateResetButton();
	}

	function populateCountries(region) {
		const countrySelect = document.getElementById('country-select');
		if (!countrySelect) return;

		const previous = countrySelect.value;
		const countries = region && REGION_COUNTRIES[region]
			? REGION_COUNTRIES[region]
			: Object.values(REGION_COUNTRIES).reduce(function(all, list) {
				list.forEach(function(c) { if (all.indexOf(c) === -1) all.push(c); });
				return all;
			}, []).sort();

		countrySelect.innerHTML = '<option value="">All countries</option>';
		countries.forEach(function(c) {
			const opt = document.createElement('option');
			opt.value = c;
			opt.textContent = c;
			countrySelect.appendChild(opt);
		});

		countrySelect.value = countries.indexOf(previous) !== -1 ? previous : '';
	}

	// Called by the SVG map's onclick handlers
	function mapSelect(region) {
		const regionSelect = document.getElementById('region-select');
		if (!regionSelect) return;

		regionSelect.value = region;
		populateCountries(region);
		filterAndUpdate();

		const heading = document.getElementById('distributors-heading');
		if (heading) heading.scrollIntoView({ behavior: 'smooth' });
	}

	function initDistributors() {
		const regionSelect = document.getElementById('region-select');
		const countrySelect = document.getElementById('country-select');
		const resetBtn = document.getElementById('reset-button');

		if (!regionSelect || !countrySelect) return;

		regionSelect.addEventListener('change', function() {
			populateCountries(regionSelect.value);
			filterAndUpdate();
		});

		countrySelect.addEventListener('change', function() {
			filterAndUpdate();
		});

		if (resetBtn) {
			resetBtn.addEventListener('click', function() {
				regionSelect.value = '';
				populateCountries('');
				countrySelect.value = '';
				filterAndUpdate();
			});
		}

		filterAndUpdate();
	}

	// Make mapSelect globally available for SVG onclick
	window.mapSelect = mapSelect;

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initDistributors);
	} else {
		initDistributors();
	}
	document.addEventListener('astro:page-load', initDistributors);
</script>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.container {
		max-width: 1080px;
		margin: 0 auto;
		padding: 0 var(--spacing-5);
	}

	.distributors-page {
		padding: calc(#{$header-height} + #{$spacing-10}) 0 #{$spacing-16};
	}

	h1 {
		@include page-title;
		margin-bottom: var(--spacing-2);
	}

	#des {
		@include text-m;
		color: var(--color-text);
		margin-bottom: var(--spacing-6);
	}

	.map-wrapper {
		width: 100%;
		margin-bottom: var(--spacing-8);
		overflow: hidden;
		border-radius: var(--radius-lg);

		object {
			width: 100%;
			height: auto;
			display: block;
		}

		:global([data-theme='dark']) & object {
			filter: invert(0.88) hue-rotate(180deg);
		}
	}

	h2 {
		@include section-title;
		margin-bottom: var(--spacing-6);
	}

	.distributors-grid-layout {
		display: flex;
		gap: var(--spacing-6);
		align-items: flex-start;

		@include media-down(md) {
			flex-direction: column;
		}
	}

	.finder-sidebar {
		width: 280px;
		flex-shrink: 0;
		position: sticky;
		top: 5rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--spacing-5);
		background: var(--color-bg);

		@include media-down(md) {
			width: 100%;
			position: static;
		}

		h3 {
			@include subsection-title;
			margin-bottom: var(--spacing-4);
		}

		hr {
			border: none;
			border-top: 1px solid var(--color-border);
			margin: var(--spacing-4) 0;
		}
	}

	.finder-form {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.drop-selector {
		width: 100%;
		padding: 0.625rem 0.75rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		@include text-s;
		background: var(--color-bg);
		color: var(--color-text);
		cursor: pointer;
	}

	.reset-btn {
		width: 100%;
		padding: 0.5rem;
		background: transparent;
		border: none;
		border-radius: var(--radius-sm);
		@include text-s;
		color: var(--color-primary);
		cursor: pointer;
		transition: background 0.2s;

		&:hover {
			background: color-mix(in srgb, var(--color-primary) 8%, transparent);
		}
	}

	.reseller-btn {
		display: block;
		width: 100%;
		padding: 0.75rem;
		text-align: center;
		background: var(--color-primary);
		border: none;
		border-radius: var(--radius-md);
		@include text-s;
		font-weight: $font-weight-bold;
		color: #fff;
		text-decoration: none;
		letter-spacing: 0.5px;
		transition: opacity 0.2s;

		&:hover {
			opacity: 0.85;
		}

		:global([data-theme='dark']) & {
			color: #1a1a2e;
		}
	}

	.results-container {
		flex: 1;
		min-width: 0;
	}

	.results-count {
		@include text-s;
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-3);
	}

	.results-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0;

		@include media-down(sm) {
			grid-template-columns: 1fr;
		}
	}

	.no-results {
		text-align: center;
		padding: var(--spacing-8);
		color: var(--color-text-secondary);
		@include text-m;
	}
</style>

<style is:global>
	.distributor-box {
		padding: 1.25rem 1.5rem;
		border: 1px solid var(--color-border);

		.dist-title {
			font-size: 1.125rem;
			font-weight: 700;
			margin: 0 0 0.625rem;
			color: var(--color-text);
		}

		.dist-field {
			font-size: 0.875rem;
			margin: 0.25rem 0;
			color: var(--color-text);

			span {
				color: var(--color-text-secondary);
			}
		}

		.dist-link {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}
</style>
