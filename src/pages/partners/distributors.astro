---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { DISTRIBUTORS, REGIONS } from '~/data/partners/distributors';

const regionCountries: Record<string, string[]> = {};
REGIONS.forEach((region) => {
	const countries = new Set<string>();
	DISTRIBUTORS.forEach((d) => {
		if (d.regions.includes(region)) {
			d.countries.forEach((c) => countries.add(c));
		}
	});
	regionCountries[region] = Array.from(countries).sort();
});
---

<BaseLayout
	title="ThingsBoard Distributors"
	description="Find a ThingsBoard distributor or reseller in your region."
	pageId="distributors"
>
	<section class="distributors-page">
		<div class="container">
			<h1>ThingsBoard Distributors</h1>
			<p id="des">Select a region using the map or the finder</p>

			<div class="map-wrapper">
				<object id="distributor-map" data="/images/partners/map-of-distributors.svg" type="image/svg+xml" aria-label="World map of ThingsBoard distributors"></object>
			</div>

			<h2 id="distributors-heading">Find our local re-seller</h2>

			<div class="distributors-grid-layout">
				<div class="finder-sidebar">
					<h3>Finder</h3>
					<div class="finder-form">
						<select id="region-select" class="drop-selector">
							<option value="" selected>All regions</option>
							{REGIONS.map((region) => (
								<option value={region}>{region}</option>
							))}
						</select>
						<select id="country-select" class="drop-selector">
							<option value="">All countries</option>
						</select>
						<button type="button" id="reset-button" class="reset-btn" style="display: none;">Reset filters</button>
						<hr />
						<a href="/contact-us/" class="reseller-btn">BECOME A RESELLER</a>
					</div>
				</div>

				<div id="results-container" class="results-container">
					<p id="results-count" class="results-count"></p>
					<div id="results-grid" class="results-grid"></div>
					<p id="no-results" class="no-results" style="display: none;">Coming soon</p>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<script is:inline define:vars={{ DISTRIBUTORS, regionCountries }}>
	window.__DISTRIBUTORS_DATA__ = DISTRIBUTORS;
	window.__REGION_COUNTRIES__ = regionCountries;
</script>

<script is:inline>
	function renderDistributors(list) {
		const grid = document.getElementById('results-grid');
		const noResults = document.getElementById('no-results');
		const resultsCount = document.getElementById('results-count');
		if (!grid) return;

		if (!list || list.length === 0) {
			grid.innerHTML = '';
			if (noResults) noResults.style.display = '';
			if (resultsCount) resultsCount.textContent = '';
			return;
		}

		if (noResults) noResults.style.display = 'none';
		if (resultsCount) {
			resultsCount.textContent = list.length + ' distributor' + (list.length !== 1 ? 's' : '') + ' found';
		}

		grid.innerHTML = list.map(function(d) {
			let contactHtml = '';
			if (d.email) {
				const mailHref = d.email.includes('@') ? 'mailto:' + d.email + '?subject=Introduction request' : '';
				contactHtml = '<div class="dist-field"><span>Contact Us: </span><a href="' + mailHref + '" class="dist-link">' + d.email + '</a></div>';
			}

			let siteHtml = '';
			if (d.website) {
				const cleanUrl = d.website.replace(/^https?:\/\//, '').replace(/^www\./, '');
				siteHtml = '<div class="dist-field"><span>Visit us at: </span><a href="https://' + d.website.replace(/^https?:\/\//, '') + '" target="_blank" rel="noopener noreferrer" class="dist-link">' + cleanUrl + '</a></div>';
			}

			return '<div class="distributor-box"><p class="dist-title">' + d.name + '</p>' + contactHtml + siteHtml + '</div>';
		}).join('');
	}

	function updateResetButton() {
		const regionSelect = document.getElementById('region-select');
		const resetBtn = document.getElementById('reset-button');
		if (!resetBtn || !regionSelect) return;
		resetBtn.style.display = regionSelect.value ? '' : 'none';
	}

	function filterAndUpdate() {
		const regionSelect = document.getElementById('region-select');
		const countrySelect = document.getElementById('country-select');
		if (!regionSelect || !countrySelect) return;

		const region = regionSelect.value;
		const country = countrySelect.value;
		const distributors = window.__DISTRIBUTORS_DATA__;
		if (!distributors) return;

		let filtered;
		if (!region) {
			filtered = distributors;
		} else if (!country) {
			filtered = distributors.filter(function(d) {
				return d.regions.indexOf(region) !== -1;
			});
		} else {
			filtered = distributors.filter(function(d) {
				return d.countries.indexOf(country) !== -1;
			});
		}

		renderDistributors(filtered);
		updateResetButton();
	}

	function populateCountries(region) {
		const countrySelect = document.getElementById('country-select');
		if (!countrySelect) return;

		const regionCountries = window.__REGION_COUNTRIES__;
		countrySelect.innerHTML = '<option value="">All countries</option>';
		if (region && regionCountries && regionCountries[region]) {
			regionCountries[region].forEach(function(c) {
				const opt = document.createElement('option');
				opt.value = c;
				opt.textContent = c;
				countrySelect.appendChild(opt);
			});
		}
	}

	// Called by the SVG map's onclick handlers
	function mapSelect(region) {
		const regionSelect = document.getElementById('region-select');
		if (!regionSelect) return;

		regionSelect.value = region;
		populateCountries(region);
		filterAndUpdate();

		const heading = document.getElementById('distributors-heading');
		if (heading) heading.scrollIntoView({ behavior: 'smooth' });
	}

	function initDistributors() {
		const regionSelect = document.getElementById('region-select');
		const countrySelect = document.getElementById('country-select');
		const resetBtn = document.getElementById('reset-button');

		if (!regionSelect || !countrySelect) return;

		regionSelect.addEventListener('change', function() {
			populateCountries(regionSelect.value);
			filterAndUpdate();
		});

		countrySelect.addEventListener('change', function() {
			filterAndUpdate();
		});

		if (resetBtn) {
			resetBtn.addEventListener('click', function() {
				regionSelect.value = '';
				populateCountries('');
				filterAndUpdate();
			});
		}

		// Show all distributors by default
		filterAndUpdate();
	}

	// Make mapSelect globally available for SVG onclick
	window.mapSelect = mapSelect;

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initDistributors);
	} else {
		initDistributors();
	}
	document.addEventListener('astro:page-load', initDistributors);
</script>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.container {
		max-width: 1080px;
		margin: 0 auto;
		padding: 0 var(--spacing-5);
	}

	.distributors-page {
		padding: calc(#{$header-height} + #{$spacing-10}) 0 #{$spacing-16};
	}

	h1 {
		@include page-title;
		margin-bottom: var(--spacing-2);
	}

	#des {
		@include text-m;
		color: var(--color-text);
		margin-bottom: var(--spacing-6);
	}

	.map-wrapper {
		width: 100%;
		margin-bottom: var(--spacing-8);
		overflow: hidden;
		border-radius: var(--radius-lg);

		object {
			width: 100%;
			height: auto;
			display: block;
		}

		:global([data-theme='dark']) & object {
			filter: invert(0.88) hue-rotate(180deg);
		}
	}

	h2 {
		@include section-title;
		margin-bottom: var(--spacing-6);
	}

	.distributors-grid-layout {
		display: flex;
		gap: var(--spacing-6);
		align-items: flex-start;

		@include media-down(md) {
			flex-direction: column;
		}
	}

	.finder-sidebar {
		width: 280px;
		flex-shrink: 0;
		position: sticky;
		top: 5rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--spacing-5);
		background: var(--color-bg);

		@include media-down(md) {
			width: 100%;
			position: static;
		}

		h3 {
			@include subsection-title;
			margin-bottom: var(--spacing-4);
		}

		hr {
			border: none;
			border-top: 1px solid var(--color-border);
			margin: var(--spacing-4) 0;
		}
	}

	.finder-form {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.drop-selector {
		width: 100%;
		padding: 0.625rem 0.75rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		@include text-s;
		background: var(--color-bg);
		color: var(--color-text);
		cursor: pointer;
	}

	.reset-btn {
		width: 100%;
		padding: 0.5rem;
		background: transparent;
		border: none;
		border-radius: var(--radius-sm);
		@include text-s;
		color: var(--color-primary);
		cursor: pointer;
		transition: background 0.2s;

		&:hover {
			background: color-mix(in srgb, var(--color-primary) 8%, transparent);
		}
	}

	.reseller-btn {
		display: block;
		width: 100%;
		padding: 0.75rem;
		text-align: center;
		background: var(--color-primary);
		border: none;
		border-radius: var(--radius-md);
		@include text-s;
		font-weight: $font-weight-bold;
		color: #fff;
		text-decoration: none;
		letter-spacing: 0.5px;
		transition: opacity 0.2s;

		&:hover {
			opacity: 0.85;
		}

		:global([data-theme='dark']) & {
			color: #1a1a2e;
		}
	}

	.results-container {
		flex: 1;
		min-width: 0;
	}

	.results-count {
		@include text-s;
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-3);
	}

	.results-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0;

		@include media-down(sm) {
			grid-template-columns: 1fr;
		}
	}

	.no-results {
		text-align: center;
		padding: var(--spacing-8);
		color: var(--color-text-secondary);
		@include text-m;
	}
</style>

<style is:global>
	.distributor-box {
		padding: 1.25rem 1.5rem;
		border: 1px solid var(--color-border);

		.dist-title {
			font-size: 1.125rem;
			font-weight: 700;
			margin: 0 0 0.625rem;
			color: var(--color-text);
		}

		.dist-field {
			font-size: 0.875rem;
			margin: 0.25rem 0;
			color: var(--color-text);

			span {
				color: var(--color-text-secondary);
			}
		}

		.dist-link {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}
</style>
