---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout
	title="ThingsBoard Marketplace"
	description="ThingsBoard is launching a Software Marketplace to distribute custom widgets, pre-configured dashboards, rule chains, and other components."
	pageId="marketplace"
>
	<section class="marketplace-hero">
		<div class="container">
			<h1>ThingsBoard Marketplace</h1>
			<p class="hero-desc">
				ThingsBoard is about to launch a Software Marketplace to distribute custom ThingsBoard
				components like widgets, pre-configured dashboards, rule chains, and other items. The
				Marketplace will soon be available in all CE and PE installations.
			</p>
		</div>
	</section>

	<section class="marketplace-cards-section">
		<div class="container">
			<div class="marketplace-cards">
				<div class="marketplace-card">
					<div class="marketplace-card-icon">
						<Icon name="tabler:users" />
					</div>
					<h2 class="marketplace-card-title">For Customers</h2>
					<p class="marketplace-card-desc">
						Marketplace will allow you to explore IoT solutions and ThingsBoard components
						provided by 100+ ThingsBoard Contributors and Technology Partners.
					</p>
				</div>
				<div class="marketplace-card">
					<div class="marketplace-card-icon">
						<Icon name="tabler:user-star" />
					</div>
					<h2 class="marketplace-card-title">For Sellers</h2>
					<p class="marketplace-card-desc">
						We welcome you to become a seller at ThingsBoard Marketplace and distribute your
						free and paid products to thousands of ThingsBoard customers. This is an early
						call to submit information about your custom products. We will use this
						information to prepare the Marketplace.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="marketplace-cta">
		<div class="container">
			<p class="cta-desc">
				The early birds will get priority listing and a minimum marketplace fee for paid
				products. Top publishers of free content will get valuable gifts from ThingsBoard Team on
				a monthly basis: up to 100% license discounts, support, and other rewards.
			</p>
			<a class="btn-primary" href="https://forms.gle/pBtyPCXtzke4HmNE6">Become a Seller</a>
		</div>
	</section>
</BaseLayout>

<style lang="scss">
	@use '../../styles/_variables.scss' as *;

	.container {
		max-width: 1080px;
		margin: 0 auto;
		padding: 0 var(--spacing-5);
	}

	.marketplace-hero {
		padding: calc(#{$header-height} + #{$spacing-10}) 0 var(--spacing-8);
		text-align: center;

		h1 {
			@include page-title;
			margin-bottom: var(--spacing-4);
		}
	}

	.hero-desc {
		@include text-m;
		color: var(--color-text-secondary);
		max-width: 800px;
		margin: 0 auto;
		line-height: 1.7;
	}

	.marketplace-cards-section {
		padding: var(--spacing-4) 0 var(--spacing-10);
	}

	.marketplace-cards {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-6);

		@include media-down(md) {
			grid-template-columns: 1fr;
		}
	}

	.marketplace-card {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-4);
		padding: var(--spacing-8);
		border-radius: var(--radius-lg);
		border: 1px solid var(--color-border);
		background: var(--color-bg-surface);
		transition: transform 0.2s, box-shadow 0.2s;

		&:hover {
			transform: translateY(-2px);
			box-shadow: var(--shadow-card-hover, 0 4px 12px rgba(0, 0, 0, 0.1));
		}
	}

	.marketplace-card-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 56px;
		height: 56px;
		border-radius: 12px;
		background: color-mix(in srgb, var(--color-primary) 10%, transparent);

		:global(svg) {
			width: 24px;
			height: 24px;
			color: var(--color-primary);
		}
	}

	.marketplace-card-title {
		@include subsection-title;
		color: var(--color-text);
	}

	.marketplace-card-desc {
		@include text-m;
		color: var(--color-text-secondary);
		line-height: 1.7;
	}

	.marketplace-cta {
		padding: 0 0 var(--spacing-16);
		text-align: center;
	}

	.cta-desc {
		@include text-m;
		color: var(--color-text-secondary);
		max-width: 800px;
		margin: 0 auto var(--spacing-8);
		line-height: 1.7;
	}

	.btn-primary {
		@include button-base;
		background: var(--color-primary);
		color: #fff;
		padding: 14px 32px;
		font-weight: $font-weight-semibold;
		border-radius: var(--radius-md);
		letter-spacing: 0.3px;
		transition: opacity 0.2s;

		&:hover {
			opacity: 0.85;
		}

		:global([data-theme='dark']) & {
			color: #1a1a2e;
		}
	}
</style>
