---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComparisonMatrix from '../../components/Landing/ComparisonMatrix.astro';

const matrixColumns = [
	{ label: 'Google\nIoT Core', accentColor: '#305680', borderColor: '#acbbcc' },
	{ label: 'ThingsBoard\nProfessional Edition', accentColor: '#27ae60', highlight: true },
];

const matrixRows = [
	{ label: 'Asset/Device Management and Data Collection', values: [true, true] },
	{ label: 'MQTT, HTTP transports', values: [true, true] },
	{ label: 'Pub/Sub Integration', values: [true, true] },
	{ label: 'Commands to devices', values: [true, true] },
	{ label: 'Scalability', values: [true, true] },
	{
		label: 'User management and RBAC',
		href: '/docs/user-guide/rbac/',
		values: [false, true],
	},
	{
		label: 'Real-time, customizable dashboards',
		href: '/docs/pe/user-guide/dashboards/',
		values: [false, true],
	},
	{
		label: 'White-labeled branded IoT solutions',
		href: '/docs/user-guide/white-labeling/',
		values: [false, true],
	},
	{
		label: 'OTA updates support',
		href: '/docs/pe/user-guide/ota-updates/',
		values: [false, true],
	},
	{
		label: 'Additional LWM2M and SNMP transports',
		href: '/docs/pe/getting-started-guides/connectivity/',
		values: [false, true],
	},
	{
		label: 'NB-IoT, SigFox, LoRaWAN and other integrations',
		href: '/docs/user-guide/integrations/',
		values: [false, true],
	},
];

const concepts = [
	{
		title: 'Device',
		href: '/docs/pe/user-guide/ui/devices/',
		text: 'ThingsBoard supports provisioning and management of <a href="/docs/pe/user-guide/ui/devices/">devices</a> similar to Google IoT Core. However, IoT application is not only about devices. ThingsBoard supports other <a href="/docs/pe/user-guide/entities-and-relations/">entities and relations</a> between them. The relations model enables advanced use cases and business logic. For example, you may configure relations between assets, devices, customers, etc.',
	},
	{
		title: 'Telemetry',
		href: '/docs/pe/user-guide/telemetry/',
		text: 'Telemetry is the event data sent from the device to the cloud. For example, measurements about the environment. ThingsBoard allows you to collect data from devices similar to IoT Core. ThingsBoard also enables data processing (including validation, alerting, etc.) and storage inside the platform. See <a href="/docs/pe/user-guide/rule-engine-2-0/re-getting-started/">Rule Engine</a> for more details. You may also forward the data to external systems (e.g., PubSub) and reuse your existing data processing flow.',
	},
	{
		title: 'Device state',
		href: '/docs/pe/user-guide/device-connectivity-status/',
		text: 'ThingsBoard monitors device <a href="/docs/pe/user-guide/device-connectivity-status/">connectivity status</a> and allows devices to upload their state via the client <a href="/docs/pe/user-guide/attributes/#client-side-attributes">attributes</a> feature. You can configure the platform to raise alerts when devices are offline or change state. ThingsBoard also allows you to distribute over-the-air <a href="/docs/pe/user-guide/ota-updates/">firmware and software updates</a> and monitor the update process.',
	},
	{
		title: 'Device configuration',
		href: '/docs/pe/user-guide/attributes/',
		text: 'ThingsBoard capabilities of device configuration as similar to Google IoT Core. See docs about device <a href="/docs/pe/user-guide/attributes/">attributes</a>. Experienced users may notice a few important differences: ThingsBoard allows to push each attribute(configuration) update separately; One may change configuration attributes via Dashboard, Admin UI, REST API call, or script; Attributes are sent to the device via JSON or protobuf format.',
	},
	{
		title: 'Device registry and device manager',
		href: '/docs/pe/user-guide/device-provisioning/',
		text: 'ThingsBoard provides flexible interfaces for registering, monitoring, and configuring devices: Dashboards, Admin Web UI, REST API, <a href="/docs/pe/user-guide/provisioning/#bulk-provisioning">CSV upload</a>, and automatic <a href="/docs/pe/user-guide/device-provisioning/">provisioning</a>. The platform gives you much more flexibility on how to add, group and control devices. You can register devices under different tenants or assign devices to different customers. End users are able to <a href="/docs/pe/user-guide/claiming-devices/">claim devices</a> during the <a href="/docs/pe/user-guide/self-registration/">self-registration</a> process. ThingsBoard has all the required built-in instruments to enable complex use cases.',
	},
	{
		title: 'Publishing over MQTT and HTTP',
		href: '/docs/pe/getting-started-guides/connectivity/',
		text: 'A central IoT Core point is an MQTT broker that allows data exchange between devices and the cloud. ThingsBoard also acts like an MQTT broker, but there are a few differences. With ThingsBoard, you are not limited by static topic name patterns and can define any wildcard topic filters for your needs. The platform accepts JSON or protobuf payloads. ThingsBoard supports <a href="/docs/pe/user-guide/access-token/">access tokens</a>, <a href="/docs/pe/user-guide/basic-mqtt/">basic MQTT credentials</a> or <a href="/docs/pe/user-guide/certificates/">X.509 certificates</a>. In addition to MQTT and HTTP support, devices can natively communicate with the platform using other protocols like CoAP, LwM2M, and SNMP. You may also use our <a href="/docs/iot-gateway/what-is-iot-gateway/">IoT Gateway</a> to integrate devices connected to legacy and third-party systems via BLE, CAN, Modbus, OPC-UA, BACnet, ODBC, etc. ThingsBoard also has built-in integrations with external systems like SigFox, LoRaWAN, NB IoT, etc. You may find a list of all available integrations <a href="/docs/user-guide/integrations/">on the integrations page</a>.',
	},
	{
		title: 'Send commands to and from devices',
		href: '/docs/pe/user-guide/rpc/',
		text: 'You may send commands to and from devices with the ThingsBoard <a href="/docs/pe/user-guide/rpc/">RPC</a> feature. The commands can be persisted or not, one-way or two-way, and you can configure retry and failure policies for different command types. Commands may be triggered by the user via the dashboard, via REST API, or based on events received by the platform.',
	},
];
---

<BaseLayout
	title="ThingsBoard is a Google IoT Core alternative"
	description="ThingsBoard is an excellent alternative to Google IoT Core. Learn how to migrate from Google IoT Core to ThingsBoard Professional Edition."
	pageId="google-iot-core-alternative"
>
	<div id="google-iot-core-alternative">

		<!-- Intro -->
		<section class="intro">
			<div class="page-container">
				<h1>ThingsBoard as a Google IoT Core alternative</h1>
			</div>
		</section>

		<!-- Description (two paragraphs) -->
		<section class="description">
			<!-- shapes are direct children → position relative to full-width section -->
			<div class="shape small1" aria-hidden="true"></div>
			<div class="shape small2" aria-hidden="true"></div>
			<div class="shape small3" aria-hidden="true"></div>
			<div class="page-container">
				<p>
					Google Cloud shut down the IoT Core service in August 2023. You might be wondering where
					and how to migrate. ThingsBoard is an excellent alternative to Google IoT Cloud. Launched
					in 2016 as an open-source project, ThingsBoard has grown to a mature platform with 1000+
					customers worldwide.
				</p>
				<p>
					ThingsBoard, Inc. provides managed services, training, support, and software development
					services around the platform. We may also host and manage a private platform instance in
					your existing Google Cloud infrastructure.
				</p>
			</div>
		</section>

		<!-- Features comparison intro -->
		<section class="features-comparison">
			<div class="page-container">
				<h2>Features comparison</h2>
				<p>
					Google IoT Core acts as an MQTT Broker and provides Device Registry and Pub/Sub
					integration. ThingsBoard provides an alternative implementation to Google IoT Core
					features with similar and, in some cases, identical APIs. Our platform is much more than
					a <a href="/docs/reference/msa/">scalable</a> service to accept and route telemetry.
					ThingsBoard brings full IoT application enablement capabilities. See the feature
					comparison table below:
				</p>
			</div>
		</section>

		<!-- Comparison matrix -->
		<ComparisonMatrix columns={matrixColumns} rows={matrixRows} noTopMargin />
		<div class="matrix-note page-container">
			<p>
				Learn more about ThingsBoard features <a
					href="/docs/pe/getting-started-guides/what-is-thingsboard/">in the ThingsBoard overview</a
				>.
			</p>
		</div>

		<!-- Key concepts -->
		<section class="bottom-features">
			<div class="shape small11" aria-hidden="true"></div>
			<div class="shape small12" aria-hidden="true"></div>
			<div class="shape small13" aria-hidden="true"></div>
			<div class="shape small14" aria-hidden="true"></div>
			<div class="shape small15" aria-hidden="true"></div>
			<div class="page-container">
				<h3>Key concepts</h3>
				<p>See mapping of the key IoT Core concepts to ThingsBoard features documentation below:</p>
				<div class="cards row">
					{
						concepts.map((c) => (
							<div class="col-lg-6">
								<div class="block">
									<div>
										<a class="concept-title" href={c.href}>
											{c.title}
										</a>
										<p set:html={c.text} />
									</div>
								</div>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="bottom-cta">
			<a href="/docs/contact-us/" class="try-pe">Contact us</a>
		</section>
	</div>
</BaseLayout>

<style lang="scss">
	@use '~/styles/variables' as *;

	$green: #17bb52;
	$green-mid: #27ae60;
	$green-dark: #1f8b4d;
	$text-dark: #212924;
	$text-body: #393939;

	// ── Container ─────────────────────────────────────────────────
	.page-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 20px;

		@media (min-width: 1500px) {
			max-width: 1400px;
		}
	}

	// ── Shared text styles ─────────────────────────────────────────
	#google-iot-core-alternative {
		overflow-x: clip;
		color: $text-dark;

		p {
			color: $text-body;
			font-size: 18px;
			font-weight: 400;
			line-height: 27px;
			margin: 4px 0 18px;
		}

		a:not(.try-pe):not(.concept-title) {
			color: $green-mid;
			font-weight: 500;
			font-size: 18px;
		}
	}

	// ── Intro ──────────────────────────────────────────────────────
	.intro {
		// header-height (80px) + original top padding
		padding-top: calc(#{$header-height} + 28px);
		padding-bottom: 140px;

		@media (min-width: 1025px) {
			padding-top: calc(#{$header-height} + 140px);
		}

		h1 {
			font-weight: 600;
			text-align: center;
			font-size: 36px;
			line-height: 48px;
			margin-bottom: 0;

			@media (min-width: 768px) {
				font-size: 42px;
				line-height: 52px;
			}
		}
	}

	// ── Description ────────────────────────────────────────────────
	// Shapes are direct children → right/left measured from section's full width
	.description {
		position: relative;
		overflow-x: clip; // prevents horizontal scroll; does NOT clip absolute children
		overflow-y: visible;
		padding: 190px 0 60px;

		.page-container {
			position: relative;
			z-index: 1;
		}
	}

	// ── Decorative shapes (shared) ─────────────────────────────────
	.shape {
		position: absolute;
		transform: skewY(-6deg);
		width: 436px;
		height: 90px;
		z-index: 0;
		pointer-events: none;

		&.small1 {
			top: 20px;
			left: 0;
			background-color: $green-mid;
		}

		&.small2 {
			top: 30px;
			left: 270px;
			border: 2px solid #234732;
			background: none;
		}

		&.small3 {
			top: -60px;
			right: 0;
			background-color: $green-dark;
		}
	}

	// ── Features comparison intro ──────────────────────────────────
	.features-comparison {
		padding: 40px 0 60px;

		h2 {
			font-weight: 500;
			font-size: 36px;
			margin-bottom: 16px;
		}
	}

	// ── Matrix note ────────────────────────────────────────────────
	.matrix-note {
		padding: 24px 20px 80px;
	}

	// ── Bottom features (Key concepts) ─────────────────────────────
	.bottom-features {
		position: relative;
		overflow-x: clip;
		overflow-y: visible;
		background-color: #f7f9fc;
		padding: 60px 0 200px;

		// dark band at the top (skewed like the original)
		&::before {
			content: '';
			display: block;
			position: absolute;
			top: 320px;
			left: -5%;
			right: -5%;
			height: 525px;
			background-color: #252628;
			transform: skewY(-6deg);
			transform-origin: top left;
			z-index: 0;
		}

		// dark band at the bottom (skewed like the original)
		&::after {
			content: '';
			display: block;
			position: absolute;
			top: 1100px;
			left: -5%;
			right: -5%;
			height: 400px;
			background-color: #252628;
			transform: skewY(-6deg);
			transform-origin: bottom right;
			z-index: 0;
		}

		// Shapes are direct children → right/left from section edge
		.shape {
			z-index: 1;

			&.small11 {
				top: 66px;
				right: -218px;
				background-color: $green-mid;
			}

			&.small12 {
				top: 785px;
				left: -218px;
				border: 4px solid #234732;
				background: none;
			}

			&.small13 {
				top: 1230px;
				left: 0;
				background-color: $green-dark;
			}

			&.small14 {
				top: 1170px;
				left: 120px;
				background-color: $green-mid;
			}

			&.small15 {
				top: 1466px;
				right: -218px;
				border: 4px solid $green-mid;
				background: none;
			}
		}

		.page-container {
			position: relative;
			z-index: 2;
		}

		h3 {
			font-size: 36px;
			font-weight: 600;
			line-height: 63px;
			margin-bottom: 0;

			@media (min-width: 768px) {
				font-size: 42px;
			}

			&::before {
				display: none;
			}
		}

		> .page-container > p {
			color: #868686;
		}

		.cards {
			padding-top: 50px;
			justify-content: center;

			& > div {
				margin-bottom: 36px;

				&.col-lg-6 {
					padding: 0 18px;
					max-width: 100%;

					@media (min-width: 992px) {
						max-width: 50%;
					}
				}
			}
		}

		.block {
			padding: 48px;
			width: 100%;
			height: 100%;
			background: white;
			border-radius: 6px;
			box-shadow: 0 50px 50px -20px rgba(0, 0, 0, 0.15);
			text-align: start;

			@media (min-width: 750px) {
				display: flex;
				text-align: left;
			}

			div {
				width: 100%;
			}

			// links inside set:html paragraphs don't get scoped hash → use :global
			:global(p a) {
				color: $green-mid;
				font-weight: 500;
				font-size: 18px;
			}
		}

		.concept-title {
			color: $green-mid;
			font-size: 24px;
			font-weight: 500;
			margin-bottom: 6px;
			display: block;
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}

	// ── CTA ────────────────────────────────────────────────────────
	.bottom-cta {
		margin: 0 calc(-50vw + 50%);
		padding: 124px max(calc(50vw - 50%), 1.25rem);
		text-align: center;
		background: #fff;

		.try-pe {
			background-color: $green;
			font-size: 24px;
			font-weight: 400;
			text-align: center;
			color: white;
			border-radius: 4px;
			text-decoration: none;
			padding: 15px 128px;
			box-shadow: 0 28px 16px -20px rgba(13, 39, 67, 0.25);
			display: inline-block;

			&:hover {
				background-color: #35c86a;
				color: #fff;
			}

			&:active {
				background-color: $green-dark;
			}

			@media (max-width: 600px) {
				padding: 15px 40px;
			}
		}
	}
</style>
