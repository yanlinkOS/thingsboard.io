---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '../../../components/Landing/Hero.astro';
import CustomersLogo from '../../../components/Landing/CustomersLogo.astro';
import FeatureBlockSection from '../../../components/Landing/FeatureBlockSection.astro';
import RBACDiagramSection from '../../../components/Landing/RBACDiagramSection.astro';
import DualFeatureSection from '../../../components/Landing/DualFeatureSection.astro';
import ComparisonTable from '../../../components/Landing/ComparisonTable.astro';
import FeatureCard from '../../../components/Landing/FeatureCard.astro';
import { Products } from '@models/site.models';
---

<BaseLayout
	headerVariant="transparent"
	forceLightTheme
	title="ThingsBoard Professional Edition"
	description="Advanced ThingsBoard IoT Platform distribution with white-labeling, advanced RBAC, platform integrations, entity groups, scheduler, reporting, and more."
>
	<main>
		<Hero
			product={Products.PE}
			title="ThingsBoard Professional Edition"
			subtitle="Get it now and unlock advanced features for your IoT solution"
			buttons={[{ text: 'Get it now', href: '/pricing/', variant: 'outline' }]}
			anchorLink="#intro"
			backgroundImage="/hero/pe-cover.webp"
			videoBackground={{
				webm: 'https://video.thingsboard.io/pe-cover.webm',
				mp4: 'https://video.thingsboard.io/pe-cover.mp4',
			}}
		/>

		<section id="overflow">
			<CustomersLogo productTag="pe" />

			<section id="intro">
				<div class="intro-div">
					<h2>Advanced ThingsBoard IoT Platform distribution</h2>
					<span>with value added features</span>
				</div>
			</section>

			<!-- White-labeling (light-grey skewed bg via real DOM background div) -->
			<FeatureBlockSection
				id="labeling"
				heading="White-labeling"
				description="Rebrand ThingsBoard platform web interface with your company or product logo and color scheme in 2 minutes. No coding or service restart required. Allow your customers and their sub-customers to white-label their interface as well."
				links={[{ href: '/docs/pe/user-guide/white-labeling/', text: 'Read more about white labeling' }]}
				imageSrc="/src/assets/images/landings/pe/white-labeling.webp"
				imageAlt="White-labeling interface example"
				imageWidth={978}
				imageHeight={883}
				imageWidths={[540, 978]}
				imageSizes="(min-width: 1500px) 570px, (min-width: 769px) 540px, calc(100vw - 2.5rem)"
				bgId="background-white-labeling"
				bgDivs={['main1', 'small1', 'small2', 'small3']}
				variant="pe"
				imageEqual={true}
			/>

			<!-- Advanced RBAC (plain white bg) -->
			<RBACDiagramSection />

			<!-- Platform Integrations (dark #262C28 bg) -->
			<FeatureBlockSection
				id="integration"
				heading="Platform Integrations"
				description="Stream data from devices connected to existing IoT Platforms to enable real-time interactive dashboards and efficient data processing. Connect NB IoT, LoRaWAN and SigFox devices with specific payload formats using highly customizable data converters. Design and plugin your own converter as a JavaScript functions in real-time."
				links={[{ href: '/docs/pe/user-guide/integrations/', text: 'Read more about platform integrations' }]}
				imageSrc="/src/assets/images/landings/pe/integrations.svg"
				imageAlt="Platform integrations diagram"
				imageWidth={626}
				imageHeight={605}
				dark={true}
				bgId="background-platform-integrations"
				bgDivs={['main2', 'small4', 'small5']}
				listIconSrc="/src/assets/images/landings/pe/integrations-list.svg"
				listIconAlt="Integrations list"
				listIconWidth={282}
				listIconHeight={225}
				imageEqual={true}
			/>

			<!-- Entity Groups (plain white bg) -->
			<FeatureBlockSection
				id="entity-groups"
				heading="Entity Groups"
				description="Group your entities (device, assets, etc.) to simplify administration tasks. Customize set of columns for each group and trigger actions on entities directly from administration interface."
				links={[{ href: '/docs/pe/user-guide/groups/', text: 'Read more about entity groups' }]}
				imageSrc="/src/assets/images/landings/pe/entity-groups.svg"
				imageAlt="Entity groups administration interface"
				imageWidth={626}
				imageHeight={390}
				imageFirst={true}
				variant="pe"
				imageEqual={true}
			/>

			<!-- Scheduler + Reporting (skewed light-grey bg) -->
			<DualFeatureSection
				id="scheduler-section"
				left={{
					heading: 'Scheduler',
					description:
						'Schedule various types of events including report generation, commands to devices and configuration updates with flexible schedule configuration.',
					readMoreHref: '/docs/pe/user-guide/scheduler/',
					readMoreText: 'Read more about scheduler',
				}}
				right={{
					heading: 'Reporting',
					description:
						'Generate great looking reports using dashboards visualization capabilities. Generate reports by schedule or export by demand.',
					readMoreHref: '/docs/pe/user-guide/reporting/report-templates/',
					readMoreText: 'Read more about reporting',
				}}
				imageSrc="/src/assets/images/landings/pe/scheduler.svg"
				imageAlt="Scheduler interface"
				imageWidth={532}
				imageHeight={565}
				bgId="background-scheduler"
				bgDivs={['main3', 'small6', 'small7', 'small8']}
				variant="pe"
			/>

			<!-- CSV/XLS Export (dark bottom strip via background-data-export) -->
			<FeatureBlockSection
				id="export"
				heading="CSV/XLS data export"
				description="Export any dashboard widget data to CSV or XLS format. Allow your customers to download valuable insights from their device's data and review them in offline mode."
				links={[{ href: '/docs/pe/user-guide/csv-xls-data-export/', text: 'Read more about CSV/XLS data export' }]}
				imageSrc="/src/assets/images/landings/pe/data-export.svg"
				imageAlt="Data export interface"
				imageWidth={626}
				imageHeight={530}
				imageFirst={true}
				variant="pe"
				listIconSrc="/src/assets/images/landings/pe/export-list.svg"
				listIconAlt="Export formats list"
				listIconWidth={215}
				listIconHeight={160}
				listIconLeft={-240}
				listIconTop={100}
				bgId="background-data-export"
				bgDivs={['bottom', 'small9']}
				imageEqual={true}
			/>

			<!-- Feature Comparison Table (skewed bg built-in) -->
			<ComparisonTable />

			<!-- Bottom feature cards -->
			<section id="features">
				<div class="features-inner">
					<FeatureCard
						variant="pe"
						icon="/src/assets/images/landings/pe/cloud-premises.svg"
						title="Flexible deployment options"
						description="Deploy ThingsBoard platform in the cloud or on-premises. Use commodity hardware to scale out horizontally by adding new nodes to your cluster. Single ThingsBoard server can support 10 000+ devices and 100M messages per hour, while simple cluster can support millions of devices and billions of messages."
						href="/docs/pe/reference/architecture/microservices/"
					/>
					<div class="features-divider"></div>
					<FeatureCard
						variant="pe"
						icon="/src/assets/images/landings/pe/pricing-models.svg"
						alt="Pricing models overview for ThingsBoard Professional Edition"
						title="Simple and predictable pricing models"
						description={'Say "No!" to per message or per device pricing that turns to a monster bills in production system. ThingsBoard PE supports two simple and predictable pricing models depending on your product life-cycle stage.'}
						href="/pricing/"
					/>
				</div>
			</section>

			<!-- CTA -->
			<section id="bottom">
				<div class="bottom-inner">
					<a id="Products_PE_GetItNow" href="/pricing/" class="try-pe gtm_button">Get it now</a>
				</div>
			</section>
		</section>
	</main>
</BaseLayout>

<style is:global lang="scss">
	@use '../../../styles/landing';
	@use '../../../styles/variables' as *;

	main {
		width: 100%;
	}

	#overflow {
		overflow: hidden;
	}

	#intro {
		text-align: center;
		padding: 5rem 1.875rem 0;
		margin-bottom: 10rem;

		@media screen and (max-width: 768px) {
			padding: 3rem 1.25rem 0;
		}
	}

	.intro-div {
		max-width: 1200px;
		margin: 0 auto;

		h2 {
			font-size: $font-size-5xl;
			font-weight: $font-weight-semibold;
			line-height: 1.3;
			color: $color-text-primary;
			margin: 0 0 1rem;

			@media screen and (max-width: 768px) {
				font-size: $font-size-4xl;
			}
		}

		span {
			font-size: $font-size-4xl;
			font-weight: $font-weight-normal;
			line-height: 2.5rem;
			color: $color-text-secondary;
			margin: 0;
		}
	}

	// Shadow for feature block images
	.feature-block-section .block img {
		border-radius: $radius-md;
		box-shadow:
			0 50px 50px -20px rgba(0, 0, 0, 0.15),
			0 0 30px 0 rgba(0, 0, 0, 0.1);
	}

	#features {
		padding: 6.25rem 1.875rem 5rem;

		@media screen and (min-width: 1500px) {
			padding-left: 6.25rem;
			padding-right: 6.25rem;
		}

		@media screen and (max-width: 768px) {
			padding: 3rem 1.25rem;
		}
	}

	.features-inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 3rem;

		@media screen and (min-width: 768px) {
			flex-direction: row;
			align-items: flex-start;
			gap: 0;

			.feature-item {
				flex: 0 0 calc(50% - 1px - 3rem);
				min-width: 0;
			}
		}

		@media screen and (min-width: 1500px) {
			max-width: 1400px;
		}
	}

	.features-divider {
		display: none;

		@media screen and (min-width: 768px) {
			display: block;
			width: 2px;
			align-self: stretch;
			background-color: #dadbda;
			margin: 0 3rem;
			flex-shrink: 0;
		}
	}

	#bottom {
		margin: 0 calc(-50vw + 50%);
		padding: 5.125rem 0 7.75rem;
		text-align: center;
		background-color: $color-bg-white;
	}

	.bottom-inner {
		display: flex;
		justify-content: center;
	}

	.try-pe {
		display: inline-block;
		background-color: $color-pe-link;
		color: $color-white;
		font-size: 1.5rem;
		font-weight: $font-weight-normal;
		text-align: center;
		text-decoration: none;
		border-radius: 4px;
		padding: 0.9375rem 8rem;
		box-shadow: 0 28px 16px -20px rgba(13, 39, 67, 0.25);
		transition: background-color 0.6s;

		&:hover {
			background-color: $color-pe-dark;
			text-decoration: none;
			color: $color-white;
		}

		&:active {
			background-color: $color-pe-link;
			transition-duration: 0s;
		}

		@media screen and (max-width: 768px) {
			padding: 0.9375rem 3rem;
			font-size: $font-size-xl;
		}
	}

	:root section {
		background: none;
	}

	// Overflow container
	#overflow {
		overflow: hidden;
	}

	[id^='background-'] {
		z-index: -1;
		position: absolute;
		top: 524px;
		left: 50%;
	}

	[id^='background-'] div {
		position: absolute;
		transform: skewY(-6deg);
		width: 436px;
		height: 90px;
	}

	[id^='background-'] .main1 {
		top: -558px;
		width: 2560px;
		height: 525px;
		left: -1280px;
		background-color: #f4f4f4;
	}

	[id^='background-'] .small1 {
		top: -542px;
		right: 524px;
		background-color: #27ae60;
	}

	[id^='background-'] .small2 {
		top: -532px;
		right: 270px;
		border: 2px solid #234732;
	}

	[id^='background-'] .small3 {
		top: -686px;
		left: 524px;
		background-color: #1f8b4d;
	}

	[id^='background-'] .main2 {
		top: -510px;
		width: 2560px;
		height: 525px;
		left: -1280px;
		background-color: #262c28;
	}

	[id^='background-'] .small4 {
		top: -660px;
		left: 836px;
		background-color: #27ae60;
	}

	[id^='background-'] .small5 {
		top: 66px;
		right: 528px;
		border: 4px solid #27ae60;
	}

	[id^='background-'] .main3 {
		top: -503px;
		width: 2560px;
		height: 525px;
		left: -1280px;
		background-color: #f4f4f4;
	}

	[id^='background-'] .small6 {
		top: -467px;
		right: 804px;
		background-color: #1f8b4d;
	}

	[id^='background-'] .small7 {
		top: -644px;
		left: 566px;
		background-color: #27ae60;
	}

	[id^='background-'] .small8 {
		top: -114px;
		left: 804px;
		border: 2px solid #234732;
	}

	[id^='background-'] .bottom {
		top: -70px;
		width: 2560px;
		height: 130px;
		left: -1280px;
		background-color: #262c28;
	}

	[id^='background-'] .small9 {
		top: -10px;
		left: 565px;
		background-color: #1f8b4d;
	}

	// The #export section has a dark (#262c28) bottom strip behind the read-more link.
	// $color-pe-link (#166c37) is designed for light backgrounds (5.89:1 on white)
	// but fails on #262c28 (~2:1). Override with $color-pe (#17bb52, 5.59:1 on #262c28).
	#export .read-more-link--pe,
	#export .read-more-link--pe .arrow {
		color: $color-pe;
	}

	@media screen and (min-width: 1025px) {
		[id^='background-'] .main2 {
			height: 525px;
		}

		[id^='background-'] .bottom {
			top: -17px;
		}
	}
</style>
