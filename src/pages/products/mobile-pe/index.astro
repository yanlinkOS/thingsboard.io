---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import MobileFeatureBlock from '../../../components/Landing/MobileFeatureBlock.astro';
---

<BaseLayout
	forceLightTheme
	title="ThingsBoard PE Mobile Application"
	description="ThingsBoard PE Mobile Application is an open-source project based on Flutter. Build your own advanced IoT mobile application with minimum coding efforts."
	pageId="mobile-pe"
>
	<main>
		<div id="overflow">
			<section id="intro">
				<div class="intro-inner">
					<h1>
						<a href="/docs/pe/mobile/">ThingsBoard PE Mobile Application</a> is an open-source{' '}
						<a href="https://github.com/thingsboard/flutter_thingsboard_pe_app">project</a> based on Flutter
					</h1>
					<h2 class="second">Build your own advanced IoT mobile application with minimum coding efforts</h2>
					<h3 class="second">Powered by ThingsBoard PE IoT Platform</h3>
				</div>
			</section>

			<section class="features">
				<div class="features-inner">
					<div class="features-top">
						<div class="background">
							<div class="main1"></div>
							<div class="small1"></div>
							<div class="small2"></div>
							<div class="small3"></div>
						</div>

						<MobileFeatureBlock
							heading="Home screen with flexible navigation"
							description="Browse everything from home screen. Use Platform to configure dashboard icons, order and visibility."
							readMoreHref="/docs/pe/mobile/customize-dashboards/"
							phoneBgSrc="/images/mobile/pe/mobile-bg-pe.svg"
							phoneSideSrc="/images/mobile/pe/pe-flexible-nav.svg"
							phoneSideClass="flexible"
							frameImageSrc="/images/mobile/pe/browse-dashboards-frame.png"
							videoMp4="https://video.thingsboard.io/mobile/pe/browse-dashboards.mp4"
							videoWebm="https://video.thingsboard.io/mobile/pe/browse-dashboards.webm"
							variant="pe"
						/>

						<MobileFeatureBlock
							heading="White-labeling"
							description={`Rebrand your mobile app interface with your company or product logo and color scheme using ThingsBoard PE <a href="/docs/pe/user-guide/white-labeling/">white-labeling</a> feature.`}
							readMoreHref="/docs/pe/mobile/white-labeling/"
							phoneBgSrc="/images/mobile/pe/mobile-bg-pe.svg"
							phoneSideSrc="/images/mobile/pe/pe-white-labeling.svg"
							phoneSideClass="w-label"
							frameImageSrc="/images/mobile/pe/white-labeling-frame.png"
							videoMp4="https://video.thingsboard.io/mobile/pe/white-labeling.mp4"
							videoWebm="https://video.thingsboard.io/mobile/pe/white-labeling.webm"
							imageFirst={true}
							shadowRight={true}
							pointsRight={true}
							blockClass="vis"
							variant="pe"
						/>
					</div>
				</div>
			</section>

			<section class="features">
				<div class="features-inner">
					<div class="features-top">
						<div class="background">
							<div class="main2"></div>
							<img src="/images/grid.svg" alt="" />
							<div class="small4"></div>
							<div class="small5"></div>
						</div>

						<MobileFeatureBlock
							heading="Self-registration"
							description={`Setup sign-up page for your customers using ThingsBoard PE <a href="/docs/pe/user-guide/self-registration/">self-registration</a> feature.`}
							readMoreHref="/docs/pe/mobile/self-registration/"
							phoneBgSrc="/images/mobile/pe/mobile-bg-pe.svg"
							phoneSideSrc="/images/mobile/pe/pe-self-registration.svg"
							phoneSideClass="self-reg"
							frameImageSrc="/images/mobile/pe/self-registration-frame.png"
							videoMp4="https://video.thingsboard.io/mobile/pe/self-registration.mp4"
							videoWebm="https://video.thingsboard.io/mobile/pe/self-registration.webm"
							dark={true}
							variant="pe"
						/>

						<MobileFeatureBlock
							heading="Simple and convenient alarms management"
							description="Manage alarms in one place. Navigate to related dashboards configurable from the Platform."
							readMoreHref="/docs/pe/mobile/alarm-dashboard/"
							phoneBgSrc="/images/mobile/pe/mobile-bg-pe.svg"
							phoneSideSrc="/images/mobile/pe/pe-alarms-m.svg"
							phoneSideClass="alarms-m"
							frameImageSrc="/images/mobile/pe/manage-alarms-frame.png"
							videoMp4="https://video.thingsboard.io/mobile/pe/manage-alarms.mp4"
							videoWebm="https://video.thingsboard.io/mobile/pe/manage-alarms.webm"
							imageFirst={true}
							shadowRight={true}
							pointsRight={true}
							blockClass="micro"
							variant="pe"
						/>
					</div>
				</div>
			</section>

			<section class="features">
				<div class="features-inner">
					<div class="features-top">
						<div class="background">
							<div class="main3"></div>
							<div class="small6"></div>
							<div class="small7"></div>
							<div class="small8"></div>
						</div>

						<MobileFeatureBlock
							heading="Structured devices navigation"
							description="Browse devices grouped by their type and online status. On ThingsBoard, assign device specific dashboard and image."
							readMoreHref="/docs/pe/mobile/customize-devices/"
							phoneBgSrc="/images/mobile/pe/mobile-bg-pe.svg"
							phoneSideSrc="/images/mobile/pe/pe-devices-nav.svg"
							phoneSideClass="devices-nav"
							frameImageSrc="/images/mobile/pe/navigate-devices-frame.png"
							videoMp4="https://video.thingsboard.io/mobile/pe/navigate-devices.mp4"
							videoWebm="https://video.thingsboard.io/mobile/pe/navigate-devices.webm"
							variant="pe"
						/>

						<MobileFeatureBlock
							heading="Rich set of mobile actions"
							description="Use mobile device to take photo, scan QR code, update location and more within dashboard. Extend the action with your own processing logic using ThingsBoard."
							readMoreHref="/docs/pe/mobile/mobile-actions/"
							phoneBgSrc="/images/mobile/pe/mobile-bg-pe.svg"
							phoneSideSrc="/images/mobile/pe/pe-mobile-act.svg"
							phoneSideClass="mobile-act"
							frameImageSrc="/images/mobile/pe/mobile-actions-frame.png"
							videoMp4="https://video.thingsboard.io/mobile/pe/mobile-actions.mp4"
							videoWebm="https://video.thingsboard.io/mobile/pe/mobile-actions.webm"
							imageFirst={true}
							blockClass="micro"
							variant="pe"
						/>

						<div class="background bottom">
							<div class="bottom"></div>
							<div class="small9"></div>
						</div>
					</div>
				</div>
			</section>

			<section id="bottom">
				<div class="bottom-inner">
					<a id="Products_MobAppPE_GetStart" href="/docs/pe/mobile/getting-started/" class="getting-started gtm_button">
						Getting started
					</a>
				</div>
			</section>
		</div>
	</main>
</BaseLayout>

<style lang="scss">
	@use '../../../styles/variables' as *;

	main {
		width: 100%;
	}

	#overflow {
		overflow: hidden;
	}

	// ── Intro section ─────────────────────────────────────────────
	#intro {
		margin-bottom: 178px;
		padding-top: 200px;
		color: #212529;
		text-align: left;
		background: transparent;

		.intro-inner {
			max-width: 1400px;
			margin: 0 auto;
			padding: 0 1.25rem;
		}

		h1 {
			font-weight: 600;
			text-align: center;
			font-size: 32px;
			line-height: 52px;
			margin-bottom: 48px;

			a {
				font-weight: 600;
				font-size: 32px;
				color: $color-pe;
			}
		}

		h2.second,
		h3.second {
			text-align: center;
			color: #899aab;
			font-size: 20px;
			line-height: 1.5em;
			font-weight: normal;
		}
	}

	// ── Features sections ─────────────────────────────────────────
	.features {
		background: transparent;

		.features-inner {
			max-width: 1400px;
			margin: 0 auto;
			padding: 0 1.25rem;
		}
	}

	// ── Decorative background shapes ──────────────────────────────
	.background {
		position: absolute;
		left: 50%;

		&:not(.bottom) {
			top: 524px;
		}

		&.bottom {
			top: auto;
			bottom: 1617px;
		}

		img {
			position: absolute;
			top: -650px;
			left: 134px;
			box-shadow: none !important;
		}

		div {
			position: absolute;
			transform: skewY(-6deg);
			width: 436px;
			height: 90px;

			// ── Section 1 ──
			&.main1 {
				top: -572px;
				width: 2560px;
				height: 825px;
				left: -1280px;
				background-color: #f4f4f4;
			}

			&.small1 {
				top: -542px;
				right: 524px;
				background-color: #27ae60;
			}

			&.small2 {
				top: -532px;
				right: 270px;
				border: 2px solid #234732;
				background-color: transparent;
			}

			&.small3 {
				top: -686px;
				left: 524px;
				background-color: #1f8b4d;
				border: none;
			}

			// ── Section 2 ──
			&.main2 {
				top: -576px;
				width: 2560px;
				height: 825px;
				left: -1280px;
				background-color: #262c28;
			}

			&.small4 {
				top: -742px;
				left: 867px;
				background-color: #27ae60;
				border: none;
			}

			&.small5 {
				top: 63px;
				right: 525px;
				left: auto;
				border: 4px solid #27ae60;
			}

			// ── Section 3 ──
			&.main3 {
				top: -576px;
				width: 2560px;
				height: 825px;
				left: -1280px;
				background-color: #f4f4f4;
			}

			&.small6 {
				top: -537px;
				right: 804px;
				background-color: #1f8b4d;
				border: none;
			}

			&.small7 {
				top: -714px;
				left: 566px;
				background-color: #27ae60;
			}

			&.small8 {
				top: -84px;
				left: 804px;
				border: 2px solid #234732;
			}

			// ── Bottom ──
			&.bottom {
				bottom: -1780px;
				width: 2560px;
				height: 130px;
				left: -1280px;
				background-color: #262c28;
			}

			&.small9 {
				top: auto;
				bottom: -1760px;
				left: 565px;
				background-color: #1f8b4d;
				border: none;
			}
		}

		@media screen and (min-width: 1025px) {
			div.main1,
			div.main2,
			div.main3 {
				height: 625px;
			}
		}
	}

	// ── Bottom CTA section ────────────────────────────────────────
	#bottom {
		margin-top: 340px;
		padding: 82px 0 124px;
		text-align: center;
		background-color: #fafafa;
		margin-left: calc(-50vw + 50%);
		margin-right: calc(-50vw + 50%);

		.bottom-inner {
			max-width: 1400px;
			margin: 0 auto;
			padding: 0 1.25rem;
		}

		.getting-started {
			display: inline-block;
			font-size: 24px;
			font-weight: 400;
			text-align: center;
			color: white;
			background-color: $color-pe;
			border-radius: 4px;
			text-decoration: none;
			padding: 15px 68px;
			box-shadow: 0 28px 16px -20px rgba(13, 39, 67, 0.25);
			transition: background-color 0.3s;

			&:hover {
				background-color: $color-pe-hover;
				text-decoration: none;
				color: #fff;
			}

			&:active {
				background-color: $color-pe-dark;
				transition-duration: 0s;
			}

			@media screen and (min-width: 1025px) {
				padding: 15px 128px;
			}
		}
	}
</style>