---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '../../../components/Landing/Hero.astro';
import CustomersLogo from '../../../components/Landing/CustomersLogo.astro';
import SmartImage from '@components/SmartImage.astro';
import PaasComparisonMatrix from '../../../components/Landing/PaasComparisonMatrix.astro';
import { Products } from '@models/site.models';

const cards = [
	{
		icon: '/src/assets/images/landings/paas/improved-time.svg',
		title: 'Improved time to market',
		text: 'Save time on maintenance of the platform or configuration of the features.',
	},
	{
		icon: '/src/assets/images/landings/paas/advanced-features.svg',
		title: 'Advanced features',
		text: 'Platform supports all <a href="/products/thingsboard-pe/">Professional Edition</a> features and advanced <a href="/docs/paas/user-guide/security/domains/">domain management</a>.',
	},
	{
		icon: '/src/assets/images/landings/paas/reduced-costs.svg',
		title: 'Reduced costs',
		text: 'The cost of the cluster infrastructure is shared between the users of the platform.',
	},
	{
		icon: '/src/assets/images/landings/paas/high-availability.svg',
		title: 'High availability',
		text: 'ThingsBoard Cloud uses microservices architecture and is deployed in multiple availability zones.',
	},
	{
		icon: '/src/assets/images/landings/paas/data-durability.svg',
		title: 'Data durability',
		text: "Platform uses data replication and backup procedures to make sure you don't lose the data.",
	},
];
---

<BaseLayout
	headerVariant="transparent"
	forceLightTheme
	title="ThingsBoard Cloud"
	description="ThingsBoard Cloud — fully managed, scalable, fault-tolerant IoT platform with Professional Edition features and no self-hosting required."
>
	<main>
		<Hero
			product={Products.PAAS}
			title="ThingsBoard Cloud"
			subtitle="Fully managed, scalable and fault-tolerant platform for your IoT applications"
			buttons={[{ text: 'Try it now', href: '/pricing/', variant: 'outline' }]}
			anchorLink="#intro"
			backgroundImage="/hero/pe-cover.webp"
			videoBackground={{
				webm: 'https://video.thingsboard.io/pe-cover.webm',
				mp4: 'https://video.thingsboard.io/pe-cover.mp4',
			}}
		/>

		<section id="overflow">
			<CustomersLogo productTag="paas" />

			<div id="background" aria-hidden="true">
				<div class="main"></div>
				<div class="small1"></div>
				<div class="small2"></div>
				<div class="small3"></div>
				<div class="small4"></div>
				<div class="bottom"></div>
				<div class="small5"></div>
			</div>

			<section id="intro">
				<h2 class="intro-title">
					<a href="/docs/paas/why-thingsboard/">ThingsBoard Cloud</a> is a fully managed, scalable and fault-tolerant platform
					for your IoT applications
				</h2>

				<div id="labeling">
					<p>
						ThingsBoard Cloud is for everyone who would like to use ThingsBoard Professional Edition but don't want to
						host their own instance of the platform.
					</p>
				</div>

				<div id="cards">
					{
						cards.map((card) => (
							<div class="card">
								<SmartImage src={card.icon} alt={card.title} width={100} height={106} />
								<h3>{card.title}</h3>
								<p set:html={card.text} />
							</div>
						))
					}
				</div>
			</section>

			<PaasComparisonMatrix />

			<section id="bottom">
				<a id="Products_Cloud_GetItNow" href="/pricing/" class="try-paas gtm_button">Get it now</a>
				<a href="/products/paas/privacy-policy/" class="privacy-link">ThingsBoard Cloud Privacy policy</a>
			</section>
		</section>
	</main>
</BaseLayout>

<style is:global lang="scss">
	@use '../../../styles/landing';
	@use '../../../styles/variables' as *;

	main {
		width: 100%;
	}

	#overflow {
		overflow: hidden;
		position: relative;
	}

	#bottom {
		background-color: #f9fbfe;
		margin: 0 calc(-50vw + 50%);
		padding: 66px 1.25rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
	}

	.try-paas {
		display: inline-block;
		background-color: $color-primary-dark;
		color: $color-white;
		font-size: 1.5rem;
		font-weight: $font-weight-normal;
		text-align: center;
		text-decoration: none;
		border-radius: $radius-sm;
		padding: 0.9375rem 8rem;
		box-shadow: 0 28px 16px -20px rgba(12, 29, 51, 0.25);
		transition: background-color 0.6s;

		&:hover {
			background-color: $color-primary-hover;
			text-decoration: none;
			color: $color-white;
		}

		&:active {
			background-color: $color-primary-dark;
			transition-duration: 0s;
		}

		@include media-down(md) {
			padding: 0.9375rem 3rem;
			font-size: $font-size-xl;
		}
	}

	.privacy-link {
		color: #6b6b72;
		font-size: $font-size-base;
		text-decoration: none;

		&:hover {
			text-decoration: underline;
		}
	}

	// ── Decorative background shapes ──────────────────────────────
	#background {
		position: absolute;
		top: 405px;
		left: 50%;

		> div {
			position: absolute;
		}

		.main {
			width: 2560px;
			height: 525px;
			left: -1280px;
			background-color: #f8fafe;
			transform: skewY(-6deg);
		}

		.small1 {
			top: 16px;
			right: 524px;
			width: 436px;
			height: 90px;
			background-color: $color-primary;
			transform: skewY(-6deg);
		}

		.small2 {
			top: -140px;
			left: 810px;
			width: 436px;
			height: 90px;
			border: 2px solid #29384b;
			transform: skewY(-6deg);
		}

		.small3 {
			top: 592px;
			right: 706px;
			width: 436px;
			height: 90px;
			border: 2px solid #29384b;
			transform: skewY(-6deg);
		}

		.small4 {
			top: 390px;
			left: 568px;
			width: 436px;
			height: 90px;
			background-color: #366cb4;
			transform: skewY(-6deg);
		}

		.bottom {
			top: 849px;
			width: 2560px;
			height: 130px;
			left: -1280px;
			background-color: #2c4362;
			transform: skewY(-6deg);
		}

		.small5 {
			top: 849px;
			left: 773px;
			width: 436px;
			height: 90px;
			background-color: $color-primary;
			transform: skewY(-6deg);
		}

		@media (max-width: 992px) {
			top: 570px;
		}
	}

	// ── Intro section ─────────────────────────────────────────────
	#intro {
		position: relative;
		max-width: 1400px;
		margin: 0 auto 80px;
		padding: 80px 1.25rem 0;
		background: transparent;
		color: $color-dark;
		text-align: center;

		@include media-up(2xl) {
			margin-bottom: 160px;
		}
	}

	.intro-title {
		color: $color-dark;
		font-weight: $font-weight-semibold;
		text-align: center;
		font-size: 32px;
		line-height: 48px;
		margin: 0;

		a {
			color: $color-primary;
		}
	}

	#labeling {
		margin: 48px 0 112px;
		text-align: center;

		p {
			color: $color-text-light;
			font-size: $font-size-xl;
			line-height: 1.5;
			font-weight: $font-weight-normal;
			max-width: 64%;
			margin: 0 auto;

			@include media-down(md) {
				max-width: 100%;
			}
		}
	}

	#cards {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 36px;
		padding-top: 50px;
	}

	.card {
		flex: 1 1 calc(50% - 36px);
		max-width: calc(50% - 36px);
		padding: 56px 48px;
		background: $color-white;
		border-radius: $radius-md;
		box-shadow: 0 50px 50px -20px rgba(0, 0, 0, 0.15);
		text-align: center;

		@include media-up(xl) {
			flex: 1 1 calc(33% - 36px);
			max-width: calc(33% - 36px);
		}

		@include media-down(md) {
			flex: 1 1 100%;
			max-width: 100%;
		}

		img {
			display: block;
			margin: 0 auto 28px;
		}

		h3 {
			font-size: $font-size-2xl;
			font-weight: $font-weight-semibold;
			line-height: $line-height-tight;
			color: $color-dark;
			margin: 0 0 0.5rem;
		}

		p {
			color: $color-text-secondary;
			font-size: $font-size-lg;
			font-weight: $font-weight-normal;
			line-height: 27px;
			margin: 9px 0 0;

			a {
				font: inherit;
				color: #1a6fd4;
				text-decoration: none;

				&:hover {
					text-decoration: underline;
				}
			}
		}
	}
</style>
