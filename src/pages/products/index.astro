---
import BaseLayout from '../../layouts/BaseLayout.astro';

const cards = [
	{
		href: '/products/paas/',
		icon: '/images/products/thingsboard-c-icon.svg',
		alt: 'Cloud',
		title: 'ThingsBoard Cloud',
		desc: 'Platform as a service',
		cls: 'cloud',
		color: '#2a7dec',
	},
	{
		href: '/products/thingsboard-pe/',
		icon: '/images/products/thingsboard-p-icon.svg',
		alt: 'Professional Edition',
		title: 'ThingsBoard Professional Edition',
		desc: 'Advanced IoT platform',
		cls: 'prof',
		color: '#1f8b4d',
	},
	{
		href: '/',
		icon: '/images/products/thingsboard-cm-icon.svg',
		alt: 'Community Edition',
		title: 'ThingsBoard Community Edition',
		desc: 'Open-source platform',
		cls: 'com',
		color: '#305680',
	},
	{
		href: '/products/thingsboard-edge/',
		icon: '/images/products/thingsboard-e-icon.svg',
		alt: 'Edge',
		title: 'ThingsBoard Edge',
		desc: 'Edge computing',
		cls: 'thingsboard-edge',
		color: '#009688',
	},
	{
		href: '/docs/iot-gateway/',
		icon: '/images/products/gateway-icon.svg',
		alt: 'Gateway',
		title: 'ThingsBoard IoT Gateway',
		desc: 'Connect legacy protocols',
		cls: 'gateway',
		color: '#7A4DC3',
	},
	{
		href: '/docs/license-server/',
		icon: '/images/products/license-icon.svg',
		alt: 'License',
		title: 'ThingsBoard License Server',
		desc: 'Billing solution',
		cls: 'license',
		color: '#1f8b4d',
	},
	{
		href: '/products/trendz/',
		icon: '/images/products/trendz-icon.svg',
		alt: 'Analytics Platform',
		title: 'Trendz Analytics Platform',
		desc: 'Data analytics and Prediction',
		cls: 'trendz',
		color: '#5555ff',
	},
	{
		href: '/products/mobile/',
		icon: '/images/products/tb-mobile-icon.svg',
		alt: 'Device icon',
		title: 'ThingsBoard Mobile Application',
		desc: 'IoT mobile product',
		cls: 'mobile',
		color: '#305680',
	},
	{
		href: '/products/mobile-pe/',
		icon: '/images/products/tb-pe-mobile-icon.svg',
		alt: 'PE Mobile Application',
		title: 'ThingsBoard PE Mobile Application',
		desc: 'Advanced IoT mobile product',
		cls: 'pe-mobile',
		color: '#1f8b4d',
	},
	{
		href: '/products/mqtt-broker/',
		icon: '/images/products/tbmq-icon.svg',
		alt: 'TBMQ',
		title: 'ThingsBoard MQTT Broker',
		desc: 'Scalable MQTT broker',
		cls: 'mqtt-broker card-middle',
		color: '#1f8b4d',
	},
];
---

<BaseLayout title="Products" description="ThingsBoard Products" pageId="products">
	<div class="products-page">
		<h1 class="main-title">Products</h1>

		<div class="products-cards">
			{
				cards.map((card) => (
					<a
						href={card.href}
						class={`card ${card.cls}`}
						style={`--hover-color: ${card.color}`}
					>
						<img src={card.icon} alt={card.alt} />
						<h5 class="title">{card.title}</h5>
						<p>{card.desc}</p>
					</a>
				))
			}
		</div>
	</div>
</BaseLayout>

<style lang="scss">
	.products-page {
		padding: 60px 20px 108px;
		max-width: 1200px;
		margin: 0 auto;
	}

	.main-title {
		text-align: center;
		margin-bottom: 80px;
		font-size: 32px;
		font-weight: 700;
		color: #212529;
	}

	.products-cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
	}

	.card {
		color: #212529;
		padding: 31px;
		border: 1px solid #ebebeb;
		position: relative;
		cursor: pointer;
		text-align: center;
		align-items: center;
		text-decoration: none;
		display: flex;
		flex-direction: column;
		transition:
			box-shadow 0.15s ease,
			border-color 0.15s ease;

		img {
			width: 54px;
		}

		.title {
			font-weight: 600;
			margin: 8px 0 14px;
			font-size: 16px;
			transition: color 0.15s ease;
		}

		p {
			font-size: 14px;
			line-height: 22px;
			margin: 0;
			color: #212529;
		}

		&:hover {
			border-color: var(--hover-color);
			box-shadow: inset 0 0 0 3px var(--hover-color);

			.title {
				color: var(--hover-color);
			}
		}

		&.card-middle {
			grid-column: 2;
		}
	}

	@media screen and (max-width: 768px) {
		.products-cards {
			grid-template-columns: 1fr;
		}

		.card.card-middle {
			grid-column: 1;
		}
	}
</style>
