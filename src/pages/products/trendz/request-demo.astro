---
import BaseLayout from '@layouts/BaseLayout.astro';
import DemoRequestForm from '../../../components/DemoRequestForm.astro';

const features = [
	'One-click integration with ThingsBoard',
	'Self-service analytics',
	'Data clear and filtering',
	'Advanced visualizations',
	'Share and collaborate visualization',
	'Keep your data secure',
];
---

<BaseLayout
	headerVariant="solid-shadow"
	forceLightTheme
	title="Trendz Analytics Demo Request"
	description="Request a Trendz Analytics demo to see how to build self-service visual analytics on ThingsBoard data and discover trends, patterns, and insights."
	pageId="products-form"
>
	<DemoRequestForm
		title="Trendz Analytics Demo Request"
		description="Create interactive visual analytics and discover trends, patterns and insight from your data:"
		features={features}
		gtmFormId="Products_TA_GetADemoForm"
	/>
</BaseLayout>
