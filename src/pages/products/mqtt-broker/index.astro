---

<BaseLayout
	title="TBMQ - Open Source MQTT Broker - Scalable IoT Messaging"
	description="Deliver 3M+ MQTT messages/sec with TBMQ — a fault-tolerant open-source MQTT broker with clustering and message durability."
	pageId="mqtt-broker"
	gitHubPlatform={Products.TBMQ}
>
	<main>
		<Hero
			product={Products.TBMQ}
			title={['TBMQ', 'Open-source MQTT Broker']}
			subtitle="Scalable, fault-tolerant, and durable messaging for millions of MQTT clients"
			buttons={[
				{
					text: 'Contact us',
					href: '/contact-us/?subject=TBMQ&tbmqorder&message=I%20am%20interested%20in%20TBMQ&customTitle=GetTBMQ',
					variant: 'outline',
				},
				{ text: 'Get started', href: '/docs/mqtt-broker/getting-started/', variant: 'outline', },
			]}
			anchorLink="#content"
			backgroundImage="/hero/tbmq-cover.webp"
			achievement={null}
		/>

		<div id="content">
			<TopFeaturesSection />
			<ScenariosSection />
			<InstallationOptionsSection />
			<MiddleFeaturesSection />
			<ComparisonTable
				title="TBMQ feature comparison"
				groups={tbmqGroups}
				peColor="#1f8b4d"
				centerTitle={true}
				bgColor="#F2F8F4"
				noSkew={true}
				fixedMaxWidth={true}
			/>
			<BottomFeaturesSection />
			<GetStartedSection />
			<NewsSection />
		</div>
	</main>
</BaseLayout>

<style lang="scss">
	@use '../../../styles/variables' as *;

	:global(#mqtt-broker) {
		--tb-main-color: #{$color-pe};
		--tb-main-color-hover: #{$color-pe-dark};
	}

	:global(#mqtt-broker #hero .button:hover) {
		background-color: $color-pe-dark;
		filter: none;
	}

	:global(#mqtt-broker #content a:not(.btn):not(.news-tag):not(.news-title)) {
		color: #1f8b4d;
	}
</style>
