---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Landing/Hero.astro';
import TopFeaturesSection from '../../../components/MqttBroker/TopFeaturesSection.astro';
import ScenariosSection from '../../../components/MqttBroker/ScenariosSection.astro';
import InstallationOptionsSection from '../../../components/MqttBroker/InstallationOptionsSection.astro';
import MiddleFeaturesSection from '../../../components/MqttBroker/MiddleFeaturesSection.astro';
import ComparisonTable from '../../../components/Landing/ComparisonTable.astro';
import BottomFeaturesSection from '../../../components/MqttBroker/BottomFeaturesSection.astro';
import GetStartedSection from '../../../components/MqttBroker/GetStartedSection.astro';
import NewsSection from '../../../components/MqttBroker/NewsSection.astro';
import { Products } from '@models/site.models';

const tbmqGroups = [
	{
		category: 'Broker Core',
		rows: [
			{
				label: 'MQTT 3.1 / 3.1.1 support',
				href: '/docs/mqtt-broker/user-guide/mqtt-protocol/#differences-between-mqtt-311-and-mqtt-50',
				ce: true,
				pe: true,
			},
			{
				label: 'MQTT 5.0 support',
				href: '/docs/mqtt-broker/user-guide/mqtt-protocol/#new-features-in-mqtt-50',
				ce: true,
				pe: true,
			},
			{
				label: 'Scalability (Clustering)',
				href: '/docs/mqtt-broker/architecture/',
				ce: true,
				pe: true,
			},
			{
				label: 'MQTT over WebSocket',
				href: '/docs/mqtt-broker/user-guide/mqtt-over-ws/',
				ce: true,
				pe: true,
			},
			{
				label: 'WebSocket client',
				href: '/docs/mqtt-broker/user-guide/ui/websocket-client/',
				ce: true,
				pe: true,
			},
			{
				label: 'Backpressure support',
				href: '/docs/mqtt-broker/user-guide/backpressure/',
				ce: true,
				pe: true,
			},
		],
	},
	{
		category: 'Security & Admin',
		rows: [
			{
				label: 'Basic authentication',
				href: '/docs/mqtt-broker/security/authentication/basic/',
				ce: true,
				pe: true,
			},
			{
				label: 'X.509 certificate chain authentication',
				href: '/docs/mqtt-broker/security/authentication/x509/',
				ce: true,
				pe: true,
			},
			{
				label: 'JWT authentication',
				href: '/docs/mqtt-broker/security/authentication/jwt/',
				ce: true,
				pe: true,
			},
			{
				label: 'Access control list (ACL)',
				href: '/docs/mqtt-broker/security/overview/#authorization',
				ce: true,
				pe: true,
			},
			{
				label: 'Single Sign-On (SSO) / OAuth2',
				href: '/docs/pe/mqtt-broker/security/oauth-2-support/',
				ce: false,
				pe: true,
			},
			{
				label: 'Role-Based Access Control (RBAC)',
				href: '/docs/pe/mqtt-broker/security/rbac/',
				ce: false,
				pe: true,
			},
			{
				label: 'Audit logs',
				ce: false,
				peText: 'Coming soon',
			},
		],
	},
	{
		category: 'Monitoring & Management',
		rows: [
			{
				label: 'MQTT sessions and subscriptions management',
				href: '/docs/mqtt-broker/user-guide/ui/monitoring/',
				ce: true,
				pe: true,
			},
			{
				label: 'Metrics monitoring',
				href: '/docs/mqtt-broker/user-guide/ui/monitoring/',
				ce: true,
				pe: true,
			},
			{
				label: 'Unauthorized MQTT clients',
				href: '/docs/mqtt-broker/user-guide/ui/unauthorized-clients/',
				ce: true,
				pe: true,
			},
			{
				label: 'Blocked MQTT clients',
				href: '/docs/mqtt-broker/other/blocked-client/',
				ce: true,
				pe: true,
			},
		],
	},
	{
		category: 'Extensibility & Customization',
		rows: [
			{
				label: 'System integrations',
				ceText: 'Basic',
				ceLinkHref: '/docs/mqtt-broker/integrations/',
				peText: 'Advanced (coming soon)',
				peLinkHref: '/docs/pe/mqtt-broker/integrations/',
			},
			{
				label: 'White labeling',
				href: '/docs/pe/mqtt-broker/white-labeling/',
				ce: false,
				pe: true,
			},
		],
	},
	{
		category: 'Deployment Options',
		rows: [
			{
				label: 'Self-Managed (On-premise/Cloud)',
				href: '/pricing/?section=tbmq-options&product=tbmq-pe',
				ce: true,
				pe: true,
			},
			{
				label: 'Managed Private Cloud',
				href: '/pricing/?section=tbmq-options&product=tbmq-private-cloud',
				ce: false,
				pe: true,
			},
		],
	},
	{
		category: 'Support',
		rows: [
			{
				label: 'Support Model',
				ceText: 'Community',
				ceLinkHref: '/pricing/?section=tbmq-options&product=tbmq-ce',
				peText: 'Advanced + SLA',
				peLinkHref: '/pricing/?section=tbmq-options&product=tbmq-pe',
			},
		],
	},
