---
import BaseLayout from '@layouts/BaseLayout.astro';
import MobileFeatureBlock from '../../../components/Landing/MobileFeatureBlock.astro';
---

<BaseLayout
	headerVariant="solid-shadow"
	forceLightTheme
	title="ThingsBoard Mobile Application"
	description="ThingsBoard Mobile Application is an open-source project based on Flutter. Build your own IoT mobile application with minimum coding efforts."
>
	<main>
		<div id="overflow">
			<section id="intro">
				<div class="intro-inner">
					<h1>
						<a href="/docs/mobile/">ThingsBoard Mobile Application</a> is an open-source{' '}
						<a href="https://github.com/thingsboard/flutter_thingsboard_app">project</a> based on Flutter
					</h1>
					<h2 class="second">Build your own IoT mobile application with minimum coding efforts</h2>
					<h3 class="second">Powered by ThingsBoard IoT Platform</h3>
				</div>
			</section>

			<section class="features">
				<div class="features-inner">
					<div class="features-top">
						<div class="background">
							<div class="main1"></div>
							<div class="small1"></div>
							<div class="small2"></div>
							<div class="small3"></div>
							<div class="small4"></div>
						</div>

						<MobileFeatureBlock
							heading="Home screen with flexible navigation"
							description="Browse everything from home screen. Use Platform to configure dashboard icons, order and visibility."
							readMoreHref="/docs/mobile/customize-dashboards/"
							readMoreSrOnlySuffix=" about flexible dashboard navigation"
							phoneBgSrc="/images/mobile/mobile-bg.svg"
							phoneSideSrc="/images/mobile/flexible-nav.svg"
							phoneSideAlt="Flexible navigation in ThingsBoard Mobile App"
							phoneSideClass="flexible"
							frameImageSrc="/src/assets/images/landings/mobile/browse-dashboards-frame.png"
							videoMp4="https://video.thingsboard.io/mobile/browse-dashboards.mp4"
							videoWebm="https://video.thingsboard.io/mobile/browse-dashboards.webm"
						/>

						<MobileFeatureBlock
							heading="Simple and convenient alarms management"
							description="Manage alarms in one place. Navigate to related dashboards configurable from the Platform."
							readMoreHref="/docs/mobile/alarm-dashboard/"
							readMoreSrOnlySuffix=" about alarms management"
							phoneBgSrc="/images/mobile/mobile-bg.svg"
							phoneSideSrc="/images/mobile/alarms-m.svg"
							phoneSideAlt="Alarms screen in ThingsBoard Mobile Application"
							phoneSideClass="alarms-m"
							frameImageSrc="/src/assets/images/landings/mobile/manage-alarms-frame.png"
							videoMp4="https://video.thingsboard.io/mobile/manage-alarms.mp4"
							videoWebm="https://video.thingsboard.io/mobile/manage-alarms.webm"
							imageFirst={true}
							shadowRight={true}
							pointsRight={true}
							blockClass="vis"
						/>
					</div>
				</div>
			</section>

			<section class="features">
				<div class="features-inner">
					<div class="features-top">
						<div class="background">
							<div class="main2"></div>
							<img src="/images/grid.svg" alt="Background grid pattern for ThingsBoard product page" />
							<div class="small5"></div>
							<div class="small6"></div>
						</div>

						<MobileFeatureBlock
							heading="Structured devices navigation"
							description="Browse devices grouped by their type and online status. On ThingsBoard, assign device specific dashboard and image."
							readMoreHref="/docs/mobile/customize-devices/"
							readMoreSrOnlySuffix=" about structured device navigation"
							phoneBgSrc="/images/mobile/mobile-bg.svg"
							phoneSideSrc="/images/mobile/devices-nav.svg"
							phoneSideAlt="Devices navigation in ThingsBoard Mobile App"
							phoneSideClass="devices-nav"
							frameImageSrc="/src/assets/images/landings/mobile/navigate-devices-frame.png"
							videoMp4="https://video.thingsboard.io/mobile/navigate-devices.mp4"
							videoWebm="https://video.thingsboard.io/mobile/navigate-devices.webm"
							dark={true}
						/>

						<MobileFeatureBlock
							heading="Rich set of mobile actions"
							description="Use mobile device to take photo, scan QR code, update location and more within dashboard. Extend the action with your own processing logic using ThingsBoard."
							readMoreHref="/docs/mobile/mobile-actions/"
							readMoreSrOnlySuffix=" about mobile actions"
							phoneBgSrc="/images/mobile/mobile-bg.svg"
							phoneSideSrc="/images/mobile/mobile-act.svg"
							phoneSideAlt="Mobile action feature in ThingsBoard Mobile App"
							phoneSideClass="mobile-act"
							frameImageSrc="/src/assets/images/landings/mobile/mobile-actions-frame.png"
							videoMp4="https://video.thingsboard.io/mobile/mobile-actions.mp4"
							videoWebm="https://video.thingsboard.io/mobile/mobile-actions.webm"
							imageFirst={true}
							shadowRight={true}
							blockClass="micro"
						/>

						<div class="background bottom">
							<div class="bottom"></div>
							<div class="small7"></div>
						</div>
					</div>
				</div>
			</section>

			<section id="bottom">
				<div class="bottom-inner">
					<a id="Products_MobApp_GetStart" href="/docs/mobile/getting-started/" class="getting-started gtm_button">
						Getting started
					</a>
				</div>
			</section>
		</div>
	</main>
</BaseLayout>

<style lang="scss" is:global>
	@use '../../../styles/landing';
	.read-more-link--default,
	.read-more-link--default .arrow {
		color: #1a6fd4;
	}
</style>

<style lang="scss">
	@use '../../../styles/variables' as *;

	main {
		width: 100%;
	}

	#overflow {
		overflow: hidden;
	}

	// ── Intro section ─────────────────────────────────────────────
	#intro {
		margin-bottom: 178px;
		padding-top: 120px;
		color: #212529;
		text-align: left;
		background: transparent;

		.intro-inner {
			max-width: 1400px;
			margin: 0 auto;
			padding: 0 1.25rem;
		}

		h1 {
			font-weight: 600;
			text-align: center;
			font-size: 32px;
			line-height: 52px;
			margin-bottom: 48px;

			a {
				font-weight: 600;
				font-size: 32px;
				color: #2a7dec;
			}
		}

		h2.second,
		h3.second {
			text-align: center;
			color: #5c6878;
			font-size: 20px;
			line-height: 1.5em;
			font-weight: normal;
		}
	}

	// ── Features sections ─────────────────────────────────────────
	.features {
		background: transparent;

		.features-inner {
			max-width: 1400px;
			margin: 0 auto;
			padding: 0 1.25rem;
		}
	}

	// ── Decorative background shapes ──────────────────────────────
	.background {
		position: absolute;
		left: 50%;

		&:not(.bottom) {
			top: 524px;
		}

		&.bottom {
			top: unset;
			bottom: 1617px;
		}

		img {
			position: absolute;
			top: -650px;
			left: 134px;
			box-shadow: none !important;
		}

		div {
			position: absolute;
			transform: skewY(-6deg);
			width: 436px;
			height: 90px;

			// ── Section 1 ──
			&.main1 {
				top: -572px;
				width: 2560px;
				height: 825px;
				left: -1280px;
				background-color: #f7f9fc;
			}

			&.small1 {
				top: -528px;
				right: 646px;
				background-color: #305680;
			}

			&.small2 {
				top: -590px;
				right: 408px;
				background-color: #2a7dec;
			}

			&.small3 {
				top: -715px;
				left: 789px;
				border: 4px solid #2a7dec;
			}

			&.small4 {
				top: 122px;
				right: 814px;
				border: 2px solid #0d2743;
			}

			// ── Section 2 ──
			&.main2 {
				top: -576px;
				width: 2560px;
				height: 825px;
				left: -1280px;
				background-color: #252628;
			}

			&.small5 {
				top: -742px;
				left: 867px;
				border: 4px solid #305680;
			}

			&.small6 {
				top: 63px;
				right: 525px;
				background-color: #305680;
			}

			// ── Bottom ──
			&.bottom {
				bottom: -1780px;
				width: 2560px;
				height: 130px;
				left: -1280px;
				background-color: #262c28;
			}

			&.small7 {
				bottom: -1760px;
				left: 565px;
				background-color: #305680;
			}
		}

		@media screen and (min-width: 1025px) {
			div.main1,
			div.main2 {
				height: 625px;
			}
		}
	}

	// ── Bottom CTA section ────────────────────────────────────────
	#bottom {
		margin-top: 340px;
		padding: 82px 0 124px;
		text-align: center;
		background-color: #f9fbfe;
		margin-left: calc(-50vw + 50%);
		margin-right: calc(-50vw + 50%);

		.bottom-inner {
			max-width: 1400px;
			margin: 0 auto;
			padding: 0 1.25rem;
		}

		.getting-started {
			display: inline-block;
			font-size: 24px;
			font-weight: 400;
			text-align: center;
			color: white;
			background-color: #2a7dec;
			border-radius: 4px;
			text-decoration: none;
			padding: 15px 68px;
			box-shadow: 0 28px 16px -20px rgba(13, 39, 67, 0.25);
			transition: background-color 0.3s;

			&:hover {
				background-color: #4f97f8;
				text-decoration: none;
				color: #fff;
			}

			&:active {
				background-color: #2a7dec;
				transition-duration: 0s;
			}

			@media screen and (min-width: 1025px) {
				padding: 15px 128px;
			}
		}
	}
</style>
