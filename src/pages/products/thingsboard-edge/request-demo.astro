---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DemoRequestForm from '../../../components/DemoRequestForm.astro';

const features = [
	'Operate with local devices without connection to cloud',
	'Monitor local events/time series data with real-time dashboard',
	'Push to cloud only subset of filtered data from edge devices',
	'React to critical local situations on site without connection to cloud',
	'Update thousands of edge configurations in a single click',
	'Store data locally from devices without connection to cloud and push to cloud once connection is restored',
];
---

<BaseLayout forceLightTheme title="ThingsBoard Edge Demo Request" pageId="products-form">
	<DemoRequestForm
		title="ThingsBoard Edge Demo Request"
		description="Connect devices to ThingsBoard Edge and start processing data locally without internet connection:"
		features={features}
		gtmFormId="Products_Edge_DemoRequestForm"
	/>
</BaseLayout>