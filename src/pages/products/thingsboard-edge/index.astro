---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '../../../components/Landing/Hero.astro';
import EdgeStatsSection from '../../../components/Landing/EdgeStatsSection.astro';
import EdgeArchitectureSection from '../../../components/Landing/EdgeArchitectureSection.astro';
import EdgeComparisonMatrix from '../../../components/Landing/EdgeComparisonMatrix.astro';
import EdgeAuthoredQuote from '../../../components/Landing/EdgeAuthoredQuote.astro';
import EdgeGetInTouch from '../../../components/Landing/EdgeGetInTouch.astro';
import FeatureBlockSection from '../../../components/Landing/FeatureBlockSection.astro';
import EdgeBottomFeatures from '../../../components/Landing/EdgeBottomFeatures.astro';
import EdgeBottom from '../../../components/Landing/EdgeBottom.astro';
import { Products } from '@models/site.models';
---

<BaseLayout
	headerVariant="transparent"
	forceLightTheme
	title="ThingsBoard Edge"
	description="Comprehensive software solutions for edge computing, providing data analysis and management at the source of data creation."
	gitHubPlatform={Products.EDGE}
>
	<main>
		<Hero
			product={Products.EDGE}
			title="Open Source IoT Edge Computing"
			subtitle="ThingsBoard Edge: IoT that works when the internet doesn't"
			buttons={[
				{ text: 'Contact Us', href: '/contact-us/?subject=ThingsBoard%20Products', variant: 'white', target: '_blank' },
				{
					text: 'Learn More',
					href: '/docs/edge/why-thingsboard-edge/',
					variant: 'outline',
					srOnlySuffix: 'about ThingsBoard Edge',
					target: '_blank',
				},
			]}
			anchorLink="#intro"
			backgroundImage="/hero/edge-cover.webp"
			videoBackground={{ mp4: 'https://video.thingsboard.io/edge-cover.mp4' }}
			achievement={null}
		/>

		<section id="overflow">
			<EdgeStatsSection />
			<EdgeArchitectureSection />
			<EdgeComparisonMatrix />
			<EdgeAuthoredQuote />
			<EdgeGetInTouch />

			<h2 class="edge-key-features-title">Edge Key Features</h2>

			<FeatureBlockSection
				id="local-deployment"
				heading="Local Deployment and Storage"
				description="Process and store data from local (edge) devices independently of the server. Sync updates with the server once connectivity is restored."
				links={[
					{ href: '/docs/edge/why-thingsboard-edge/', text: 'Edge CE', target: '_blank' },
					{ href: '/docs/edge/pe/why-thingsboard-edge/', text: 'Edge PE', target: '_blank' },
				]}
				imageSrc="/src/assets/images/landings/edge/local-deployment.svg"
				imageAlt="Local deployment and storage"
				imageWidth={587}
				imageHeight={504}
			/>

			<FeatureBlockSection
				id="data-filtering"
				heading="Data Filtering"
				description="Use the ThingsBoard Edge service to filter data from local (edge) devices and forward only a subset of data to the server for further processing or storage."
				links={[
					{ href: '/docs/edge/why-thingsboard-edge/', text: 'Edge CE', target: '_blank' },
					{ href: '/docs/edge/pe/why-thingsboard-edge/', text: 'Edge PE', target: '_blank' },
				]}
				imageSrc="/src/assets/images/landings/edge/data-filtering.svg"
				imageAlt="Data filtering"
				imageWidth={528}
				imageHeight={126}
				imageFirst={true}
				bgId="edge-bg-data-filtering"
				bgDivs={['main1', 'small1', 'small2', 'small3']}
			/>

			<FeatureBlockSection
				id="local-alarms"
				heading="Local Alarms"
				description="Respond instantly to critical situations on-site, even without connectivity to server."
				links={[
					{ href: '/docs/edge/why-thingsboard-edge/', text: 'Edge CE', target: '_blank' },
					{ href: '/docs/edge/pe/why-thingsboard-edge/', text: 'Edge PE', target: '_blank' },
				]}
				imageSrc="/src/assets/images/landings/edge/local-alarms.svg"
				imageAlt="Local alarms"
				imageWidth={587}
				imageHeight={504}
				dark={true}
				bgId="edge-bg-local-alarms"
				bgDivs={['main2', 'small5', 'small6', 'small7']}
			/>

			<FeatureBlockSection
				id="batch-update"
				heading="Batch Update and Visualization"
				description="Update thousands of edge configurations with a single click. Monitor local events and time series data using a real-time dashboard."
				links={[
					{ href: '/docs/edge/why-thingsboard-edge/', text: 'Edge CE', target: '_blank' },
					{ href: '/docs/edge/pe/why-thingsboard-edge/', text: 'Edge PE', target: '_blank' },
				]}
				imageSrc="/src/assets/images/landings/edge/batch-update.svg"
				imageAlt="Batch update and visualization"
				imageWidth={620}
				imageHeight={389}
				imageFirst={true}
			/>

			<EdgeBottomFeatures />
			<EdgeBottom />
		</section>
	</main>
</BaseLayout>

<style lang="scss" is:global>
	:root {
		--tb-main-color: #00796b;
	}

	main {
		width: 100%;
	}

	#overflow {
		overflow: hidden;
	}

	.edge-key-features-title {
		text-align: center;
		font-size: 42px;
		font-weight: 600;
		color: #212529;
		margin: 60px 0 0;

		@media screen and (max-width: 768px) {
			font-size: 28px;
			margin: 40px 0 0;
		}
	}

	// Edge read-more link color
	.read-more-link {
		color: #00796b;

		.arrow {
			color: #00796b;
		}

		&:hover {
			color: #1eb7a9;

			.arrow {
				color: #1eb7a9;
			}
		}
	}

	// Dark section — white links
	#local-alarms .read-more-link {
		color: white;

		.arrow {
			color: white;
		}

		&:hover {
			color: rgba(255, 255, 255, 0.8);

			.arrow {
				color: rgba(255, 255, 255, 0.8);
			}
		}
	}

	// Edge feature sections customization
	#local-deployment,
	#data-filtering,
	#local-alarms,
	#batch-update {
		.main-div {
			max-width: 1400px;
			padding: 0 1.875rem;

			@media screen and (min-width: 1500px) {
				padding: 0 5rem;
			}

			@media screen and (max-width: 768px) {
				padding: 0 1.25rem;
			}
		}

		.block {
			padding: 80px 20px;

			@media screen and (max-width: 768px) {
				padding: 40px 20px;
			}
		}

		.phrase-heading {
			font-size: 36px;
			font-weight: 500;
			line-height: 1.5;
		}

		p {
			font-size: 18px;
			color: #5e6560;
		}
	}

	// Specific block padding overrides (after general rule)
	#data-filtering .block {
		padding: 230px 20px 100px;
		@media screen and (max-width: 750px) {
			padding: 100px 20px 40px;
		}
	}

	@media screen and (max-width: 750px) {
		#local-alarms .block {
			padding: 120px 20px;
		}
	}

	#batch-update .block {
		padding-bottom: 120px;
	}

	// Background: data-filtering
	#edge-bg-data-filtering {
		z-index: -1;
		position: absolute;
		left: 50%;

		div {
			position: absolute;
			transform: skewY(-6deg);
			width: 436px;
			height: 90px;
		}

		.main1 {
			top: 8px;
			width: 2560px;
			height: 627px;
			left: -1280px;
			background-color: #effaf9;
		}

		.small1 {
			top: 71px;
			right: 646px;
			border: 4px solid #185b55;
		}

		.small2 {
			top: 18px;
			right: 467px;
			background-color: #009688;
		}

		.small3 {
			top: -135px;
			left: 789px;
			background-color: #185b55;
			border: none;
		}
	}

	// Background: local-alarms (dark)
	#edge-bg-local-alarms {
		z-index: -1;
		position: absolute;
		left: 50%;

		div {
			position: absolute;
			transform: skewY(-6deg);
			width: 436px;
			height: 90px;
		}

		.main2 {
			top: 80px;
			width: 2560px;
			height: 725px;
			left: -1280px;
			background-color: #222929;
		}

		.small5 {
			top: 145px;
			right: 552px;
			background-color: #185b55;
		}

		.small6 {
			top: -42px;
			left: 824px;
			border: 4px solid #009688;
		}

		.small7 {
			top: 900px;
			right: 829px;
			background-color: #009688;
		}
	}
</style>
